/-- Finite recursive composition on the left: if each singleton `{v}` is
conditionally independent of the rest of the finite set together with `Y`,
then the whole finite set is conditionally independent of `Y`. -/
theorem condIndepVertices_finset_left_of_singleton_cover
    (S : Finset V) {Y Z : Set V}
    (hstep : ∀ v ∈ S,
      CondIndepVertices bn μ ({v} : Set V) (((↑(S.erase v) : Set V) ∪ Y)) Z) :
    CondIndepVertices bn μ (↑S : Set V) Y Z := by
  classical
  induction S using Finset.induction_on with
  | empty =>
      simpa using condIndepVertices_empty_left (bn := bn) (μ := μ) Y Z
  | @insert a S ha ih =>
      have hA :
          CondIndepVertices bn μ ({a} : Set V) (((↑S : Set V) ∪ Y)) Z := by
        simpa [Finset.erase_insert, ha] using hstep a (by simp)
      have hstepS :
          ∀ v ∈ S,
            CondIndepVertices bn μ ({v} : Set V) (((↑(S.erase v) : Set V) ∪ Y)) Z := by
        intro v hv
        have hbig :
            CondIndepVertices bn μ ({v} : Set V)
              (((↑((insert a S).erase v) : Set V) ∪ Y)) Z := by
          exact hstep v (by simp [hv])
        have hsub :
            ((↑(S.erase v) : Set V) ∪ Y) ⊆ (((↑((insert a S).erase v) : Set V) ∪ Y) : Set V) := by
          intro w hw
          rcases hw with hw | hw
          · left
            have hwv : w ≠ v := (Finset.mem_erase.mp hw).1
            have hwS : w ∈ S := (Finset.mem_erase.mp hw).2
            simp [hwv, hwS]
          · exact Or.inr hw
        exact condIndepVertices_of_le_right (bn := bn) (μ := μ) hsub hbig
      have hS : CondIndepVertices bn μ (↑S : Set V) Y Z := ih hstepS
      simpa [Finset.coe_insert, Set.union_assoc, Set.union_left_comm, Set.union_comm] using
        (condIndepVertices_union_left_of_condIndep_union
          (bn := bn) (μ := μ) (U := (↑S : Set V)) (X := ({a} : Set V)) (Y := Y) (Z := Z)
          hA hS)

