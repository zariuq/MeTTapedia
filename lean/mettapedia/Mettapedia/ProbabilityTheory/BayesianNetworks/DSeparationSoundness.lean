/-
# D-Separation Soundness Infrastructure

This file defines conditional independence of vertex sets in a Bayesian network
using Mathlib's measure-theoretic `CondIndep`, and proves basic properties.

## Main Definitions

- `CondIndepVertices`: Conditional independence of vertex sets X, Y given Z,
  expressed via σ-algebras generated by coordinate projections.

## Main Results

- `condIndepVertices_symm`: Symmetry of conditional independence.
- `condIndepVertices_empty_left/right`: Independence holds trivially when X or Y is empty.
- `condIndepVertices_of_le_left/right`: Monotonicity (subsets preserve independence).

## References

- Koller & Friedman, "Probabilistic Graphical Models" (2009), Chapter 3
- Pearl, "Probabilistic Reasoning in Intelligent Systems" (1988)
-/

import Mettapedia.ProbabilityTheory.BayesianNetworks.BayesianNetwork
import Mettapedia.ProbabilityTheory.BayesianNetworks.DSeparation
import Mettapedia.ProbabilityTheory.BayesianNetworks.DSeparationMoralEquiv
import Mettapedia.ProbabilityTheory.BayesianNetworks.EventSets
import Mathlib.Data.Fintype.Card
import Mathlib.MeasureTheory.Constructions.Polish.Basic
import Mathlib.MeasureTheory.Integral.Bochner.Set
import Mathlib.MeasureTheory.PiSystem

open MeasureTheory ProbabilityTheory

namespace Mettapedia.ProbabilityTheory.BayesianNetworks.BayesianNetwork

variable {V : Type*} [Fintype V] [DecidableEq V]
variable (bn : BayesianNetwork V)
variable [∀ v : V, StandardBorelSpace (bn.stateSpace v)]
variable [StandardBorelSpace bn.JointSpace]
variable (μ : Measure bn.JointSpace) [IsFiniteMeasure μ]

/-! ## Conditional Independence of Vertex Sets -/

/-- Conditional independence of vertex sets X and Y given Z in a Bayesian network.

This wraps Mathlib's `ProbabilityTheory.CondIndep` using σ-algebras generated by
coordinate projections for each vertex set. -/
def CondIndepVertices (X Y Z : Set V) : Prop :=
  ProbabilityTheory.CondIndep
    (m' := bn.measurableSpaceOfVertices Z)
    (m₁ := bn.measurableSpaceOfVertices X)
    (m₂ := bn.measurableSpaceOfVertices Y)
    (hm' := measurableSpaceOfVertices_le (bn := bn) Z)
    μ

/-- The σ-algebra generated by a single coordinate projection. -/
noncomputable def singleVertexMeasurableSpace (v : V) : MeasurableSpace bn.JointSpace :=
  MeasurableSpace.comap (fun ω : bn.JointSpace => ω v) (by infer_instance)


/-! ## Basic Properties -/

omit [Fintype V] [DecidableEq V] [∀ v : V, StandardBorelSpace (bn.stateSpace v)] in
/-- Conditional independence is symmetric in X and Y. -/
theorem condIndepVertices_symm {X Y Z : Set V}
    (h : CondIndepVertices bn μ X Y Z) :
    CondIndepVertices bn μ Y X Z :=
by
  unfold CondIndepVertices at h ⊢
  exact CondIndep.symm h

omit [Fintype V] [DecidableEq V] [∀ v : V, StandardBorelSpace (bn.stateSpace v)] in
/-- If X is empty, conditional independence holds trivially. -/
theorem condIndepVertices_empty_left (Y Z : Set V) :
    CondIndepVertices bn μ ∅ Y Z := by
  unfold CondIndepVertices
  have h : bn.measurableSpaceOfVertices ∅ = ⊥ := by
    simp [measurableSpaceOfVertices, iSup_of_empty]
  rw [h]
  exact condIndep_bot_left (bn.measurableSpaceOfVertices Y)

omit [Fintype V] [DecidableEq V] [∀ v : V, StandardBorelSpace (bn.stateSpace v)] in
/-- If Y is empty, conditional independence holds trivially. -/
theorem condIndepVertices_empty_right (X Z : Set V) :
    CondIndepVertices bn μ X ∅ Z := by
  exact condIndepVertices_symm bn μ (condIndepVertices_empty_left bn μ X Z)

omit [Fintype V] [DecidableEq V] [∀ (v : V), StandardBorelSpace (bn.stateSpace v)]
  [StandardBorelSpace bn.JointSpace] in
/-- σ-algebra monotonicity: S' ⊆ S → σ(S') ≤ σ(S). -/
theorem measurableSpaceOfVertices_mono {S S' : Set V} (h : S' ⊆ S) :
    bn.measurableSpaceOfVertices S' ≤ bn.measurableSpaceOfVertices S := by
  unfold measurableSpaceOfVertices
  exact iSup_le fun ⟨v, hv⟩ => le_iSup_of_le ⟨v, h hv⟩ le_rfl

omit [Fintype V] [DecidableEq V] [∀ (v : V), StandardBorelSpace (bn.stateSpace v)]
  [StandardBorelSpace bn.JointSpace] in
/-- The σ-algebra generated by a union of vertex sets is the supremum of the
corresponding vertex σ-algebras. -/
theorem measurableSpaceOfVertices_union {S T : Set V} :
    bn.measurableSpaceOfVertices (S ∪ T) =
      bn.measurableSpaceOfVertices S ⊔ bn.measurableSpaceOfVertices T := by
  apply le_antisymm
  · unfold measurableSpaceOfVertices
    refine iSup_le ?_
    intro v
    rcases v with ⟨v, hvST⟩
    rw [Set.mem_union] at hvST
    rcases hvST with hvS | hvT
    · exact le_sup_of_le_left <| le_iSup_of_le ⟨v, hvS⟩ le_rfl
    · exact le_sup_of_le_right <| le_iSup_of_le ⟨v, hvT⟩ le_rfl
  · refine sup_le ?_ ?_
    · exact measurableSpaceOfVertices_mono (bn := bn) (fun _ hv => Or.inl hv)
    · exact measurableSpaceOfVertices_mono (bn := bn) (fun _ hv => Or.inr hv)

omit [Fintype V] [DecidableEq V] [∀ v : V, StandardBorelSpace (bn.stateSpace v)] in
/-- Monotonicity: if X' ⊆ X and X ⫫ Y | Z, then X' ⫫ Y | Z. -/
theorem condIndepVertices_of_le_left {X X' Y Z : Set V} (hXX' : X' ⊆ X)
    (h : CondIndepVertices bn μ X Y Z) :
    CondIndepVertices bn μ X' Y Z := by
  unfold CondIndepVertices at *
  exact condIndep_of_condIndep_of_le_left h (measurableSpaceOfVertices_mono bn hXX')

omit [Fintype V] [DecidableEq V] [∀ v : V, StandardBorelSpace (bn.stateSpace v)] in
/-- Monotonicity: if Y' ⊆ Y and X ⫫ Y | Z, then X ⫫ Y' | Z. -/
theorem condIndepVertices_of_le_right {X Y Y' Z : Set V} (hYY' : Y' ⊆ Y)
    (h : CondIndepVertices bn μ X Y Z) :
    CondIndepVertices bn μ X Y' Z := by
  unfold CondIndepVertices at *
  exact condIndep_of_condIndep_of_le_right h (measurableSpaceOfVertices_mono bn hYY')

omit [Fintype V] [DecidableEq V] [∀ v : V, StandardBorelSpace (bn.stateSpace v)] in
/-- If the left vertex set is already measurable in the conditioning σ-algebra,
then conditional independence is automatic. -/
theorem condIndepVertices_of_subset_left_conditioning {X Y Z : Set V}
    (hXZ : X ⊆ Z) :
    CondIndepVertices bn μ X Y Z := by
  let mZ : MeasurableSpace bn.JointSpace := bn.measurableSpaceOfVertices Z
  let mY : MeasurableSpace bn.JointSpace := bn.measurableSpaceOfVertices Y
  let hmZ : mZ ≤ (MeasurableSpace.pi : MeasurableSpace bn.JointSpace) :=
    measurableSpaceOfVertices_le (bn := bn) Z
  let hmX : bn.measurableSpaceOfVertices X ≤ mZ :=
    measurableSpaceOfVertices_mono (bn := bn) hXZ
  let hmY : mY ≤ (MeasurableSpace.pi : MeasurableSpace bn.JointSpace) :=
    measurableSpaceOfVertices_le (bn := bn) Y
  have hIdZ :
      @Measurable bn.JointSpace bn.JointSpace
        mZ mZ
        (fun ω => ω) := by
    exact measurable_id
  have hIdY :
      @Measurable bn.JointSpace bn.JointSpace
        (MeasurableSpace.pi : MeasurableSpace bn.JointSpace) mY
        (fun ω => ω) := by
    exact measurable_id.mono le_rfl hmY
  have hfun :=
    ProbabilityTheory.condIndepFun_of_measurable_left
      (m' := mZ) (mΩ := (MeasurableSpace.pi : MeasurableSpace bn.JointSpace))
      (hm' := hmZ)
      (mβ := mZ) (mβ' := mY)
      (X := id)
      (Y := id)
      hIdZ hIdY (μ := μ)
  have hbase :
      ProbabilityTheory.CondIndep
        (m' := mZ) (m₁ := mZ) (m₂ := mY) (hm' := hmZ) μ := by
    simpa [MeasurableSpace.comap_id] using
      (ProbabilityTheory.condIndepFun_iff_condIndep
        (m' := mZ) (mΩ := (MeasurableSpace.pi : MeasurableSpace bn.JointSpace))
        (hm' := hmZ) (mβ := mZ) (mγ := mY)
        (f := id)
        (g := id)
        (μ := μ)).1 hfun
  unfold CondIndepVertices
  exact ProbabilityTheory.condIndep_of_condIndep_of_le_left hbase hmX

omit [Fintype V] [DecidableEq V] [∀ v : V, StandardBorelSpace (bn.stateSpace v)] in
/-- If the right vertex set is already measurable in the conditioning σ-algebra,
then conditional independence is automatic. -/
theorem condIndepVertices_of_subset_right_conditioning {X Y Z : Set V}
    (hYZ : Y ⊆ Z) :
    CondIndepVertices bn μ X Y Z := by
  exact condIndepVertices_symm (bn := bn) (μ := μ)
    (condIndepVertices_of_subset_left_conditioning (bn := bn) (μ := μ) hYZ)

omit [Fintype V] [DecidableEq V] [∀ v : V, StandardBorelSpace (bn.stateSpace v)] in
/-- If the left event is measurable in the conditioning σ-algebra, then it is
conditionally independent of any ambient measurable right event. -/
theorem condIndepSet_of_measurable_left {Z : Set V} {s t : Set bn.JointSpace}
    (hs : MeasurableSet[bn.measurableSpaceOfVertices Z] s)
    (ht : MeasurableSet t) :
    ProbabilityTheory.CondIndepSet
      (m' := bn.measurableSpaceOfVertices Z)
      (hm' := measurableSpaceOfVertices_le (bn := bn) Z)
      s t μ := by
  let mZ : MeasurableSpace bn.JointSpace := bn.measurableSpaceOfVertices Z
  let hmZ : mZ ≤ (MeasurableSpace.pi : MeasurableSpace bn.JointSpace) :=
    measurableSpaceOfVertices_le (bn := bn) Z
  have hIdZ :
      @Measurable bn.JointSpace bn.JointSpace
        mZ mZ
        (fun ω => ω) := by
    exact measurable_id
  have hfun :=
    ProbabilityTheory.condIndepFun_of_measurable_left
      (m' := mZ) (mΩ := (MeasurableSpace.pi : MeasurableSpace bn.JointSpace))
      (hm' := hmZ)
      (mβ := mZ) (mβ' := (MeasurableSpace.pi : MeasurableSpace bn.JointSpace))
      (X := id)
      (Y := id)
      hIdZ measurable_id (μ := μ)
  have hbase :
      ProbabilityTheory.CondIndep
        (m' := mZ) (m₁ := mZ)
        (m₂ := (MeasurableSpace.pi : MeasurableSpace bn.JointSpace))
        (hm' := hmZ) μ := by
    simpa [MeasurableSpace.comap_id] using
      (ProbabilityTheory.condIndepFun_iff_condIndep
        (m' := mZ) (mΩ := (MeasurableSpace.pi : MeasurableSpace bn.JointSpace))
        (hm' := hmZ)
        (mβ := mZ) (mγ := (MeasurableSpace.pi : MeasurableSpace bn.JointSpace))
        (f := id)
        (g := id)
        (μ := μ)).1 hfun
  exact hbase.condIndepSet_of_measurableSet hs ht

omit [Fintype V] [DecidableEq V] [∀ v : V, StandardBorelSpace (bn.stateSpace v)] in
/-- If the right event is measurable in the conditioning σ-algebra, then it is
conditionally independent of any ambient measurable left event. -/
theorem condIndepSet_of_measurable_right {Z : Set V} {s t : Set bn.JointSpace}
    (hs : MeasurableSet s)
    (ht : MeasurableSet[bn.measurableSpaceOfVertices Z] t) :
    ProbabilityTheory.CondIndepSet
      (m' := bn.measurableSpaceOfVertices Z)
      (hm' := measurableSpaceOfVertices_le (bn := bn) Z)
      s t μ := by
  rw [ProbabilityTheory.condIndepSet_iff_condIndep
    (m' := bn.measurableSpaceOfVertices Z)
    (hm' := measurableSpaceOfVertices_le (bn := bn) Z)
    (s := s) (t := t) (μ := μ)]
  have hts : ProbabilityTheory.CondIndepSet
      (m' := bn.measurableSpaceOfVertices Z)
      (hm' := measurableSpaceOfVertices_le (bn := bn) Z)
      t s μ :=
    condIndepSet_of_measurable_left (bn := bn) (μ := μ) (Z := Z) ht hs
  rw [ProbabilityTheory.condIndepSet_iff_condIndep
    (m' := bn.measurableSpaceOfVertices Z)
    (hm' := measurableSpaceOfVertices_le (bn := bn) Z)
    (s := t) (t := s) (μ := μ)] at hts
  exact CondIndep.symm hts

omit [Fintype V] [DecidableEq V] [∀ v : V, StandardBorelSpace (bn.stateSpace v)] in
/-- Intersecting a left event with a conditioning-measurable event preserves
conditional independence. -/
theorem condIndepSet_inter_left_of_measurable {Z : Set V} {u s t : Set bn.JointSpace}
    (hu : MeasurableSet[bn.measurableSpaceOfVertices Z] u)
    (hs : MeasurableSet s) (ht : MeasurableSet t)
    (hst : ProbabilityTheory.CondIndepSet
      (m' := bn.measurableSpaceOfVertices Z)
      (hm' := measurableSpaceOfVertices_le (bn := bn) Z)
      s t μ) :
    ProbabilityTheory.CondIndepSet
      (m' := bn.measurableSpaceOfVertices Z)
      (hm' := measurableSpaceOfVertices_le (bn := bn) Z)
      (u ∩ s) t μ := by
  have hus : ProbabilityTheory.CondIndepSet
      (m' := bn.measurableSpaceOfVertices Z)
      (hm' := measurableSpaceOfVertices_le (bn := bn) Z)
      u s μ :=
    condIndepSet_of_measurable_left (bn := bn) (μ := μ) (Z := Z) hu hs
  have hu_st : ProbabilityTheory.CondIndepSet
      (m' := bn.measurableSpaceOfVertices Z)
      (hm' := measurableSpaceOfVertices_le (bn := bn) Z)
      u (s ∩ t) μ :=
    condIndepSet_of_measurable_left (bn := bn) (μ := μ) (Z := Z) hu (hs.inter ht)
  rw [ProbabilityTheory.condIndepSet_iff
    (m' := bn.measurableSpaceOfVertices Z)
    (hm' := measurableSpaceOfVertices_le (bn := bn) Z)
    (s := u ∩ s) (t := t)
    (((measurableSpaceOfVertices_le (bn := bn) Z) _ hu).inter hs) ht (μ := μ)]
  rw [ProbabilityTheory.condIndepSet_iff
    (m' := bn.measurableSpaceOfVertices Z)
    (hm' := measurableSpaceOfVertices_le (bn := bn) Z)
    (s := u) (t := s)
    ((measurableSpaceOfVertices_le (bn := bn) Z) _ hu) hs (μ := μ)] at hus
  rw [ProbabilityTheory.condIndepSet_iff
    (m' := bn.measurableSpaceOfVertices Z)
    (hm' := measurableSpaceOfVertices_le (bn := bn) Z)
    (s := u) (t := s ∩ t)
    ((measurableSpaceOfVertices_le (bn := bn) Z) _ hu) (hs.inter ht) (μ := μ)] at hu_st
  rw [ProbabilityTheory.condIndepSet_iff
    (m' := bn.measurableSpaceOfVertices Z)
    (hm' := measurableSpaceOfVertices_le (bn := bn) Z)
    (s := s) (t := t)
    hs ht (μ := μ)] at hst
  calc
    μ[((u ∩ s) ∩ t).indicator (1 : bn.JointSpace → ℝ) |
        bn.measurableSpaceOfVertices Z]
        =ᵐ[μ] μ[(u ∩ (s ∩ t)).indicator (1 : bn.JointSpace → ℝ) |
          bn.measurableSpaceOfVertices Z] := by
            rw [show (((u ∩ s) ∩ t : Set bn.JointSpace)) = u ∩ (s ∩ t) by
              ext ω
              simp [and_assoc]]
    _ =ᵐ[μ] μ[u.indicator (1 : bn.JointSpace → ℝ) |
          bn.measurableSpaceOfVertices Z] *
        μ[(s ∩ t).indicator (1 : bn.JointSpace → ℝ) |
          bn.measurableSpaceOfVertices Z] := hu_st
    _ =ᵐ[μ] μ[u.indicator (1 : bn.JointSpace → ℝ) |
          bn.measurableSpaceOfVertices Z] *
        (μ[s.indicator (1 : bn.JointSpace → ℝ) |
            bn.measurableSpaceOfVertices Z] *
          μ[t.indicator (1 : bn.JointSpace → ℝ) |
            bn.measurableSpaceOfVertices Z]) := by
              exact Filter.EventuallyEq.mul (Filter.EventuallyEq.refl _ _) hst
    _ =ᵐ[μ] (μ[u.indicator (1 : bn.JointSpace → ℝ) |
            bn.measurableSpaceOfVertices Z] *
          μ[s.indicator (1 : bn.JointSpace → ℝ) |
            bn.measurableSpaceOfVertices Z]) *
        μ[t.indicator (1 : bn.JointSpace → ℝ) |
          bn.measurableSpaceOfVertices Z] := by
            exact Filter.EventuallyEq.of_eq (by
              ext ω
              simp [mul_assoc])
    _ =ᵐ[μ] μ[(u ∩ s).indicator (1 : bn.JointSpace → ℝ) |
          bn.measurableSpaceOfVertices Z] *
        μ[t.indicator (1 : bn.JointSpace → ℝ) |
          bn.measurableSpaceOfVertices Z] := by
            exact Filter.EventuallyEq.mul hus.symm (Filter.EventuallyEq.refl _ _)

omit [Fintype V] [DecidableEq V] [∀ v : V, StandardBorelSpace (bn.stateSpace v)] in
/-- Intersecting a right event with a conditioning-measurable event preserves
conditional independence. -/
theorem condIndepSet_inter_right_of_measurable {Z : Set V} {s t u : Set bn.JointSpace}
    (hs : MeasurableSet s)
    (ht : MeasurableSet t)
    (hu : MeasurableSet[bn.measurableSpaceOfVertices Z] u)
    (hst : ProbabilityTheory.CondIndepSet
      (m' := bn.measurableSpaceOfVertices Z)
      (hm' := measurableSpaceOfVertices_le (bn := bn) Z)
      s t μ) :
    ProbabilityTheory.CondIndepSet
      (m' := bn.measurableSpaceOfVertices Z)
      (hm' := measurableSpaceOfVertices_le (bn := bn) Z)
      s (t ∩ u) μ := by
  rw [ProbabilityTheory.condIndepSet_iff_condIndep
    (m' := bn.measurableSpaceOfVertices Z)
    (hm' := measurableSpaceOfVertices_le (bn := bn) Z)
    (s := s) (t := t ∩ u) (μ := μ)]
  have hts :
      ProbabilityTheory.CondIndepSet
        (m' := bn.measurableSpaceOfVertices Z)
        (hm' := measurableSpaceOfVertices_le (bn := bn) Z)
        t s μ := by
    rw [ProbabilityTheory.condIndepSet_iff_condIndep
      (m' := bn.measurableSpaceOfVertices Z)
      (hm' := measurableSpaceOfVertices_le (bn := bn) Z)
      (s := t) (t := s) (μ := μ)]
    rw [ProbabilityTheory.condIndepSet_iff_condIndep
      (m' := bn.measurableSpaceOfVertices Z)
      (hm' := measurableSpaceOfVertices_le (bn := bn) Z)
      (s := s) (t := t) (μ := μ)] at hst
    exact CondIndep.symm hst
  have hleft :
      ProbabilityTheory.CondIndepSet
        (m' := bn.measurableSpaceOfVertices Z)
        (hm' := measurableSpaceOfVertices_le (bn := bn) Z)
        (u ∩ t) s μ :=
    condIndepSet_inter_left_of_measurable
      (bn := bn) (μ := μ) (Z := Z) hu ht hs
      hts
  rw [ProbabilityTheory.condIndepSet_iff_condIndep
    (m' := bn.measurableSpaceOfVertices Z)
    (hm' := measurableSpaceOfVertices_le (bn := bn) Z)
    (s := u ∩ t) (t := s) (μ := μ)] at hleft
  simpa [Set.inter_comm] using CondIndep.symm hleft

omit [Fintype V] [DecidableEq V] [∀ v : V, StandardBorelSpace (bn.stateSpace v)] in
/-- If `s` is conditionally independent of both `u` and `u ∩ t`, and `u` is
conditionally independent of `t`, then `(u ∩ s)` is conditionally independent
of `t`. This is the recursive composition step used to grow the left-hand side
of a conditional-independence statement from stronger smaller obligations. -/
theorem condIndepSet_inter_left_of_condIndep
    {Z : Set V} {u s t : Set bn.JointSpace}
    (hu : MeasurableSet u)
    (hs : MeasurableSet s)
    (ht : MeasurableSet t)
    (hsu : ProbabilityTheory.CondIndepSet
      (m' := bn.measurableSpaceOfVertices Z)
      (hm' := measurableSpaceOfVertices_le (bn := bn) Z)
      s u μ)
    (hs_ut : ProbabilityTheory.CondIndepSet
      (m' := bn.measurableSpaceOfVertices Z)
      (hm' := measurableSpaceOfVertices_le (bn := bn) Z)
      s (u ∩ t) μ)
    (hut : ProbabilityTheory.CondIndepSet
      (m' := bn.measurableSpaceOfVertices Z)
      (hm' := measurableSpaceOfVertices_le (bn := bn) Z)
      u t μ) :
    ProbabilityTheory.CondIndepSet
      (m' := bn.measurableSpaceOfVertices Z)
      (hm' := measurableSpaceOfVertices_le (bn := bn) Z)
      (u ∩ s) t μ := by
  rw [ProbabilityTheory.condIndepSet_iff
    (m' := bn.measurableSpaceOfVertices Z)
    (hm' := measurableSpaceOfVertices_le (bn := bn) Z)
    (s := u ∩ s) (t := t)
    (hu.inter hs) ht (μ := μ)]
  rw [ProbabilityTheory.condIndepSet_iff
    (m' := bn.measurableSpaceOfVertices Z)
    (hm' := measurableSpaceOfVertices_le (bn := bn) Z)
    (s := s) (t := u)
    hs hu (μ := μ)] at hsu
  rw [ProbabilityTheory.condIndepSet_iff
    (m' := bn.measurableSpaceOfVertices Z)
    (hm' := measurableSpaceOfVertices_le (bn := bn) Z)
    (s := s) (t := u ∩ t)
    hs (hu.inter ht) (μ := μ)] at hs_ut
  rw [ProbabilityTheory.condIndepSet_iff
    (m' := bn.measurableSpaceOfVertices Z)
    (hm' := measurableSpaceOfVertices_le (bn := bn) Z)
    (s := u) (t := t)
    hu ht (μ := μ)] at hut
  have hsu' :
      μ[(u ∩ s).indicator (1 : bn.JointSpace → ℝ) |
          bn.measurableSpaceOfVertices Z] =ᵐ[μ]
        μ[s.indicator (1 : bn.JointSpace → ℝ) |
            bn.measurableSpaceOfVertices Z] *
          μ[u.indicator (1 : bn.JointSpace → ℝ) |
            bn.measurableSpaceOfVertices Z] := by
    calc
      μ[(u ∩ s).indicator (1 : bn.JointSpace → ℝ) |
          bn.measurableSpaceOfVertices Z] =ᵐ[μ]
        μ[(s ∩ u).indicator (1 : bn.JointSpace → ℝ) |
          bn.measurableSpaceOfVertices Z] := by
            exact Filter.EventuallyEq.of_eq (by
              ext ω
              simp [Set.inter_comm])
      _ =ᵐ[μ] μ[s.indicator (1 : bn.JointSpace → ℝ) |
            bn.measurableSpaceOfVertices Z] *
          μ[u.indicator (1 : bn.JointSpace → ℝ) |
            bn.measurableSpaceOfVertices Z] := hsu
  calc
    μ[((u ∩ s) ∩ t).indicator (1 : bn.JointSpace → ℝ) |
        bn.measurableSpaceOfVertices Z]
        =ᵐ[μ] μ[(s ∩ (u ∩ t)).indicator (1 : bn.JointSpace → ℝ) |
          bn.measurableSpaceOfVertices Z] := by
            exact Filter.EventuallyEq.of_eq (by
              ext ω
              simp [Set.inter_left_comm, Set.inter_assoc])
    _ =ᵐ[μ] μ[s.indicator (1 : bn.JointSpace → ℝ) |
          bn.measurableSpaceOfVertices Z] *
        μ[(u ∩ t).indicator (1 : bn.JointSpace → ℝ) |
          bn.measurableSpaceOfVertices Z] := hs_ut
    _ =ᵐ[μ] μ[s.indicator (1 : bn.JointSpace → ℝ) |
          bn.measurableSpaceOfVertices Z] *
        (μ[u.indicator (1 : bn.JointSpace → ℝ) |
            bn.measurableSpaceOfVertices Z] *
          μ[t.indicator (1 : bn.JointSpace → ℝ) |
            bn.measurableSpaceOfVertices Z]) := by
              exact Filter.EventuallyEq.mul (Filter.EventuallyEq.refl _ _) hut
    _ =ᵐ[μ] (μ[s.indicator (1 : bn.JointSpace → ℝ) |
            bn.measurableSpaceOfVertices Z] *
          μ[u.indicator (1 : bn.JointSpace → ℝ) |
            bn.measurableSpaceOfVertices Z]) *
        μ[t.indicator (1 : bn.JointSpace → ℝ) |
          bn.measurableSpaceOfVertices Z] := by
            exact Filter.EventuallyEq.of_eq (by
              ext ω
              simp [mul_assoc])
    _ =ᵐ[μ] μ[(u ∩ s).indicator (1 : bn.JointSpace → ℝ) |
