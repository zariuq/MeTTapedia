/- Impossibility witness, NOT a dependency: the hook cut set is not rooted
dual-connected, so the old four-adjacency fresh-chain route is false. The
active F4 proof uses star/square connectivity. -/
set_option maxRecDepth 10000 in
theorem not_rootedDualConnectedCutSet_hookSlackHullCutSet :
    ¬ RootedDualConnectedCutSet (GridClauseId.horizontal 1 0) hookSlackHullCutSet := by
  intro hconn
  let target := GridClauseId.horizontal 0 2
  have htarget : target ∈ hookSlackHullCutSet := by
    rw [hookSlackHullCutSet_eq_explicit]
    simp [target]
  let R := fun a b : GridClauseId =>
    a ∈ hookSlackHullCutSet ∧ b ∈ hookSlackHullCutSet ∧ gridClauseDualAdjacent a b
  have hreach : Relation.ReflTransGen R (GridClauseId.horizontal 1 0) target := by
    simpa [R] using hconn.2 target htarget
  have hcompReach :
      ∀ {x : GridClauseId},
        Relation.ReflTransGen R (GridClauseId.horizontal 1 0) x →
          x ∈ hookSlackRootDualComponent := by
    intro x hx
    induction hx with
    | refl =>
        simp [hookSlackRootDualComponent]
    | @tail _ _ _ hyz ih =>
        exact hookSlackRootDualComponent_closed ih hyz.2.1 hyz.2.2
  have htargetComp : target ∈ hookSlackRootDualComponent := hcompReach hreach
  simp [target, hookSlackRootDualComponent] at htargetComp

set_option maxRecDepth 10000 in
theorem rootedStarConnectedCutSet_hookSlackHullCutSet :
    RootedStarConnectedCutSet
      (GridClauseId.horizontal 1 0) hookSlackHullCutSet := by
  refine rootedStarConnectedCutSet_of_clauseChain
    (root := GridClauseId.horizontal 1 0) (s := hookSlackHullCutSet)
    (tail :=
      [GridClauseId.horizontal 1 1,
       GridClauseId.horizontal 1 2,
       GridClauseId.horizontal 0 2,
       GridClauseId.vertical 0 1,
       GridClauseId.vertical 1 2])
    ?_ ?_ ?_ ?_
  · rw [hookSlackHullCutSet_eq_explicit]
    simp
  · simp [gridClauseStarAdjacent, gridNodeStarAdjacent, gridClauseDualEndpoints]
  · intro c hc
    rw [hookSlackHullCutSet_eq_explicit]
    simp at hc ⊢
    exact Or.inr hc
  · intro x hx
    rw [hookSlackHullCutSet_eq_explicit] at hx
    simp at hx ⊢
    exact hx

