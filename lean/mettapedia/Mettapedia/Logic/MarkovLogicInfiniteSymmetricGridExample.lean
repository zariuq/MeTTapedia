/-- Summing the finite-volume weights over any fixed inside-region gain class is
bounded by the total partition after multiplying by the cut factor. This is the
algebraic Peierls step before any geometric extraction or counting. -/
theorem symmetricGridZeroField_flipGainAssignmentFinset_weightSum_mul_cutFactor_le_partition
    (w : ℝ) {Λ : Region GridNode} (inside : Region GridNode) (hInsideΛ : inside ⊆ Λ)
    (ξ : BoundaryCondition GridNode) :
    (ENNReal.ofReal (Real.exp w)) ^
        ((gridRegionSupport Λ).filter (gridBaseClauseCutsRegion inside)).card *
        Finset.sum (symmetricGridFlipGainAssignmentFinset inside hInsideΛ ξ) (fun x =>
          (symmetricGridZeroFieldStrictSpec w).finiteVolumeWeight Λ x ξ) ≤
      (symmetricGridZeroFieldStrictSpec w).finiteVolumePartition Λ ξ := by
  classical
  let M := symmetricGridZeroFieldStrictSpec w
  let A := symmetricGridFlipGainAssignmentFinset inside hInsideΛ ξ
  let factor : ENNReal := ENNReal.ofReal (Real.exp w)
  let flip : LocalAssignment GridNode Λ → LocalAssignment GridNode Λ :=
    flipInsideLocalAssignment inside hInsideΛ
  let wt : LocalAssignment GridNode Λ → ENNReal := fun x => M.finiteVolumeWeight Λ x ξ
  have hflip_injective : Function.Injective flip := by
    intro x y hxy
    have hxy' := congrArg flip hxy
    simpa [flip, flipInsideLocalAssignment_involutive] using hxy'
  have hweight_eq :
      ∀ x ∈ A,
        wt (flip x) =
          factor ^ ((gridRegionSupport Λ).filter (gridBaseClauseCutsRegion inside)).card *
            wt x := by
    intro x hx
    have hgain :
        ∀ j ∈ (gridRegionSupport Λ).filter (gridBaseClauseCutsRegion inside),
          symmetricGridBaseClauseFlipGainCondition inside hInsideΛ x ξ j :=
      (Finset.mem_filter.mp hx).2
    simpa [M, factor, flip, wt] using
      (symmetricGridZeroField_finiteVolumeWeight_flipInside_eq_cutFactor_of_gainCondition
        (w := w) (Λ := Λ) inside hInsideΛ x ξ hgain)
  calc
    factor ^ ((gridRegionSupport Λ).filter (gridBaseClauseCutsRegion inside)).card *
        Finset.sum A wt
      = Finset.sum A (fun x =>
          factor ^ ((gridRegionSupport Λ).filter (gridBaseClauseCutsRegion inside)).card *
            wt x) := by
            rw [Finset.mul_sum]
    _ = Finset.sum A (fun x => wt (flip x)) := by
          refine Finset.sum_congr rfl ?_
          intro x hx
          exact (hweight_eq x hx).symm
    _ = Finset.sum (A.image flip) wt := by
          refine (Finset.sum_image ?hinj).symm
          intro x hx y hy hxy
          exact hflip_injective hxy
    _ ≤ Finset.sum Finset.univ wt := by
          exact Finset.sum_le_univ_sum_of_nonneg (fun _ => zero_le)
    _ = M.finiteVolumePartition Λ ξ := by
          simp [M, wt, Mettapedia.Logic.MarkovLogicInfiniteSpecification.InfiniteGroundMLNSpec.finiteVolumePartition]

/-- The fixed-region partition bound specialized to a corner separator witness. -/
theorem cornerAxisSeparator_zeroField_flipGainAssignmentFinset_weightSum_mul_cutFactor_le_partition
    (w : ℝ) {n : ℕ} (sep : CornerAxisSeparator n)
    (ξ : BoundaryCondition GridNode) :
    (ENNReal.ofReal (Real.exp w)) ^ sep.cutBaseClauses.card *
        Finset.sum (symmetricGridFlipGainAssignmentFinset sep.inside sep.inside_subset ξ) (fun x =>
          (symmetricGridZeroFieldStrictSpec w).finiteVolumeWeight (gridExhaustion.region n) x ξ) ≤
      (symmetricGridZeroFieldStrictSpec w).finiteVolumePartition (gridExhaustion.region n) ξ := by
  simpa [CornerAxisSeparator.cutBaseClauses]
    using
      (symmetricGridZeroField_flipGainAssignmentFinset_weightSum_mul_cutFactor_le_partition
        (w := w) (Λ := gridExhaustion.region n) sep.inside sep.inside_subset ξ)

/-- The cylinder mass of the fixed-region gain-class is exactly the sum of the
finite-volume weights of its assignments. -/
theorem symmetricGridFlipGainAssignmentFinset_cylinderMass_eq_weightSum
    (w : ℝ) {Λ : Region GridNode} (inside : Region GridNode) (hInsideΛ : inside ⊆ Λ)
    (ξ : BoundaryCondition GridNode) :
    finiteVolumeCylinderMass
        (symmetricGridZeroFieldStrictSpec w).toInfiniteGroundMLNSpec
        Λ ξ Λ
        ((symmetricGridFlipGainAssignmentFinset inside hInsideΛ ξ :
          Finset (LocalAssignment GridNode Λ)) : Set (LocalAssignment GridNode Λ)) =
      Finset.sum (symmetricGridFlipGainAssignmentFinset inside hInsideΛ ξ) (fun x =>
        (symmetricGridZeroFieldStrictSpec w).toInfiniteGroundMLNSpec.finiteVolumeWeight Λ x ξ) := by
  classical
  let M := (symmetricGridZeroFieldStrictSpec w).toInfiniteGroundMLNSpec
  let A := symmetricGridFlipGainAssignmentFinset inside hInsideΛ ξ
  let wt : LocalAssignment GridNode Λ → ENNReal := fun x => M.finiteVolumeWeight Λ x ξ
  have hpatch :
      finiteVolumeCylinderMass M Λ ξ Λ
          ((A : Finset (LocalAssignment GridNode Λ)) : Set (LocalAssignment GridNode Λ)) =
        ∑ x : LocalAssignment GridNode Λ, if x ∈ A then wt x else 0 := by
    unfold finiteVolumeCylinderMass
    refine Finset.sum_congr rfl ?_
    intro x hx
    have hxiff :
        patch Λ x ξ ∈ MeasureTheory.cylinder Λ
            ((A : Finset (LocalAssignment GridNode Λ)) :
              Set (LocalAssignment GridNode Λ)) ↔
          x ∈ A := by
      simpa [Set.mem_preimage] using
        congrArg (fun T : Set (LocalAssignment GridNode Λ) => x ∈ T)
          (Mettapedia.Logic.MarkovLogicInfiniteUniqueness.ClassicalInfiniteGroundMLNSpec.preimage_cylinder_patch
            (Δ := Λ) (ξ := ξ)
            (((A : Finset (LocalAssignment GridNode Λ)) :
              Set (LocalAssignment GridNode Λ))))
    by_cases hxA : x ∈ A <;> simp [wt, hxA, hxiff]
  calc
    finiteVolumeCylinderMass M Λ ξ Λ
        ((A : Finset (LocalAssignment GridNode Λ)) :
          Set (LocalAssignment GridNode Λ)) =
      Finset.sum A wt := by
        rw [hpatch]
        have hsumFilter :
            (∑ x : LocalAssignment GridNode Λ, (if x ∈ A then wt x else 0)) =
              Finset.sum
                ((Finset.univ : Finset (LocalAssignment GridNode Λ)).filter
                  (fun x => x ∈ A)) wt := by
          exact
            (Finset.sum_filter
              (s := (Finset.univ : Finset (LocalAssignment GridNode Λ)))
              (p := fun x => x ∈ A) (f := wt)).symm
        have hAfilter :
            (Finset.univ : Finset (LocalAssignment GridNode Λ)).filter
                (fun x => x ∈ A) = A := by
          ext x
          simp [A]
        rw [hsumFilter, hAfilter]
    _ =
      Finset.sum (symmetricGridFlipGainAssignmentFinset inside hInsideΛ ξ) (fun x =>
        (symmetricGridZeroFieldStrictSpec w).toInfiniteGroundMLNSpec.finiteVolumeWeight Λ x ξ) := by
          simp [A, wt, M]

/-- The fixed-region gain-class cylinder event carries at most reciprocal cut
factor mass under the finite-volume world measure, expressed without division as
`cutFactor * P(event) ≤ 1`. -/
theorem symmetricGridZeroField_flipGainAssignmentFinset_finiteVolumeWorldMeasure_mul_cutFactor_le_one
    (w : ℝ) {Λ : Region GridNode} (inside : Region GridNode) (hInsideΛ : inside ⊆ Λ)
    (ξ : BoundaryCondition GridNode) :
    (ENNReal.ofReal (Real.exp w)) ^
        ((gridRegionSupport Λ).filter (gridBaseClauseCutsRegion inside)).card *
      finiteVolumeWorldMeasure
        (symmetricGridZeroFieldStrictSpec w).toInfiniteGroundMLNSpec Λ ξ
        (Mettapedia.Logic.MarkovLogicInfinitePositive.StrictlyPositiveInfiniteGroundMLNSpec.finiteVolumePartition_ne_zero
          (symmetricGridZeroFieldStrictSpec w) Λ ξ)
        (MeasureTheory.cylinder Λ
          (((symmetricGridFlipGainAssignmentFinset inside hInsideΛ ξ :
              Finset (LocalAssignment GridNode Λ)) :
            Set (LocalAssignment GridNode Λ)))) ≤ 1 := by
  classical
  let M := symmetricGridZeroFieldStrictSpec w
  let Minf := M.toInfiniteGroundMLNSpec
  let A := symmetricGridFlipGainAssignmentFinset inside hInsideΛ ξ
  let factor : ENNReal := ENNReal.ofReal (Real.exp w)
  let hZ :
      Minf.finiteVolumePartition Λ ξ ≠ 0 :=
    Mettapedia.Logic.MarkovLogicInfinitePositive.StrictlyPositiveInfiniteGroundMLNSpec.finiteVolumePartition_ne_zero
      M Λ ξ
  have htop : Minf.finiteVolumePartition Λ ξ ≠ ⊤ :=
    finiteVolumePartition_ne_top Minf Λ ξ
  have hmeas :
      MeasurableSet (((A : Finset (LocalAssignment GridNode Λ)) :
        Set (LocalAssignment GridNode Λ))) :=
    A.finite_toSet.measurableSet
  have hmeasure :
      finiteVolumeWorldMeasure Minf Λ ξ hZ
          (MeasureTheory.cylinder Λ
            (((A : Finset (LocalAssignment GridNode Λ)) :
              Set (LocalAssignment GridNode Λ)))) =
        Finset.sum A (fun x => Minf.finiteVolumeWeight Λ x ξ) *
          (Minf.finiteVolumePartition Λ ξ)⁻¹ := by
    rw [finiteVolumeWorldMeasure_cylinder
      (M := Minf) (Λ := Λ) (I := Λ)
      (S := (((A : Finset (LocalAssignment GridNode Λ)) :
        Set (LocalAssignment GridNode Λ)))) hmeas ξ hZ]
    rw [symmetricGridFlipGainAssignmentFinset_cylinderMass_eq_weightSum
      (w := w) (Λ := Λ) inside hInsideΛ ξ]
  calc
    factor ^ ((gridRegionSupport Λ).filter (gridBaseClauseCutsRegion inside)).card *
        finiteVolumeWorldMeasure Minf Λ ξ hZ
          (MeasureTheory.cylinder Λ
            (((A : Finset (LocalAssignment GridNode Λ)) :
              Set (LocalAssignment GridNode Λ)))) =
      factor ^ ((gridRegionSupport Λ).filter (gridBaseClauseCutsRegion inside)).card *
        (Finset.sum A (fun x => Minf.finiteVolumeWeight Λ x ξ) *
          (Minf.finiteVolumePartition Λ ξ)⁻¹) := by
            rw [hmeasure]
    _ =
      (factor ^ ((gridRegionSupport Λ).filter (gridBaseClauseCutsRegion inside)).card *
        Finset.sum A (fun x => Minf.finiteVolumeWeight Λ x ξ)) *
          (Minf.finiteVolumePartition Λ ξ)⁻¹ := by
            ac_rfl
    _ ≤ Minf.finiteVolumePartition Λ ξ * (Minf.finiteVolumePartition Λ ξ)⁻¹ := by
          exact mul_le_mul_of_nonneg_right
            (symmetricGridZeroField_flipGainAssignmentFinset_weightSum_mul_cutFactor_le_partition
              (w := w) (Λ := Λ) inside hInsideΛ ξ)
            (by exact zero_le)
    _ = 1 := by
          exact ENNReal.mul_inv_cancel hZ htop

/-- The explicit generic separator event for an inside region also pays the
reciprocal cut-factor penalty, since it lies inside the already-controlled
gain class. -/
theorem falseInsideTrueCutBoundaryRegion_finiteVolumeWorldMeasure_mul_cutFactor_le_one
    (w : ℝ) {Λ : Region GridNode} (inside : Region GridNode) (hInsideΛ : inside ⊆ Λ)
    (ξ : BoundaryCondition GridNode) :
    (ENNReal.ofReal (Real.exp w)) ^
        ((gridRegionSupport Λ).filter (gridBaseClauseCutsRegion inside)).card *
      finiteVolumeWorldMeasure
        (symmetricGridZeroFieldStrictSpec w).toInfiniteGroundMLNSpec Λ ξ
        (Mettapedia.Logic.MarkovLogicInfinitePositive.StrictlyPositiveInfiniteGroundMLNSpec.finiteVolumePartition_ne_zero
          (symmetricGridZeroFieldStrictSpec w) Λ ξ)
        (MeasureTheory.cylinder Λ
          (((falseInsideTrueCutBoundaryRegionFinset inside hInsideΛ ξ :
              Finset (LocalAssignment GridNode Λ)) :
            Set (LocalAssignment GridNode Λ)))) ≤ 1 := by
  classical
  let M := symmetricGridZeroFieldStrictSpec w
  let Minf := M.toInfiniteGroundMLNSpec
  let hZ :
      Minf.finiteVolumePartition Λ ξ ≠ 0 :=
    Mettapedia.Logic.MarkovLogicInfinitePositive.StrictlyPositiveInfiniteGroundMLNSpec.finiteVolumePartition_ne_zero
      M Λ ξ
  let A := symmetricGridFlipGainAssignmentFinset inside hInsideΛ ξ
  let B := falseInsideTrueCutBoundaryRegionFinset inside hInsideΛ ξ
  have hsubset :
      (((B : Finset (LocalAssignment GridNode Λ)) :
          Set (LocalAssignment GridNode Λ))) ⊆
        (((A : Finset (LocalAssignment GridNode Λ)) :
          Set (LocalAssignment GridNode Λ))) := by
    intro x hx
    exact falseInsideTrueCutBoundaryRegionFinset_subset_flipGainAssignmentFinset
      inside hInsideΛ ξ hx
  have hAmeas :
      MeasurableSet (((A : Finset (LocalAssignment GridNode Λ)) :
        Set (LocalAssignment GridNode Λ))) :=
    A.finite_toSet.measurableSet
  have hBmeas :
      MeasurableSet (((B : Finset (LocalAssignment GridNode Λ)) :
        Set (LocalAssignment GridNode Λ))) :=
    B.finite_toSet.measurableSet
  have hmono :
      finiteVolumeWorldMeasure
          Minf Λ ξ hZ
          (MeasureTheory.cylinder Λ
            (((B : Finset (LocalAssignment GridNode Λ)) :
              Set (LocalAssignment GridNode Λ)))) ≤
        finiteVolumeWorldMeasure
          Minf Λ ξ hZ
          (MeasureTheory.cylinder Λ
            (((A : Finset (LocalAssignment GridNode Λ)) :
              Set (LocalAssignment GridNode Λ)))) := by
    rw [finiteVolumeWorldMeasure_cylinder_region_eq_assignmentPMF_toMeasure
      (M := Minf) (Δ := Λ) (ξ := ξ) (hZ := hZ)
      (S := (((B : Finset (LocalAssignment GridNode Λ)) :
        Set (LocalAssignment GridNode Λ)))) hBmeas]
    rw [finiteVolumeWorldMeasure_cylinder_region_eq_assignmentPMF_toMeasure
      (M := Minf) (Δ := Λ) (ξ := ξ) (hZ := hZ)
      (S := (((A : Finset (LocalAssignment GridNode Λ)) :
        Set (LocalAssignment GridNode Λ)))) hAmeas]
    exact MeasureTheory.measure_mono hsubset
  calc
    (ENNReal.ofReal (Real.exp w)) ^
        ((gridRegionSupport Λ).filter (gridBaseClauseCutsRegion inside)).card *
      finiteVolumeWorldMeasure
        Minf Λ ξ hZ
        (MeasureTheory.cylinder Λ
          (((B : Finset (LocalAssignment GridNode Λ)) :
            Set (LocalAssignment GridNode Λ)))) ≤
      (ENNReal.ofReal (Real.exp w)) ^
          ((gridRegionSupport Λ).filter (gridBaseClauseCutsRegion inside)).card *
        finiteVolumeWorldMeasure
          Minf Λ ξ hZ
          (MeasureTheory.cylinder Λ
            (((A : Finset (LocalAssignment GridNode Λ)) :
              Set (LocalAssignment GridNode Λ)))) := by
          exact mul_le_mul_of_nonneg_left hmono (by exact zero_le)
    _ ≤ 1 := by
          simpa [A] using
            (symmetricGridZeroField_flipGainAssignmentFinset_finiteVolumeWorldMeasure_mul_cutFactor_le_one
              (w := w) (Λ := Λ) inside hInsideΛ ξ)

/-- The plus-boundary finite-volume world measure on the stage-`n` box. -/
noncomputable def symmetricGridZeroFieldPlusStageWorldMeasure
    (w : ℝ) (n : ℕ) : Measure (InfiniteWorld GridNode) :=
  let M := symmetricGridZeroFieldStrictSpec w
  finiteVolumeWorldMeasure
    M.toInfiniteGroundMLNSpec
    (gridExhaustion.region n) gridPlusBoundary
    (Mettapedia.Logic.MarkovLogicInfinitePositive.StrictlyPositiveInfiniteGroundMLNSpec.finiteVolumePartition_ne_zero
      M (gridExhaustion.region n) gridPlusBoundary)

/-- The corresponding full-region assignment measure on stage `n`. -/
noncomputable def symmetricGridZeroFieldPlusStageAssignmentMeasure
    (w : ℝ) (n : ℕ) :
    Measure (LocalAssignment GridNode (gridExhaustion.region n)) :=
  let M := symmetricGridZeroFieldStrictSpec w
  let Minf := M.toInfiniteGroundMLNSpec
  let hZ :
      InfiniteGroundMLNSpec.finiteVolumePartition Minf (gridExhaustion.region n) gridPlusBoundary ≠ 0 :=
    Mettapedia.Logic.MarkovLogicInfinitePositive.StrictlyPositiveInfiniteGroundMLNSpec.finiteVolumePartition_ne_zero
      M (gridExhaustion.region n) gridPlusBoundary
  (finiteVolumeAssignmentPMF Minf (gridExhaustion.region n) gridPlusBoundary hZ).toMeasure

