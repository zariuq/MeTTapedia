theorem visibleBoundarySeparatorEdges_partition_avoiding_paths
    {n : ℕ} {hull : Region GridNode} {U : GridNode × GridNode → Prop}
    [DecidablePred U]
    (hconn : OriginConnectedRegion hull)
    {ePos eNeg : GridNode × GridNode}
    (hePos : ePos ∈ visibleBoundarySeparatorEdges n hull)
    (heNeg : eNeg ∈ visibleBoundarySeparatorEdges n hull)
    (hpos : U ePos) (hneg : ¬ U eNeg)
    {x : GridNode} (hx : x ∈ hull) :
    (∃ b ∈ gridStageBoundaryRegion n,
      b ∈ boundaryConnectedOutsideSubregion n hull ∧
        Relation.ReflTransGen
          (gridAdjacentInHullExteriorUnionAvoidsSeparatorEdges n hull
            ((visibleBoundarySeparatorEdges n hull).filter (fun e => ¬ U e)))
          b x) ∧
      ∃ b ∈ gridStageBoundaryRegion n,
        b ∈ boundaryConnectedOutsideSubregion n hull ∧
          Relation.ReflTransGen
            (gridAdjacentInHullExteriorUnionAvoidsSeparatorEdges n hull
              ((visibleBoundarySeparatorEdges n hull).filter U))
            b x := by
  have hnegSubset :
      (visibleBoundarySeparatorEdges n hull).filter (fun e => ¬ U e) ⊆
        (visibleBoundarySeparatorEdges n hull).erase ePos := by
    intro f hf
    rw [Finset.mem_erase]
    have hfSep : f ∈ visibleBoundarySeparatorEdges n hull :=
      (Finset.mem_filter.1 hf).1
    have hfNeg : ¬ U f :=
      (Finset.mem_filter.1 hf).2
    exact ⟨fun hfe => hfNeg (by simpa [hfe] using hpos), hfSep⟩
  have hposSubset :
      (visibleBoundarySeparatorEdges n hull).filter U ⊆
        (visibleBoundarySeparatorEdges n hull).erase eNeg := by
    intro f hf
    rw [Finset.mem_erase]
    have hfSep : f ∈ visibleBoundarySeparatorEdges n hull :=
      (Finset.mem_filter.1 hf).1
    have hfPos : U f :=
      (Finset.mem_filter.1 hf).2
    exact ⟨fun hfe => hneg (by simpa [hfe] using hfPos), hfSep⟩
  exact
    ⟨visibleBoundarySeparatorEdges_hullExteriorUnion_reachable_from_stageBoundary_to_hull_avoids_subset_erase
        hconn hePos hnegSubset hx,
      visibleBoundarySeparatorEdges_hullExteriorUnion_reachable_from_stageBoundary_to_hull_avoids_subset_erase
        hconn heNeg hposSubset hx⟩

