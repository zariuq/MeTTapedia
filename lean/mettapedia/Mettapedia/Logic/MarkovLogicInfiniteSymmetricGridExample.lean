                          (∀ k : Fin len,
                            node (k.1 + 1) =
                              cutWalkMoveTarget (node k.1)
                                (cutWalkMoveFromClauseEndpoint (step k) (node k.1))) ∧
                            step ⟨0, hpos⟩ = GridClauseId.horizontal i 0 ∧
                              tag ⟨0, hpos⟩ = CutWalkVisitTag.fresh ∧
                                (∀ k : Fin len,
                                  tag k = CutWalkVisitTag.fresh →
                                    step k ∈ s.1) ∧
                                  (∀ x ∈ s.1,
                                    ∃ k : Fin len,
