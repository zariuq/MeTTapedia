    ∃ f :
      {s // s ∈ originConnectedHullCutSetCandidatesInCutCardBoxAxisAnchored m i j} →
        CutWalkCode m,
      Function.Injective f := by
  exact ⟨cutWalkEncode (m := m) (i := i) (j := j),
    cutWalkEncode_injective_of_decode_exists hdecode⟩

