theorem CutWalkReplayPrefix.appendDirect_fresh_step_mem
    {i : ℕ} {s : Finset GridClauseId}
    (pref : CutWalkReplayPrefix i)
    (c : GridClauseId)
    (hcNode : pref.node pref.len ∈ gridClauseDualEndpoints c)
    (hc : c ∈ s)
    (hmem :
      ∀ k : Fin pref.len,
        pref.tag k = CutWalkVisitTag.fresh →
          pref.step k ∈ s) :
    ∀ k : Fin (pref.appendDirect c hcNode).len,
      (pref.appendDirect c hcNode).tag k = CutWalkVisitTag.fresh →
        (pref.appendDirect c hcNode).step k ∈ s := by
  intro k htag
  by_cases hk : k.1 < pref.len
  · have htagOld : pref.tag ⟨k.1, hk⟩ = CutWalkVisitTag.fresh := by
      simpa [CutWalkReplayPrefix.appendDirect, hk] using htag
    simpa [CutWalkReplayPrefix.appendDirect, hk] using hmem ⟨k.1, hk⟩ htagOld
  · simpa [CutWalkReplayPrefix.appendDirect, hk] using hc

theorem CutWalkReplayPrefix.appendDirect_fresh_cover_insert
    {i : ℕ} {t : Finset GridClauseId}
    (pref : CutWalkReplayPrefix i)
    (c : GridClauseId)
    (hcNode : pref.node pref.len ∈ gridClauseDualEndpoints c)
    (hcover :
      ∀ x ∈ t,
        ∃ k : Fin pref.len,
          pref.tag k = CutWalkVisitTag.fresh ∧
            pref.step k = x) :
    ∀ x ∈ insert c t,
      ∃ k : Fin (pref.appendDirect c hcNode).len,
        (pref.appendDirect c hcNode).tag k = CutWalkVisitTag.fresh ∧
          (pref.appendDirect c hcNode).step k = x := by
  intro x hx
  rw [Finset.mem_insert] at hx
  rcases hx with rfl | hx
  · refine ⟨⟨pref.len, by simp [CutWalkReplayPrefix.appendDirect]⟩, ?_, ?_⟩
    · simp [CutWalkReplayPrefix.appendDirect]
    · simp [CutWalkReplayPrefix.appendDirect]
  · rcases hcover x hx with ⟨k, htag, hstep⟩
    refine ⟨⟨k.1, by simp [CutWalkReplayPrefix.appendDirect]⟩, ?_, ?_⟩
    · simpa [CutWalkReplayPrefix.appendDirect, k.2] using htag
    · simpa [CutWalkReplayPrefix.appendDirect, k.2] using hstep

