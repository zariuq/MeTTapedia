theorem exists_cutClause_of_mem_visibleOuterBoundary
    {n : ℕ} {hull : Region GridNode} {s : Finset GridClauseId}
    {p : GridNode}
    (hsEq :
      s =
        (gridRegionSupport (gridExhaustion.region n)).filter
          (gridBaseClauseCutsRegion hull))
    (hHull : hull ⊆ gridExhaustion.region n)
    (hp : p ∈ visibleOuterBoundary n hull) :
    ∃ c ∈ s,
      p ∈ gridClausePrimalEndpoints c ∧ gridBaseClauseCutsRegion hull c := by
  rcases mem_visibleOuterBoundary_iff.1 hp with
    ⟨hpOutside, q, hqHull, hpq⟩
  let c := gridAdjacentClauseId p q
  have hpNotHull : p ∉ hull :=
    boundaryConnectedOutsideSubregion_not_mem_inside hpOutside
  have hcut : gridBaseClauseCutsRegion hull c := by
    dsimp [c]
    rw [gridBaseClauseCutsRegion_gridAdjacentClauseId_iff hpq]
    exact Or.inr ⟨hpNotHull, hqHull⟩
  have hcMem : c ∈ s := by
    dsimp [c]
    exact gridAdjacentClauseId_mem_cutSet_of_eq_of_mem_right
      hsEq hHull hqHull hpq hcut
  exact ⟨c, hcMem,
    left_mem_gridClausePrimalEndpoints_gridAdjacentClauseId hpq, hcut⟩

theorem exists_cutClause_of_mem_visibleOuterBoundary_of_cutSet_eq
    {visibleStage cutStage : ℕ} {hull : Region GridNode}
    {s : Finset GridClauseId} {p : GridNode}
    (hsEq :
      s =
        (gridRegionSupport (gridExhaustion.region cutStage)).filter
          (gridBaseClauseCutsRegion hull))
    (hHull : hull ⊆ gridExhaustion.region cutStage)
    (hp : p ∈ visibleOuterBoundary visibleStage hull) :
    ∃ c ∈ s,
      p ∈ gridClausePrimalEndpoints c ∧ gridBaseClauseCutsRegion hull c := by
  rcases mem_visibleOuterBoundary_iff.1 hp with
    ⟨hpOutside, q, hqHull, hpq⟩
  let c := gridAdjacentClauseId p q
  have hpNotHull : p ∉ hull :=
    boundaryConnectedOutsideSubregion_not_mem_inside hpOutside
  have hcut : gridBaseClauseCutsRegion hull c := by
    dsimp [c]
    rw [gridBaseClauseCutsRegion_gridAdjacentClauseId_iff hpq]
    exact Or.inr ⟨hpNotHull, hqHull⟩
  have hcMem : c ∈ s := by
    dsimp [c]
    exact gridAdjacentClauseId_mem_cutSet_of_eq_of_mem_right
      hsEq hHull hqHull hpq hcut
  exact ⟨c, hcMem,
    left_mem_gridClausePrimalEndpoints_gridAdjacentClauseId hpq, hcut⟩

noncomputable def visibleBoundaryCutClauseChoice
    {visibleStage cutStage : ℕ} {hull : Region GridNode}
    {s : Finset GridClauseId}
    (hsEq :
      s =
        (gridRegionSupport (gridExhaustion.region cutStage)).filter
          (gridBaseClauseCutsRegion hull))
    (hHull : hull ⊆ gridExhaustion.region cutStage)
    (p : {p // p ∈ visibleOuterBoundary visibleStage hull}) :
    {c // c ∈ s} :=
  ⟨Classical.choose
      (exists_cutClause_of_mem_visibleOuterBoundary_of_cutSet_eq
        hsEq hHull p.2),
    (Classical.choose_spec
      (exists_cutClause_of_mem_visibleOuterBoundary_of_cutSet_eq
        hsEq hHull p.2)).1⟩

theorem visibleBoundaryCutClauseChoice_primalEndpoint
    {visibleStage cutStage : ℕ} {hull : Region GridNode}
    {s : Finset GridClauseId}
    (hsEq :
      s =
        (gridRegionSupport (gridExhaustion.region cutStage)).filter
          (gridBaseClauseCutsRegion hull))
    (hHull : hull ⊆ gridExhaustion.region cutStage)
    (p : {p // p ∈ visibleOuterBoundary visibleStage hull}) :
    p.1 ∈
      gridClausePrimalEndpoints
        (visibleBoundaryCutClauseChoice
          (visibleStage := visibleStage) (cutStage := cutStage)
          (hull := hull) (s := s) hsEq hHull p).1 := by
  exact (Classical.choose_spec
    (exists_cutClause_of_mem_visibleOuterBoundary_of_cutSet_eq
      hsEq hHull p.2)).2.1

theorem visibleBoundaryCutClauseChoice_cuts
    {visibleStage cutStage : ℕ} {hull : Region GridNode}
    {s : Finset GridClauseId}
    (hsEq :
      s =
        (gridRegionSupport (gridExhaustion.region cutStage)).filter
          (gridBaseClauseCutsRegion hull))
    (hHull : hull ⊆ gridExhaustion.region cutStage)
    (p : {p // p ∈ visibleOuterBoundary visibleStage hull}) :
    gridBaseClauseCutsRegion hull
      (visibleBoundaryCutClauseChoice
        (visibleStage := visibleStage) (cutStage := cutStage)
        (hull := hull) (s := s) hsEq hHull p).1 := by
  exact (Classical.choose_spec
    (exists_cutClause_of_mem_visibleOuterBoundary_of_cutSet_eq
      hsEq hHull p.2)).2.2

theorem horizontal_mem_gridRegionSupport_gridExhaustion_region_iff
    {n i j : ℕ} :
    GridClauseId.horizontal i j ∈ gridRegionSupport (gridExhaustion.region n) ↔
      i < n + 1 ∧ j < n + 1 := by
  constructor
  · intro hj
    rcases gridRegionSupport_sound hj with ⟨a, haClause, haStage⟩
    have ha :
        a = (i, j) ∨ a = (i + 1, j) := by
      simpa [gridClause] using haClause
    rcases Finset.mem_product.1 haStage with ⟨ha1, ha2⟩
    rcases ha with rfl | rfl
    · exact ⟨Finset.mem_range.mp ha1, Finset.mem_range.mp ha2⟩
    · exact ⟨Nat.lt_of_succ_lt (Finset.mem_range.mp ha1), Finset.mem_range.mp ha2⟩
  · rintro ⟨hi, hj⟩
    apply gridRegionSupport_complete
    refine ⟨(i, j), ?_,
      Finset.mem_product.2 ⟨Finset.mem_range.mpr hi, Finset.mem_range.mpr hj⟩⟩
    simp [gridClause]

theorem vertical_mem_gridRegionSupport_gridExhaustion_region_iff
    {n i j : ℕ} :
    GridClauseId.vertical i j ∈ gridRegionSupport (gridExhaustion.region n) ↔
      i < n + 1 ∧ j < n + 1 := by
  constructor
  · intro hj
    rcases gridRegionSupport_sound hj with ⟨a, haClause, haStage⟩
    have ha :
        a = (i, j) ∨ a = (i, j + 1) := by
      simpa [gridClause] using haClause
    rcases Finset.mem_product.1 haStage with ⟨ha1, ha2⟩
    rcases ha with rfl | rfl
    · exact ⟨Finset.mem_range.mp ha1, Finset.mem_range.mp ha2⟩
    · exact ⟨Finset.mem_range.mp ha1, Nat.lt_of_succ_lt (Finset.mem_range.mp ha2)⟩
  · rintro ⟨hi, hj⟩
    apply gridRegionSupport_complete
    refine ⟨(i, j), ?_,
      Finset.mem_product.2 ⟨Finset.mem_range.mpr hi, Finset.mem_range.mpr hj⟩⟩
    simp [gridClause]

theorem originContainingSubregionCutBaseClauses_eq_of_stage_subsets
    {m n : ℕ} {inside : Region GridNode}
    (hInsideM : inside ⊆ gridExhaustion.region m)
    (hInsideN : inside ⊆ gridExhaustion.region n) :
    (gridRegionSupport (gridExhaustion.region n)).filter (gridBaseClauseCutsRegion inside) =
      (gridRegionSupport (gridExhaustion.region m)).filter (gridBaseClauseCutsRegion inside) := by
  ext j
  constructor
  · intro hj
    rcases Finset.mem_filter.1 hj with ⟨_, hjCut⟩
    refine Finset.mem_filter.2 ⟨?_, hjCut⟩
    apply gridRegionSupport_complete
    rcases gridBaseClauseCutsRegion_imp_clauseTouchesRegion hjCut with ⟨a, haClause, haInside⟩
    exact ⟨a, haClause, hInsideM haInside⟩
  · intro hj
    rcases Finset.mem_filter.1 hj with ⟨_, hjCut⟩
    refine Finset.mem_filter.2 ⟨?_, hjCut⟩
    apply gridRegionSupport_complete
    rcases gridBaseClauseCutsRegion_imp_clauseTouchesRegion hjCut with ⟨a, haClause, haInside⟩
    exact ⟨a, haClause, hInsideN haInside⟩

theorem originContainingSubregionCutCard_eq_of_stage_subsets
    {m n : ℕ} {inside : Region GridNode}
    (hInsideM : inside ⊆ gridExhaustion.region m)
    (hInsideN : inside ⊆ gridExhaustion.region n) :
    originContainingSubregionCutCard n inside =
      originContainingSubregionCutCard m inside := by
  unfold originContainingSubregionCutCard
  simp [originContainingSubregionCutBaseClauses_eq_of_stage_subsets hInsideM hInsideN]

/-- A cut clause belongs to the outer cut when its outside endpoint is either
already outside the stage box or lies in the boundary-connected exterior
component of the in-box complement. This ignores hole boundaries. -/
def gridBaseClauseCutsOuterRegion
    (n : ℕ) (inside : Region GridNode) : GridClauseId → Prop
  | .prior _ _ => False
  | .horizontal i j =>
      (((i, j) ∈ inside) ∧
          (((i + 1, j) ∉ gridExhaustion.region n) ∨
            (i + 1, j) ∈ boundaryConnectedOutsideSubregion n inside)) ∨
        ((((i, j) ∉ gridExhaustion.region n) ∨
            (i, j) ∈ boundaryConnectedOutsideSubregion n inside) ∧
          (i + 1, j) ∈ inside)
  | .vertical i j =>
      (((i, j) ∈ inside) ∧
          (((i, j + 1) ∉ gridExhaustion.region n) ∨
            (i, j + 1) ∈ boundaryConnectedOutsideSubregion n inside)) ∨
        ((((i, j) ∉ gridExhaustion.region n) ∨
            (i, j) ∈ boundaryConnectedOutsideSubregion n inside) ∧
          (i, j + 1) ∈ inside)

noncomputable instance (n : ℕ) (inside : Region GridNode) :
    DecidablePred (gridBaseClauseCutsOuterRegion n inside) :=
  Classical.decPred _

/-- The outer cut set for a stage-box inside witness. -/
noncomputable def originContainingSubregionOuterCutBaseClauses
    (n : ℕ) (inside : Region GridNode) : Finset GridClauseId :=
  (gridRegionSupport (gridExhaustion.region n)).filter (gridBaseClauseCutsOuterRegion n inside)

/-- The size of the outer cut set, ignoring hole boundaries. -/
noncomputable def originContainingSubregionOuterCutCard
    (n : ℕ) (inside : Region GridNode) : ℕ :=
  (originContainingSubregionOuterCutBaseClauses n inside).card

theorem gridBaseClauseCutsOuterRegion_imp_cutsRegion
    {n : ℕ} {inside : Region GridNode}
    (hInside : inside ⊆ gridExhaustion.region n)
    {j : GridClauseId}
    (hj : gridBaseClauseCutsOuterRegion n inside j) :
    gridBaseClauseCutsRegion inside j := by
  cases j with
  | prior i j =>
      cases hj
  | horizontal i j =>
      rcases hj with h | h
      · refine Or.inl ⟨h.1, ?_⟩
        rcases h.2 with hOutStage | hOutExt
        · intro hmem
          exact hOutStage (hInside hmem)
        · exact boundaryConnectedOutsideSubregion_not_mem_inside hOutExt
      · refine Or.inr ⟨?_, h.2⟩
        rcases h.1 with hOutStage | hOutExt
        · intro hmem
          exact hOutStage (hInside hmem)
        · exact boundaryConnectedOutsideSubregion_not_mem_inside hOutExt
  | vertical i j =>
      rcases hj with h | h
      · refine Or.inl ⟨h.1, ?_⟩
        rcases h.2 with hOutStage | hOutExt
        · intro hmem
          exact hOutStage (hInside hmem)
        · exact boundaryConnectedOutsideSubregion_not_mem_inside hOutExt
      · refine Or.inr ⟨?_, h.2⟩
        rcases h.1 with hOutStage | hOutExt
        · intro hmem
          exact hOutStage (hInside hmem)
        · exact boundaryConnectedOutsideSubregion_not_mem_inside hOutExt

theorem originContainingSubregionOuterCutBaseClauses_subset_cutBaseClauses
    {n : ℕ} {inside : Region GridNode}
    (hInside : inside ⊆ gridExhaustion.region n) :
    originContainingSubregionOuterCutBaseClauses n inside ⊆
      (gridRegionSupport (gridExhaustion.region n)).filter (gridBaseClauseCutsRegion inside) := by
  unfold originContainingSubregionOuterCutBaseClauses
  intro j hj
  rcases Finset.mem_filter.1 hj with ⟨hjSupp, hjOuter⟩
  exact Finset.mem_filter.2 ⟨hjSupp,
    gridBaseClauseCutsOuterRegion_imp_cutsRegion hInside hjOuter⟩

theorem originContainingSubregionOuterCutCard_le_cutCard
    {n : ℕ} {inside : Region GridNode}
    (hInside : inside ⊆ gridExhaustion.region n) :
    originContainingSubregionOuterCutCard n inside ≤
      originContainingSubregionCutCard n inside := by
  unfold originContainingSubregionOuterCutCard originContainingSubregionCutCard
  exact Finset.card_le_card
    (originContainingSubregionOuterCutBaseClauses_subset_cutBaseClauses hInside)

theorem gridBaseClauseCutsRegion_boundaryConnectedHullRegion_iff
    {n : ℕ} {inside : Region GridNode}
    (hInside : inside ⊆ gridExhaustion.region n)
    {j : GridClauseId} :
    gridBaseClauseCutsRegion (boundaryConnectedHullRegion n inside) j ↔
      gridBaseClauseCutsOuterRegion n inside j := by
  cases j with
  | prior i j =>
      simp [gridBaseClauseCutsRegion, gridBaseClauseCutsOuterRegion]
  | horizontal i j =>
      constructor
      · intro hj
        rcases hj with h | h
        · have hLeftIn : (i, j) ∈ inside := by
            rcases not_mem_boundaryConnectedHullRegion_iff.1 h.2 with hRightOut | hRightExt
            · exact mem_inside_of_mem_boundaryConnectedHullRegion_of_adj_not_stage
                h.1 hRightOut (gridAdjacent_horizontal_forward i j)
            · exact mem_inside_of_mem_boundaryConnectedHullRegion_of_adj_boundaryConnectedOutside
                h.1 hRightExt (gridAdjacent_horizontal_forward i j)
          rcases not_mem_boundaryConnectedHullRegion_iff.1 h.2 with hRightOut | hRightExt
          · exact Or.inl ⟨hLeftIn, Or.inl hRightOut⟩
          · exact Or.inl ⟨hLeftIn, Or.inr hRightExt⟩
        · have hRightIn : (i + 1, j) ∈ inside := by
            rcases not_mem_boundaryConnectedHullRegion_iff.1 h.1 with hLeftOut | hLeftExt
            · exact mem_inside_of_mem_boundaryConnectedHullRegion_of_adj_not_stage
                h.2 hLeftOut (gridAdjacent_horizontal_backward i j)
            · exact mem_inside_of_mem_boundaryConnectedHullRegion_of_adj_boundaryConnectedOutside
                h.2 hLeftExt (gridAdjacent_horizontal_backward i j)
          rcases not_mem_boundaryConnectedHullRegion_iff.1 h.1 with hLeftOut | hLeftExt
          · exact Or.inr ⟨Or.inl hLeftOut, hRightIn⟩
          · exact Or.inr ⟨Or.inr hLeftExt, hRightIn⟩
      · intro hj
        rcases hj with h | h
        · refine Or.inl ?_
          constructor
          · exact inside_subset_boundaryConnectedHullRegion hInside h.1
          · rcases h.2 with hRightOut | hRightExt
            · exact not_mem_boundaryConnectedHullRegion_of_not_stage hRightOut
            · exact not_mem_boundaryConnectedHullRegion_of_mem_boundaryConnectedOutside hRightExt
        · refine Or.inr ?_
          constructor
          · rcases h.1 with hLeftOut | hLeftExt
            · exact not_mem_boundaryConnectedHullRegion_of_not_stage hLeftOut
            · exact not_mem_boundaryConnectedHullRegion_of_mem_boundaryConnectedOutside hLeftExt
          · exact inside_subset_boundaryConnectedHullRegion hInside h.2
  | vertical i j =>
      constructor
      · intro hj
        rcases hj with h | h
        · have hDownIn : (i, j) ∈ inside := by
            rcases not_mem_boundaryConnectedHullRegion_iff.1 h.2 with hUpOut | hUpExt
            · exact mem_inside_of_mem_boundaryConnectedHullRegion_of_adj_not_stage
                h.1 hUpOut (gridAdjacent_vertical_forward i j)
            · exact mem_inside_of_mem_boundaryConnectedHullRegion_of_adj_boundaryConnectedOutside
                h.1 hUpExt (gridAdjacent_vertical_forward i j)
          rcases not_mem_boundaryConnectedHullRegion_iff.1 h.2 with hUpOut | hUpExt
          · exact Or.inl ⟨hDownIn, Or.inl hUpOut⟩
          · exact Or.inl ⟨hDownIn, Or.inr hUpExt⟩
        · have hUpIn : (i, j + 1) ∈ inside := by
            rcases not_mem_boundaryConnectedHullRegion_iff.1 h.1 with hDownOut | hDownExt
            · exact mem_inside_of_mem_boundaryConnectedHullRegion_of_adj_not_stage
                h.2 hDownOut (gridAdjacent_vertical_backward i j)
            · exact mem_inside_of_mem_boundaryConnectedHullRegion_of_adj_boundaryConnectedOutside
                h.2 hDownExt (gridAdjacent_vertical_backward i j)
          rcases not_mem_boundaryConnectedHullRegion_iff.1 h.1 with hDownOut | hDownExt
          · exact Or.inr ⟨Or.inl hDownOut, hUpIn⟩
          · exact Or.inr ⟨Or.inr hDownExt, hUpIn⟩
      · intro hj
        rcases hj with h | h
        · refine Or.inl ?_
          constructor
          · exact inside_subset_boundaryConnectedHullRegion hInside h.1
          · rcases h.2 with hUpOut | hUpExt
            · exact not_mem_boundaryConnectedHullRegion_of_not_stage hUpOut
            · exact not_mem_boundaryConnectedHullRegion_of_mem_boundaryConnectedOutside hUpExt
        · refine Or.inr ?_
          constructor
          · rcases h.1 with hDownOut | hDownExt
            · exact not_mem_boundaryConnectedHullRegion_of_not_stage hDownOut
            · exact not_mem_boundaryConnectedHullRegion_of_mem_boundaryConnectedOutside hDownExt
          · exact inside_subset_boundaryConnectedHullRegion hInside h.2

theorem originContainingSubregionCutBaseClauses_boundaryConnectedHullRegion_eq_outerCutBaseClauses
    {n : ℕ} {inside : Region GridNode}
    (hInside : inside ⊆ gridExhaustion.region n) :
    (gridRegionSupport (gridExhaustion.region n)).filter
        (gridBaseClauseCutsRegion (boundaryConnectedHullRegion n inside)) =
      originContainingSubregionOuterCutBaseClauses n inside := by
  ext j
  simp [originContainingSubregionOuterCutBaseClauses,
    gridBaseClauseCutsRegion_boundaryConnectedHullRegion_iff hInside]

theorem originContainingSubregionCutCard_boundaryConnectedHullRegion_eq_outerCutCard
    {n : ℕ} {inside : Region GridNode}
    (hInside : inside ⊆ gridExhaustion.region n) :
    originContainingSubregionCutCard n (boundaryConnectedHullRegion n inside) =
      originContainingSubregionOuterCutCard n inside := by
  unfold originContainingSubregionCutCard originContainingSubregionOuterCutCard
  rw [originContainingSubregionCutBaseClauses_boundaryConnectedHullRegion_eq_outerCutBaseClauses
    hInside]

/-- The finite family of distinct boundary-connected hulls arising from
origin-connected stage-box witnesses. This quotients away interior hole
choices and is the sharper family for the remaining counting step. -/
noncomputable def originConnectedHullContainingSubregions (n : ℕ) : Finset (Region GridNode) := by
  classical
  exact (originConnectedContainingSubregions n).image
    (boundaryConnectedHullRegion n)

theorem mem_originConnectedHullContainingSubregions_iff
    {n : ℕ} {hull : Region GridNode} :
    hull ∈ originConnectedHullContainingSubregions n ↔
      ∃ inside ∈ originConnectedContainingSubregions n,
        boundaryConnectedHullRegion n inside = hull := by
  classical
  unfold originConnectedHullContainingSubregions
  constructor
  · intro h
    rcases Finset.mem_image.mp h with ⟨inside, hinside, rfl⟩
    exact ⟨inside, hinside, rfl⟩
  · intro h
    rcases h with ⟨inside, hinside, rfl⟩
    exact Finset.mem_image.mpr ⟨inside, hinside, rfl⟩

theorem mem_originConnectedHullContainingSubregions_imp_originContaining
    {n : ℕ} {hull : Region GridNode}
    (hhull : hull ∈ originConnectedHullContainingSubregions n) :
    hull ∈ originContainingSubregions n := by
  rcases mem_originConnectedHullContainingSubregions_iff.1 hhull with
    ⟨inside, hinside, rfl⟩
  rcases mem_originConnectedContainingSubregions_iff.1 hinside with ⟨hInside, hconn⟩
  rw [mem_originContainingSubregions_iff]
  exact ⟨boundaryConnectedHullRegion_subset_stage,
    inside_subset_boundaryConnectedHullRegion hInside hconn.1⟩

theorem two_le_originConnectedHullContainingSubregionCutCard
    {n : ℕ} {hull : Region GridNode}
    (hhull : hull ∈ originConnectedHullContainingSubregions n) :
    2 ≤ originContainingSubregionCutCard n hull := by
  have hinside : hull ∈ originContainingSubregions n :=
    mem_originConnectedHullContainingSubregions_imp_originContaining hhull
  obtain ⟨i, j, hhor⟩ := originContainingSubregion_exists_horizontalCut hinside
  obtain ⟨i', j', hvert⟩ := originContainingSubregion_exists_verticalCut hinside
  have hsubset :
      ({GridClauseId.horizontal i j, GridClauseId.vertical i' j'} : Finset GridClauseId) ⊆
        (gridRegionSupport (gridExhaustion.region n)).filter (gridBaseClauseCutsRegion hull) := by
    intro x hx
    simp at hx
    rcases hx with rfl | rfl
    · exact hhor
    · exact hvert
  have hcard := Finset.card_le_card hsubset
  unfold originContainingSubregionCutCard
  simpa using hcard

theorem originConnectedHullContainingSubregions_filter_cutCard_zero_eq_empty
    (n : ℕ) :
    (originConnectedHullContainingSubregions n).filter
        (fun hull => originContainingSubregionCutCard n hull = 0) = ∅ := by
  classical
  apply Finset.filter_false_of_mem
  intro hull hhull hcut
  have hge : 2 ≤ originContainingSubregionCutCard n hull :=
    two_le_originConnectedHullContainingSubregionCutCard hhull
  have hpos : 0 < originContainingSubregionCutCard n hull :=
    lt_of_lt_of_le (by decide : 0 < 2) hge
  exact Nat.ne_of_gt hpos hcut

theorem originConnectedHullContainingSubregions_filter_cutCard_one_eq_empty
    (n : ℕ) :
    (originConnectedHullContainingSubregions n).filter
        (fun hull => originContainingSubregionCutCard n hull = 1) = ∅ := by
  classical
  apply Finset.filter_false_of_mem
  intro hull hhull hcut
  have hge : 2 ≤ originContainingSubregionCutCard n hull :=
    two_le_originConnectedHullContainingSubregionCutCard hhull
  have hone : 1 < originContainingSubregionCutCard n hull :=
    lt_of_lt_of_le (by decide : 1 < 2) hge
  exact Nat.ne_of_gt hone hcut

theorem originConnectedHullContainingSubregions_cutCard_zero_count
    (n : ℕ) :
    (((originConnectedHullContainingSubregions n).filter
        (fun hull => originContainingSubregionCutCard n hull = 0)).card : ENNReal) = 0 := by
  simp [originConnectedHullContainingSubregions_filter_cutCard_zero_eq_empty]

theorem originConnectedHullContainingSubregions_cutCard_one_count
    (n : ℕ) :
    (((originConnectedHullContainingSubregions n).filter
        (fun hull => originContainingSubregionCutCard n hull = 1)).card : ENNReal) = 0 := by
  simp [originConnectedHullContainingSubregions_filter_cutCard_one_eq_empty]

theorem originConnectedHullContainingSubregions_cutCard_count_eq_zero_of_lt_two
    (n m : ℕ)
    (hm : m < 2) :
    (((originConnectedHullContainingSubregions n).filter
        (fun hull => originContainingSubregionCutCard n hull = m)).card : ENNReal) = 0 := by
  cases m with
  | zero =>
      simpa using originConnectedHullContainingSubregions_cutCard_zero_count n
  | succ m =>
      cases m with
      | zero =>
          simpa using originConnectedHullContainingSubregions_cutCard_one_count n
      | succ m' =>
          exfalso
          have h2 : 2 ≤ Nat.succ (Nat.succ m') :=
            Nat.succ_le_succ (Nat.succ_le_succ (Nat.zero_le m'))
          have hmle : Nat.succ (Nat.succ m') ≤ 1 := Nat.lt_succ_iff.mp hm
          exact (Nat.not_succ_le_self 1) (le_trans h2 hmle)

/-- The canonical boundary-connected hull extracted from the origin-connected
false-spin component of a finite assignment. -/
noncomputable def patchedFalseOriginConnectedHull
    (n : ℕ)
    (x : LocalAssignment GridNode (gridExhaustion.region n)) : Region GridNode :=
  boundaryConnectedHullRegion n
    (originConnectedSubregion (patchedFalseRegion x gridPlusBoundary))

theorem patchedFalseOriginConnectedHull_mem_originConnectedHullContainingSubregions_of_originFalse
    {n : ℕ}
    (x : LocalAssignment GridNode (gridExhaustion.region n))
    (horigin :
      patch (gridExhaustion.region n) x gridPlusBoundary gridOrigin = false) :
    patchedFalseOriginConnectedHull n x ∈ originConnectedHullContainingSubregions n := by
  classical
  let inside := originConnectedSubregion (patchedFalseRegion x gridPlusBoundary)
  have hfullOrigin : gridOrigin ∈ patchedFalseRegion x gridPlusBoundary := by
    exact (mem_patchedFalseRegion_iff x gridPlusBoundary gridOrigin).2
      ⟨gridOrigin_mem_gridExhaustion_region n, horigin⟩
  have hinside :
      inside ∈ originConnectedContainingSubregions n := by
    rw [mem_originConnectedContainingSubregions_iff]
    exact ⟨originConnectedSubregion_subset_trans (patchedFalseRegion_subset x gridPlusBoundary),
      originConnectedSubregion_originConnected hfullOrigin⟩
  dsimp [patchedFalseOriginConnectedHull]
  rw [originConnectedHullContainingSubregions]
  exact Finset.mem_image.mpr
    ⟨inside, hinside, rfl⟩

theorem mem_boundaryConnectedOutsideSubregion_of_outside_row_to_boundary
    {n i j : ℕ} {inside : Region GridNode}
    (hi : i ≤ n) (hj : j ≤ n)
    (hout : ∀ k, i ≤ k → k ≤ n → (k, j) ∉ inside) :
    (i, j) ∈ boundaryConnectedOutsideSubregion n inside := by
  have hiStage : (i, j) ∈ gridExhaustion.region n := by
    exact Finset.mem_product.mpr
      ⟨Finset.mem_range.mpr (lt_of_le_of_lt hi (Nat.lt_succ_self n)),
       Finset.mem_range.mpr (lt_of_le_of_lt hj (Nat.lt_succ_self n))⟩
  have hiOutside : (i, j) ∈ outsideRegionInStage n inside := by
    rw [mem_outsideRegionInStage_iff]
    exact ⟨hiStage, hout i le_rfl hi⟩
  have hreachAux :
      ∀ d i, n - i = d → i ≤ n →
        (∀ k, i ≤ k → k ≤ n → (k, j) ∉ inside) →
          Relation.ReflTransGen
            (gridAdjacentInRegion (outsideRegionInStage n inside))
            (n, j) (i, j) := by
    intro d
    induction d with
    | zero =>
        intro i hdi hi hout
        have hiEq : i = n := by omega
        subst hiEq
        exact Relation.ReflTransGen.refl
    | succ d ih =>
        intro i hdi hi hout
        have hiLt : i < n := by omega
        have hi1 : i + 1 ≤ n := Nat.succ_le_of_lt hiLt
        have hdi' : n - (i + 1) = d := by omega
        have hreach1 :=
          ih (i + 1) hdi' hi1 (fun k hk1 hk2 => hout k (by omega) hk2)
        have hRightStage : (i + 1, j) ∈ gridExhaustion.region n := by
          exact Finset.mem_product.mpr
            ⟨Finset.mem_range.mpr (lt_of_le_of_lt hi1 (Nat.lt_succ_self n)),
             Finset.mem_range.mpr (lt_of_le_of_lt hj (Nat.lt_succ_self n))⟩
        have hRightOutside : (i + 1, j) ∈ outsideRegionInStage n inside := by
          rw [mem_outsideRegionInStage_iff]
          exact ⟨hRightStage, hout (i + 1) (Nat.le_succ i) hi1⟩
        have hLeftStage : (i, j) ∈ gridExhaustion.region n := by
          exact Finset.mem_product.mpr
            ⟨Finset.mem_range.mpr (lt_of_le_of_lt hi (Nat.lt_succ_self n)),
             Finset.mem_range.mpr (lt_of_le_of_lt hj (Nat.lt_succ_self n))⟩
        have hLeftOutside : (i, j) ∈ outsideRegionInStage n inside := by
          rw [mem_outsideRegionInStage_iff]
          exact ⟨hLeftStage, hout i le_rfl hi⟩
        exact Relation.ReflTransGen.tail hreach1
          ⟨hRightOutside, hLeftOutside, gridAdjacent_horizontal_backward i j⟩
  have hreach :
      Relation.ReflTransGen
        (gridAdjacentInRegion (outsideRegionInStage n inside))
        (n, j) (i, j) := by
    exact hreachAux (n - i) i rfl hi hout
  have hBoundary : (n, j) ∈ gridStageBoundaryRegion n := by
    rw [mem_gridStageBoundaryRegion_iff]
    constructor
    · exact Finset.mem_product.mpr
        ⟨Finset.mem_range.mpr (Nat.lt_succ_self n),
         Finset.mem_range.mpr (lt_of_le_of_lt hj (Nat.lt_succ_self n))⟩
    · exact Or.inl rfl
  have hBoundaryOutside : (n, j) ∈ outsideRegionInStage n inside := by
    rw [mem_outsideRegionInStage_iff]
    constructor
    · exact (mem_gridStageBoundaryRegion_iff.1 hBoundary).1
    · exact hout n hi le_rfl
  rw [mem_boundaryConnectedOutsideSubregion_iff]
  exact ⟨hiOutside, ⟨(n, j), hBoundary, hBoundaryOutside, hreach⟩⟩

theorem mem_boundaryConnectedOutsideSubregion_of_outside_col_to_boundary
    {n i j : ℕ} {inside : Region GridNode}
    (hi : i ≤ n) (hj : j ≤ n)
    (hout : ∀ k, j ≤ k → k ≤ n → (i, k) ∉ inside) :
    (i, j) ∈ boundaryConnectedOutsideSubregion n inside := by
  have hjStage : (i, j) ∈ gridExhaustion.region n := by
    exact Finset.mem_product.mpr
      ⟨Finset.mem_range.mpr (lt_of_le_of_lt hi (Nat.lt_succ_self n)),
       Finset.mem_range.mpr (lt_of_le_of_lt hj (Nat.lt_succ_self n))⟩
  have hjOutside : (i, j) ∈ outsideRegionInStage n inside := by
    rw [mem_outsideRegionInStage_iff]
    exact ⟨hjStage, hout j le_rfl hj⟩
  have hreachAux :
      ∀ d j, n - j = d → j ≤ n →
        (∀ k, j ≤ k → k ≤ n → (i, k) ∉ inside) →
          Relation.ReflTransGen
            (gridAdjacentInRegion (outsideRegionInStage n inside))
            (i, n) (i, j) := by
    intro d
    induction d with
    | zero =>
        intro j hdj hj hout
        have hjEq : j = n := by omega
        subst hjEq
        exact Relation.ReflTransGen.refl
    | succ d ih =>
        intro j hdj hj hout
        have hjLt : j < n := by omega
        have hj1 : j + 1 ≤ n := Nat.succ_le_of_lt hjLt
        have hdj' : n - (j + 1) = d := by omega
        have hreach1 :=
          ih (j + 1) hdj' hj1 (fun k hk1 hk2 => hout k (by omega) hk2)
        have hUpStage : (i, j + 1) ∈ gridExhaustion.region n := by
          exact Finset.mem_product.mpr
            ⟨Finset.mem_range.mpr (lt_of_le_of_lt hi (Nat.lt_succ_self n)),
             Finset.mem_range.mpr (lt_of_le_of_lt hj1 (Nat.lt_succ_self n))⟩
        have hUpOutside : (i, j + 1) ∈ outsideRegionInStage n inside := by
          rw [mem_outsideRegionInStage_iff]
          exact ⟨hUpStage, hout (j + 1) (Nat.le_succ j) hj1⟩
        have hDownStage : (i, j) ∈ gridExhaustion.region n := by
          exact Finset.mem_product.mpr
            ⟨Finset.mem_range.mpr (lt_of_le_of_lt hi (Nat.lt_succ_self n)),
             Finset.mem_range.mpr (lt_of_le_of_lt hj (Nat.lt_succ_self n))⟩
        have hDownOutside : (i, j) ∈ outsideRegionInStage n inside := by
          rw [mem_outsideRegionInStage_iff]
          exact ⟨hDownStage, hout j le_rfl hj⟩
        exact Relation.ReflTransGen.tail hreach1
          ⟨hUpOutside, hDownOutside, gridAdjacent_vertical_backward i j⟩
  have hreach :
      Relation.ReflTransGen
        (gridAdjacentInRegion (outsideRegionInStage n inside))
        (i, n) (i, j) := by
    exact hreachAux (n - j) j rfl hj hout
  have hBoundary : (i, n) ∈ gridStageBoundaryRegion n := by
    rw [mem_gridStageBoundaryRegion_iff]
    constructor
    · exact Finset.mem_product.mpr
        ⟨Finset.mem_range.mpr (lt_of_le_of_lt hi (Nat.lt_succ_self n)),
         Finset.mem_range.mpr (Nat.lt_succ_self n)⟩
    · exact Or.inr rfl
  have hBoundaryOutside : (i, n) ∈ outsideRegionInStage n inside := by
    rw [mem_outsideRegionInStage_iff]
    constructor
    · exact (mem_gridStageBoundaryRegion_iff.1 hBoundary).1
    · exact hout n hj le_rfl
  rw [mem_boundaryConnectedOutsideSubregion_iff]
  exact ⟨hjOutside, ⟨(i, n), hBoundary, hBoundaryOutside, hreach⟩⟩

theorem originContainingSubregion_exists_outerHorizontalCut
    {n : ℕ} {inside : Region GridNode}
    (hinside : inside ∈ originContainingSubregions n) :
    ∃ i j,
      GridClauseId.horizontal i j ∈ originContainingSubregionOuterCutBaseClauses n inside := by
  rcases (mem_originContainingSubregions_iff.1 hinside) with ⟨hInsideΛ, hOrigin⟩
  have hne : inside.Nonempty := ⟨gridOrigin, hOrigin⟩
  obtain ⟨p, hpIn, hpMax⟩ := Finset.exists_max_image inside Prod.fst hne
  refine ⟨p.1, p.2, ?_⟩
  unfold originContainingSubregionOuterCutBaseClauses
  rw [Finset.mem_filter]
  constructor
  · apply gridRegionSupport_complete
    refine ⟨p, ?_, hInsideΛ hpIn⟩
    simp [gridClause]
  · refine Or.inl ⟨hpIn, ?_⟩
    by_cases hpTop : p.1 = n
    · left
      intro hmem
      have : p.1 + 1 < n + 1 := (Finset.mem_product.1 hmem).1 |> Finset.mem_range.mp
      omega
    · right
      have hpStage := hInsideΛ hpIn
      have hp1Le : p.1 ≤ n := by
        exact Nat.le_of_lt_succ ((Finset.mem_product.1 hpStage).1 |> Finset.mem_range.mp)
      have hpLt : p.1 < n := Nat.lt_of_le_of_ne hp1Le hpTop
      have hp2Le : p.2 ≤ n := by
        exact Nat.le_of_lt_succ ((Finset.mem_product.1 hpStage).2 |> Finset.mem_range.mp)
      refine mem_boundaryConnectedOutsideSubregion_of_outside_row_to_boundary
        (i := p.1 + 1) (j := p.2) (by omega) hp2Le ?_
      intro k hk1 hk2 hkIn
      have hkLe : k ≤ p.1 := hpMax (k, p.2) hkIn
      omega

theorem originContainingSubregion_exists_outerVerticalCut
    {n : ℕ} {inside : Region GridNode}
    (hinside : inside ∈ originContainingSubregions n) :
    ∃ i j,
      GridClauseId.vertical i j ∈ originContainingSubregionOuterCutBaseClauses n inside := by
  rcases (mem_originContainingSubregions_iff.1 hinside) with ⟨hInsideΛ, hOrigin⟩
  have hne : inside.Nonempty := ⟨gridOrigin, hOrigin⟩
  obtain ⟨p, hpIn, hpMax⟩ := Finset.exists_max_image inside Prod.snd hne
  refine ⟨p.1, p.2, ?_⟩
  unfold originContainingSubregionOuterCutBaseClauses
  rw [Finset.mem_filter]
  constructor
  · apply gridRegionSupport_complete
    refine ⟨p, ?_, hInsideΛ hpIn⟩
    simp [gridClause]
  · refine Or.inl ⟨hpIn, ?_⟩
    by_cases hpTop : p.2 = n
    · left
      intro hmem
      have : p.2 + 1 < n + 1 := (Finset.mem_product.1 hmem).2 |> Finset.mem_range.mp
      omega
    · right
      have hpStage := hInsideΛ hpIn
      have hp2Le : p.2 ≤ n := by
        exact Nat.le_of_lt_succ ((Finset.mem_product.1 hpStage).2 |> Finset.mem_range.mp)
      have hpLt : p.2 < n := Nat.lt_of_le_of_ne hp2Le hpTop
      have hp1Le : p.1 ≤ n := by
        exact Nat.le_of_lt_succ ((Finset.mem_product.1 hpStage).1 |> Finset.mem_range.mp)
      refine mem_boundaryConnectedOutsideSubregion_of_outside_col_to_boundary
        (i := p.1) (j := p.2 + 1) hp1Le (by omega) ?_
      intro k hk1 hk2 hkIn
      have hkLe : k ≤ p.2 := hpMax (p.1, k) hkIn
      omega

theorem originContainingSubregion_exists_outerHorizontalCut_on_row
    {n j : ℕ} {inside : Region GridNode}
    (hinside : inside ∈ originContainingSubregions n)
    (hrow : ∃ i, (i, j) ∈ inside) :
    ∃ i,
      GridClauseId.horizontal i j ∈ originContainingSubregionOuterCutBaseClauses n inside := by
  rcases (mem_originContainingSubregions_iff.1 hinside) with ⟨hInsideΛ, hOrigin⟩
  let row : Finset GridNode := inside.filter (fun a => a.2 = j)
  have hrowNe : row.Nonempty := by
    rcases hrow with ⟨i, hi⟩
    exact ⟨(i, j), by simp [row, hi]⟩
  obtain ⟨p, hpRow, hpMax⟩ := Finset.exists_max_image row Prod.fst hrowNe
  have hpIn : p ∈ inside := (Finset.mem_filter.1 hpRow).1
  have hpRowEq : p.2 = j := (Finset.mem_filter.1 hpRow).2
  refine ⟨p.1, ?_⟩
  unfold originContainingSubregionOuterCutBaseClauses
  rw [Finset.mem_filter]
  constructor
  · apply gridRegionSupport_complete
    refine ⟨p, ?_, hInsideΛ hpIn⟩
    rcases p with ⟨x, y⟩
    simp at hpRowEq
    subst hpRowEq
    simp [gridClause]
  · rcases p with ⟨x, y⟩
    simp at hpRowEq
    subst hpRowEq
    refine Or.inl ⟨hpIn, ?_⟩
    by_cases hpTop : x = n
    · left
      intro hmem
      have : x + 1 < n + 1 := (Finset.mem_product.1 hmem).1 |> Finset.mem_range.mp
      omega
    · right
      have hpStage := hInsideΛ hpIn
      have hp1Le : x ≤ n := by
        exact Nat.le_of_lt_succ ((Finset.mem_product.1 hpStage).1 |> Finset.mem_range.mp)
      have hp2Le : y ≤ n := by
        exact Nat.le_of_lt_succ ((Finset.mem_product.1 hpStage).2 |> Finset.mem_range.mp)
      refine mem_boundaryConnectedOutsideSubregion_of_outside_row_to_boundary
        (i := x + 1) (j := y) (by omega) hp2Le ?_
      intro k hk1 hk2 hkIn
      have hkRow : (k, y) ∈ row := by
        simp [row, hkIn]
      have hkLe : k ≤ x := hpMax (k, y) hkRow
      omega

theorem originContainingSubregion_exists_outerHorizontalCut_on_row_max
    {n j : ℕ} {inside : Region GridNode}
    (hinside : inside ∈ originContainingSubregions n)
