/-- The contour encoder chooses a code whose decoder reconstructs the candidate,
when such a code exists. The remaining F4 content is precisely proving that the
axis-anchored cut sets all have such a contour traversal. -/
noncomputable def cutWalkEncode {m i j : ℕ} :
    {s // s ∈ originConnectedHullCutSetCandidatesInCutCardBoxAxisAnchored m i j} →
      CutWalkCode m :=
  fun s =>
    if h : ∃ code : CutWalkCode m, cutWalkDecode m i j code = s.1 then
      Classical.choose h
    else
      fun _ => (CutWalkMove.north, CutWalkVisitTag.revisit)

theorem cutWalkDecode_cutWalkEncode_of_exists {m i j : ℕ}
    (s :
      {s // s ∈ originConnectedHullCutSetCandidatesInCutCardBoxAxisAnchored m i j})
    (h : ∃ code : CutWalkCode m, cutWalkDecode m i j code = s.1) :
    cutWalkDecode m i j (cutWalkEncode (m := m) (i := i) (j := j) s) = s.1 := by
  unfold cutWalkEncode
  rw [dif_pos h]
  exact Classical.choose_spec h

theorem cutWalkEncode_injective_of_decode_exists {m i j : ℕ}
    (hdecode :
      ∀ s :
        {s // s ∈ originConnectedHullCutSetCandidatesInCutCardBoxAxisAnchored m i j},
        ∃ code : CutWalkCode m, cutWalkDecode m i j code = s.1) :
    Function.Injective
      (cutWalkEncode (m := m) (i := i) (j := j)) := by
  intro sx sy hcode
  apply Subtype.ext
  calc
    sx.1 = cutWalkDecode m i j (cutWalkEncode (m := m) (i := i) (j := j) sx) :=
      (cutWalkDecode_cutWalkEncode_of_exists sx (hdecode sx)).symm
    _ = cutWalkDecode m i j (cutWalkEncode (m := m) (i := i) (j := j) sy) := by
      rw [hcode]
    _ = sy.1 :=
      cutWalkDecode_cutWalkEncode_of_exists sy (hdecode sy)

