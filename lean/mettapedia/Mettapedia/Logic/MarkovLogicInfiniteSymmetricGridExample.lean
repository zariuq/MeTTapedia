theorem exists_starClosedWalk_of_rootedStarConnectedCutSet
    {root : GridClauseId} {s : Finset GridClauseId}
    (hstar : RootedStarConnectedCutSet root s) :
    ∃ (G : _root_.SimpleGraph GridClauseId) (p : G.Walk root root),
      p.length ≤ 2 * (s.card - 1) ∧
        (∀ a b, G.Adj a b → gridClauseStarAdjacent a b) ∧
          (∀ x ∈ p.support, x ∈ s) ∧
            (∀ x ∈ s, x ∈ p.support) := by
  let R : {c // c ∈ s} → {c // c ∈ s} → Prop :=
    fun a b => gridClauseStarAdjacent a.1 b.1
  let hRsymm : Std.Symm R := ⟨fun _ _ hab => gridClauseStarAdjacent_symm hab⟩
  let Gsub : _root_.SimpleGraph {c // c ∈ s} :=
    _root_.SimpleGraph.fromEdgeSet (Sym2.fromRel hRsymm)
  let rootSub : {c // c ∈ s} := ⟨root, hstar.root_mem⟩
  have hconnSub : Gsub.Connected := by
    simpa [Gsub, R, hRsymm] using
      (hstar.subtype_starGraph_connected)
  rcases SimpleGraph.Connected.exists_closedWalk_cover_length_le hconnSub rootSub with
    ⟨pSub, hcoverSub, hlenSub⟩
  let hStarSymm : Std.Symm gridClauseStarAdjacent :=
    ⟨fun _ _ hab => gridClauseStarAdjacent_symm hab⟩
  let G : _root_.SimpleGraph GridClauseId :=
    _root_.SimpleGraph.fromEdgeSet (Sym2.fromRel hStarSymm)
  let emb : Gsub →g G :=
    { toFun := fun c => c.1
      map_rel' := by
        intro a b hab
        have hrel : R a b := by
          simpa [Gsub, _root_.SimpleGraph.fromEdgeSet_adj,
            Sym2.toRel_fromRel] using hab.1
        have hne : a.1 ≠ b.1 := by
          intro hval
          apply hab.2
          exact Subtype.ext hval
        rw [_root_.SimpleGraph.fromEdgeSet_adj]
        constructor
        · simpa [Sym2.toRel_fromRel] using hrel
        · exact hne }
  let p : G.Walk root root := pSub.map emb
  refine ⟨G, p, ?_, ?_, ?_, ?_⟩
  · have hcardSub : Fintype.card {c // c ∈ s} = s.card :=
      Fintype.card_coe s
    simpa [p, hcardSub] using hlenSub
  · intro a b hab
    simpa [G, _root_.SimpleGraph.fromEdgeSet_adj, Sym2.toRel_fromRel]
      using hab.1
  · intro x hx
    change x ∈ (pSub.map emb).support at hx
    rw [_root_.SimpleGraph.Walk.support_map] at hx
    rcases List.mem_map.1 hx with ⟨y, _hy, rfl⟩
    exact y.2
  · intro x hx
    change x ∈ (pSub.map emb).support
    rw [_root_.SimpleGraph.Walk.support_map]
    exact List.mem_map_of_mem (hcoverSub ⟨x, hx⟩)

