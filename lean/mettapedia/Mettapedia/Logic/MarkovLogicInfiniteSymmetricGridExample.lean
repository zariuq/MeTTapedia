  have hpIn : (x, y) ∈ inside := (Finset.mem_filter.1 hpRow).1
  have hpRowEq : y = j := (Finset.mem_filter.1 hpRow).2
  subst y
  refine ⟨x, ?_, hpIn, ?_⟩
  · unfold originContainingSubregionOuterCutBaseClauses
    rw [Finset.mem_filter]
    constructor
    · apply gridRegionSupport_complete
      refine ⟨(x, j), ?_, hInsideΛ hpIn⟩
      simp [gridClause]
    · refine Or.inl ⟨hpIn, ?_⟩
      by_cases hxTop : x = n
