  refine cutWalkCodeInjection_family_of_rootedPrefix_exists ?_
  intro m hm i hi j hj s
  rcases hwalk m hm i hi j hj s with
    ⟨len, node, step, hpos, hlen, hnode0, hsource, hnext, hstep0, hmem, hcover⟩
  exact exists_rootedPrefix_of_orientedCutWalk
    (m := m) (i := i) (s := s.1) (len := len) (node := node) (step := step)
    hpos hlen hnode0 hsource hnext hstep0 hmem hcover

