    ⟨gridAdjacentClauseId_mem_gridRegionSupport_of_mem_left (hInside ha) hab, hcut⟩

theorem gridAdjacentClauseId_mem_cutBaseClauses_of_mem_right
    {n : ℕ} {inside : Region GridNode} {a b : GridNode}
    (hInside : inside ⊆ gridExhaustion.region n)
    (hb : b ∈ inside) (hab : gridAdjacent a b)
    (hcut : gridBaseClauseCutsRegion inside (gridAdjacentClauseId a b)) :
    gridAdjacentClauseId a b ∈
