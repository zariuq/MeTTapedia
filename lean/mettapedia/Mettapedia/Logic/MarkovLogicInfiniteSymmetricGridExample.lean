    (hef : visibleBoundarySeparatorEdgesSquareAdjacent m hull e f) :
    visibleBoundarySeparatorEdgesSquareAdjacent m hull f e := by
  rcases hef with ⟨he, hf, i, j, heSq, hfSq⟩
  exact ⟨hf, he, i, j, hfSq, heSq⟩

noncomputable def separatorSquareComponent
    (m : ℕ) (hull : Region GridNode) (root : GridNode × GridNode) :
    Finset (GridNode × GridNode) := by
  classical
  exact (visibleBoundarySeparatorEdges m hull).filter
    (fun e =>
      Relation.ReflTransGen
        (visibleBoundarySeparatorEdgesSquareAdjacent m hull) root e)

theorem mem_separatorSquareComponent_iff
    {m : ℕ} {hull : Region GridNode} {root e : GridNode × GridNode} :
    e ∈ separatorSquareComponent m hull root ↔
      e ∈ visibleBoundarySeparatorEdges m hull ∧
        Relation.ReflTransGen
          (visibleBoundarySeparatorEdgesSquareAdjacent m hull) root e := by
  classical
  simp [separatorSquareComponent]

