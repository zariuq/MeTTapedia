theorem boundaryConnectedOutsideSubregion_gridAdjacentInRegion_connected_of_subset_pred
    {m : ℕ} {inside : Region GridNode}
    (hm : 1 ≤ m)
    (hInside : inside ⊆ gridExhaustion.region (m - 1))
    {a b : GridNode}
    (ha : a ∈ boundaryConnectedOutsideSubregion m inside)
    (hb : b ∈ boundaryConnectedOutsideSubregion m inside) :
    Relation.ReflTransGen
      (gridAdjacentInRegion (boundaryConnectedOutsideSubregion m inside)) a b := by
  rcases mem_boundaryConnectedOutsideSubregion_iff.1 ha with
    ⟨_haOutside, ba, hbaBoundary, hbaOutside, hbaReach⟩
  rcases mem_boundaryConnectedOutsideSubregion_iff.1 hb with
    ⟨_hbOutside, bb, hbbBoundary, hbbOutside, hbbReach⟩
  have hboundaryOutside :
      gridStageBoundaryRegion m ⊆ outsideRegionInStage m inside :=
    gridStageBoundaryRegion_subset_outsideRegionInStage_of_subset_pred
      hm hInside
  have hbaExt : ba ∈ boundaryConnectedOutsideSubregion m inside :=
    mem_boundaryConnectedOutsideSubregion_of_mem_boundary hbaBoundary hbaOutside
  have hbbExt : bb ∈ boundaryConnectedOutsideSubregion m inside :=
    mem_boundaryConnectedOutsideSubregion_of_mem_boundary hbbBoundary hbbOutside
  rcases
    boundaryConnectedOutsideSubregion.reach_inside_boundaryConnectedOutside
      hbaExt hbaReach with
    ⟨_haExt, hreachBaA⟩
  rcases
    boundaryConnectedOutsideSubregion.reach_inside_boundaryConnectedOutside
      hbbExt hbbReach with
    ⟨_hbExt, hreachBbB⟩
  have hboundaryReach :
      Relation.ReflTransGen
        (gridAdjacentInRegion (boundaryConnectedOutsideSubregion m inside))
        ba bb := by
    have hstageReach :
        Relation.ReflTransGen
          (gridAdjacentInRegion (gridStageBoundaryRegion m)) ba bb :=
      gridStageBoundaryRegion_gridAdjacentInRegion_connected
        hbaBoundary hbbBoundary
    refine Relation.ReflTransGen.lift
      (p := gridAdjacentInRegion (boundaryConnectedOutsideSubregion m inside))
      id ?_ hstageReach
    intro x y hxy
    exact
      ⟨mem_boundaryConnectedOutsideSubregion_of_mem_boundary
          hxy.1 (hboundaryOutside hxy.1),
        mem_boundaryConnectedOutsideSubregion_of_mem_boundary
          hxy.2.1 (hboundaryOutside hxy.2.1),
        hxy.2.2⟩
  exact
    (reflTransGen_gridAdjacentInRegion_symm hreachBaA).trans
      (hboundaryReach.trans hreachBbB)

theorem boundaryConnectedOutsideSubregion_exists_gridAdjacent_partition_cross_with_suffix_of_subset_pred
    {m : ℕ} {inside : Region GridNode}
    (hm : 1 ≤ m)
    (hInside : inside ⊆ gridExhaustion.region (m - 1))
    {a b : GridNode}
    (ha : a ∈ boundaryConnectedOutsideSubregion m inside)
    (hb : b ∈ boundaryConnectedOutsideSubregion m inside)
    {U : GridNode → Prop}
    (haU : U a) (hbU : ¬ U b) :
    ∃ x ∈ boundaryConnectedOutsideSubregion m inside,
      ∃ y ∈ boundaryConnectedOutsideSubregion m inside,
        U x ∧ ¬ U y ∧ gridAdjacent x y ∧
          Relation.ReflTransGen
            (gridAdjacentInRegion (boundaryConnectedOutsideSubregion m inside))
            y b := by
  let ext := boundaryConnectedOutsideSubregion m inside
  have hreach :
      Relation.ReflTransGen (gridAdjacentInRegion ext) a b :=
    boundaryConnectedOutsideSubregion_gridAdjacentInRegion_connected_of_subset_pred
      hm hInside ha hb
  rcases
    exists_rel_cross_with_suffix_of_reflTransGen
      (R := gridAdjacentInRegion ext) hreach haU hbU with
    ⟨x, y, _hprefix, hxU, hxy, hyU, hyb⟩
  exact ⟨x, hxy.1, y, hxy.2.1, hxU, hyU, hxy.2.2, hyb⟩

theorem boundaryConnectedOutsideSubregion_exists_gridAdjacent_partition_cross_of_subset_pred
    {m : ℕ} {inside : Region GridNode}
    (hm : 1 ≤ m)
    (hInside : inside ⊆ gridExhaustion.region (m - 1))
    (U : GridNode → Prop)
    (hpos : ∃ a ∈ boundaryConnectedOutsideSubregion m inside, U a)
    (hneg : ∃ b ∈ boundaryConnectedOutsideSubregion m inside, ¬ U b) :
    ∃ a ∈ boundaryConnectedOutsideSubregion m inside,
      ∃ b ∈ boundaryConnectedOutsideSubregion m inside,
        U a ∧ ¬ U b ∧ gridAdjacent a b := by
  let ext := boundaryConnectedOutsideSubregion m inside
  let R : {p // p ∈ ext} → {p // p ∈ ext} → Prop :=
    fun a b => gridAdjacent a.1 b.1
  have hconnSub :
      ∀ a b : {p // p ∈ ext}, Relation.ReflTransGen R a b := by
    intro a b
    exact reflTransGen_gridAdjacentInRegion_subtype a.2 b.2
      (boundaryConnectedOutsideSubregion_gridAdjacentInRegion_connected_of_subset_pred
        hm hInside a.2 b.2)
  rcases hpos with ⟨a, haExt, haU⟩
  rcases hneg with ⟨b, hbExt, hbU⟩
  rcases
    exists_rel_cross_of_reflTransGen_connected
      (R := R) hconnSub (fun p : {p // p ∈ ext} => U p.1)
      ⟨⟨a, haExt⟩, haU⟩ ⟨⟨b, hbExt⟩, hbU⟩ with
    ⟨x, y, hxU, hyU, hxy⟩
  exact ⟨x.1, x.2, y.1, y.2, hxU, hyU, hxy⟩

theorem exists_boundaryConnectedOutside_step_into_negative_visible_of_subset_pred
    {m : ℕ} {hull : Region GridNode}
    (hm : 1 ≤ m)
    (hHull : hull ⊆ gridExhaustion.region (m - 1))
    (U : GridNode → Prop)
    (hpos : ∃ a ∈ visibleOuterBoundary m hull, U a)
    (hneg : ∃ b ∈ visibleOuterBoundary m hull, ¬ U b) :
    ∃ a ∈ boundaryConnectedOutsideSubregion m hull,
      ∃ b ∈ visibleOuterBoundary m hull,
        (a ∉ visibleOuterBoundary m hull ∨ U a) ∧ ¬ U b ∧
          gridAdjacent a b := by
  let ext := boundaryConnectedOutsideSubregion m hull
  let R : {p // p ∈ ext} → {p // p ∈ ext} → Prop :=
    fun a b => gridAdjacent a.1 b.1
  let Allowed : {p // p ∈ ext} → Prop :=
    fun p => p.1 ∉ visibleOuterBoundary m hull ∨ U p.1
  rcases hpos with ⟨p, hpVisible, hpU⟩
  rcases hneg with ⟨q, hqVisible, hqU⟩
  have hpExt : p ∈ ext :=
    visibleOuterBoundary_subset_boundaryConnectedOutsideSubregion hpVisible
  have hqExt : q ∈ ext :=
    visibleOuterBoundary_subset_boundaryConnectedOutsideSubregion hqVisible
  let ps : {p // p ∈ ext} := ⟨p, hpExt⟩
  let qs : {p // p ∈ ext} := ⟨q, hqExt⟩
  have hreachExt :
      Relation.ReflTransGen R ps qs := by
    exact reflTransGen_gridAdjacentInRegion_subtype hpExt hqExt
      (boundaryConnectedOutsideSubregion_gridAdjacentInRegion_connected_of_subset_pred
        hm hHull hpExt hqExt)
  have hpAllowed : Allowed ps := Or.inr hpU
  have hqNotAllowed : ¬ Allowed qs := by
    intro hallowed
    rcases hallowed with hqNotVisible | hqUPos
    · exact hqNotVisible hqVisible
    · exact hqU hqUPos
  have allowed_of_reach :
      ∀ {x : {p // p ∈ ext}},
        Relation.ReflTransGen
          (fun a b : {p // p ∈ ext} => Allowed a ∧ Allowed b ∧ R a b)
          ps x →
          Allowed x := by
    intro x hx
    induction hx with
    | refl =>
        exact hpAllowed
    | @tail y z hyz hstep _ih =>
        exact hstep.2.1
  have hqsNotReach :
      ¬ Relation.ReflTransGen
        (fun a b : {p // p ∈ ext} => Allowed a ∧ Allowed b ∧ R a b)
        ps qs := by
    intro hqsReach
    exact hqNotAllowed (allowed_of_reach hqsReach)
  rcases
    exists_first_forbidden_step_of_reflTransGen
      (R := R) (Allowed := Allowed)
      (start := ps) (target := qs)
      hpAllowed hreachExt hqsNotReach with
    ⟨a, b, haReach, _hbNotReach, hab, hbNotAllowed⟩
  have haAllowed : Allowed a := allowed_of_reach haReach
  have hbVisible : b.1 ∈ visibleOuterBoundary m hull := by
    by_contra hbNotVisible
    exact hbNotAllowed (Or.inl hbNotVisible)
  have hbU : ¬ U b.1 := by
    intro hbUPos
    exact hbNotAllowed (Or.inr hbUPos)
  exact ⟨a.1, a.2, b.1, hbVisible, haAllowed, hbU, hab⟩

theorem exists_nonvisible_boundaryConnectedOutside_step_into_negative_visible_of_no_star_cross
    {m : ℕ} {hull : Region GridNode} {U : GridNode → Prop}
    (hm : 1 ≤ m)
    (hHull : hull ⊆ gridExhaustion.region (m - 1))
    (hno :
      ¬ ∃ a ∈ visibleOuterBoundary m hull,
          ∃ b ∈ visibleOuterBoundary m hull,
            U a ∧ ¬ U b ∧ gridNodeStarAdjacent a b)
    (hpos : ∃ a ∈ visibleOuterBoundary m hull, U a)
    (hneg : ∃ b ∈ visibleOuterBoundary m hull, ¬ U b) :
    ∃ a ∈ boundaryConnectedOutsideSubregion m hull,
      ∃ b ∈ visibleOuterBoundary m hull,
        a ∉ visibleOuterBoundary m hull ∧ ¬ U b ∧ gridAdjacent a b := by
  rcases
    exists_boundaryConnectedOutside_step_into_negative_visible_of_subset_pred
      hm hHull U hpos hneg with
    ⟨a, haExt, b, hbVisible, haAllowed, hbU, hab⟩
  by_cases haVisible : a ∈ visibleOuterBoundary m hull
  · rcases haAllowed with haNotVisible | haU
    · exact False.elim (haNotVisible haVisible)
    · exact False.elim
        (hno ⟨a, haVisible, b, hbVisible, haU, hbU,
          gridNodeStarAdjacent_of_gridAdjacent hab⟩)
  · exact ⟨a, haExt, b, hbVisible, haVisible, hbU, hab⟩

theorem exists_nonvisible_boundaryConnectedOutside_step_into_positive_visible_of_no_star_cross
    {m : ℕ} {hull : Region GridNode} {U : GridNode → Prop}
    (hm : 1 ≤ m)
    (hHull : hull ⊆ gridExhaustion.region (m - 1))
    (hno :
      ¬ ∃ a ∈ visibleOuterBoundary m hull,
          ∃ b ∈ visibleOuterBoundary m hull,
            U a ∧ ¬ U b ∧ gridNodeStarAdjacent a b)
    (hpos : ∃ a ∈ visibleOuterBoundary m hull, U a)
    (hneg : ∃ b ∈ visibleOuterBoundary m hull, ¬ U b) :
    ∃ a ∈ boundaryConnectedOutsideSubregion m hull,
      ∃ b ∈ visibleOuterBoundary m hull,
        a ∉ visibleOuterBoundary m hull ∧ U b ∧ gridAdjacent a b := by
  classical
  have hnoNeg :
      ¬ ∃ a ∈ visibleOuterBoundary m hull,
          ∃ b ∈ visibleOuterBoundary m hull,
            (¬ U a) ∧ ¬ (¬ U b) ∧ gridNodeStarAdjacent a b := by
    intro hcross
    rcases hcross with
      ⟨a, haVisible, b, hbVisible, haNotU, hbNotNotU, hab⟩
    have hbU : U b := by
      by_contra hbNotU
      exact hbNotNotU hbNotU
    exact hno ⟨b, hbVisible, a, haVisible, hbU, haNotU,
      gridNodeStarAdjacent_symm hab⟩
  have hposNotNot : ∃ a ∈ visibleOuterBoundary m hull, ¬ ¬ U a := by
    rcases hpos with ⟨a, haVisible, haU⟩
    exact ⟨a, haVisible, fun haNotU => haNotU haU⟩
  rcases
    exists_nonvisible_boundaryConnectedOutside_step_into_negative_visible_of_no_star_cross
      (m := m) (hull := hull) (U := fun p => ¬ U p)
      hm hHull hnoNeg hneg hposNotNot with
    ⟨a, haExt, b, hbVisible, haNotVisible, hbNotNotU, hab⟩
  have hbU : U b := by
    by_contra hbNotU
    exact hbNotNotU hbNotU
  exact ⟨a, haExt, b, hbVisible, haNotVisible, hbU, hab⟩

theorem exists_visibleOuterBoundary_star_cross_of_boundaryConnectedOutside_cross_touches
    {m : ℕ} {hull : Region GridNode} {U : GridNode → Prop}
    (hcross :
      ∃ a ∈ boundaryConnectedOutsideSubregion m hull,
        ∃ b ∈ boundaryConnectedOutsideSubregion m hull,
          U a ∧ ¬ U b ∧ gridAdjacent a b ∧
            (∃ qa ∈ hull, gridAdjacent a qa) ∧
              (∃ qb ∈ hull, gridAdjacent b qb)) :
    ∃ a ∈ visibleOuterBoundary m hull,
      ∃ b ∈ visibleOuterBoundary m hull,
        U a ∧ ¬ U b ∧ gridNodeStarAdjacent a b := by
  rcases hcross with
    ⟨a, haExt, b, hbExt, haU, hbU, hab, haTouch, hbTouch⟩
  rcases haTouch with ⟨qa, hqaHull, haqa⟩
  rcases hbTouch with ⟨qb, hqbHull, hbqb⟩
  exact
    exists_visibleOuterBoundary_star_cross_of_gridAdjacent_cross
      (n := m) (hull := hull) (U := U)
      ⟨a,
        mem_visibleOuterBoundary_of_mem_boundaryConnectedOutside_of_adj_hull
          haExt hqaHull haqa,
        b,
        mem_visibleOuterBoundary_of_mem_boundaryConnectedOutside_of_adj_hull
          hbExt hqbHull hbqb,
        haU, hbU, hab⟩

theorem visibleOuterBoundary_reachable_in_boundaryConnectedOutsideSubregion_of_subset_pred
    {m : ℕ} {hull : Region GridNode}
    (hm : 1 ≤ m)
    (hHull : hull ⊆ gridExhaustion.region (m - 1))
    {a b : GridNode}
    (ha : a ∈ visibleOuterBoundary m hull)
    (hb : b ∈ visibleOuterBoundary m hull) :
    Relation.ReflTransGen
      (gridAdjacentInRegion (boundaryConnectedOutsideSubregion m hull)) a b := by
  exact
    boundaryConnectedOutsideSubregion_gridAdjacentInRegion_connected_of_subset_pred
      hm hHull
      (visibleOuterBoundary_subset_boundaryConnectedOutsideSubregion ha)
      (visibleOuterBoundary_subset_boundaryConnectedOutsideSubregion hb)

theorem visibleOuterBoundary_inside_outside_paths_of_originConnected_subset_pred
    {m : ℕ} {hull : Region GridNode}
    (hm : 1 ≤ m)
    (hHull : hull ⊆ gridExhaustion.region (m - 1))
    (hconn : OriginConnectedRegion hull)
    {a b : GridNode}
    (ha : a ∈ visibleOuterBoundary m hull)
    (hb : b ∈ visibleOuterBoundary m hull) :
    ∃ qa ∈ hull, ∃ qb ∈ hull,
      gridAdjacent a qa ∧ gridAdjacent b qb ∧
        Relation.ReflTransGen (gridAdjacentInRegion hull) qa qb ∧
          Relation.ReflTransGen
            (gridAdjacentInRegion (boundaryConnectedOutsideSubregion m hull))
            a b := by
  rcases exists_hull_neighbor_of_mem_visibleOuterBoundary ha with
    ⟨qa, hqaHull, haqa⟩
  rcases exists_hull_neighbor_of_mem_visibleOuterBoundary hb with
    ⟨qb, hqbHull, hbqb⟩
  exact
    ⟨qa, hqaHull, qb, hqbHull, haqa, hbqb,
      hconn.reachable_between hqaHull hqbHull,
      visibleOuterBoundary_reachable_in_boundaryConnectedOutsideSubregion_of_subset_pred
        hm hHull ha hb⟩

theorem stageCoConnected_boundaryConnectedHullRegion
    (n : ℕ) (inside : Region GridNode) :
    StageCoConnectedRegion n (boundaryConnectedHullRegion n inside) := by
  intro a ha
  have hEq :
      outsideRegionInStage n (boundaryConnectedHullRegion n inside) =
        boundaryConnectedOutsideSubregion n inside :=
    outsideRegionInStage_boundaryConnectedHullRegion_eq n inside
  have haExt : a ∈ boundaryConnectedOutsideSubregion n inside := by
    simpa [hEq] using ha
  rcases mem_boundaryConnectedOutsideSubregion_iff.1 haExt with
    ⟨_haOutside, b, hbBoundary, hbOutside, hreach⟩
  have hbExt : b ∈ boundaryConnectedOutsideSubregion n inside :=
    mem_boundaryConnectedOutsideSubregion_of_mem_boundary hbBoundary hbOutside
  rcases
    boundaryConnectedOutsideSubregion.reach_inside_boundaryConnectedOutside
      hbExt hreach with
    ⟨_haExt, hreachExt⟩
  refine ⟨b, hbBoundary, ?_, ?_⟩
  · simpa [hEq] using hbExt
  · simpa [hEq] using hreachExt

theorem mem_outsideRegionInStage_of_le
    {m n : ℕ} {inside : Region GridNode} {a : GridNode}
    (hmn : m ≤ n)
    (ha : a ∈ outsideRegionInStage m inside) :
    a ∈ outsideRegionInStage n inside := by
  rcases mem_outsideRegionInStage_iff.1 ha with ⟨haStage, haNotIn⟩
  rw [mem_outsideRegionInStage_iff]
  exact ⟨gridExhaustion.monotone hmn haStage, haNotIn⟩

theorem mem_outsideRegionInStage_of_mem_stage
    {m n : ℕ} {inside : Region GridNode} {a : GridNode}
    (haStage : a ∈ gridExhaustion.region m)
    (ha : a ∈ outsideRegionInStage n inside) :
    a ∈ outsideRegionInStage m inside := by
  rcases mem_outsideRegionInStage_iff.1 ha with ⟨_, haNotIn⟩
  rw [mem_outsideRegionInStage_iff]
  exact ⟨haStage, haNotIn⟩

theorem mem_gridStageBoundaryRegion_of_mem_gridStageBoundaryRegion_of_mem_stage
    {m n : ℕ} {a : GridNode}
    (hmn : m ≤ n)
    (haBoundary : a ∈ gridStageBoundaryRegion n)
    (haStage : a ∈ gridExhaustion.region m) :
    a ∈ gridStageBoundaryRegion m := by
  rcases a with ⟨i, j⟩
  rcases mem_gridStageBoundaryRegion_iff.1 haBoundary with ⟨_, hiEq | hjEq⟩
  · rcases Finset.mem_product.1 haStage with ⟨hiM, _⟩
    rw [mem_gridStageBoundaryRegion_iff]
    constructor
    · exact haStage
    · left
      have hiLt : i < m + 1 := Finset.mem_range.mp hiM
      omega
  · rcases Finset.mem_product.1 haStage with ⟨_, hjM⟩
    rw [mem_gridStageBoundaryRegion_iff]
    constructor
    · exact haStage
    · right
      have hjLt : j < m + 1 := Finset.mem_range.mp hjM
      omega

theorem patchedFalseRegion_mem_originContainingSubregions_of_originFalse
    {n : ℕ}
    (x : LocalAssignment GridNode (gridExhaustion.region n))
    (horigin :
      patch (gridExhaustion.region n) x gridPlusBoundary gridOrigin = false) :
    patchedFalseRegion x gridPlusBoundary ∈ originContainingSubregions n := by
  rw [mem_originContainingSubregions_iff]
  exact ⟨patchedFalseRegion_subset x gridPlusBoundary,
    (mem_patchedFalseRegion_iff x gridPlusBoundary gridOrigin).2
      ⟨gridOrigin_mem_gridExhaustion_region n, horigin⟩⟩

theorem originContainingSubregion_exists_horizontalCut
    {n : ℕ} {inside : Region GridNode}
    (hinside : inside ∈ originContainingSubregions n) :
    ∃ i j,
      GridClauseId.horizontal i j ∈
        (gridRegionSupport (gridExhaustion.region n)).filter (gridBaseClauseCutsRegion inside) := by
  rcases (mem_originContainingSubregions_iff.1 hinside) with ⟨hInsideΛ, hOrigin⟩
  have hne : inside.Nonempty := ⟨gridOrigin, hOrigin⟩
  obtain ⟨p, hpIn, hpMax⟩ := Finset.exists_max_image inside Prod.fst hne
  refine ⟨p.1, p.2, ?_⟩
  rw [Finset.mem_filter]
  constructor
  · apply gridRegionSupport_complete
    refine ⟨p, ?_, hInsideΛ hpIn⟩
    simp [gridClause]
  · exact Or.inl ⟨hpIn, by
      intro hsucc
      have hle : p.1 + 1 ≤ p.1 := hpMax (p.1 + 1, p.2) hsucc
      exact (Nat.not_succ_le_self p.1 hle).elim⟩

theorem originContainingSubregion_exists_verticalCut
    {n : ℕ} {inside : Region GridNode}
    (hinside : inside ∈ originContainingSubregions n) :
    ∃ i j,
      GridClauseId.vertical i j ∈
        (gridRegionSupport (gridExhaustion.region n)).filter (gridBaseClauseCutsRegion inside) := by
  rcases (mem_originContainingSubregions_iff.1 hinside) with ⟨hInsideΛ, hOrigin⟩
  have hne : inside.Nonempty := ⟨gridOrigin, hOrigin⟩
  obtain ⟨p, hpIn, hpMax⟩ := Finset.exists_max_image inside Prod.snd hne
  refine ⟨p.1, p.2, ?_⟩
  rw [Finset.mem_filter]
  constructor
  · apply gridRegionSupport_complete
    refine ⟨p, ?_, hInsideΛ hpIn⟩
    simp [gridClause]
  · exact Or.inl ⟨hpIn, by
      intro hsucc
      have hle : p.2 + 1 ≤ p.2 := hpMax (p.1, p.2 + 1) hsucc
      exact (Nat.not_succ_le_self p.2 hle).elim⟩

/-- The number of stage-box base clauses that cut a candidate inside witness
region. This is the natural size parameter for the current Peierls witness
family. -/
noncomputable def originContainingSubregionCutCard (n : ℕ) (inside : Region GridNode) : ℕ :=
  ((gridRegionSupport (gridExhaustion.region n)).filter (gridBaseClauseCutsRegion inside)).card

theorem originContainingSubregionCutCard_le
    (n : ℕ) (inside : Region GridNode) :
    originContainingSubregionCutCard n inside ≤
      (gridRegionSupport (gridExhaustion.region n)).card := by
  unfold originContainingSubregionCutCard
  exact Finset.card_le_card (Finset.filter_subset _ _)

theorem gridBaseClauseCutsRegion_imp_clauseTouchesRegion
    {inside : Region GridNode} {j : GridClauseId}
    (hj : gridBaseClauseCutsRegion inside j) :
    clauseTouchesRegion (gridClause j) inside := by
  cases j with
  | prior i j =>
      cases hj
  | horizontal i j =>
      rcases hj with h | h
      · exact ⟨(i, j), by simp [gridClause], h.1⟩
      · exact ⟨(i + 1, j), by simp [gridClause], h.2⟩
  | vertical i j =>
      rcases hj with h | h
      · exact ⟨(i, j), by simp [gridClause], h.1⟩
      · exact ⟨(i, j + 1), by simp [gridClause], h.2⟩

theorem gridRegionSupport_subset_of_subset
    {Λ Δ : Region GridNode}
    (hΛΔ : Λ ⊆ Δ) :
    gridRegionSupport Λ ⊆ gridRegionSupport Δ := by
  intro j hj
  apply gridRegionSupport_complete
  rcases gridRegionSupport_sound (Λ := Λ) (j := j) hj with ⟨a, haClause, haΛ⟩
  exact ⟨a, haClause, hΛΔ haΛ⟩

theorem gridAdjacentClauseId_mem_cutBaseClauses_of_mem_left
    {n : ℕ} {inside : Region GridNode} {a b : GridNode}
    (hInside : inside ⊆ gridExhaustion.region n)
