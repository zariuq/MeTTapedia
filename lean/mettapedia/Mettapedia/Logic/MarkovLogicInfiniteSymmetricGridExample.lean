    have hreach_to_adj :
        ∀ {x : GridClauseId}, x ∈ s → x ≠ root →
          Relation.ReflTransGen
            (fun a b => a ∈ s ∧ b ∈ s ∧ gridClauseDualAdjacent a b)
            root x →
            gridClauseDualAdjacent root x := by
      intro x hx hxNeRoot hreachx
      induction hreachx with
      | refl =>
          exact False.elim (hxNeRoot rfl)
      | @tail y z hprev hstep ih =>
          rcases hstep with ⟨hyMem, hzMem, hyzAdj⟩
          by_cases hyRoot : y = root
          · simpa [hyRoot] using hyzAdj
          · have hyAdj : gridClauseDualAdjacent root y := ih hyMem hyRoot
            have hyEqC : y = c := by
              have hyPair : y = root ∨ y = c := by
                simpa [root, hsEq] using hyMem
              rcases hyPair with hyEqRoot | hyEqC
              · exact False.elim (hyRoot hyEqRoot)
              · exact hyEqC
            have hzEqC : z = c := by
              have hzPair : z = root ∨ z = c := by
                simpa [root, hsEq] using hzMem
              rcases hzPair with hzEqRoot | hzEqC
              · exact False.elim (hxNeRoot hzEqRoot)
              · exact hzEqC
            simpa [hyEqC, hzEqC] using hyAdj
    exact hreach_to_adj hcMem hcNeRoot hreach
  rcases
    exists_rooted_cutWalkCode_decode_eq_pair_horizontal_root_of_dualAdjacent
      (m := m) (i := i) (j := j) hm (c := c) hadj with
    ⟨code, hfirst, hdecode⟩
  refine ⟨code, hfirst, ?_⟩
  simpa [root, hsEq] using hdecode

