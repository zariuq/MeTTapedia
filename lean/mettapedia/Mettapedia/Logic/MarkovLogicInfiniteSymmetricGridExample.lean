/-- The number of axis-root pairs surviving the rooted-simplex constraint
`i + j + 2 ≤ m`. -/
def axisAnchoredRootPairCount (m : ℕ) : ℕ :=
  ∑ i ∈ Finset.range m, i

theorem axisAnchoredRootPairCount_eq_sum_sub (m : ℕ) :
    axisAnchoredRootPairCount m =
      ∑ i ∈ Finset.range m, (m - (i + 1)) := by
  unfold axisAnchoredRootPairCount
  rw [← Finset.sum_range_reflect (fun i => i) m]
  refine Finset.sum_congr rfl ?_
  intro i hi
  have hi' : i < m := Finset.mem_range.1 hi
  omega

theorem axisAnchoredRootPairCount_le_two_pow (m : ℕ) :
    axisAnchoredRootPairCount m ≤ 2 ^ m := by
  induction m with
  | zero =>
      simp [axisAnchoredRootPairCount]
  | succ m ih =>
      rw [show axisAnchoredRootPairCount (m + 1) = axisAnchoredRootPairCount m + m by
            simp [axisAnchoredRootPairCount, Finset.sum_range_succ]]
      calc
