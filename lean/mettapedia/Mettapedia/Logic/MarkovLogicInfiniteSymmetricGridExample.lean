theorem exists_odd_separatorSquareComponent_walk
    {m : ℕ} {hull : Region GridNode} {root : GridNode × GridNode}
    (hm : 1 ≤ m)
    (hHull : hull ⊆ gridExhaustion.region (m - 1))
    (hroot : root ∈ visibleBoundarySeparatorEdges m hull) :
    ∃ b ∈ gridStageBoundaryRegion m,
      ∃ walk : List GridNode,
        walk.head? = some b ∧ walk.getLast? = some root.1 ∧
          List.IsChain gridAdjacent walk ∧
            (∀ p ∈ walk, p ∈ gridExhaustion.region m) ∧
              walkCrossBit (separatorSquareComponent m hull root) walk = 1 := by
  rcases
    visibleBoundarySeparatorEdges_reachable_from_stageBoundary_to_right_in_boundaryConnectedOutside
      hroot with
    ⟨b, hbBoundary, hbExt, hreach, hrightLeft⟩
  rcases exists_boundaryConnectedOutside_list_walk_of_reflTransGen
      hbExt hreach with
    ⟨outWalk, houtHead, houtLast, houtChain, houtMem⟩
  refine ⟨b, hbBoundary, outWalk ++ [root.1], ?_, ?_, ?_, ?_, ?_⟩
  · cases outWalk with
    | nil =>
        simp at houtHead
    | cons _z _zs =>
        simpa using houtHead
  · simp
  · exact list_isChain_append_singleton_of_getLast
      houtChain hrightLeft houtLast
  · intro p hp
    rw [List.mem_append] at hp
    rcases hp with hp | hp
    · exact boundaryConnectedOutsideSubregion_subset_stage
        (houtMem p hp)
    · simp at hp
      subst hp
      exact gridExhaustion.monotone (by omega)
        (hHull (visibleBoundarySeparatorEdges_left_mem hroot))
  · rw [walkCrossBit_append_singleton_of_getLast
      (separatorSquareComponent m hull root) houtLast]
    rw [walkCrossBit_separatorSquareComponent_eq_zero_of_all_boundaryConnectedOutside
      houtMem]
    rw [edgeBit_separatorSquareComponent_root_symm_eq_one hroot]
    simp

theorem exists_zero_separatorSquareComponent_walk_from_boundaryConnectedOutside
    {m : ℕ} {hull : Region GridNode} {root f : GridNode × GridNode}
    (hm : 1 ≤ m)
    (hHull : hull ⊆ gridExhaustion.region (m - 1))
    (hconn : OriginConnectedRegion hull)
    (hroot : root ∈ visibleBoundarySeparatorEdges m hull)
    (hf : f ∈ visibleBoundarySeparatorEdges m hull)
    (hfNot : f ∉ separatorSquareComponent m hull root)
    {b : GridNode}
    (hbExt : b ∈ boundaryConnectedOutsideSubregion m hull) :
    ∃ walk : List GridNode,
      walk.head? = some b ∧ walk.getLast? = some root.1 ∧
        List.IsChain gridAdjacent walk ∧
          (∀ p ∈ walk, p ∈ gridExhaustion.region m) ∧
            walkCrossBit (separatorSquareComponent m hull root) walk = 0 := by
  have hfRightExt : f.2 ∈ boundaryConnectedOutsideSubregion m hull :=
    visibleBoundarySeparatorEdges_right_boundaryConnectedOutside hf
  rcases exists_boundaryConnectedOutside_list_walk_connected_of_subset_pred
      hm hHull hbExt hfRightExt with
    ⟨outWalk, houtHead, houtLast, houtChain, houtMem⟩
  rcases exists_hull_list_walk_of_originConnectedRegion hconn
      (visibleBoundarySeparatorEdges_left_mem hf)
      (visibleBoundarySeparatorEdges_left_mem hroot) with
    ⟨hullWalk, hhullHead, hhullLast, hhullChain, hhullMem⟩
  cases hullWalk with
  | nil =>
      simp at hhullHead
  | cons h hullTail =>
      have hh : h = f.1 := by
        simpa using hhullHead
      subst hh
      refine ⟨outWalk ++ (f.1 :: hullTail), ?_, ?_, ?_, ?_, ?_⟩
      · cases outWalk with
        | nil =>
            simp at houtHead
        | cons _z _zs =>
            simpa using houtHead
      · simp [hhullLast]
      · have hbridge :
            List.IsChain gridAdjacent (f.2 :: f.1 :: hullTail) := by
          exact (List.isChain_cons_cons).2
            ⟨gridAdjacent_symm (visibleBoundarySeparatorEdges_adjacent hf),
              hhullChain⟩
        exact list_isChain_append_cons_of_getLast
          houtChain hbridge houtLast
      · intro p hp
        rw [List.mem_append] at hp
        rcases hp with hp | hp
        · exact boundaryConnectedOutsideSubregion_subset_stage
            (houtMem p hp)
        · exact gridExhaustion.monotone (by omega)
            (hHull (hhullMem p hp))
      · rw [walkCrossBit_append_cons_of_getLast
          (separatorSquareComponent m hull root) houtLast]
        rw [walkCrossBit_separatorSquareComponent_eq_zero_of_all_boundaryConnectedOutside
          houtMem]
        rw [edgeBit_separatorSquareComponent_symm_eq_zero_of_separator_not_mem_component
          hf hfNot]
        rw [walkCrossBit_separatorSquareComponent_eq_zero_of_all_mem_hull
          (f.1 :: hullTail) hhullMem]
        simp

theorem visibleBoundarySeparatorEdges_mem_separatorSquareComponent
    {m : ℕ} {hull : Region GridNode} {root f : GridNode × GridNode}
    (hm : 1 ≤ m)
    (hHull : hull ⊆ gridExhaustion.region (m - 1))
    (hconn : OriginConnectedRegion hull)
    (hco : StageCoConnectedRegion (m - 1) hull)
    (hroot : root ∈ visibleBoundarySeparatorEdges m hull)
    (hf : f ∈ visibleBoundarySeparatorEdges m hull) :
    f ∈ separatorSquareComponent m hull root := by
  classical
  by_contra hfNot
  rcases exists_odd_separatorSquareComponent_walk hm hHull hroot with
    ⟨b, hbBoundary, oddWalk, hoddHead, hoddLast, hoddChain,
      hoddStage, hoddBit⟩
  have hbExt : b ∈ boundaryConnectedOutsideSubregion m hull :=
    mem_boundaryConnectedOutsideSubregion_of_mem_boundary hbBoundary
      (gridStageBoundaryRegion_subset_outsideRegionInStage_of_subset_pred
        hm hHull hbBoundary)
  rcases
      exists_zero_separatorSquareComponent_walk_from_boundaryConnectedOutside
        hm hHull hconn hroot hf hfNot hbExt with
    ⟨zeroWalk, hzeroHead, hzeroLast, hzeroChain, hzeroStage,
      hzeroBit⟩
  cases oddWalk with
  | nil =>
      simp at hoddHead
  | cons oddStart oddTail =>
      have hoddStart : oddStart = b := by
        simpa using hoddHead
      subst oddStart
      cases zeroWalk with
      | nil =>
          simp at hzeroHead
      | cons zeroStart zeroTail =>
          have hzeroStart : zeroStart = b := by
            simpa using hzeroHead
          subst zeroStart
          have hoddLastGet :
              (b :: oddTail).getLast (by simp) = root.1 := by
            have hgl :=
              List.getLast?_eq_some_getLast
                (l := b :: oddTail) (by simp)
            rw [hoddLast] at hgl
            exact (Option.some.inj hgl).symm
          have hzeroLastGet :
              (b :: zeroTail).getLast (by simp) = root.1 := by
            have hgl :=
              List.getLast?_eq_some_getLast
                (l := b :: zeroTail) (by simp)
            rw [hzeroLast] at hgl
            exact (Option.some.inj hgl).symm
          have hsame :
              walkCrossBit (separatorSquareComponent m hull root)
                  (b :: oddTail) =
                walkCrossBit (separatorSquareComponent m hull root)
                  (b :: zeroTail) :=
            walkCrossBit_eq_of_same_endpoints_cons
              (separatorSquareComponent_squareEvenBits hm hHull hco)
              hoddStage hoddChain hzeroStage hzeroChain
              (by rw [hoddLastGet, hzeroLastGet])
          rw [hoddBit, hzeroBit] at hsame
          have hone_ne_zero : (1 : ZMod 2) ≠ 0 := by decide
          exact hone_ne_zero hsame

