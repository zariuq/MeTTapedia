    hookSlackHull ∈ originConnectedHullContainingSubregions 4 := by
  exact mem_originConnectedHullContainingSubregions_iff.2
    ⟨hookSlackInside, hookSlackInside_mem_originConnectedContainingSubregions, rfl⟩

theorem hookSlackHullCutCard_eq_outerCutCard :
    hookSlackHullCutCard = originContainingSubregionOuterCutCard 4 hookSlackInside := by
  simp [hookSlackHullCutCard, hookSlackHull,
    originContainingSubregionCutCard_boundaryConnectedHullRegion_eq_outerCutCard
      hookSlackInside_subset_stage4]

theorem hookSlackHullCutCard_gt_axisRootLower :
    1 + 1 + 2 < hookSlackHullCutCard := by
  rw [hookSlackHullCutCard_eq_outerCutCard]
  exact hookSlackInside_outerCutCard_gt_axisRootLower

