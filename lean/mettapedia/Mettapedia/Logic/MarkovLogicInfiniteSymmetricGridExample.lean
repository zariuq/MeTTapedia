theorem rootedDualConnectedCutSet_of_mem_axisAnchored_card_two
    {i j : ℕ} {s : Finset GridClauseId}
    (hs : s ∈ originConnectedHullCutSetCandidatesInCutCardBoxAxisAnchored 2 i j) :
    RootedDualConnectedCutSet (GridClauseId.horizontal i 0) s := by
  have hnotLt : ¬ 2 < i + j + 2 := by
    intro hlt
    have hempty :
        originConnectedHullCutSetCandidatesInCutCardBoxAxisAnchored 2 i j = ∅ :=
      originConnectedHullCutSetCandidatesInCutCardBoxAxisAnchored_eq_empty_of_lt hlt
    rw [hempty] at hs
    simp at hs
  have hi : i = 0 := by omega
  have hj : j = 0 := by omega
  subst i
  subst j
  let root := GridClauseId.horizontal 0 0
  let vert := GridClauseId.vertical 0 0
  have hroot : root ∈ s :=
    horizontal_root_mem_of_mem_originConnectedHullCutSetCandidatesInCutCardBoxAxisAnchored hs
  have hvert : vert ∈ s :=
    vertical_root_mem_of_mem_originConnectedHullCutSetCandidatesInCutCardBoxAxisAnchored hs
  have hcard : s.card = 2 :=
    card_eq_of_mem_originConnectedHullCutSetCandidatesInCutCardBoxAxisAnchored hs
  rcases finset_eq_pair_of_card_eq_two_of_mem
      (s := s) (a := root) hroot hcard with
    ⟨b, hbNe, hsPair⟩
  have hvertEq : vert = b := by
    have hv : vert = root ∨ vert = b := by
      simpa [hsPair, root, vert] using hvert
    rcases hv with hvRoot | hvB
    · simp [root, vert] at hvRoot
    · exact hvB
  have hsEq : s = ({root, vert} : Finset GridClauseId) := by
    simpa [hvertEq] using hsPair
  refine ⟨by simpa [root] using hroot, ?_⟩
  intro x hx
  have hxPair : x = root ∨ x = vert := by
    simpa [hsEq, root, vert] using hx
  rcases hxPair with hxRoot | hxVert
  · subst hxRoot
    exact Relation.ReflTransGen.refl
  · subst hxVert
    exact Relation.ReflTransGen.tail Relation.ReflTransGen.refl
      ⟨by simpa [root] using hroot,
        by simpa [vert] using hvert,
        by simp [vert]⟩

