  · omega

theorem AxisAnchoredDiagHullProfile.vertical_equal_step_star
    {m i j : ℕ} {s : Finset GridClauseId}
    (prof : AxisAnchoredDiagHullProfile m i j s)
    (k : Fin i)
    (heq :
      prof.gV ⟨k.1 + 1, Nat.succ_lt_succ k.2⟩ =
        prof.gV ⟨k.1, Nat.lt_trans k.2 (Nat.lt_succ_self i)⟩) :
    gridClauseStarAdjacent
      (GridClauseId.vertical
        (⟨k.1, Nat.lt_trans k.2 (Nat.lt_succ_self i)⟩ : Fin (i + 1)).1
        (prof.gV ⟨k.1, Nat.lt_trans k.2 (Nat.lt_succ_self i)⟩))
      (GridClauseId.vertical
        (⟨k.1 + 1, Nat.succ_lt_succ k.2⟩ : Fin (i + 1)).1
