theorem mem_inside_of_bottomHorizontal_outerCut_of_card_eq
    {n i j : ℕ} {inside : Region GridNode}
    (hinside : inside ∈ originConnectedContainingSubregions n)
    (hhor :
      GridClauseId.horizontal i 0 ∈ originContainingSubregionOuterCutBaseClauses n inside)
    (hvert :
      GridClauseId.vertical 0 j ∈ originContainingSubregionOuterCutBaseClauses n inside)
    (hcard : originContainingSubregionOuterCutCard n inside = i + j + 2) :
    (i, 0) ∈ inside := by
  have hhorCut : gridBaseClauseCutsOuterRegion n inside (GridClauseId.horizontal i 0) :=
    (Finset.mem_filter.1 hhor).2
  have hvertCut : gridBaseClauseCutsOuterRegion n inside (GridClauseId.vertical 0 j) :=
    (Finset.mem_filter.1 hvert).2
  rcases hhorCut with h | h
  · exact h.1
  · have hi : (i + 1, 0) ∈ inside := h.2
    rcases hvertCut with h' | h'
    · have hbase := outerCutCard_lower_of_insideEndpoints hinside hi h'.1
      rw [hcard] at hbase
      omega
    · have hbase := outerCutCard_lower_of_insideEndpoints hinside hi h'.2
      rw [hcard] at hbase
      omega

