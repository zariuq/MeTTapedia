theorem mem_boundaryConnectedOutsideSubregion_of_ge
    {m n : ℕ} {inside : Region GridNode} {a : GridNode}
    (hmn : m ≤ n)
    (haStage : a ∈ gridExhaustion.region m)
    (ha : a ∈ boundaryConnectedOutsideSubregion n inside) :
    a ∈ boundaryConnectedOutsideSubregion m inside := by
  rcases mem_boundaryConnectedOutsideSubregion_iff.1 ha with
    ⟨_, ⟨b, hbBoundary, hbOut, hreach⟩⟩
  have haux :
      ∀ {c : GridNode},
        Relation.ReflTransGen (gridAdjacentInRegion (outsideRegionInStage n inside)) b c →
          c ∈ gridExhaustion.region m →
          c ∈ boundaryConnectedOutsideSubregion m inside := by
    intro c hreachc
    induction hreachc with
    | refl =>
        intro hcStage
        have hbBoundaryM :
            b ∈ gridStageBoundaryRegion m :=
          mem_gridStageBoundaryRegion_of_mem_gridStageBoundaryRegion_of_mem_stage
            hmn hbBoundary hcStage
        have hbOutM : b ∈ outsideRegionInStage m inside :=
          mem_outsideRegionInStage_of_mem_stage hcStage hbOut
        exact mem_boundaryConnectedOutsideSubregion_of_mem_boundary hbBoundaryM hbOutM
    | @tail c d hreachcd hstep ih =>
        intro hdStage
        by_cases hcStage : c ∈ gridExhaustion.region m
        · have hcExt : c ∈ boundaryConnectedOutsideSubregion m inside := ih hcStage
          have hdOutM : d ∈ outsideRegionInStage m inside :=
            mem_outsideRegionInStage_of_mem_stage hdStage hstep.2.1
          exact mem_boundaryConnectedOutsideSubregion_of_mem_outside_of_adj
            hdOutM hcExt hstep.2.2
        · have hdBoundary :
              d ∈ gridStageBoundaryRegion m :=
            mem_gridStageBoundaryRegion_of_mem_stage_of_adj_not_stage
              hdStage hcStage (gridAdjacent_symm hstep.2.2)
          have hdOutM : d ∈ outsideRegionInStage m inside :=
            mem_outsideRegionInStage_of_mem_stage hdStage hstep.2.1
          exact mem_boundaryConnectedOutsideSubregion_of_mem_boundary hdBoundary hdOutM
  exact haux hreach haStage

theorem boundaryConnectedHullRegion_subset_stage_of_subset
    {m n : ℕ} {inside : Region GridNode}
    (hInside : inside ⊆ gridExhaustion.region m) :
    boundaryConnectedHullRegion n inside ⊆ gridExhaustion.region m := by
  intro a ha
  cases le_total n m with
  | inl hnm =>
      exact gridExhaustion.monotone hnm (boundaryConnectedHullRegion_subset_stage ha)
  | inr hmn =>
      by_contra haNotStage
      have haExt :
          a ∈ boundaryConnectedOutsideSubregion n inside :=
        mem_boundaryConnectedOutsideSubregion_of_mem_stage_of_not_mem_stage
          hInside (boundaryConnectedHullRegion_subset_stage ha) haNotStage
      exact (mem_boundaryConnectedHullRegion_iff.1 ha).2 haExt

theorem boundaryConnectedHullRegion_eq_of_stage_subsets
    {m n : ℕ} {inside : Region GridNode}
    (hInsideM : inside ⊆ gridExhaustion.region m)
    (hInsideN : inside ⊆ gridExhaustion.region n) :
    boundaryConnectedHullRegion n inside = boundaryConnectedHullRegion m inside := by
  ext a
  cases le_total m n with
  | inl hmn =>
      constructor
      · intro ha
        have haStageM :
            a ∈ gridExhaustion.region m :=
          boundaryConnectedHullRegion_subset_stage_of_subset hInsideM ha
        rw [mem_boundaryConnectedHullRegion_iff] at ha ⊢
        refine ⟨haStageM, ?_⟩
        intro haExtM
        exact ha.2 (mem_boundaryConnectedOutsideSubregion_of_le hmn hInsideM haExtM)
      · intro ha
        rw [mem_boundaryConnectedHullRegion_iff] at ha ⊢
        refine ⟨gridExhaustion.monotone hmn ha.1, ?_⟩
        intro haExtN
        exact ha.2
          (mem_boundaryConnectedOutsideSubregion_of_ge hmn ha.1 haExtN)
  | inr hnm =>
      constructor
      · intro ha
        rw [mem_boundaryConnectedHullRegion_iff] at ha ⊢
        refine ⟨gridExhaustion.monotone hnm ha.1, ?_⟩
        intro haExtM
        exact ha.2
          (mem_boundaryConnectedOutsideSubregion_of_ge hnm ha.1 haExtM)
      · intro ha
        have haStageN :
            a ∈ gridExhaustion.region n :=
          boundaryConnectedHullRegion_subset_stage_of_subset hInsideN ha
        rw [mem_boundaryConnectedHullRegion_iff] at ha ⊢
        refine ⟨haStageN, ?_⟩
        intro haExtN
        exact ha.2 (mem_boundaryConnectedOutsideSubregion_of_le hnm hInsideN haExtN)

theorem two_le_originContainingSubregionOuterCutCard
    {n : ℕ} {inside : Region GridNode}
    (hinside : inside ∈ originContainingSubregions n) :
    2 ≤ originContainingSubregionOuterCutCard n inside := by
  obtain ⟨i, j, hhor⟩ := originContainingSubregion_exists_outerHorizontalCut hinside
  obtain ⟨i', j', hvert⟩ := originContainingSubregion_exists_outerVerticalCut hinside
  have hsubset :
      ({GridClauseId.horizontal i j, GridClauseId.vertical i' j'} : Finset GridClauseId) ⊆
        originContainingSubregionOuterCutBaseClauses n inside := by
    intro x hx
    simp at hx
    rcases hx with rfl | rfl
    · exact hhor
    · exact hvert
  unfold originContainingSubregionOuterCutCard
  exact Finset.card_le_card hsubset

theorem two_le_originConnectedContainingSubregionOuterCutCard
    {n : ℕ} {inside : Region GridNode}
    (hinside : inside ∈ originConnectedContainingSubregions n) :
    2 ≤ originContainingSubregionOuterCutCard n inside := by
  rcases (mem_originConnectedContainingSubregions_iff.1 hinside) with ⟨hInside, hconn⟩
  exact two_le_originContainingSubregionOuterCutCard
    (mem_originContainingSubregions_iff.2 ⟨hInside, hconn.1⟩)

theorem snd_lt_originContainingSubregionOuterCutCard_of_mem_originConnectedContainingSubregions
    {n : ℕ} {inside : Region GridNode} {a : GridNode}
    (hinside : inside ∈ originConnectedContainingSubregions n)
    (ha : a ∈ inside) :
    a.2 < originContainingSubregionOuterCutCard n inside := by
  classical
  rcases (mem_originConnectedContainingSubregions_iff.1 hinside) with ⟨hInside, hconn⟩
  have hinside' : inside ∈ originContainingSubregions n :=
    (mem_originContainingSubregions_iff.2 ⟨hInside, hconn.1⟩)
  let f : Fin (a.2 + 1) → GridClauseId := fun k =>
    GridClauseId.horizontal
      (Classical.choose
        (originContainingSubregion_exists_outerHorizontalCut_on_row
          (n := n) (j := k.1) (inside := inside) hinside'
          (exists_mem_row_of_originConnected hconn ha k.1 (Nat.le_of_lt_succ k.2))))
      k.1
  have hsubset :
      (Finset.univ.image f) ⊆ originContainingSubregionOuterCutBaseClauses n inside := by
    intro j hj
    rcases Finset.mem_image.1 hj with ⟨k, _hk, rfl⟩
    exact Classical.choose_spec
      (originContainingSubregion_exists_outerHorizontalCut_on_row
        (n := n) (j := k.1) (inside := inside) hinside'
        (exists_mem_row_of_originConnected hconn ha k.1 (Nat.le_of_lt_succ k.2)))
  have hinj : Function.Injective f := by
    intro k₁ k₂ hEq
    have hsnd :
        (match f k₁ with
          | GridClauseId.horizontal _ j => j
          | _ => 0) =
        (match f k₂ with
          | GridClauseId.horizontal _ j => j
          | _ => 0) := by
      simpa [f] using congrArg
        (fun c =>
          match c with
          | GridClauseId.horizontal _ j => j
          | _ => 0) hEq
    exact Fin.ext hsnd
  have hcard :
      (Finset.univ : Finset (Fin (a.2 + 1))).card ≤
        (originContainingSubregionOuterCutBaseClauses n inside).card := by
    calc
      (Finset.univ : Finset (Fin (a.2 + 1))).card = (Finset.univ.image f).card := by
        symm
        exact Finset.card_image_of_injective _ hinj
      _ ≤ (originContainingSubregionOuterCutBaseClauses n inside).card :=
        Finset.card_le_card hsubset
  unfold originContainingSubregionOuterCutCard
  simpa using hcard

theorem fst_lt_originContainingSubregionOuterCutCard_of_mem_originConnectedContainingSubregions
    {n : ℕ} {inside : Region GridNode} {a : GridNode}
    (hinside : inside ∈ originConnectedContainingSubregions n)
    (ha : a ∈ inside) :
    a.1 < originContainingSubregionOuterCutCard n inside := by
  classical
  rcases (mem_originConnectedContainingSubregions_iff.1 hinside) with ⟨hInside, hconn⟩
  have hinside' : inside ∈ originContainingSubregions n :=
    (mem_originContainingSubregions_iff.2 ⟨hInside, hconn.1⟩)
  let f : Fin (a.1 + 1) → GridClauseId := fun k =>
    GridClauseId.vertical
      k.1
      (Classical.choose
        (originContainingSubregion_exists_outerVerticalCut_on_col
          (n := n) (i := k.1) (inside := inside) hinside'
          (exists_mem_col_of_originConnected hconn ha k.1 (Nat.le_of_lt_succ k.2))))
  have hsubset :
      (Finset.univ.image f) ⊆ originContainingSubregionOuterCutBaseClauses n inside := by
    intro j hj
    rcases Finset.mem_image.1 hj with ⟨k, _hk, rfl⟩
    exact Classical.choose_spec
      (originContainingSubregion_exists_outerVerticalCut_on_col
        (n := n) (i := k.1) (inside := inside) hinside'
        (exists_mem_col_of_originConnected hconn ha k.1 (Nat.le_of_lt_succ k.2)))
  have hinj : Function.Injective f := by
    intro k₁ k₂ hEq
    have hfst :
        (match f k₁ with
          | GridClauseId.vertical i _ => i
          | _ => 0) =
        (match f k₂ with
          | GridClauseId.vertical i _ => i
          | _ => 0) := by
      simpa [f] using congrArg
        (fun c =>
          match c with
          | GridClauseId.vertical i _ => i
          | _ => 0) hEq
    exact Fin.ext hfst
  have hcard :
      (Finset.univ : Finset (Fin (a.1 + 1))).card ≤
        (originContainingSubregionOuterCutBaseClauses n inside).card := by
    calc
      (Finset.univ : Finset (Fin (a.1 + 1))).card = (Finset.univ.image f).card := by
        symm
        exact Finset.card_image_of_injective _ hinj
      _ ≤ (originContainingSubregionOuterCutBaseClauses n inside).card :=
        Finset.card_le_card hsubset
  unfold originContainingSubregionOuterCutCard
  simpa using hcard

theorem outerCutFactorInv_le_cutFactorInv_of_nonneg
    {w : ℝ} (hw : 0 ≤ w) {n : ℕ} {inside : Region GridNode}
    (hInside : inside ⊆ gridExhaustion.region n) :
    ((ENNReal.ofReal (Real.exp w)) ^ originContainingSubregionCutCard n inside)⁻¹ ≤
      ((ENNReal.ofReal (Real.exp w)) ^ originContainingSubregionOuterCutCard n inside)⁻¹ := by
  let e : ENNReal := ENNReal.ofReal (Real.exp w)
  have he1 : (1 : ENNReal) ≤ e := by
    simpa [e] using
      (show ENNReal.ofReal (1 : ℝ) ≤ ENNReal.ofReal (Real.exp w) from
        ENNReal.ofReal_le_ofReal (Real.one_le_exp_iff.mpr hw))
  have hcard : originContainingSubregionOuterCutCard n inside ≤
      originContainingSubregionCutCard n inside :=
    originContainingSubregionOuterCutCard_le_cutCard hInside
  rcases Nat.exists_eq_add_of_le hcard with ⟨t, ht⟩
  have hpow :
      e ^ originContainingSubregionOuterCutCard n inside ≤
        e ^ originContainingSubregionCutCard n inside := by
    have ht' : originContainingSubregionOuterCutCard n inside + t =
        originContainingSubregionCutCard n inside := ht.symm
    have hpow_t : (1 : ENNReal) ≤ e ^ t := one_le_pow_of_one_le' he1 t
    calc
      e ^ originContainingSubregionOuterCutCard n inside
          ≤ e ^ originContainingSubregionOuterCutCard n inside * e ^ t := by
            calc
              e ^ originContainingSubregionOuterCutCard n inside
                  = 1 * e ^ originContainingSubregionOuterCutCard n inside := by rw [one_mul]
              _ ≤ e ^ t * e ^ originContainingSubregionOuterCutCard n inside := by
                    gcongr
              _ = e ^ originContainingSubregionOuterCutCard n inside * e ^ t := by
                    rw [mul_comm]
      _ = e ^ originContainingSubregionCutCard n inside := by
            rw [← pow_add, ht']
  simpa [e] using ENNReal.inv_le_inv' hpow

theorem two_le_originContainingSubregionCutCard
    {n : ℕ} {inside : Region GridNode}
    (hinside : inside ∈ originContainingSubregions n) :
    2 ≤ originContainingSubregionCutCard n inside := by
  obtain ⟨i, j, hhor⟩ := originContainingSubregion_exists_horizontalCut hinside
  obtain ⟨i', j', hvert⟩ := originContainingSubregion_exists_verticalCut hinside
  have hsubset :
      ({GridClauseId.horizontal i j, GridClauseId.vertical i' j'} : Finset GridClauseId) ⊆
        (gridRegionSupport (gridExhaustion.region n)).filter (gridBaseClauseCutsRegion inside) := by
    intro x hx
    simp at hx
    rcases hx with rfl | rfl
    · exact hhor
    · exact hvert
  have hcard := Finset.card_le_card hsubset
  unfold originContainingSubregionCutCard
  simpa using hcard

theorem two_le_originConnectedContainingSubregionCutCard
    {n : ℕ} {inside : Region GridNode}
    (hinside : inside ∈ originConnectedContainingSubregions n) :
    2 ≤ originContainingSubregionCutCard n inside := by
  rcases (mem_originConnectedContainingSubregions_iff.1 hinside) with ⟨hInside, hconn⟩
  exact two_le_originContainingSubregionCutCard
    (mem_originContainingSubregions_iff.2 ⟨hInside, hconn.1⟩)

theorem originConnectedContainingSubregions_filter_cutCard_zero_eq_empty
    (n : ℕ) :
    (originConnectedContainingSubregions n).filter
        (fun inside => originContainingSubregionCutCard n inside = 0) = ∅ := by
  classical
  apply Finset.filter_false_of_mem
  intro inside hinside hcut
  have hge : 2 ≤ originContainingSubregionCutCard n inside :=
    two_le_originConnectedContainingSubregionCutCard hinside
  have hpos : 0 < originContainingSubregionCutCard n inside :=
    lt_of_lt_of_le (by decide : 0 < 2) hge
  exact Nat.ne_of_gt hpos hcut

theorem originConnectedContainingSubregions_filter_cutCard_one_eq_empty
    (n : ℕ) :
    (originConnectedContainingSubregions n).filter
