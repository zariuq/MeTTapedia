theorem CutWalkReplayPrefix.appendMoveTagged_fresh_step_mem
    {i : ℕ} {s : Finset GridClauseId}
    (pref : CutWalkReplayPrefix i)
    (move : CutWalkMove) (newTag : CutWalkVisitTag)
    (hvalid : cutWalkMoveValidAt (pref.node pref.len) move)
    (hnew : newTag = CutWalkVisitTag.fresh →
      cutWalkMoveClause (pref.node pref.len) move ∈ s)
    (hmem :
      ∀ k : Fin pref.len,
        pref.tag k = CutWalkVisitTag.fresh →
          pref.step k ∈ s) :
    ∀ k : Fin (pref.appendMoveTagged move newTag hvalid).len,
      (pref.appendMoveTagged move newTag hvalid).tag k = CutWalkVisitTag.fresh →
        (pref.appendMoveTagged move newTag hvalid).step k ∈ s := by
  intro k htag
  by_cases hk : k.1 < pref.len
  · have htagOld : pref.tag ⟨k.1, hk⟩ = CutWalkVisitTag.fresh := by
      simpa [CutWalkReplayPrefix.appendMoveTagged, hk] using htag
    simpa [CutWalkReplayPrefix.appendMoveTagged, hk] using hmem ⟨k.1, hk⟩ htagOld
  · have hnewTag : newTag = CutWalkVisitTag.fresh := by
      simpa [CutWalkReplayPrefix.appendMoveTagged, hk] using htag
    simpa [CutWalkReplayPrefix.appendMoveTagged, hk] using hnew hnewTag

theorem CutWalkReplayPrefix.appendMoveTagged_fresh_cover
    {i : ℕ} {t : Finset GridClauseId}
    (pref : CutWalkReplayPrefix i)
    (move : CutWalkMove) (newTag : CutWalkVisitTag)
    (hvalid : cutWalkMoveValidAt (pref.node pref.len) move)
    (hcover :
      ∀ x ∈ t,
        ∃ k : Fin pref.len,
          pref.tag k = CutWalkVisitTag.fresh ∧
            pref.step k = x) :
    ∀ x ∈ t,
      ∃ k : Fin (pref.appendMoveTagged move newTag hvalid).len,
        (pref.appendMoveTagged move newTag hvalid).tag k = CutWalkVisitTag.fresh ∧
          (pref.appendMoveTagged move newTag hvalid).step k = x := by
  intro x hx
  rcases hcover x hx with ⟨k, htag, hstep⟩
  refine ⟨⟨k.1, by simp [CutWalkReplayPrefix.appendMoveTagged]⟩, ?_, ?_⟩
  · simpa [CutWalkReplayPrefix.appendMoveTagged, k.2] using htag
  · simpa [CutWalkReplayPrefix.appendMoveTagged, k.2] using hstep

theorem CutWalkReplayPrefix.exists_appendMoveListRevisit
    {i : ℕ} {s t : Finset GridClauseId}
    (moves : List CutWalkMove)
    (pref : CutWalkReplayPrefix i) (hpos : 0 < pref.len)
    (hvalid : cutWalkMoveListValidFrom (pref.node pref.len) moves)
    (hmem :
      ∀ k : Fin pref.len,
        pref.tag k = CutWalkVisitTag.fresh →
          pref.step k ∈ s)
    (hcover :
      ∀ x ∈ t,
        ∃ k : Fin pref.len,
          pref.tag k = CutWalkVisitTag.fresh ∧
            pref.step k = x) :
    ∃ pref' : CutWalkReplayPrefix i,
      pref'.len = pref.len + moves.length ∧
        pref'.node pref'.len = cutWalkMoveListTarget (pref.node pref.len) moves ∧
          (∀ hpos' : 0 < pref'.len,
            pref'.step ⟨0, hpos'⟩ = pref.step ⟨0, hpos⟩ ∧
              pref'.tag ⟨0, hpos'⟩ = pref.tag ⟨0, hpos⟩) ∧
            (∀ k : Fin pref'.len,
              pref'.tag k = CutWalkVisitTag.fresh →
                pref'.step k ∈ s) ∧
              (∀ x ∈ t,
                ∃ k : Fin pref'.len,
                  pref'.tag k = CutWalkVisitTag.fresh ∧
                    pref'.step k = x) := by
  induction moves generalizing pref with
  | nil =>
      refine ⟨pref, by simp, by simp [cutWalkMoveListTarget], ?_, hmem, hcover⟩
      intro hpos'
      constructor <;> rfl
  | cons move moves ih =>
      rcases hvalid with ⟨hmove, hrest⟩
      let pref₁ := pref.appendMoveTagged move CutWalkVisitTag.revisit hmove
      have hpos₁ : 0 < pref₁.len := by simp [pref₁]
      have hvalidRest :
          cutWalkMoveListValidFrom (pref₁.node pref₁.len) moves := by
        have hterm₁ :
            pref₁.node pref₁.len = cutWalkMoveTarget (pref.node pref.len) move := by
          simpa [pref₁] using
            pref.appendMoveTagged_terminal_node move CutWalkVisitTag.revisit hmove
        rw [hterm₁]
        exact hrest
      have hmem₁ :
          ∀ k : Fin pref₁.len,
            pref₁.tag k = CutWalkVisitTag.fresh →
              pref₁.step k ∈ s :=
        pref.appendMoveTagged_fresh_step_mem move CutWalkVisitTag.revisit hmove
          (by intro h; cases h) hmem
      have hcover₁ :
          ∀ x ∈ t,
            ∃ k : Fin pref₁.len,
              pref₁.tag k = CutWalkVisitTag.fresh ∧
                pref₁.step k = x :=
        pref.appendMoveTagged_fresh_cover move CutWalkVisitTag.revisit hmove hcover
      rcases ih pref₁ hpos₁ hvalidRest hmem₁ hcover₁ with
        ⟨pref₂, hlen₂, hnode₂, hfirst₂, hmem₂, hcover₂⟩
      refine ⟨pref₂, ?_, ?_, ?_, hmem₂, hcover₂⟩
      · rw [hlen₂]
        simp [pref₁]
        omega
      · have hterm₁ :
            pref₁.node pref₁.len = cutWalkMoveTarget (pref.node pref.len) move := by
          simpa [pref₁] using
            pref.appendMoveTagged_terminal_node move CutWalkVisitTag.revisit hmove
        rw [hnode₂, hterm₁]
        rfl
      · intro hpos₂
        rcases hfirst₂ hpos₂ with ⟨hstep₂, htag₂⟩
        have hstep₁ : pref₁.step ⟨0, hpos₁⟩ = pref.step ⟨0, hpos⟩ :=
          pref.appendMoveTagged_step_zero move CutWalkVisitTag.revisit hmove hpos
        have htag₁ : pref₁.tag ⟨0, hpos₁⟩ = pref.tag ⟨0, hpos⟩ :=
          pref.appendMoveTagged_tag_zero move CutWalkVisitTag.revisit hmove hpos
        exact ⟨hstep₂.trans hstep₁, htag₂.trans htag₁⟩

