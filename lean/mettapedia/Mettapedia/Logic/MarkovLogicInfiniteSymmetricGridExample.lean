theorem walkCrossBit_separatorSquareComponent_eq_zero_of_all_mem_hull
    {m : ℕ} {hull : Region GridNode} {root : GridNode × GridNode} :
    ∀ walk : List GridNode,
      (∀ p ∈ walk, p ∈ hull) →
        walkCrossBit (separatorSquareComponent m hull root) walk = 0 := by
  intro walk
  induction walk with
  | nil =>
      intro _hmem
      simp [walkCrossBit]
  | cons a tail ih =>
      intro hmem
      cases tail with
      | nil =>
          simp [walkCrossBit]
      | cons b rest =>
          have ha : a ∈ hull := hmem a (by simp)
          have hb : b ∈ hull := hmem b (by simp)
          have htail : ∀ p ∈ b :: rest, p ∈ hull := by
            intro p hp
            exact hmem p (by simp [hp])
          rw [walkCrossBit]
          rw [edgeBit_separatorSquareComponent_eq_zero_of_mem_hull ha hb]
          rw [ih htail]
          simp

