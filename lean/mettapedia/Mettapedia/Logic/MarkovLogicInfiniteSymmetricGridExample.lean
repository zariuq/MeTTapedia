    {e f : GridNode × GridNode}
    (he : e ∈ visibleBoundarySeparatorEdges m hull)
    (hf : f ∈ visibleBoundarySeparatorEdges m hull)
    (hreach :
      Relation.ReflTransGen
        (visibleBoundarySeparatorEdgesSquareAdjacent m hull) e f) :
    (cutSetStarGraph s).Reachable
      ⟨gridAdjacentClauseId e.1 e.2,
        gridAdjacentClauseId_mem_cutSet_of_visibleBoundarySeparatorEdge
          hsEq hHull he⟩
      ⟨gridAdjacentClauseId f.1 f.2,
        gridAdjacentClauseId_mem_cutSet_of_visibleBoundarySeparatorEdge
          hsEq hHull hf⟩ := by
  let fallback : {c // c ∈ s} :=
    ⟨gridAdjacentClauseId e.1 e.2,
      gridAdjacentClauseId_mem_cutSet_of_visibleBoundarySeparatorEdge
        hsEq hHull he⟩
  let edgeClause : GridNode × GridNode → {c // c ∈ s} := fun x =>
    if hx : x ∈ visibleBoundarySeparatorEdges m hull then
      ⟨gridAdjacentClauseId x.1 x.2,
        gridAdjacentClauseId_mem_cutSet_of_visibleBoundarySeparatorEdge
          hsEq hHull hx⟩
    else fallback
  have hstep :
      ∀ a b,
        visibleBoundarySeparatorEdgesSquareAdjacent m hull a b →
          cutSetStarRel s (edgeClause a) (edgeClause b) := by
    intro a b hab
    have ha : a ∈ visibleBoundarySeparatorEdges m hull := hab.1
    have hb : b ∈ visibleBoundarySeparatorEdges m hull := hab.2.1
    simp [edgeClause, ha, hb, cutSetStarRel,
      gridClauseStarAdjacent_gridAdjacentClauseId_of_visibleBoundarySeparatorEdgesSquareAdjacent hab]
  have hreachClause :
      Relation.ReflTransGen (cutSetStarRel s) (edgeClause e) (edgeClause f) :=
    Relation.ReflTransGen.lift edgeClause hstep hreach
  rw [cutSetStarGraph_reachable_eq_reflTransGen]
  simpa [edgeClause, he, hf, fallback] using hreachClause

theorem cutSetStarGraph_connected_of_originConnected_stageCoConnected_cut_eq
    {m : ℕ} {hull : Region GridNode} {s : Finset GridClauseId}
    (hm : 1 ≤ m)
    (hsEq :
      s =
        (gridRegionSupport (gridExhaustion.region (m - 1))).filter
