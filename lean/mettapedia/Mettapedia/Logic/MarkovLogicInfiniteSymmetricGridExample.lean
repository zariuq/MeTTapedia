@[simp] theorem gridClauseDualAdjacent_horizontal_vertical_right
    (i j : ℕ) :
    gridClauseDualAdjacent
      (GridClauseId.horizontal i j)
      (GridClauseId.vertical i (j + 1)) := by
  refine ⟨(i, j + 1), ?_, ?_⟩ <;> simp [gridClauseDualEndpoints]

theorem reflTransGen_gridClauseStarAdjacentIn_horizontal_interval
    {s : Finset GridClauseId} (i lo hi : ℕ)
    (hlohi : lo ≤ hi)
    (hmem : ∀ t, lo ≤ t → t ≤ hi → GridClauseId.horizontal i t ∈ s) :
    Relation.ReflTransGen (gridClauseStarAdjacentIn s)
      (GridClauseId.horizontal i lo) (GridClauseId.horizontal i hi) := by
  revert lo
  induction hi with
  | zero =>
      intro lo hlohi hmem
      have hEq : lo = 0 := by omega
      subst hEq
      exact Relation.ReflTransGen.refl
  | succ hi ih =>
      intro lo hlohi hmem
      by_cases hEq : lo = hi + 1
      · subst hEq
        exact Relation.ReflTransGen.refl
      · have hlohi' : lo ≤ hi := by omega
        have ihreach :
            Relation.ReflTransGen (gridClauseStarAdjacentIn s)
              (GridClauseId.horizontal i lo) (GridClauseId.horizontal i hi) :=
          ih lo hlohi' (fun t htlo hthi => hmem t htlo (by omega))
        exact Relation.ReflTransGen.tail ihreach
          ⟨hmem hi hlohi' (by omega),
            hmem (hi + 1) (by omega) le_rfl,
            gridClauseStarAdjacent_of_dualAdjacent
              (gridClauseDualAdjacent_horizontal_succ i hi)⟩

theorem reflTransGen_gridClauseStarAdjacentIn_vertical_interval
    {s : Finset GridClauseId} (j lo hi : ℕ)
    (hlohi : lo ≤ hi)
    (hmem : ∀ t, lo ≤ t → t ≤ hi → GridClauseId.vertical t j ∈ s) :
    Relation.ReflTransGen (gridClauseStarAdjacentIn s)
      (GridClauseId.vertical lo j) (GridClauseId.vertical hi j) := by
  revert lo
  induction hi with
  | zero =>
      intro lo hlohi hmem
      have hEq : lo = 0 := by omega
      subst hEq
      exact Relation.ReflTransGen.refl
  | succ hi ih =>
      intro lo hlohi hmem
      by_cases hEq : lo = hi + 1
      · subst hEq
        exact Relation.ReflTransGen.refl
      · have hlohi' : lo ≤ hi := by omega
        have ihreach :
            Relation.ReflTransGen (gridClauseStarAdjacentIn s)
              (GridClauseId.vertical lo j) (GridClauseId.vertical hi j) :=
          ih lo hlohi' (fun t htlo hthi => hmem t htlo (by omega))
        exact Relation.ReflTransGen.tail ihreach
          ⟨hmem hi hlohi' (by omega),
            hmem (hi + 1) (by omega) le_rfl,
            gridClauseStarAdjacent_of_dualAdjacent
              (gridClauseDualAdjacent_vertical_succ hi j)⟩

theorem gridBaseClauseCutsRegion_gridAdjacentClauseId_iff
    {inside : Region GridNode} {a b : GridNode}
    (hab : gridAdjacent a b) :
    gridBaseClauseCutsRegion inside (gridAdjacentClauseId a b) ↔
      ((a ∈ inside ∧ b ∉ inside) ∨ (a ∉ inside ∧ b ∈ inside)) := by
  rcases a with ⟨i, j⟩
  rcases b with ⟨i', j'⟩
  rcases hab with h | h | h | h
  · rcases h with ⟨hi, hj⟩
    subst hi
    subst hj
    simp [gridAdjacentClauseId, gridBaseClauseCutsRegion]
  · rcases h with ⟨hi, hj⟩
    subst hi
    subst hj
    constructor <;> intro h
    · simpa [gridAdjacentClauseId, gridBaseClauseCutsRegion, and_left_comm, and_assoc,
        and_comm, or_left_comm, or_assoc, or_comm] using h
    · simpa [gridAdjacentClauseId, gridBaseClauseCutsRegion, and_left_comm, and_assoc,
        and_comm, or_left_comm, or_assoc, or_comm] using h
  · rcases h with ⟨hi, hj⟩
    subst hi
    subst hj
    simp [gridAdjacentClauseId, gridBaseClauseCutsRegion]
  · rcases h with ⟨hi, hj⟩
    subst hi
    subst hj
    constructor <;> intro h
    · simpa [gridAdjacentClauseId, gridBaseClauseCutsRegion, and_left_comm, and_assoc,
        and_comm, or_left_comm, or_assoc, or_comm] using h
    · simpa [gridAdjacentClauseId, gridBaseClauseCutsRegion, and_left_comm, and_assoc,
        and_comm, or_left_comm, or_assoc, or_comm] using h

theorem exists_gridAdjacent_edge_of_gridBaseClauseCutsRegion
    {inside : Region GridNode} {j : GridClauseId}
    (hj : gridBaseClauseCutsRegion inside j) :
    ∃ a b : GridNode,
      gridAdjacent a b ∧ gridAdjacentClauseId a b = j ∧
        ((a ∈ inside ∧ b ∉ inside) ∨ (a ∉ inside ∧ b ∈ inside)) := by
  cases j with
  | prior i j => cases hj
  | horizontal i j =>
      refine ⟨(i, j), (i + 1, j), gridAdjacent_horizontal_forward i j, by simp, ?_⟩
      simpa [gridBaseClauseCutsRegion] using hj
  | vertical i j =>
      refine ⟨(i, j), (i, j + 1), gridAdjacent_vertical_forward i j, by simp, ?_⟩
      simpa [gridBaseClauseCutsRegion] using hj

theorem exists_primalEndpoint_mem_of_gridBaseClauseCutsRegion
    {inside : Region GridNode} {j : GridClauseId}
    (hj : gridBaseClauseCutsRegion inside j) :
    ∃ p, p ∈ gridClausePrimalEndpoints j ∧ p ∈ inside := by
  rcases exists_gridAdjacent_edge_of_gridBaseClauseCutsRegion hj with
    ⟨a, b, hab, hEq, hside⟩
  rcases hside with ⟨ha, _hb⟩ | ⟨_ha, hb⟩
  · refine ⟨a, ?_, ha⟩
    rw [← hEq]
    exact left_mem_gridClausePrimalEndpoints_gridAdjacentClauseId hab
  · refine ⟨b, ?_, hb⟩
    rw [← hEq]
    exact right_mem_gridClausePrimalEndpoints_gridAdjacentClauseId hab

theorem exists_primalEndpoint_not_mem_of_gridBaseClauseCutsRegion
    {inside : Region GridNode} {j : GridClauseId}
    (hj : gridBaseClauseCutsRegion inside j) :
    ∃ p, p ∈ gridClausePrimalEndpoints j ∧ p ∉ inside := by
  rcases exists_gridAdjacent_edge_of_gridBaseClauseCutsRegion hj with
    ⟨a, b, hab, hEq, hside⟩
  rcases hside with ⟨_ha, hb⟩ | ⟨ha, _hb⟩
  · refine ⟨b, ?_, hb⟩
    rw [← hEq]
    exact right_mem_gridClausePrimalEndpoints_gridAdjacentClauseId hab
  · refine ⟨a, ?_, ha⟩
    rw [← hEq]
    exact left_mem_gridClausePrimalEndpoints_gridAdjacentClauseId hab

theorem mem_iff_mem_of_not_gridBaseClauseCutsRegion_gridAdjacentClauseId
    {inside : Region GridNode} {a b : GridNode}
    (hab : gridAdjacent a b)
    (hnotcut : ¬ gridBaseClauseCutsRegion inside (gridAdjacentClauseId a b)) :
    a ∈ inside ↔ b ∈ inside := by
  rw [gridBaseClauseCutsRegion_gridAdjacentClauseId_iff hab] at hnotcut
  by_cases ha : a ∈ inside
  · constructor
    · intro _
      by_cases hb : b ∈ inside
      · exact hb
      · exfalso
        exact hnotcut (Or.inl ⟨ha, hb⟩)
    · intro _; exact ha
  · constructor
    · intro hIn
      exfalso
      exact ha hIn
    · intro hb
      by_cases hIn : a ∈ inside
      · exact hIn
      · exfalso
        exact hnotcut (Or.inr ⟨hIn, hb⟩)

theorem not_mem_iff_not_mem_of_not_gridBaseClauseCutsRegion_gridAdjacentClauseId
    {inside : Region GridNode} {a b : GridNode}
    (hab : gridAdjacent a b)
    (hnotcut : ¬ gridBaseClauseCutsRegion inside (gridAdjacentClauseId a b)) :
    a ∉ inside ↔ b ∉ inside := by
  constructor <;> intro h
  · intro hb
    exact h ((mem_iff_mem_of_not_gridBaseClauseCutsRegion_gridAdjacentClauseId hab hnotcut).2 hb)
  · intro ha
    exact h ((mem_iff_mem_of_not_gridBaseClauseCutsRegion_gridAdjacentClauseId hab hnotcut).1 ha)

theorem not_gridBaseClauseCutsRegion_gridAdjacentClauseId_of_mem_mem
    {inside : Region GridNode} {a b : GridNode}
    (ha : a ∈ inside) (hb : b ∈ inside)
    (hab : gridAdjacent a b) :
    ¬ gridBaseClauseCutsRegion inside (gridAdjacentClauseId a b) := by
  rw [gridBaseClauseCutsRegion_gridAdjacentClauseId_iff hab]
  simp [ha, hb]

theorem clauseTouchesRegion_gridAdjacentClauseId_of_mem_left
    {Λ : Region GridNode} {a b : GridNode}
    (ha : a ∈ Λ) (hab : gridAdjacent a b) :
    clauseTouchesRegion (gridClause (gridAdjacentClauseId a b)) Λ := by
  refine ⟨a, ?_, ha⟩
  rcases a with ⟨i, j⟩
  rcases b with ⟨i', j'⟩
  rcases hab with h | h | h | h
  · rcases h with ⟨hi, hj⟩
    subst hi
    subst hj
    simp [gridClause, gridAdjacentClauseId]
  · rcases h with ⟨hi, hj⟩
    subst hi
    subst hj
    simp [gridClause, gridAdjacentClauseId]
  · rcases h with ⟨hi, hj⟩
    subst hi
    subst hj
    simp [gridClause, gridAdjacentClauseId]
  · rcases h with ⟨hi, hj⟩
    subst hi
    subst hj
    simp [gridClause, gridAdjacentClauseId]

theorem gridAdjacentClauseId_mem_gridRegionSupport_of_mem_left
    {Λ : Region GridNode} {a b : GridNode}
    (ha : a ∈ Λ) (hab : gridAdjacent a b) :
    gridAdjacentClauseId a b ∈ gridRegionSupport Λ := by
  apply gridRegionSupport_complete
  exact clauseTouchesRegion_gridAdjacentClauseId_of_mem_left ha hab

theorem gridAdjacentClauseId_mem_gridRegionSupport_of_mem_right
    {Λ : Region GridNode} {a b : GridNode}
    (hb : b ∈ Λ) (hab : gridAdjacent a b) :
    gridAdjacentClauseId a b ∈ gridRegionSupport Λ := by
  rw [gridAdjacentClauseId_symm hab]
  exact gridAdjacentClauseId_mem_gridRegionSupport_of_mem_left hb (gridAdjacent_symm hab)

/-- The adjacency relation restricted to a finite inside region. -/
def gridAdjacentInRegion (inside : Region GridNode) (a b : GridNode) : Prop :=
  a ∈ inside ∧ b ∈ inside ∧ gridAdjacent a b

theorem gridAdjacentInRegion_symm
    {inside : Region GridNode} {a b : GridNode} :
    gridAdjacentInRegion inside a b → gridAdjacentInRegion inside b a := by
  intro h
  exact ⟨h.2.1, h.1, gridAdjacent_symm h.2.2⟩

def gridAdjacentRegionRel (inside : Region GridNode) :
    {p // p ∈ inside} → {p // p ∈ inside} → Prop :=
  fun a b => gridAdjacent a.1 b.1

theorem gridAdjacentRegionRel_symm (inside : Region GridNode) :
    Std.Symm (gridAdjacentRegionRel inside) :=
  ⟨fun _ _ hab => gridAdjacent_symm hab⟩

def gridAdjacentRegionGraph (inside : Region GridNode) :
    SimpleGraph {p // p ∈ inside} :=
  SimpleGraph.fromEdgeSet
    (Sym2.fromRel (gridAdjacentRegionRel_symm inside))

theorem gridAdjacentRegionGraph_reachable_eq_reflTransGen
    (inside : Region GridNode) :
    (gridAdjacentRegionGraph inside).Reachable =
      Relation.ReflTransGen (gridAdjacentRegionRel inside) := by
  exact SimpleGraph.reachable_fromEdgeSet_fromRel_eq_reflTransGen
    (gridAdjacentRegionRel_symm inside)

theorem gridAdjacentRegionGraph_connected_of_reflTransGen
    {inside : Region GridNode}
    (hnonempty : Nonempty {p // p ∈ inside})
    (hconn :
      ∀ a b : {p // p ∈ inside},
        Relation.ReflTransGen (gridAdjacentRegionRel inside) a b) :
    (gridAdjacentRegionGraph inside).Connected := by
  haveI : Nonempty {p // p ∈ inside} := hnonempty
  refine ⟨?_⟩
  intro a b
  rw [gridAdjacentRegionGraph_reachable_eq_reflTransGen]
  exact hconn a b

theorem reflTransGen_gridAdjacentInRegion_subtype
    {inside : Region GridNode} {a b : GridNode}
    (ha : a ∈ inside) (hb : b ∈ inside)
    (hreach :
      Relation.ReflTransGen (gridAdjacentInRegion inside) a b) :
    Relation.ReflTransGen
      (fun x y : {p // p ∈ inside} => gridAdjacent x.1 y.1)
      ⟨a, ha⟩ ⟨b, hb⟩ := by
  let f : GridNode → {p // p ∈ inside} := fun p =>
    if hp : p ∈ inside then ⟨p, hp⟩ else ⟨a, ha⟩
  have hf :
      ∀ x y : GridNode,
        gridAdjacentInRegion inside x y →
          (fun x y : {p // p ∈ inside} => gridAdjacent x.1 y.1)
            (f x) (f y) := by
    intro x y hxy
    simp [f, hxy.1, hxy.2.1, hxy.2.2]
  have hsub :=
    Relation.ReflTransGen.lift
      (p := fun x y : {p // p ∈ inside} => gridAdjacent x.1 y.1)
      f hf hreach
  simpa [f, ha, hb] using hsub

theorem exists_rel_cross_of_reflTransGen_connected
    {α : Type*} {R : α → α → Prop}
    (hconn : ∀ a b : α, Relation.ReflTransGen R a b)
    (U : α → Prop)
    (hpos : ∃ a, U a)
    (hneg : ∃ b, ¬ U b) :
    ∃ a b, U a ∧ ¬ U b ∧ R a b := by
  rcases hpos with ⟨u, hu⟩
  rcases hneg with ⟨v, hv⟩
  have hreach : Relation.ReflTransGen R u v := hconn u v
  have hpath_cross :
      ∀ {x y : α}, Relation.ReflTransGen R x y →
        U x → ¬ U y → ∃ a b, U a ∧ ¬ U b ∧ R a b := by
    intro x y hxy hxU hyU
    induction hxy with
    | refl =>
        exact False.elim (hyU hxU)
    | @tail z y hxz hzy ih =>
        by_cases hzU : U z
        · exact ⟨z, y, hzU, hyU, hzy⟩
        · exact ih hzU
  exact hpath_cross hreach hu hv

theorem exists_first_forbidden_step_of_reflTransGen
    {α : Type*} {R : α → α → Prop} {Allowed : α → Prop}
    {start target : α}
    (hstart : Allowed start)
    (hreach : Relation.ReflTransGen R start target)
    (htarget :
      ¬ Relation.ReflTransGen
        (fun a b : α => Allowed a ∧ Allowed b ∧ R a b) start target) :
    ∃ a b,
      Relation.ReflTransGen
        (fun a b : α => Allowed a ∧ Allowed b ∧ R a b) start a ∧
        ¬ Relation.ReflTransGen
          (fun a b : α => Allowed a ∧ Allowed b ∧ R a b) start b ∧
        R a b ∧ ¬ Allowed b := by
  let RAllowed : α → α → Prop := fun a b => Allowed a ∧ Allowed b ∧ R a b
  have allowed_of_reach :
      ∀ {x : α}, Relation.ReflTransGen RAllowed start x → Allowed x := by
    intro x hx
    induction hx with
    | refl =>
        exact hstart
    | @tail y z hyz hstep _ih =>
        exact hstep.2.1
  induction hreach with
  | refl =>
      exact False.elim (htarget Relation.ReflTransGen.refl)
  | @tail x y hprev hstep ih =>
      by_cases hxReach : Relation.ReflTransGen RAllowed start x
      · have hxAllowed : Allowed x := allowed_of_reach hxReach
        by_cases hyAllowed : Allowed y
        · have hyReach : Relation.ReflTransGen RAllowed start y :=
            Relation.ReflTransGen.tail hxReach
              ⟨hxAllowed, hyAllowed, hstep⟩
          exact False.elim (htarget hyReach)
        · exact ⟨x, y, hxReach, htarget, hstep, hyAllowed⟩
      · exact ih hxReach

theorem exists_first_forbidden_step_with_suffix_of_reflTransGen
    {α : Type*} {R : α → α → Prop} {Allowed : α → Prop}
    {start target : α}
    (hstart : Allowed start)
    (hreach : Relation.ReflTransGen R start target)
    (htarget :
      ¬ Relation.ReflTransGen
        (fun a b : α => Allowed a ∧ Allowed b ∧ R a b) start target) :
    ∃ a b,
      Relation.ReflTransGen
        (fun a b : α => Allowed a ∧ Allowed b ∧ R a b) start a ∧
        R a b ∧ ¬ Allowed b ∧ Relation.ReflTransGen R b target := by
  let RAllowed : α → α → Prop := fun a b => Allowed a ∧ Allowed b ∧ R a b
  have allowed_of_reach :
      ∀ {x : α}, Relation.ReflTransGen RAllowed start x → Allowed x := by
    intro x hx
    induction hx with
    | refl =>
        exact hstart
    | @tail y z hyz hstep _ih =>
        exact hstep.2.1
  induction hreach with
  | refl =>
      exact False.elim (htarget Relation.ReflTransGen.refl)
  | @tail x y hprev hstep ih =>
      by_cases hxReach : Relation.ReflTransGen RAllowed start x
      · have hxAllowed : Allowed x := allowed_of_reach hxReach
        by_cases hyAllowed : Allowed y
        · have hyReach : Relation.ReflTransGen RAllowed start y :=
            Relation.ReflTransGen.tail hxReach
              ⟨hxAllowed, hyAllowed, hstep⟩
          exact False.elim (htarget hyReach)
        · exact ⟨x, y, hxReach, hstep, hyAllowed, Relation.ReflTransGen.refl⟩
      · rcases ih hxReach with
          ⟨a, b, haReach, hab, hbNotAllowed, hbt⟩
        exact ⟨a, b, haReach, hab, hbNotAllowed,
          Relation.ReflTransGen.tail hbt hstep⟩

theorem exists_rel_cross_with_suffix_of_reflTransGen
    {α : Type*} {R : α → α → Prop} {U : α → Prop}
    {start target : α}
    (hreach : Relation.ReflTransGen R start target)
    (hstart : U start) (htarget : ¬ U target) :
    ∃ a b,
      Relation.ReflTransGen
        (fun x y : α => U x ∧ U y ∧ R x y) start a ∧
        U a ∧ R a b ∧ ¬ U b ∧ Relation.ReflTransGen R b target := by
  let RAllowed : α → α → Prop := fun x y => U x ∧ U y ∧ R x y
  have allowed_of_reach :
      ∀ {x : α}, Relation.ReflTransGen RAllowed start x → U x := by
    intro x hx
    induction hx with
    | refl =>
        exact hstart
    | @tail y z hyz hstep _ih =>
        exact hstep.2.1
  have hnotAllowedReach :
      ¬ Relation.ReflTransGen RAllowed start target := by
    intro htargetReach
    exact htarget (allowed_of_reach htargetReach)
  rcases
    exists_first_forbidden_step_with_suffix_of_reflTransGen
      (R := R) (Allowed := U) hstart hreach hnotAllowedReach with
    ⟨a, b, haReach, hab, hbNotAllowed, hbt⟩
  exact ⟨a, b, haReach, allowed_of_reach haReach, hab, hbNotAllowed, hbt⟩

theorem reflTransGen_eq_or_exists_first_step
    {α : Type*} {R : α → α → Prop} {start target : α}
    (hreach : Relation.ReflTransGen R start target) :
    target = start ∨
      ∃ a, R start a ∧ Relation.ReflTransGen R a target := by
  induction hreach with
  | refl =>
      exact Or.inl rfl
  | @tail x y hprev hxy ih =>
      rcases ih with hxEq | hstep
      · subst hxEq
        exact Or.inr ⟨y, hxy, Relation.ReflTransGen.refl⟩
      · rcases hstep with ⟨a, hstarta, hax⟩
        exact Or.inr ⟨a, hstarta, Relation.ReflTransGen.tail hax hxy⟩

theorem gridAdjacent_mem_gridExhaustion_region_succ_of_mem
    {n : ℕ} {a b : GridNode}
    (ha : a ∈ gridExhaustion.region n)
    (hab : gridAdjacent a b) :
    b ∈ gridExhaustion.region (n + 1) := by
  rcases a with ⟨i, j⟩
  rcases b with ⟨i', j'⟩
  rcases Finset.mem_product.1 ha with ⟨hi, hj⟩
  have hiLe : i ≤ n := Nat.le_of_lt_succ (Finset.mem_range.1 hi)
  have hjLe : j ≤ n := Nat.le_of_lt_succ (Finset.mem_range.1 hj)
  rcases hab with h | h | h | h
  all_goals
    rcases h with ⟨rfl, rfl⟩
    exact Finset.mem_product.2
      ⟨Finset.mem_range.2 (by omega), Finset.mem_range.2 (by omega)⟩

theorem reflTransGen_gridAdjacentInRegion_mono
    {inside hull : Region GridNode} (hsub : inside ⊆ hull)
    {a b : GridNode}
    (hreach : Relation.ReflTransGen (gridAdjacentInRegion inside) a b) :
    Relation.ReflTransGen (gridAdjacentInRegion hull) a b := by
  induction hreach with
  | refl =>
      exact Relation.ReflTransGen.refl
  | @tail b c hreach hstep ih =>
      exact Relation.ReflTransGen.tail ih ⟨hsub hstep.1, hsub hstep.2.1, hstep.2.2⟩

theorem reflTransGen_gridAdjacentInRegion_symm
    {inside : Region GridNode} {a b : GridNode}
    (hreach : Relation.ReflTransGen (gridAdjacentInRegion inside) a b) :
    Relation.ReflTransGen (gridAdjacentInRegion inside) b a := by
  induction hreach with
  | refl =>
      exact Relation.ReflTransGen.refl
  | @tail b c hreach hstep ih =>
      exact Relation.ReflTransGen.head (gridAdjacentInRegion_symm hstep) ih

/-- The origin-connected component of an inside region, computed using
nearest-neighbour reachability inside the region. -/
noncomputable def originConnectedSubregion (inside : Region GridNode) : Region GridNode := by
  classical
  exact inside.filter (fun a =>
    Relation.ReflTransGen (gridAdjacentInRegion inside) gridOrigin a)

theorem mem_originConnectedSubregion_iff
    {inside : Region GridNode} {a : GridNode} :
    a ∈ originConnectedSubregion inside ↔
      a ∈ inside ∧
        Relation.ReflTransGen (gridAdjacentInRegion inside) gridOrigin a := by
  simp [originConnectedSubregion]

theorem originConnectedSubregion_subset
    {inside : Region GridNode} {a : GridNode}
    (ha : a ∈ originConnectedSubregion inside) :
    a ∈ inside := by
  exact (mem_originConnectedSubregion_iff.1 ha).1

theorem originConnectedSubregion_subset_trans
    {inside Λ : Region GridNode} (hInsideΛ : inside ⊆ Λ) :
    originConnectedSubregion inside ⊆ Λ := by
  intro a ha
  exact hInsideΛ (originConnectedSubregion_subset ha)

theorem origin_mem_originConnectedSubregion
    {inside : Region GridNode} (horigin : gridOrigin ∈ inside) :
    gridOrigin ∈ originConnectedSubregion inside := by
  rw [mem_originConnectedSubregion_iff]
  exact ⟨horigin, Relation.ReflTransGen.refl⟩

theorem mem_originConnectedSubregion_of_mem_of_adj
    {inside : Region GridNode} {a b : GridNode}
    (ha : a ∈ originConnectedSubregion inside) (hb : b ∈ inside)
    (hadj : gridAdjacent a b) :
    b ∈ originConnectedSubregion inside := by
  rcases mem_originConnectedSubregion_iff.1 ha with ⟨haIn, hreach⟩
  rw [mem_originConnectedSubregion_iff]
  exact ⟨hb, Relation.ReflTransGen.tail hreach ⟨haIn, hb, hadj⟩⟩

/-- A finite region is origin-connected when every site in it is reachable from
the origin by a nearest-neighbour path that stays inside the region. -/
def OriginConnectedRegion (inside : Region GridNode) : Prop :=
  gridOrigin ∈ inside ∧
    ∀ a ∈ inside, Relation.ReflTransGen (gridAdjacentInRegion inside) gridOrigin a

/-- Rootless finite connectedness for grid regions. This is the induction
substrate for boundary-connectivity arguments where the removable vertex need
not preserve the distinguished origin. -/
def GridConnectedRegion (inside : Region GridNode) : Prop :=
  inside.Nonempty ∧
    ∀ a ∈ inside, ∀ b ∈ inside,
      Relation.ReflTransGen (gridAdjacentInRegion inside) a b

theorem OriginConnectedRegion.reachable_between
    {inside : Region GridNode} (hconn : OriginConnectedRegion inside)
    {a b : GridNode} (ha : a ∈ inside) (hb : b ∈ inside) :
    Relation.ReflTransGen (gridAdjacentInRegion inside) a b :=
  (reflTransGen_gridAdjacentInRegion_symm (hconn.2 a ha)).trans
    (hconn.2 b hb)

theorem OriginConnectedRegion.gridConnectedRegion
    {inside : Region GridNode} (hconn : OriginConnectedRegion inside) :
    GridConnectedRegion inside := by
  exact ⟨⟨gridOrigin, hconn.1⟩, fun a ha b hb =>
    hconn.reachable_between ha hb⟩

theorem GridConnectedRegion.gridAdjacentRegionGraph_connected
    {inside : Region GridNode} (hconn : GridConnectedRegion inside) :
    (gridAdjacentRegionGraph inside).Connected := by
  rcases hconn with ⟨hnonempty, hreach⟩
  rcases hnonempty with ⟨p, hp⟩
  refine gridAdjacentRegionGraph_connected_of_reflTransGen
    ⟨⟨p, hp⟩⟩ ?_
  intro a b
  exact reflTransGen_gridAdjacentInRegion_subtype a.2 b.2
    (hreach a.1 a.2 b.1 b.2)

theorem GridConnectedRegion.exists_gridAdjacent_partition_cross
    {inside : Region GridNode} (hconn : GridConnectedRegion inside)
    (U : GridNode → Prop)
    (hpos : ∃ a ∈ inside, U a)
    (hneg : ∃ b ∈ inside, ¬ U b) :
    ∃ a ∈ inside, ∃ b ∈ inside, U a ∧ ¬ U b ∧ gridAdjacent a b := by
  let R : {p // p ∈ inside} → {p // p ∈ inside} → Prop :=
    fun a b => gridAdjacent a.1 b.1
  have hconnSub :
      ∀ a b : {p // p ∈ inside}, Relation.ReflTransGen R a b := by
    intro a b
    exact reflTransGen_gridAdjacentInRegion_subtype a.2 b.2
      (hconn.2 a.1 a.2 b.1 b.2)
  rcases hpos with ⟨a, haInside, haU⟩
  rcases hneg with ⟨b, hbInside, hbU⟩
  rcases
    exists_rel_cross_of_reflTransGen_connected
      (R := R) hconnSub (fun p : {p // p ∈ inside} => U p.1)
      ⟨⟨a, haInside⟩, haU⟩ ⟨⟨b, hbInside⟩, hbU⟩ with
    ⟨x, y, hxU, hyU, hxy⟩
  exact ⟨x.1, x.2, y.1, y.2, hxU, hyU, hxy⟩

theorem GridConnectedRegion.exists_preconnected_delete_vertex
    {inside : Region GridNode} (hconn : GridConnectedRegion inside) :
    ∃ v : {p // p ∈ inside},
      ((gridAdjacentRegionGraph inside).induce
        ({v}ᶜ : Set {p // p ∈ inside})).Preconnected := by
  exact
    hconn.gridAdjacentRegionGraph_connected
      |>.exists_preconnected_induce_compl_singleton_of_finite

theorem GridConnectedRegion.exists_delete_vertex_gridAdjacentInRegion_preconnected
    {inside : Region GridNode} (hconn : GridConnectedRegion inside) :
    ∃ v : {p // p ∈ inside},
      ∀ {a b : GridNode},
        a ∈ inside.erase v.1 →
          b ∈ inside.erase v.1 →
            Relation.ReflTransGen
              (gridAdjacentInRegion (inside.erase v.1)) a b := by
  rcases hconn.exists_preconnected_delete_vertex with ⟨v, hpre⟩
  refine ⟨v, ?_⟩
  intro a b ha hb
  have haInside : a ∈ inside := (Finset.mem_erase.1 ha).2
  have hbInside : b ∈ inside := (Finset.mem_erase.1 hb).2
  have haNe : a ≠ v.1 := (Finset.mem_erase.1 ha).1
  have hbNe : b ≠ v.1 := (Finset.mem_erase.1 hb).1
  let av : ({v}ᶜ : Set {p // p ∈ inside}) := by
    refine ⟨⟨a, haInside⟩, ?_⟩
    rw [Set.mem_compl_iff, Set.mem_singleton_iff]
    intro hEq
    exact haNe (congrArg Subtype.val hEq)
  let bv : ({v}ᶜ : Set {p // p ∈ inside}) := by
    refine ⟨⟨b, hbInside⟩, ?_⟩
    rw [Set.mem_compl_iff, Set.mem_singleton_iff]
    intro hEq
    exact hbNe (congrArg Subtype.val hEq)
  have hreachGraph :
      ((gridAdjacentRegionGraph inside).induce
        ({v}ᶜ : Set {p // p ∈ inside})).Reachable av bv :=
    hpre av bv
  rw [SimpleGraph.reachable_eq_reflTransGen] at hreachGraph
  let f : ({v}ᶜ : Set {p // p ∈ inside}) → GridNode := fun x => x.1.1
  have hf :
      ∀ x y : ({v}ᶜ : Set {p // p ∈ inside}),
        ((gridAdjacentRegionGraph inside).induce
          ({v}ᶜ : Set {p // p ∈ inside})).Adj x y →
          gridAdjacentInRegion (inside.erase v.1) (f x) (f y) := by
    intro x y hxy
    have hxNeSub : x.1 ≠ v := by
      intro hxEq
      exact x.2 (by simpa [Set.mem_singleton_iff] using hxEq)
    have hyNeSub : y.1 ≠ v := by
      intro hyEq
      exact y.2 (by simpa [Set.mem_singleton_iff] using hyEq)
    have hxErase : x.1.1 ∈ inside.erase v.1 := by
      rw [Finset.mem_erase]
      exact ⟨fun hxEq => hxNeSub (Subtype.ext hxEq), x.1.2⟩
    have hyErase : y.1.1 ∈ inside.erase v.1 := by
      rw [Finset.mem_erase]
      exact ⟨fun hyEq => hyNeSub (Subtype.ext hyEq), y.1.2⟩
    have hxyBase : (gridAdjacentRegionGraph inside).Adj x.1 y.1 :=
      (SimpleGraph.induce_adj).1 hxy
    have hxyGrid : gridAdjacent x.1.1 y.1.1 := by
      rw [gridAdjacentRegionGraph, SimpleGraph.fromEdgeSet_adj] at hxyBase
      simpa [gridAdjacentRegionRel, Sym2.toRel_fromRel] using hxyBase.1
    exact ⟨hxErase, hyErase, hxyGrid⟩
  have hreach :=
    Relation.ReflTransGen.lift
      (p := gridAdjacentInRegion (inside.erase v.1)) f hf hreachGraph
  simpa [f, av, bv] using hreach

theorem GridConnectedRegion.exists_delete_vertex_gridConnectedRegion
    {inside : Region GridNode} (hconn : GridConnectedRegion inside)
    (hcard : 1 < inside.card) :
    ∃ v : {p // p ∈ inside}, GridConnectedRegion (inside.erase v.1) := by
  rcases hconn.exists_delete_vertex_gridAdjacentInRegion_preconnected with
    ⟨v, hpre⟩
  have hcardErase : 0 < (inside.erase v.1).card := by
    rw [Finset.card_erase_of_mem v.2]
    omega
  have hnonempty : (inside.erase v.1).Nonempty :=
    Finset.card_pos.1 hcardErase
  exact ⟨v, hnonempty, fun a ha b hb => hpre ha hb⟩

theorem GridConnectedRegion.exists_delete_vertex_gridConnectedRegion_adjacent_remaining
    {inside : Region GridNode} (hconn : GridConnectedRegion inside)
    (hcard : 1 < inside.card) :
    ∃ v : {p // p ∈ inside},
      GridConnectedRegion (inside.erase v.1) ∧
        ∃ u ∈ inside.erase v.1, gridAdjacent v.1 u := by
  rcases hconn.exists_delete_vertex_gridAdjacentInRegion_preconnected with
    ⟨v, hpre⟩
  have hcardErase : 0 < (inside.erase v.1).card := by
    rw [Finset.card_erase_of_mem v.2]
    omega
  have hnonemptyErase : (inside.erase v.1).Nonempty :=
    Finset.card_pos.1 hcardErase
  have hconnErase : GridConnectedRegion (inside.erase v.1) :=
    ⟨hnonemptyErase, fun a ha b hb => hpre ha hb⟩
  haveI : Nontrivial {p // p ∈ inside} := by
    rcases (Finset.one_lt_card_iff_nontrivial.1 hcard) with
      ⟨a, ha, b, hb, hab⟩
    exact ⟨⟨⟨a, ha⟩, ⟨b, hb⟩, fun h => hab (congrArg Subtype.val h)⟩⟩
  rcases
    hconn.gridAdjacentRegionGraph_connected.preconnected.exists_adj_of_nontrivial v with
    ⟨u, hvuGraph⟩
  have hvu : gridAdjacent v.1 u.1 := by
    rw [gridAdjacentRegionGraph, SimpleGraph.fromEdgeSet_adj] at hvuGraph
    simpa [gridAdjacentRegionRel, Sym2.toRel_fromRel] using hvuGraph.1
  have huErase : u.1 ∈ inside.erase v.1 := by
    rw [Finset.mem_erase]
    exact ⟨fun huv => hvuGraph.ne (Subtype.ext huv.symm), u.2⟩
  exact ⟨v, hconnErase, u.1, huErase, hvu⟩

theorem OriginConnectedRegion.exists_gridAdjacent_partition_cross
    {inside : Region GridNode} (hconn : OriginConnectedRegion inside)
    (U : GridNode → Prop)
    (hpos : ∃ a ∈ inside, U a)
    (hneg : ∃ b ∈ inside, ¬ U b) :
    ∃ a ∈ inside, ∃ b ∈ inside, U a ∧ ¬ U b ∧ gridAdjacent a b := by
  let R : {p // p ∈ inside} → {p // p ∈ inside} → Prop :=
    fun a b => gridAdjacent a.1 b.1
  have hconnSub :
      ∀ a b : {p // p ∈ inside}, Relation.ReflTransGen R a b := by
    intro a b
    exact reflTransGen_gridAdjacentInRegion_subtype a.2 b.2
      (hconn.reachable_between a.2 b.2)
  rcases hpos with ⟨a, haInside, haU⟩
  rcases hneg with ⟨b, hbInside, hbU⟩
  rcases
    exists_rel_cross_of_reflTransGen_connected
      (R := R) hconnSub (fun p : {p // p ∈ inside} => U p.1)
      ⟨⟨a, haInside⟩, haU⟩ ⟨⟨b, hbInside⟩, hbU⟩ with
    ⟨x, y, hxU, hyU, hxy⟩
  exact ⟨x.1, x.2, y.1, y.2, hxU, hyU, hxy⟩

theorem OriginConnectedRegion.gridAdjacentRegionGraph_connected
    {inside : Region GridNode} (hconn : OriginConnectedRegion inside) :
    (gridAdjacentRegionGraph inside).Connected := by
  refine gridAdjacentRegionGraph_connected_of_reflTransGen
    ⟨⟨gridOrigin, hconn.1⟩⟩ ?_
  intro a b
  exact reflTransGen_gridAdjacentInRegion_subtype a.2 b.2
    (hconn.reachable_between a.2 b.2)

theorem OriginConnectedRegion.exists_preconnected_delete_vertex
    {inside : Region GridNode} (hconn : OriginConnectedRegion inside) :
    ∃ v : {p // p ∈ inside},
      ((gridAdjacentRegionGraph inside).induce
        ({v}ᶜ : Set {p // p ∈ inside})).Preconnected := by
  exact
    hconn.gridAdjacentRegionGraph_connected
      |>.exists_preconnected_induce_compl_singleton_of_finite

theorem OriginConnectedRegion.exists_delete_vertex_gridAdjacentInRegion_preconnected
    {inside : Region GridNode} (hconn : OriginConnectedRegion inside) :
    ∃ v : {p // p ∈ inside},
      ∀ {a b : GridNode},
        a ∈ inside.erase v.1 →
          b ∈ inside.erase v.1 →
            Relation.ReflTransGen
              (gridAdjacentInRegion (inside.erase v.1)) a b := by
  rcases hconn.exists_preconnected_delete_vertex with ⟨v, hpre⟩
  refine ⟨v, ?_⟩
  intro a b ha hb
  have haInside : a ∈ inside := (Finset.mem_erase.1 ha).2
  have hbInside : b ∈ inside := (Finset.mem_erase.1 hb).2
  have haNe : a ≠ v.1 := (Finset.mem_erase.1 ha).1
  have hbNe : b ≠ v.1 := (Finset.mem_erase.1 hb).1
  let av : ({v}ᶜ : Set {p // p ∈ inside}) := by
    refine ⟨⟨a, haInside⟩, ?_⟩
    rw [Set.mem_compl_iff, Set.mem_singleton_iff]
    intro hEq
    exact haNe (congrArg Subtype.val hEq)
  let bv : ({v}ᶜ : Set {p // p ∈ inside}) := by
    refine ⟨⟨b, hbInside⟩, ?_⟩
    rw [Set.mem_compl_iff, Set.mem_singleton_iff]
    intro hEq
    exact hbNe (congrArg Subtype.val hEq)
  have hreachGraph :
      ((gridAdjacentRegionGraph inside).induce
        ({v}ᶜ : Set {p // p ∈ inside})).Reachable av bv :=
    hpre av bv
  rw [SimpleGraph.reachable_eq_reflTransGen] at hreachGraph
  let f : ({v}ᶜ : Set {p // p ∈ inside}) → GridNode := fun x => x.1.1
  have hf :
      ∀ x y : ({v}ᶜ : Set {p // p ∈ inside}),
        ((gridAdjacentRegionGraph inside).induce
          ({v}ᶜ : Set {p // p ∈ inside})).Adj x y →
          gridAdjacentInRegion (inside.erase v.1) (f x) (f y) := by
    intro x y hxy
    have hxNeSub : x.1 ≠ v := by
      intro hxEq
      exact x.2 (by simpa [Set.mem_singleton_iff] using hxEq)
    have hyNeSub : y.1 ≠ v := by
      intro hyEq
      exact y.2 (by simpa [Set.mem_singleton_iff] using hyEq)
    have hxErase : x.1.1 ∈ inside.erase v.1 := by
      rw [Finset.mem_erase]
      exact ⟨fun hxEq => hxNeSub (Subtype.ext hxEq), x.1.2⟩
    have hyErase : y.1.1 ∈ inside.erase v.1 := by
      rw [Finset.mem_erase]
      exact ⟨fun hyEq => hyNeSub (Subtype.ext hyEq), y.1.2⟩
    have hxyBase : (gridAdjacentRegionGraph inside).Adj x.1 y.1 :=
      (SimpleGraph.induce_adj).1 hxy
    have hxyGrid : gridAdjacent x.1.1 y.1.1 := by
      rw [gridAdjacentRegionGraph, SimpleGraph.fromEdgeSet_adj] at hxyBase
      simpa [gridAdjacentRegionRel, Sym2.toRel_fromRel] using hxyBase.1
    exact ⟨hxErase, hyErase, hxyGrid⟩
  have hreach :=
    Relation.ReflTransGen.lift
      (p := gridAdjacentInRegion (inside.erase v.1)) f hf hreachGraph
  simpa [f, av, bv] using hreach

theorem originConnectedSubregion_originConnected
    {inside : Region GridNode} (horigin : gridOrigin ∈ inside) :
    OriginConnectedRegion (originConnectedSubregion inside) := by
  refine ⟨origin_mem_originConnectedSubregion horigin, ?_⟩
  intro a ha
  rcases mem_originConnectedSubregion_iff.1 ha with ⟨_, hreach⟩
  have hlift :
      ∀ {b : GridNode},
        Relation.ReflTransGen (gridAdjacentInRegion inside) gridOrigin b →
          b ∈ originConnectedSubregion inside →
            Relation.ReflTransGen
              (gridAdjacentInRegion (originConnectedSubregion inside))
              gridOrigin b := by
    intro b hreach
    induction hreach with
    | refl =>
        intro _
        exact Relation.ReflTransGen.refl
    | @tail b c hreach hstep ih =>
        intro hcComp
        have hbComp : b ∈ originConnectedSubregion inside := by
          rw [mem_originConnectedSubregion_iff]
          exact ⟨hstep.1, hreach⟩
        exact Relation.ReflTransGen.tail (ih hbComp) ⟨hbComp, hcComp, hstep.2.2⟩
  exact hlift hreach ha

theorem exists_mem_row_of_reach
    {inside : Region GridNode} (horigin : gridOrigin ∈ inside)
    {a : GridNode}
    (hreach : Relation.ReflTransGen (gridAdjacentInRegion inside) gridOrigin a) :
    ∀ k ≤ a.2, ∃ i, (i, k) ∈ inside := by
  induction hreach with
  | refl =>
      intro k hk
      have hk0 : k = 0 := by
        simpa [gridOrigin] using hk
      subst hk0
      exact ⟨0, horigin⟩
  | @tail b c hreach hstep ih =>
      intro k hk
      rcases hstep with ⟨hbIn, hcIn, hadj⟩
      rcases hadj with h | h | h | h
      · have hEq : c.2 = b.2 := by omega
        have hk' : k ≤ b.2 := by omega
        rcases ih k hk' with ⟨i, hi⟩
        exact ⟨i, hi⟩
      · have hEq : c.2 = b.2 := by omega
        have hk' : k ≤ b.2 := by omega
        rcases ih k hk' with ⟨i, hi⟩
        exact ⟨i, hi⟩
      · by_cases hkc : k = c.2
        · exact ⟨c.1, by simpa [hkc] using hcIn⟩
        · have hk' : k ≤ b.2 := by omega
          rcases ih k hk' with ⟨i, hi⟩
          exact ⟨i, hi⟩
      · have hk' : k ≤ b.2 := by omega
        rcases ih k hk' with ⟨i, hi⟩
        exact ⟨i, hi⟩

theorem exists_mem_col_of_reach
    {inside : Region GridNode} (horigin : gridOrigin ∈ inside)
    {a : GridNode}
    (hreach : Relation.ReflTransGen (gridAdjacentInRegion inside) gridOrigin a) :
    ∀ k ≤ a.1, ∃ j, (k, j) ∈ inside := by
  induction hreach with
  | refl =>
      intro k hk
      have hk0 : k = 0 := by
        simpa [gridOrigin] using hk
      subst hk0
      exact ⟨0, horigin⟩
  | @tail b c hreach hstep ih =>
      intro k hk
      rcases hstep with ⟨hbIn, hcIn, hadj⟩
      rcases hadj with h | h | h | h
      · by_cases hkc : k = c.1
        · exact ⟨c.2, by simpa [hkc] using hcIn⟩
        · have hk' : k ≤ b.1 := by omega
          rcases ih k hk' with ⟨j, hj⟩
          exact ⟨j, hj⟩
      · have hk' : k ≤ b.1 := by omega
        rcases ih k hk' with ⟨j, hj⟩
        exact ⟨j, hj⟩
      · have hk' : k ≤ b.1 := by omega
        rcases ih k hk' with ⟨j, hj⟩
        exact ⟨j, hj⟩
      · have hk' : k ≤ b.1 := by omega
        rcases ih k hk' with ⟨j, hj⟩
        exact ⟨j, hj⟩

theorem exists_mem_row_of_originConnected
    {inside : Region GridNode} (hconn : OriginConnectedRegion inside)
    {a : GridNode} (ha : a ∈ inside) :
    ∀ k ≤ a.2, ∃ i, (i, k) ∈ inside := by
  exact exists_mem_row_of_reach hconn.1 (hconn.2 a ha)

theorem exists_mem_col_of_originConnected
    {inside : Region GridNode} (hconn : OriginConnectedRegion inside)
    {a : GridNode} (ha : a ∈ inside) :
    ∀ k ≤ a.1, ∃ j, (k, j) ∈ inside := by
  exact exists_mem_col_of_reach hconn.1 (hconn.2 a ha)

theorem falseInside_trueCutBoundaryRegion_originConnectedSubregion
    {Λ : Region GridNode} {inside : Region GridNode} {hInsideΛ : inside ⊆ Λ}
    {x : LocalAssignment GridNode Λ} {ξ : BoundaryCondition GridNode}
    (hsep : FalseInsideTrueCutBoundaryRegion inside hInsideΛ x ξ) :
    FalseInsideTrueCutBoundaryRegion
      (originConnectedSubregion inside)
      (originConnectedSubregion_subset_trans hInsideΛ)
      x ξ := by
  rcases hsep with ⟨hinsideFalse, hcutTrue⟩
  refine ⟨?_, ?_⟩
  · intro a ha
    exact hinsideFalse a (originConnectedSubregion_subset ha)
  · intro j hj
    have hjSupport : j ∈ gridRegionSupport Λ := (Finset.mem_filter.mp hj).1
    have hjCutComp :
        gridBaseClauseCutsRegion (originConnectedSubregion inside) j :=
      (Finset.mem_filter.mp hj).2
    cases j with
    | prior i j =>
        trivial
    | horizontal i j =>
        refine ⟨?_, ?_⟩
        · intro hLeftComp
          have hRightNotComp : (i + 1, j) ∉ originConnectedSubregion inside := by
            intro hRightComp
            rcases hjCutComp with hcut | hcut
            · exact hcut.2 hRightComp
            · exact hcut.1 hLeftComp
          have hLeftIn : (i, j) ∈ inside := originConnectedSubregion_subset hLeftComp
          have hRightNotIn : (i + 1, j) ∉ inside := by
            intro hRightIn
            have hRightComp :
                (i + 1, j) ∈ originConnectedSubregion inside :=
              mem_originConnectedSubregion_of_mem_of_adj
                hLeftComp hRightIn (gridAdjacent_horizontal_forward i j)
            exact hRightNotComp hRightComp
          have hjInside :
              GridClauseId.horizontal i j ∈
                (gridRegionSupport Λ).filter (gridBaseClauseCutsRegion inside) := by
            exact Finset.mem_filter.mpr ⟨hjSupport, Or.inl ⟨hLeftIn, hRightNotIn⟩⟩
          exact (hcutTrue _ hjInside).1 hLeftIn
        · intro hRightComp
          have hLeftNotComp : (i, j) ∉ originConnectedSubregion inside := by
            intro hLeftComp
            rcases hjCutComp with hcut | hcut
            · exact hcut.2 hRightComp
            · exact hcut.1 hLeftComp
          have hRightIn : (i + 1, j) ∈ inside := originConnectedSubregion_subset hRightComp
          have hLeftNotIn : (i, j) ∉ inside := by
            intro hLeftIn
            have hLeftComp :
                (i, j) ∈ originConnectedSubregion inside :=
              mem_originConnectedSubregion_of_mem_of_adj
                hRightComp hLeftIn (gridAdjacent_horizontal_backward i j)
            exact hLeftNotComp hLeftComp
          have hjInside :
              GridClauseId.horizontal i j ∈
                (gridRegionSupport Λ).filter (gridBaseClauseCutsRegion inside) := by
            exact Finset.mem_filter.mpr ⟨hjSupport, Or.inr ⟨hLeftNotIn, hRightIn⟩⟩
          exact (hcutTrue _ hjInside).2 hRightIn
    | vertical i j =>
        refine ⟨?_, ?_⟩
        · intro hDownComp
          have hUpNotComp : (i, j + 1) ∉ originConnectedSubregion inside := by
            intro hUpComp
            rcases hjCutComp with hcut | hcut
            · exact hcut.2 hUpComp
            · exact hcut.1 hDownComp
          have hDownIn : (i, j) ∈ inside := originConnectedSubregion_subset hDownComp
          have hUpNotIn : (i, j + 1) ∉ inside := by
            intro hUpIn
            have hUpComp :
                (i, j + 1) ∈ originConnectedSubregion inside :=
              mem_originConnectedSubregion_of_mem_of_adj
                hDownComp hUpIn (gridAdjacent_vertical_forward i j)
            exact hUpNotComp hUpComp
          have hjInside :
              GridClauseId.vertical i j ∈
                (gridRegionSupport Λ).filter (gridBaseClauseCutsRegion inside) := by
            exact Finset.mem_filter.mpr ⟨hjSupport, Or.inl ⟨hDownIn, hUpNotIn⟩⟩
          exact (hcutTrue _ hjInside).1 hDownIn
        · intro hUpComp
          have hDownNotComp : (i, j) ∉ originConnectedSubregion inside := by
            intro hDownComp
            rcases hjCutComp with hcut | hcut
            · exact hcut.2 hUpComp
            · exact hcut.1 hDownComp
          have hUpIn : (i, j + 1) ∈ inside := originConnectedSubregion_subset hUpComp
          have hDownNotIn : (i, j) ∉ inside := by
            intro hDownIn
            have hDownComp :
                (i, j) ∈ originConnectedSubregion inside :=
              mem_originConnectedSubregion_of_mem_of_adj
                hUpComp hDownIn (gridAdjacent_vertical_backward i j)
            exact hDownNotComp hDownComp
          have hjInside :
              GridClauseId.vertical i j ∈
                (gridRegionSupport Λ).filter (gridBaseClauseCutsRegion inside) := by
            exact Finset.mem_filter.mpr ⟨hjSupport, Or.inr ⟨hDownNotIn, hUpIn⟩⟩
          exact (hcutTrue _ hjInside).2 hUpIn

theorem falseInside_trueCutBoundaryRegion_patchedFalseRegion_gridPlusBoundary
    {Λ : Region GridNode}
    (x : LocalAssignment GridNode Λ) :
    FalseInsideTrueCutBoundaryRegion
      (patchedFalseRegion x gridPlusBoundary)
      (patchedFalseRegion_subset x gridPlusBoundary)
      x gridPlusBoundary := by
  refine ⟨?_, ?_⟩
  · intro a ha
    exact (mem_patchedFalseRegion_iff x gridPlusBoundary a).1 ha |>.2
  · intro j hj
    have hjcut :
        gridBaseClauseCutsRegion (patchedFalseRegion x gridPlusBoundary) j :=
      (Finset.mem_filter.mp hj).2
    cases j with
    | prior i j =>
        trivial
    | horizontal i j =>
        refine ⟨?_, ?_⟩
        · intro hLeftIn
          by_cases hRightΛ : (i + 1, j) ∈ Λ
          · cases hRightSpin : patch Λ x gridPlusBoundary (i + 1, j) <;> simp at hRightSpin ⊢
            have hRightIn : (i + 1, j) ∈ patchedFalseRegion x gridPlusBoundary := by
              exact (mem_patchedFalseRegion_iff x gridPlusBoundary (i + 1, j)).2
                ⟨hRightΛ, hRightSpin⟩
            rcases hjcut with hcut | hcut
            · exact False.elim (hcut.2 hRightIn)
            · exact False.elim (hcut.1 hLeftIn)
          · simp [patch, hRightΛ, gridPlusBoundary]
        · intro hRightIn
          by_cases hLeftΛ : (i, j) ∈ Λ
          · cases hLeftSpin : patch Λ x gridPlusBoundary (i, j) <;> simp at hLeftSpin ⊢
            have hLeftIn : (i, j) ∈ patchedFalseRegion x gridPlusBoundary := by
              exact (mem_patchedFalseRegion_iff x gridPlusBoundary (i, j)).2
                ⟨hLeftΛ, hLeftSpin⟩
            rcases hjcut with hcut | hcut
            · exact False.elim (hcut.2 hRightIn)
            · exact False.elim (hcut.1 hLeftIn)
          · simp [patch, hLeftΛ, gridPlusBoundary]
    | vertical i j =>
        refine ⟨?_, ?_⟩
        · intro hDownIn
          by_cases hUpΛ : (i, j + 1) ∈ Λ
          · cases hUpSpin : patch Λ x gridPlusBoundary (i, j + 1) <;> simp at hUpSpin ⊢
            have hUpIn : (i, j + 1) ∈ patchedFalseRegion x gridPlusBoundary := by
              exact (mem_patchedFalseRegion_iff x gridPlusBoundary (i, j + 1)).2
                ⟨hUpΛ, hUpSpin⟩
            rcases hjcut with hcut | hcut
            · exact False.elim (hcut.2 hUpIn)
            · exact False.elim (hcut.1 hDownIn)
          · simp [patch, hUpΛ, gridPlusBoundary]
        · intro hUpIn
          by_cases hDownΛ : (i, j) ∈ Λ
          · cases hDownSpin : patch Λ x gridPlusBoundary (i, j) <;> simp at hDownSpin ⊢
            have hDownIn : (i, j) ∈ patchedFalseRegion x gridPlusBoundary := by
              exact (mem_patchedFalseRegion_iff x gridPlusBoundary (i, j)).2
                ⟨hDownΛ, hDownSpin⟩
            rcases hjcut with hcut | hcut
            · exact False.elim (hcut.2 hUpIn)
            · exact False.elim (hcut.1 hDownIn)
          · simp [patch, hDownΛ, gridPlusBoundary]

theorem exists_falseInside_trueCutBoundaryRegion_of_plusBoundary_originFalse
    {n : ℕ}
    (x : LocalAssignment GridNode (gridExhaustion.region n))
    (horigin :
      patch (gridExhaustion.region n) x gridPlusBoundary gridOrigin = false) :
    ∃ inside : Region GridNode,
      ∃ hInside : inside ⊆ gridExhaustion.region n,
        gridOrigin ∈ inside ∧
          FalseInsideTrueCutBoundaryRegion inside hInside x gridPlusBoundary := by
  refine ⟨patchedFalseRegion x gridPlusBoundary, patchedFalseRegion_subset x gridPlusBoundary, ?_, ?_⟩
  · exact (mem_patchedFalseRegion_iff x gridPlusBoundary gridOrigin).2
      ⟨gridOrigin_mem_gridExhaustion_region n, horigin⟩
  · exact falseInside_trueCutBoundaryRegion_patchedFalseRegion_gridPlusBoundary x

theorem exists_originConnected_falseInside_trueCutBoundaryRegion_of_plusBoundary_originFalse
    {n : ℕ}
    (x : LocalAssignment GridNode (gridExhaustion.region n))
    (horigin :
      patch (gridExhaustion.region n) x gridPlusBoundary gridOrigin = false) :
    ∃ inside : Region GridNode,
      ∃ hInside : inside ⊆ gridExhaustion.region n,
        OriginConnectedRegion inside ∧
          FalseInsideTrueCutBoundaryRegion inside hInside x gridPlusBoundary := by
  let full := patchedFalseRegion x gridPlusBoundary
  have hfullOrigin : gridOrigin ∈ full := by
    exact (mem_patchedFalseRegion_iff x gridPlusBoundary gridOrigin).2
      ⟨gridOrigin_mem_gridExhaustion_region n, horigin⟩
  have hfullSep :
      FalseInsideTrueCutBoundaryRegion full (patchedFalseRegion_subset x gridPlusBoundary)
        x gridPlusBoundary :=
    falseInside_trueCutBoundaryRegion_patchedFalseRegion_gridPlusBoundary x
  refine ⟨originConnectedSubregion full,
    originConnectedSubregion_subset_trans (patchedFalseRegion_subset x gridPlusBoundary), ?_, ?_⟩
  · exact originConnectedSubregion_originConnected hfullOrigin
  · exact falseInside_trueCutBoundaryRegion_originConnectedSubregion hfullSep

/-- All finite subregions of the stage box that contain the origin. This is the
finite witness family for the first Peierls union-bound reduction. -/
noncomputable def originContainingSubregions (n : ℕ) : Finset (Region GridNode) :=
  (gridExhaustion.region n).powerset.filter (fun inside => gridOrigin ∈ inside)

/-- The finite family of stage-box subregions that contain the origin and are
connected to it by nearest-neighbour paths inside the region. -/
noncomputable def originConnectedContainingSubregions (n : ℕ) : Finset (Region GridNode) :=
  by
    classical
    exact (originContainingSubregions n).filter OriginConnectedRegion

theorem mem_originContainingSubregions_iff
    {n : ℕ} {inside : Region GridNode} :
    inside ∈ originContainingSubregions n ↔
      inside ⊆ gridExhaustion.region n ∧ gridOrigin ∈ inside := by
  simp [originContainingSubregions, Finset.mem_powerset]

theorem mem_originConnectedContainingSubregions_iff
    {n : ℕ} {inside : Region GridNode} :
    inside ∈ originConnectedContainingSubregions n ↔
      inside ⊆ gridExhaustion.region n ∧ OriginConnectedRegion inside := by
  classical
  constructor
  · intro h
    rw [originConnectedContainingSubregions] at h
    have hfilter := Finset.mem_filter.mp h
    rcases (mem_originContainingSubregions_iff.1 hfilter.1) with ⟨hInside, hOrigin⟩
    rcases hfilter.2 with ⟨_, hconn⟩
    exact ⟨hInside, ⟨hOrigin, hconn⟩⟩
  · intro h
    rcases h with ⟨hInside, hconn⟩
    rcases hconn with ⟨hOrigin, hreach⟩
    rw [originConnectedContainingSubregions]
    exact Finset.mem_filter.mpr
      ⟨(mem_originContainingSubregions_iff.2 ⟨hInside, hOrigin⟩), ⟨hOrigin, hreach⟩⟩

/-- The top/right boundary strip of the `n`-th square stage box. -/
noncomputable def gridStageBoundaryRegion (n : ℕ) : Region GridNode :=
  (gridExhaustion.region n).filter (fun a => a.1 = n ∨ a.2 = n)

theorem mem_gridStageBoundaryRegion_iff
    {n : ℕ} {a : GridNode} :
    a ∈ gridStageBoundaryRegion n ↔
      a ∈ gridExhaustion.region n ∧ (a.1 = n ∨ a.2 = n) := by
  simp [gridStageBoundaryRegion]

theorem gridStageBoundaryRegion_reachable_to_corner
    {n : ℕ} {a : GridNode}
    (ha : a ∈ gridStageBoundaryRegion n) :
    Relation.ReflTransGen
      (gridAdjacentInRegion (gridStageBoundaryRegion n)) a (n, n) := by
  rcases a with ⟨i, j⟩
  rcases mem_gridStageBoundaryRegion_iff.1 ha with ⟨haStage, hside⟩
  rcases Finset.mem_product.1 haStage with ⟨hiRange, hjRange⟩
  have hiLe : i ≤ n :=
    Nat.le_of_lt_succ (Finset.mem_range.mp hiRange)
  have hjLe : j ≤ n :=
    Nat.le_of_lt_succ (Finset.mem_range.mp hjRange)
  let R := gridAdjacentInRegion (gridStageBoundaryRegion n)
  have hright :
      ∀ d j, n - j = d → j ≤ n →
        Relation.ReflTransGen R (n, j) (n, n) := by
    intro d
    induction d with
    | zero =>
        intro j hdj hj
        have hjEq : j = n := by omega
        subst hjEq
        exact Relation.ReflTransGen.refl
    | succ d ih =>
        intro j hdj hj
        have hjLt : j < n := by omega
        have hj1 : j + 1 ≤ n := Nat.succ_le_of_lt hjLt
        have hstep : R (n, j) (n, j + 1) := by
          dsimp [R, gridAdjacentInRegion]
          refine ⟨?_, ?_, gridAdjacent_vertical_forward n j⟩
          · rw [mem_gridStageBoundaryRegion_iff]
            constructor
            · exact Finset.mem_product.mpr
                ⟨Finset.mem_range.mpr (Nat.lt_succ_self n),
                 Finset.mem_range.mpr (lt_of_le_of_lt hj (Nat.lt_succ_self n))⟩
            · exact Or.inl rfl
          · rw [mem_gridStageBoundaryRegion_iff]
            constructor
            · exact Finset.mem_product.mpr
                ⟨Finset.mem_range.mpr (Nat.lt_succ_self n),
                 Finset.mem_range.mpr
                  (lt_of_le_of_lt hj1 (Nat.lt_succ_self n))⟩
            · exact Or.inl rfl
        exact Relation.ReflTransGen.head hstep
          (ih (j + 1) (by omega) hj1)
  have htop :
      ∀ d i, n - i = d → i ≤ n →
        Relation.ReflTransGen R (i, n) (n, n) := by
    intro d
    induction d with
    | zero =>
        intro i hdi hi
        have hiEq : i = n := by omega
        subst hiEq
        exact Relation.ReflTransGen.refl
    | succ d ih =>
        intro i hdi hi
        have hiLt : i < n := by omega
        have hi1 : i + 1 ≤ n := Nat.succ_le_of_lt hiLt
        have hstep : R (i, n) (i + 1, n) := by
          dsimp [R, gridAdjacentInRegion]
          refine ⟨?_, ?_, gridAdjacent_horizontal_forward i n⟩
          · rw [mem_gridStageBoundaryRegion_iff]
            constructor
            · exact Finset.mem_product.mpr
                ⟨Finset.mem_range.mpr (lt_of_le_of_lt hi (Nat.lt_succ_self n)),
                 Finset.mem_range.mpr (Nat.lt_succ_self n)⟩
            · exact Or.inr rfl
          · rw [mem_gridStageBoundaryRegion_iff]
            constructor
            · exact Finset.mem_product.mpr
                ⟨Finset.mem_range.mpr
                  (lt_of_le_of_lt hi1 (Nat.lt_succ_self n)),
                 Finset.mem_range.mpr (Nat.lt_succ_self n)⟩
            · exact Or.inr rfl
        exact Relation.ReflTransGen.head hstep
          (ih (i + 1) (by omega) hi1)
  rcases hside with hiEq | hjEq
  · have hiEq' : i = n := by simpa using hiEq
    subst i
    exact hright (n - j) j rfl hjLe
  · have hjEq' : j = n := by simpa using hjEq
    subst j
    exact htop (n - i) i rfl hiLe

theorem gridStageBoundaryRegion_gridAdjacentInRegion_connected
    {n : ℕ} {a b : GridNode}
    (ha : a ∈ gridStageBoundaryRegion n)
    (hb : b ∈ gridStageBoundaryRegion n) :
    Relation.ReflTransGen
      (gridAdjacentInRegion (gridStageBoundaryRegion n)) a b := by
  exact (gridStageBoundaryRegion_reachable_to_corner ha).trans
    (reflTransGen_gridAdjacentInRegion_symm
      (gridStageBoundaryRegion_reachable_to_corner hb))

/-- The complement of an inside witness, restricted to the finite stage box. -/
noncomputable def outsideRegionInStage (n : ℕ) (inside : Region GridNode) : Region GridNode :=
  (gridExhaustion.region n).filter (fun a => a ∉ inside)

theorem mem_outsideRegionInStage_iff
    {n : ℕ} {inside : Region GridNode} {a : GridNode} :
    a ∈ outsideRegionInStage n inside ↔
      a ∈ gridExhaustion.region n ∧ a ∉ inside := by
  simp [outsideRegionInStage]

theorem outsideRegionInStage_subset_of_subset
    {n : ℕ} {inside₁ inside₂ : Region GridNode}
    (hsub : inside₁ ⊆ inside₂) :
    outsideRegionInStage n inside₂ ⊆ outsideRegionInStage n inside₁ := by
  intro a ha
  rw [mem_outsideRegionInStage_iff] at ha ⊢
  exact ⟨ha.1, fun haInside₁ => ha.2 (hsub haInside₁)⟩

/-- The part of the stage-box complement that is connected to the box boundary.
This is the honest “exterior component” used to ignore interior holes. -/
noncomputable def boundaryConnectedOutsideSubregion
    (n : ℕ) (inside : Region GridNode) : Region GridNode := by
  classical
  let outside := outsideRegionInStage n inside
  exact outside.filter (fun a =>
    ∃ b ∈ gridStageBoundaryRegion n, b ∈ outside ∧
      Relation.ReflTransGen (gridAdjacentInRegion outside) b a)

theorem mem_boundaryConnectedOutsideSubregion_iff
    {n : ℕ} {inside : Region GridNode} {a : GridNode} :
    a ∈ boundaryConnectedOutsideSubregion n inside ↔
      a ∈ outsideRegionInStage n inside ∧
        ∃ b ∈ gridStageBoundaryRegion n, b ∈ outsideRegionInStage n inside ∧
          Relation.ReflTransGen
            (gridAdjacentInRegion (outsideRegionInStage n inside)) b a := by
  classical
  simp [boundaryConnectedOutsideSubregion, outsideRegionInStage]

theorem boundaryConnectedOutsideSubregion_subset_of_subset
    {n : ℕ} {inside₁ inside₂ : Region GridNode}
    (hsub : inside₁ ⊆ inside₂) :
    boundaryConnectedOutsideSubregion n inside₂ ⊆
      boundaryConnectedOutsideSubregion n inside₁ := by
  intro a ha
  rcases mem_boundaryConnectedOutsideSubregion_iff.1 ha with
    ⟨haOut₂, b, hbBoundary, hbOut₂, hreach₂⟩
  have houtsideSub :
      outsideRegionInStage n inside₂ ⊆ outsideRegionInStage n inside₁ :=
    outsideRegionInStage_subset_of_subset hsub
  have hreach₁ :
      Relation.ReflTransGen
        (gridAdjacentInRegion (outsideRegionInStage n inside₁)) b a :=
    reflTransGen_gridAdjacentInRegion_mono houtsideSub hreach₂
  rw [mem_boundaryConnectedOutsideSubregion_iff]
  exact ⟨houtsideSub haOut₂, b, hbBoundary, houtsideSub hbOut₂, hreach₁⟩

theorem boundaryConnectedOutsideSubregion_subset_stage
    {n : ℕ} {inside : Region GridNode} :
    boundaryConnectedOutsideSubregion n inside ⊆ gridExhaustion.region n := by
  intro a ha
  exact (mem_outsideRegionInStage_iff.1
    (mem_boundaryConnectedOutsideSubregion_iff.1 ha).1).1

theorem boundaryConnectedOutsideSubregion_not_mem_inside
    {n : ℕ} {inside : Region GridNode} {a : GridNode}
    (ha : a ∈ boundaryConnectedOutsideSubregion n inside) :
    a ∉ inside := by
  exact (mem_outsideRegionInStage_iff.1
    (mem_boundaryConnectedOutsideSubregion_iff.1 ha).1).2

/-- The exterior sites visible from a hull: points in the boundary-connected
outside component that touch the hull by a nearest-neighbour edge. -/
noncomputable def visibleOuterBoundary
    (n : ℕ) (hull : Region GridNode) : Region GridNode := by
  classical
  exact (boundaryConnectedOutsideSubregion n hull).filter
    (fun p => ∃ q ∈ hull, gridAdjacent p q)

theorem mem_visibleOuterBoundary_iff
    {n : ℕ} {hull : Region GridNode} {p : GridNode} :
    p ∈ visibleOuterBoundary n hull ↔
      p ∈ boundaryConnectedOutsideSubregion n hull ∧
        ∃ q ∈ hull, gridAdjacent p q := by
  classical
  simp [visibleOuterBoundary]

theorem visibleOuterBoundary_not_mem_hull
    {n : ℕ} {hull : Region GridNode} {p : GridNode}
    (hp : p ∈ visibleOuterBoundary n hull) :
    p ∉ hull :=
  boundaryConnectedOutsideSubregion_not_mem_inside
    (mem_visibleOuterBoundary_iff.1 hp).1

theorem visibleOuterBoundary_subset_boundaryConnectedOutsideSubregion
    {n : ℕ} {hull : Region GridNode} :
    visibleOuterBoundary n hull ⊆ boundaryConnectedOutsideSubregion n hull := by
  intro p hp
  exact (mem_visibleOuterBoundary_iff.1 hp).1

theorem visibleOuterBoundary_subset_stage
    {n : ℕ} {hull : Region GridNode} :
    visibleOuterBoundary n hull ⊆ gridExhaustion.region n := by
  intro p hp
  exact boundaryConnectedOutsideSubregion_subset_stage
    (visibleOuterBoundary_subset_boundaryConnectedOutsideSubregion hp)

theorem exists_hull_neighbor_of_mem_visibleOuterBoundary
    {n : ℕ} {hull : Region GridNode} {p : GridNode}
    (hp : p ∈ visibleOuterBoundary n hull) :
    ∃ q ∈ hull, gridAdjacent p q :=
  (mem_visibleOuterBoundary_iff.1 hp).2

theorem mem_visibleOuterBoundary_of_mem_boundaryConnectedOutside_of_adj_hull
    {n : ℕ} {hull : Region GridNode} {p q : GridNode}
    (hpExt : p ∈ boundaryConnectedOutsideSubregion n hull)
    (hqHull : q ∈ hull)
    (hpq : gridAdjacent p q) :
    p ∈ visibleOuterBoundary n hull := by
  rw [mem_visibleOuterBoundary_iff]
  exact ⟨hpExt, q, hqHull, hpq⟩

theorem mem_visibleOuterBoundary_of_mem_visibleOuterBoundary_of_subset_of_adj
    {n : ℕ} {inside₁ inside₂ : Region GridNode} {p q : GridNode}
    (hsub : inside₁ ⊆ inside₂)
    (hp : p ∈ visibleOuterBoundary n inside₂)
    (hq : q ∈ inside₁)
    (hpq : gridAdjacent p q) :
    p ∈ visibleOuterBoundary n inside₁ := by
  rcases mem_visibleOuterBoundary_iff.1 hp with ⟨hpExt₂, _htouch₂⟩
  exact mem_visibleOuterBoundary_of_mem_boundaryConnectedOutside_of_adj_hull
    (boundaryConnectedOutsideSubregion_subset_of_subset hsub hpExt₂)
    hq hpq

theorem mem_visibleOuterBoundary_erase_of_mem_visibleOuterBoundary_of_adj_ne
    {n : ℕ} {inside : Region GridNode} {v p q : GridNode}
    (hp : p ∈ visibleOuterBoundary n inside)
    (hq : q ∈ inside)
    (hqne : q ≠ v)
    (hpq : gridAdjacent p q) :
    p ∈ visibleOuterBoundary n (inside.erase v) := by
  exact
    mem_visibleOuterBoundary_of_mem_visibleOuterBoundary_of_subset_of_adj
      (inside₁ := inside.erase v) (inside₂ := inside)
      (by
        intro x hx
        exact (Finset.mem_erase.1 hx).2)
      hp (Finset.mem_erase.2 ⟨hqne, hq⟩) hpq

/-- The finite graph carrier for the Timár separator argument: the hull together
with its boundary-connected exterior component. -/
noncomputable def hullExteriorUnion (n : ℕ) (hull : Region GridNode) : Region GridNode :=
  hull ∪ boundaryConnectedOutsideSubregion n hull

theorem mem_hullExteriorUnion_iff
    {n : ℕ} {hull : Region GridNode} {p : GridNode} :
    p ∈ hullExteriorUnion n hull ↔
      p ∈ hull ∨ p ∈ boundaryConnectedOutsideSubregion n hull := by
  simp [hullExteriorUnion]

theorem mem_hullExteriorUnion_of_mem_hull
    {n : ℕ} {hull : Region GridNode} {p : GridNode}
    (hp : p ∈ hull) :
    p ∈ hullExteriorUnion n hull :=
  mem_hullExteriorUnion_iff.2 (Or.inl hp)

theorem mem_hullExteriorUnion_of_mem_boundaryConnectedOutside
    {n : ℕ} {hull : Region GridNode} {p : GridNode}
    (hp : p ∈ boundaryConnectedOutsideSubregion n hull) :
    p ∈ hullExteriorUnion n hull :=
  mem_hullExteriorUnion_iff.2 (Or.inr hp)

theorem gridAdjacentIn_hullExteriorUnion_iff
    {n : ℕ} {hull : Region GridNode} {a b : GridNode} :
    gridAdjacentInRegion (hullExteriorUnion n hull) a b ↔
      (a ∈ boundaryConnectedOutsideSubregion n hull ∨ a ∈ hull) ∧
        (b ∈ boundaryConnectedOutsideSubregion n hull ∨ b ∈ hull) ∧
          gridAdjacent a b := by
  constructor
  · intro h
    rcases mem_hullExteriorUnion_iff.1 h.1 with haHull | haExt
    · rcases mem_hullExteriorUnion_iff.1 h.2.1 with hbHull | hbExt
      · exact ⟨Or.inr haHull, Or.inr hbHull, h.2.2⟩
      · exact ⟨Or.inr haHull, Or.inl hbExt, h.2.2⟩
    · rcases mem_hullExteriorUnion_iff.1 h.2.1 with hbHull | hbExt
      · exact ⟨Or.inl haExt, Or.inr hbHull, h.2.2⟩
      · exact ⟨Or.inl haExt, Or.inl hbExt, h.2.2⟩
  · intro h
    rcases h with ⟨ha, hb, hab⟩
    refine ⟨?_, ?_, hab⟩
    · rcases ha with haExt | haHull
      · exact mem_hullExteriorUnion_of_mem_boundaryConnectedOutside haExt
      · exact mem_hullExteriorUnion_of_mem_hull haHull
    · rcases hb with hbExt | hbHull
      · exact mem_hullExteriorUnion_of_mem_boundaryConnectedOutside hbExt
      · exact mem_hullExteriorUnion_of_mem_hull hbHull

/-- The finite edge separator used in Timár's proof: hull-side vertices paired
with visible outside vertices, one nearest-neighbour edge across the boundary. -/
noncomputable def visibleBoundarySeparatorEdges
    (n : ℕ) (hull : Region GridNode) : Finset (GridNode × GridNode) := by
  classical
  exact (hull.product (visibleOuterBoundary n hull)).filter
    (fun e => gridAdjacent e.1 e.2)

theorem mem_visibleBoundarySeparatorEdges_iff
    {n : ℕ} {hull : Region GridNode} {e : GridNode × GridNode} :
    e ∈ visibleBoundarySeparatorEdges n hull ↔
      e.1 ∈ hull ∧ e.2 ∈ visibleOuterBoundary n hull ∧
        gridAdjacent e.1 e.2 := by
  constructor
  · intro he
    have hraw :
        (e.1 ∈ hull ∧ e.2 ∈ visibleOuterBoundary n hull) ∧
          gridAdjacent e.1 e.2 := by
      simpa [visibleBoundarySeparatorEdges] using he
    exact ⟨hraw.1.1, hraw.1.2, hraw.2⟩
  · intro he
    have hraw :
        (e.1 ∈ hull ∧ e.2 ∈ visibleOuterBoundary n hull) ∧
          gridAdjacent e.1 e.2 :=
      ⟨⟨he.1, he.2.1⟩, he.2.2⟩
    simpa [visibleBoundarySeparatorEdges] using hraw

theorem visibleBoundarySeparatorEdges_left_mem
    {n : ℕ} {hull : Region GridNode} {e : GridNode × GridNode}
    (he : e ∈ visibleBoundarySeparatorEdges n hull) :
    e.1 ∈ hull :=
  (mem_visibleBoundarySeparatorEdges_iff.1 he).1

theorem visibleBoundarySeparatorEdges_right_mem
    {n : ℕ} {hull : Region GridNode} {e : GridNode × GridNode}
    (he : e ∈ visibleBoundarySeparatorEdges n hull) :
    e.2 ∈ visibleOuterBoundary n hull :=
  (mem_visibleBoundarySeparatorEdges_iff.1 he).2.1

theorem visibleBoundarySeparatorEdges_adjacent
    {n : ℕ} {hull : Region GridNode} {e : GridNode × GridNode}
    (he : e ∈ visibleBoundarySeparatorEdges n hull) :
    gridAdjacent e.1 e.2 :=
  (mem_visibleBoundarySeparatorEdges_iff.1 he).2.2

theorem visibleBoundarySeparatorEdges_right_boundaryConnectedOutside
    {n : ℕ} {hull : Region GridNode} {e : GridNode × GridNode}
    (he : e ∈ visibleBoundarySeparatorEdges n hull) :
    e.2 ∈ boundaryConnectedOutsideSubregion n hull :=
  visibleOuterBoundary_subset_boundaryConnectedOutsideSubregion
    (visibleBoundarySeparatorEdges_right_mem he)

theorem visibleBoundarySeparatorEdges_right_not_mem_hull
    {n : ℕ} {hull : Region GridNode} {e : GridNode × GridNode}
    (he : e ∈ visibleBoundarySeparatorEdges n hull) :
    e.2 ∉ hull :=
  visibleOuterBoundary_not_mem_hull
    (visibleBoundarySeparatorEdges_right_mem he)

theorem visibleBoundarySeparatorEdges_reverse_not_mem
    {n : ℕ} {hull : Region GridNode} {e : GridNode × GridNode}
    (he : e ∈ visibleBoundarySeparatorEdges n hull) :
    (e.2, e.1) ∉ visibleBoundarySeparatorEdges n hull := by
  intro hrev
  exact visibleBoundarySeparatorEdges_right_not_mem_hull he
    (visibleBoundarySeparatorEdges_left_mem hrev)

theorem gridAdjacentIn_boundaryConnectedOutside_ne_visibleBoundarySeparatorEdge
    {n : ℕ} {hull : Region GridNode} {a b : GridNode}
    {e : GridNode × GridNode}
    (hab : gridAdjacentInRegion (boundaryConnectedOutsideSubregion n hull) a b)
    (he : e ∈ visibleBoundarySeparatorEdges n hull) :
    (a, b) ≠ e ∧ (b, a) ≠ e := by
  constructor
  · intro hEq
    have haEq : a = e.1 := congrArg Prod.fst hEq
    exact boundaryConnectedOutsideSubregion_not_mem_inside
      (by simpa [haEq] using hab.1)
      (visibleBoundarySeparatorEdges_left_mem he)
  · intro hEq
    have hbEq : b = e.1 := congrArg Prod.fst hEq
    exact boundaryConnectedOutsideSubregion_not_mem_inside
      (by simpa [hbEq] using hab.2.1)
      (visibleBoundarySeparatorEdges_left_mem he)

theorem gridAdjacentIn_hull_ne_visibleBoundarySeparatorEdge
    {n : ℕ} {hull : Region GridNode} {a b : GridNode}
    {e : GridNode × GridNode}
    (hab : gridAdjacentInRegion hull a b)
    (he : e ∈ visibleBoundarySeparatorEdges n hull) :
    (a, b) ≠ e ∧ (b, a) ≠ e := by
  constructor
  · intro hEq
    have hbEq : b = e.2 := congrArg Prod.snd hEq
    exact visibleBoundarySeparatorEdges_right_not_mem_hull he
      (by simpa [hbEq] using hab.2.1)
  · intro hEq
    have haEq : a = e.2 := congrArg Prod.snd hEq
    exact visibleBoundarySeparatorEdges_right_not_mem_hull he
      (by simpa [haEq] using hab.1)

def gridAdjacentInHullExteriorUnionCrossesOnlySeparatorEdge
    (n : ℕ) (hull : Region GridNode) (e : GridNode × GridNode)
    (a b : GridNode) : Prop :=
  gridAdjacentInRegion (hullExteriorUnion n hull) a b ∧
    ((a, b) = (e.2, e.1) ∨
      ∀ f ∈ visibleBoundarySeparatorEdges n hull,
        (a, b) ≠ f ∧ (b, a) ≠ f)

def gridAdjacentInHullExteriorUnionAvoidsSeparatorEdge
    (n : ℕ) (hull : Region GridNode) (f : GridNode × GridNode)
    (a b : GridNode) : Prop :=
  gridAdjacentInRegion (hullExteriorUnion n hull) a b ∧
    (a, b) ≠ f ∧ (b, a) ≠ f

def gridAdjacentInHullExteriorUnionAvoidsSeparatorEdges
    (n : ℕ) (hull : Region GridNode) (s : Finset (GridNode × GridNode))
    (a b : GridNode) : Prop :=
  gridAdjacentInRegion (hullExteriorUnion n hull) a b ∧
    ∀ f ∈ s, (a, b) ≠ f ∧ (b, a) ≠ f

theorem gridAdjacentInHullExteriorUnionAvoidsSeparatorEdges_mono
    {n : ℕ} {hull : Region GridNode}
    {s t : Finset (GridNode × GridNode)} {a b : GridNode}
    (hst : t ⊆ s)
    (hab : gridAdjacentInHullExteriorUnionAvoidsSeparatorEdges n hull s a b) :
    gridAdjacentInHullExteriorUnionAvoidsSeparatorEdges n hull t a b :=
  ⟨hab.1, fun f hf => hab.2 f (hst hf)⟩

theorem gridAdjacentInHullExteriorUnionCrossesOnlySeparatorEdge_of_boundaryConnectedOutside
    {n : ℕ} {hull : Region GridNode} {e : GridNode × GridNode}
    {a b : GridNode}
    (hab : gridAdjacentInRegion (boundaryConnectedOutsideSubregion n hull) a b) :
    gridAdjacentInHullExteriorUnionCrossesOnlySeparatorEdge n hull e a b := by
  constructor
  · exact ⟨mem_hullExteriorUnion_of_mem_boundaryConnectedOutside hab.1,
      mem_hullExteriorUnion_of_mem_boundaryConnectedOutside hab.2.1,
      hab.2.2⟩
  · right
    intro f hf
    exact gridAdjacentIn_boundaryConnectedOutside_ne_visibleBoundarySeparatorEdge
      hab hf

theorem gridAdjacentInHullExteriorUnionCrossesOnlySeparatorEdge_of_hull
    {n : ℕ} {hull : Region GridNode} {e : GridNode × GridNode}
    {a b : GridNode}
    (hab : gridAdjacentInRegion hull a b) :
    gridAdjacentInHullExteriorUnionCrossesOnlySeparatorEdge n hull e a b := by
  constructor
  · exact ⟨mem_hullExteriorUnion_of_mem_hull hab.1,
      mem_hullExteriorUnion_of_mem_hull hab.2.1, hab.2.2⟩
  · right
    intro f hf
    exact gridAdjacentIn_hull_ne_visibleBoundarySeparatorEdge hab hf

theorem gridAdjacentInHullExteriorUnionCrossesOnlySeparatorEdge_chosen
    {n : ℕ} {hull : Region GridNode} {e : GridNode × GridNode}
    (he : e ∈ visibleBoundarySeparatorEdges n hull) :
    gridAdjacentInHullExteriorUnionCrossesOnlySeparatorEdge
      n hull e e.2 e.1 := by
  constructor
  · exact ⟨mem_hullExteriorUnion_of_mem_boundaryConnectedOutside
        (visibleBoundarySeparatorEdges_right_boundaryConnectedOutside he),
      mem_hullExteriorUnion_of_mem_hull
        (visibleBoundarySeparatorEdges_left_mem he),
      gridAdjacent_symm (visibleBoundarySeparatorEdges_adjacent he)⟩
  · exact Or.inl rfl

theorem gridAdjacentInHullExteriorUnionCrossesOnlySeparatorEdge_separator_eq
    {n : ℕ} {hull : Region GridNode} {e f : GridNode × GridNode}
    {a b : GridNode}
    (he : e ∈ visibleBoundarySeparatorEdges n hull)
    (hstep :
      gridAdjacentInHullExteriorUnionCrossesOnlySeparatorEdge n hull e a b)
    (hf : f ∈ visibleBoundarySeparatorEdges n hull)
    (hcross : (a, b) = f ∨ (b, a) = f) :
    f = e := by
  rcases hstep with ⟨_hUnion, hchosen | havoid⟩
  · rcases hcross with habf | hbaf
    · exfalso
      have hae : a = e.2 := congrArg Prod.fst hchosen
      have haf : a = f.1 := congrArg Prod.fst habf
      have heRightHull : e.2 ∈ hull := by
        simpa [← hae, haf] using visibleBoundarySeparatorEdges_left_mem hf
      exact visibleBoundarySeparatorEdges_right_not_mem_hull he heRightHull
    · have hae : a = e.2 := congrArg Prod.fst hchosen
      have hbe : b = e.1 := congrArg Prod.snd hchosen
      have hrev : (b, a) = e := by
        ext <;> simp [hae, hbe]
      exact hbaf.symm.trans hrev
  · rcases hcross with habf | hbaf
    · exact False.elim ((havoid f hf).1 habf)
    · exact False.elim ((havoid f hf).2 hbaf)

theorem gridAdjacentInHullExteriorUnionCrossesOnlySeparatorEdge_avoids_of_ne
    {n : ℕ} {hull : Region GridNode} {e f : GridNode × GridNode}
    {a b : GridNode}
    (he : e ∈ visibleBoundarySeparatorEdges n hull)
    (hstep :
      gridAdjacentInHullExteriorUnionCrossesOnlySeparatorEdge n hull e a b)
    (hf : f ∈ visibleBoundarySeparatorEdges n hull)
    (hne : f ≠ e) :
    gridAdjacentInHullExteriorUnionAvoidsSeparatorEdge n hull f a b := by
  refine ⟨hstep.1, ?_, ?_⟩
  · intro habf
    exact hne
      (gridAdjacentInHullExteriorUnionCrossesOnlySeparatorEdge_separator_eq
        he hstep hf (Or.inl habf))
  · intro hbaf
    exact hne
      (gridAdjacentInHullExteriorUnionCrossesOnlySeparatorEdge_separator_eq
        he hstep hf (Or.inr hbaf))

theorem gridAdjacentInHullExteriorUnionCrossesOnlySeparatorEdge_avoids_erase
    {n : ℕ} {hull : Region GridNode} {e : GridNode × GridNode}
    {a b : GridNode}
    (he : e ∈ visibleBoundarySeparatorEdges n hull)
    (hstep :
      gridAdjacentInHullExteriorUnionCrossesOnlySeparatorEdge n hull e a b) :
    gridAdjacentInHullExteriorUnionAvoidsSeparatorEdges n hull
      ((visibleBoundarySeparatorEdges n hull).erase e) a b := by
  refine ⟨hstep.1, ?_⟩
  intro f hf
  rcases Finset.mem_erase.1 hf with ⟨hfe, hfSep⟩
  exact
    (gridAdjacentInHullExteriorUnionCrossesOnlySeparatorEdge_avoids_of_ne
      he hstep hfSep hfe).2

theorem not_hullExteriorUnion_reachable_avoiding_visibleBoundarySeparatorEdges
    {n : ℕ} {hull : Region GridNode} {out x : GridNode}
    (hout : out ∈ boundaryConnectedOutsideSubregion n hull)
    (hx : x ∈ hull) :
    ¬ Relation.ReflTransGen
      (gridAdjacentInHullExteriorUnionAvoidsSeparatorEdges n hull
        (visibleBoundarySeparatorEdges n hull)) out x := by
  intro hreach
  let Ext : GridNode → Prop :=
    fun p => p ∈ boundaryConnectedOutsideSubregion n hull
  let R : GridNode → GridNode → Prop :=
    gridAdjacentInHullExteriorUnionAvoidsSeparatorEdges n hull
      (visibleBoundarySeparatorEdges n hull)
  have allowed_of_reach :
      ∀ {y : GridNode},
        Relation.ReflTransGen
          (fun a b : GridNode => Ext a ∧ Ext b ∧ R a b) out y →
        Ext y := by
    intro y hy
    induction hy with
    | refl =>
        exact hout
    | @tail a b hprev hstep _ih =>
        exact hstep.2.1
  have htarget :
      ¬ Relation.ReflTransGen
        (fun a b : GridNode => Ext a ∧ Ext b ∧ R a b) out x := by
    intro hxReach
    exact boundaryConnectedOutsideSubregion_not_mem_inside
      (by simpa [Ext] using allowed_of_reach hxReach) hx
  rcases
    exists_first_forbidden_step_of_reflTransGen
      (R := R) (Allowed := Ext) (start := out) (target := x)
      (by simpa [Ext] using hout) (by simpa [R] using hreach) htarget with
    ⟨a, b, haReach, _hbNoReach, hab, hbNotExt⟩
  have haExt : a ∈ boundaryConnectedOutsideSubregion n hull := by
    have haAllowed : Ext a := by
      induction haReach with
      | refl =>
          exact hout
      | @tail u v hprev hstep _ih =>
          exact hstep.2.1
    simpa [Ext] using haAllowed
  have hbHull : b ∈ hull := by
    rcases mem_hullExteriorUnion_iff.1 hab.1.2.1 with hbHull | hbExt
    · exact hbHull
    · exact False.elim (hbNotExt (by simpa [Ext] using hbExt))
  have habGrid : gridAdjacent a b := hab.1.2.2
  have haVisible : a ∈ visibleOuterBoundary n hull :=
    mem_visibleOuterBoundary_of_mem_boundaryConnectedOutside_of_adj_hull
      haExt hbHull habGrid
  have he : (b, a) ∈ visibleBoundarySeparatorEdges n hull := by
    rw [mem_visibleBoundarySeparatorEdges_iff]
    exact ⟨hbHull, haVisible, gridAdjacent_symm habGrid⟩
  exact (hab.2 (b, a) he).2 rfl

theorem visibleBoundarySeparatorEdges_right_reachable_from_stageBoundary
    {n : ℕ} {hull : Region GridNode} {e : GridNode × GridNode}
    (he : e ∈ visibleBoundarySeparatorEdges n hull) :
    ∃ b ∈ gridStageBoundaryRegion n,
      b ∈ outsideRegionInStage n hull ∧
        Relation.ReflTransGen
          (gridAdjacentInRegion (outsideRegionInStage n hull)) b e.2 := by
  exact (mem_boundaryConnectedOutsideSubregion_iff.1
    (visibleBoundarySeparatorEdges_right_boundaryConnectedOutside he)).2

theorem exists_visibleBoundarySeparatorEdge_right_eq
    {n : ℕ} {hull : Region GridNode} {p : GridNode}
    (hp : p ∈ visibleOuterBoundary n hull) :
    ∃ e ∈ visibleBoundarySeparatorEdges n hull, e.2 = p := by
  rcases exists_hull_neighbor_of_mem_visibleOuterBoundary hp with
    ⟨q, hqHull, hpq⟩
  refine ⟨(q, p), ?_, rfl⟩
  rw [mem_visibleBoundarySeparatorEdges_iff]
  exact ⟨hqHull, hp, gridAdjacent_symm hpq⟩

theorem exists_visibleBoundarySeparatorEdge_right_of_visible
    {n : ℕ} {hull : Region GridNode} {U : GridNode → Prop}
    (hpos : ∃ p ∈ visibleOuterBoundary n hull, U p) :
    ∃ e ∈ visibleBoundarySeparatorEdges n hull, U e.2 := by
  rcases hpos with ⟨p, hp, hpU⟩
  rcases exists_visibleBoundarySeparatorEdge_right_eq hp with
    ⟨e, he, heq⟩
  exact ⟨e, he, by simpa [heq] using hpU⟩

theorem exists_visibleBoundarySeparatorEdge_right_not_of_visible
    {n : ℕ} {hull : Region GridNode} {U : GridNode → Prop}
    (hneg : ∃ p ∈ visibleOuterBoundary n hull, ¬ U p) :
    ∃ e ∈ visibleBoundarySeparatorEdges n hull, ¬ U e.2 := by
  rcases hneg with ⟨p, hp, hpU⟩
  rcases exists_visibleBoundarySeparatorEdge_right_eq hp with
    ⟨e, he, heq⟩
  exact ⟨e, he, by simpa [heq] using hpU⟩

theorem visibleBoundarySeparatorEdges_nonempty_of_visibleOuterBoundary_nonempty
    {n : ℕ} {hull : Region GridNode}
    (hne : (visibleOuterBoundary n hull).Nonempty) :
    (visibleBoundarySeparatorEdges n hull).Nonempty := by
  rcases hne with ⟨p, hp⟩
  rcases exists_visibleBoundarySeparatorEdge_right_eq hp with
    ⟨e, he, _heq⟩
  exact ⟨e, he⟩

theorem visibleBoundarySeparatorEdges_partition_nonempty_of_visible_partition
    {n : ℕ} {hull : Region GridNode} {U : GridNode → Prop}
    (hpos : ∃ p ∈ visibleOuterBoundary n hull, U p)
    (hneg : ∃ p ∈ visibleOuterBoundary n hull, ¬ U p) :
    (∃ e ∈ visibleBoundarySeparatorEdges n hull, U e.2) ∧
      (∃ e ∈ visibleBoundarySeparatorEdges n hull, ¬ U e.2) :=
  ⟨exists_visibleBoundarySeparatorEdge_right_of_visible hpos,
    exists_visibleBoundarySeparatorEdge_right_not_of_visible hneg⟩

theorem exists_visibleOuterBoundary_star_cross_of_separatorEdges_common_basicSquare
    {n i j : ℕ} {hull : Region GridNode} {U : GridNode → Prop}
    {e₁ e₂ : GridNode × GridNode}
    (he₁ : e₁ ∈ visibleBoundarySeparatorEdges n hull)
    (he₂ : e₂ ∈ visibleBoundarySeparatorEdges n hull)
    (hU₁ : U e₁.2) (hU₂ : ¬ U e₂.2)
    (hSq₁ : e₁.2 ∈ gridBasicSquareVertices i j)
    (hSq₂ : e₂.2 ∈ gridBasicSquareVertices i j) :
    ∃ a ∈ visibleOuterBoundary n hull,
      ∃ b ∈ visibleOuterBoundary n hull,
        U a ∧ ¬ U b ∧ gridNodeStarAdjacent a b := by
  exact
    ⟨e₁.2, visibleBoundarySeparatorEdges_right_mem he₁,
      e₂.2, visibleBoundarySeparatorEdges_right_mem he₂,
      hU₁, hU₂,
      gridBasicSquareVertices_pair_starAdjacent hSq₁ hSq₂⟩

theorem exists_visibleOuterBoundary_star_cross_of_separatorEdges_common_directedBasicSquare
    {n i j : ℕ} {hull : Region GridNode} {U : GridNode → Prop}
    {e₁ e₂ : GridNode × GridNode}
    (he₁ : e₁ ∈ visibleBoundarySeparatorEdges n hull)
    (he₂ : e₂ ∈ visibleBoundarySeparatorEdges n hull)
    (hU₁ : U e₁.2) (hU₂ : ¬ U e₂.2)
    (hSq₁ : e₁ ∈ gridBasicSquareDirectedEdges i j)
    (hSq₂ : e₂ ∈ gridBasicSquareDirectedEdges i j) :
    ∃ a ∈ visibleOuterBoundary n hull,
      ∃ b ∈ visibleOuterBoundary n hull,
        U a ∧ ¬ U b ∧ gridNodeStarAdjacent a b := by
  rcases
    (mem_gridBasicSquareDirectedEdges_iff_vertices_adjacent.1 hSq₁) with
    ⟨_hleft₁, hright₁, _hadj₁⟩
  rcases
    (mem_gridBasicSquareDirectedEdges_iff_vertices_adjacent.1 hSq₂) with
    ⟨_hleft₂, hright₂, _hadj₂⟩
  exact
    exists_visibleOuterBoundary_star_cross_of_separatorEdges_common_basicSquare
      he₁ he₂ hU₁ hU₂ hright₁ hright₂

theorem exists_visibleOuterBoundary_star_cross_of_separatorEdges_directedBasicSquare_cross
    {n : ℕ} {hull : Region GridNode} {U : GridNode → Prop}
    (hcross :
      ∃ i j,
        ∃ e₁ ∈ visibleBoundarySeparatorEdges n hull,
          ∃ e₂ ∈ visibleBoundarySeparatorEdges n hull,
            U e₁.2 ∧ ¬ U e₂.2 ∧
              e₁ ∈ gridBasicSquareDirectedEdges i j ∧
                e₂ ∈ gridBasicSquareDirectedEdges i j) :
    ∃ a ∈ visibleOuterBoundary n hull,
      ∃ b ∈ visibleOuterBoundary n hull,
        U a ∧ ¬ U b ∧ gridNodeStarAdjacent a b := by
  rcases hcross with
    ⟨i, j, e₁, he₁, e₂, he₂, hU₁, hU₂, hSq₁, hSq₂⟩
  exact
    exists_visibleOuterBoundary_star_cross_of_separatorEdges_common_directedBasicSquare
      he₁ he₂ hU₁ hU₂ hSq₁ hSq₂

theorem not_separatorEdges_directedBasicSquare_cross_of_no_visibleOuterBoundary_star_cross
    {n : ℕ} {hull : Region GridNode} {U : GridNode → Prop}
    (hno :
      ¬ ∃ a ∈ visibleOuterBoundary n hull,
          ∃ b ∈ visibleOuterBoundary n hull,
            U a ∧ ¬ U b ∧ gridNodeStarAdjacent a b) :
    ¬ ∃ i j,
        ∃ e₁ ∈ visibleBoundarySeparatorEdges n hull,
          ∃ e₂ ∈ visibleBoundarySeparatorEdges n hull,
            U e₁.2 ∧ ¬ U e₂.2 ∧
              e₁ ∈ gridBasicSquareDirectedEdges i j ∧
