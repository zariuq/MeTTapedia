theorem exists_visibleBoundarySeparatorEdge_of_reach_exterior_to_hull
    {n : ℕ} {hull : Region GridNode} {out x : GridNode}
    (hout : out ∈ boundaryConnectedOutsideSubregion n hull)
    (hx : x ∈ hull)
    (hreach :
      Relation.ReflTransGen
        (fun a b : GridNode =>
          (a ∈ boundaryConnectedOutsideSubregion n hull ∨ a ∈ hull) ∧
            (b ∈ boundaryConnectedOutsideSubregion n hull ∨ b ∈ hull) ∧
              gridAdjacent a b)
        out x) :
    ∃ e ∈ visibleBoundarySeparatorEdges n hull,
      Relation.ReflTransGen
        (fun a b : GridNode =>
          a ∈ boundaryConnectedOutsideSubregion n hull ∧
            b ∈ boundaryConnectedOutsideSubregion n hull ∧ gridAdjacent a b)
        out e.2 ∧ gridAdjacent e.2 e.1 := by
  let Ext : GridNode → Prop :=
    fun p => p ∈ boundaryConnectedOutsideSubregion n hull
  let R : GridNode → GridNode → Prop := fun a b =>
    (a ∈ boundaryConnectedOutsideSubregion n hull ∨ a ∈ hull) ∧
      (b ∈ boundaryConnectedOutsideSubregion n hull ∨ b ∈ hull) ∧
        gridAdjacent a b
  have htarget :
      ¬ Relation.ReflTransGen
        (fun a b : GridNode => Ext a ∧ Ext b ∧ R a b) out x := by
    intro hreachExt
    have hxExt : Ext x := by
      induction hreachExt with
      | refl =>
          exact hout
      | @tail a b hprev hstep _ih =>
          exact hstep.2.1
    exact boundaryConnectedOutsideSubregion_not_mem_inside
      (by simpa [Ext] using hxExt) hx
  rcases
    exists_first_forbidden_step_of_reflTransGen
      (R := R) (Allowed := Ext)
      (start := out) (target := x)
      (by simpa [Ext] using hout) (by simpa [R] using hreach) htarget with
    ⟨a, b, haReach, _hbNoReach, hab, hbNotExt⟩
  have haExt : a ∈ boundaryConnectedOutsideSubregion n hull := by
    have hAllowed : Ext a := by
      induction haReach with
      | refl =>
          exact hout
      | @tail u v hprev hstep _ih =>
          exact hstep.2.1
    simpa [Ext] using hAllowed
  have hbHull : b ∈ hull := by
    rcases hab.2.1 with hbExt | hbHull
    · exact False.elim (hbNotExt (by simpa [Ext] using hbExt))
    · exact hbHull
  have habGrid : gridAdjacent a b := hab.2.2
  have haVisible : a ∈ visibleOuterBoundary n hull :=
    mem_visibleOuterBoundary_of_mem_boundaryConnectedOutside_of_adj_hull
      haExt hbHull habGrid
  have he : (b, a) ∈ visibleBoundarySeparatorEdges n hull := by
    rw [mem_visibleBoundarySeparatorEdges_iff]
    exact ⟨hbHull, haVisible, gridAdjacent_symm habGrid⟩
  have haReachExt :
      Relation.ReflTransGen
        (fun u v : GridNode =>
          u ∈ boundaryConnectedOutsideSubregion n hull ∧
            v ∈ boundaryConnectedOutsideSubregion n hull ∧ gridAdjacent u v)
        out a := by
    refine Relation.ReflTransGen.mono ?_ haReach
    intro u v huv
    have huExt : u ∈ boundaryConnectedOutsideSubregion n hull := by
      simpa [Ext] using huv.1
    have hvExt : v ∈ boundaryConnectedOutsideSubregion n hull := by
      simpa [Ext] using huv.2.1
    have hRuv : R u v := huv.2.2
    have huvGrid : gridAdjacent u v := hRuv.2.2
    exact ⟨huExt, hvExt, huvGrid⟩
  exact ⟨(b, a), he, by simpa using haReachExt, habGrid⟩

theorem exists_visibleBoundarySeparatorEdge_of_hullExteriorUnion_reach_exterior_to_hull
    {n : ℕ} {hull : Region GridNode} {out x : GridNode}
    (hout : out ∈ boundaryConnectedOutsideSubregion n hull)
    (hx : x ∈ hull)
    (hreach :
      Relation.ReflTransGen
        (gridAdjacentInRegion (hullExteriorUnion n hull)) out x) :
    ∃ e ∈ visibleBoundarySeparatorEdges n hull,
      Relation.ReflTransGen
        (fun a b : GridNode =>
          a ∈ boundaryConnectedOutsideSubregion n hull ∧
            b ∈ boundaryConnectedOutsideSubregion n hull ∧ gridAdjacent a b)
        out e.2 ∧ gridAdjacent e.2 e.1 := by
  have hreachUnion :
      Relation.ReflTransGen
        (fun a b : GridNode =>
          (a ∈ boundaryConnectedOutsideSubregion n hull ∨ a ∈ hull) ∧
            (b ∈ boundaryConnectedOutsideSubregion n hull ∨ b ∈ hull) ∧
              gridAdjacent a b)
        out x := by
    refine Relation.ReflTransGen.mono ?_ hreach
    intro a b hab
    exact (gridAdjacentIn_hullExteriorUnion_iff.1 hab)
  exact exists_visibleBoundarySeparatorEdge_of_reach_exterior_to_hull
    hout hx hreachUnion

def visibleOuterBoundaryStarRel (n : ℕ) (hull : Region GridNode) :
    {p // p ∈ visibleOuterBoundary n hull} →
      {p // p ∈ visibleOuterBoundary n hull} → Prop :=
  fun a b => gridNodeStarAdjacent a.1 b.1

theorem visibleOuterBoundaryStarRel_symm (n : ℕ) (hull : Region GridNode) :
    Std.Symm (visibleOuterBoundaryStarRel n hull) :=
  ⟨fun _ _ hab => gridNodeStarAdjacent_symm hab⟩

def visibleOuterBoundaryStarGraph (n : ℕ) (hull : Region GridNode) :
    SimpleGraph {p // p ∈ visibleOuterBoundary n hull} :=
  SimpleGraph.fromEdgeSet
    (Sym2.fromRel (visibleOuterBoundaryStarRel_symm n hull))

theorem visibleOuterBoundaryStarGraph_reachable_eq_reflTransGen
    (n : ℕ) (hull : Region GridNode) :
    (visibleOuterBoundaryStarGraph n hull).Reachable =
      Relation.ReflTransGen (visibleOuterBoundaryStarRel n hull) := by
  exact SimpleGraph.reachable_fromEdgeSet_fromRel_eq_reflTransGen
    (visibleOuterBoundaryStarRel_symm n hull)

theorem visibleOuterBoundaryStarGraph_adj_of_star
    {n : ℕ} {hull : Region GridNode}
    {a b : {p // p ∈ visibleOuterBoundary n hull}}
    (hstar : gridNodeStarAdjacent a.1 b.1) (hne : a ≠ b) :
    (visibleOuterBoundaryStarGraph n hull).Adj a b := by
  rw [visibleOuterBoundaryStarGraph, SimpleGraph.fromEdgeSet_adj]
  exact ⟨by
    simpa [visibleOuterBoundaryStarRel, Sym2.toRel_fromRel] using hstar,
    hne⟩

theorem visibleOuterBoundaryStarGraph_adj_of_gridAdjacent
    {n : ℕ} {hull : Region GridNode}
    {a b : {p // p ∈ visibleOuterBoundary n hull}}
    (hab : gridAdjacent a.1 b.1) (hne : a ≠ b) :
    (visibleOuterBoundaryStarGraph n hull).Adj a b :=
  visibleOuterBoundaryStarGraph_adj_of_star
    (gridNodeStarAdjacent_of_gridAdjacent hab) hne

theorem visibleOuterBoundaryStarGraph_reachable_of_reflTransGen_gridAdjacent
    {n : ℕ} {hull : Region GridNode}
    {a b : {p // p ∈ visibleOuterBoundary n hull}}
    (hab :
      Relation.ReflTransGen
        (fun p q : {p // p ∈ visibleOuterBoundary n hull} =>
          gridAdjacent p.1 q.1) a b) :
    (visibleOuterBoundaryStarGraph n hull).Reachable a b := by
  rw [visibleOuterBoundaryStarGraph_reachable_eq_reflTransGen]
  induction hab with
  | refl =>
      exact Relation.ReflTransGen.refl
  | @tail x y hprev hstep ih =>
      exact Relation.ReflTransGen.tail ih
        (gridNodeStarAdjacent_of_gridAdjacent hstep)

theorem visibleOuterBoundaryStarGraph_connected_of_reflTransGen_gridAdjacent
    {n : ℕ} {hull : Region GridNode}
    (hnonempty : Nonempty {p // p ∈ visibleOuterBoundary n hull})
    (hconn :
      ∀ a b : {p // p ∈ visibleOuterBoundary n hull},
        Relation.ReflTransGen
          (fun p q : {p // p ∈ visibleOuterBoundary n hull} =>
            gridAdjacent p.1 q.1) a b) :
    (visibleOuterBoundaryStarGraph n hull).Connected := by
  haveI : Nonempty {p // p ∈ visibleOuterBoundary n hull} := hnonempty
  refine ⟨?_⟩
  intro a b
  exact visibleOuterBoundaryStarGraph_reachable_of_reflTransGen_gridAdjacent
    (hconn a b)

theorem visibleOuterBoundaryStarGraph_connected_of_gridAdjacentInRegion_connected
    {n : ℕ} {hull : Region GridNode}
    (hnonempty : (visibleOuterBoundary n hull).Nonempty)
    (hconn :
      ∀ {a b : GridNode},
        a ∈ visibleOuterBoundary n hull →
          b ∈ visibleOuterBoundary n hull →
            Relation.ReflTransGen
              (gridAdjacentInRegion (visibleOuterBoundary n hull)) a b) :
    (visibleOuterBoundaryStarGraph n hull).Connected := by
  have hnonemptySubtype : Nonempty {p // p ∈ visibleOuterBoundary n hull} := by
    rcases hnonempty with ⟨p, hp⟩
    exact ⟨⟨p, hp⟩⟩
  refine visibleOuterBoundaryStarGraph_connected_of_reflTransGen_gridAdjacent
    hnonemptySubtype ?_
  intro a b
  let f : GridNode → {p // p ∈ visibleOuterBoundary n hull} := fun p =>
    if hp : p ∈ visibleOuterBoundary n hull then ⟨p, hp⟩
    else Classical.choice hnonemptySubtype
  have hf :
      ∀ x y : GridNode,
        gridAdjacentInRegion (visibleOuterBoundary n hull) x y →
          (fun p q : {p // p ∈ visibleOuterBoundary n hull} =>
            gridAdjacent p.1 q.1) (f x) (f y) := by
    intro x y hxy
    simp [f, hxy.1, hxy.2.1, hxy.2.2]
  have hreach :=
    Relation.ReflTransGen.lift
      (p := fun p q : {p // p ∈ visibleOuterBoundary n hull} =>
        gridAdjacent p.1 q.1)
      f hf (hconn a.2 b.2)
  simpa [f, a.2, b.2] using hreach

theorem visibleOuterBoundaryStarGraph_connected_of_starConnected
    {n : ℕ} {hull : Region GridNode}
    (hnonempty : (visibleOuterBoundary n hull).Nonempty)
    (hconn :
      ∀ {a b : GridNode},
        a ∈ visibleOuterBoundary n hull →
          b ∈ visibleOuterBoundary n hull →
            Relation.ReflTransGen
              (fun p q : GridNode =>
                p ∈ visibleOuterBoundary n hull ∧
                  q ∈ visibleOuterBoundary n hull ∧ gridNodeStarAdjacent p q)
              a b) :
    (visibleOuterBoundaryStarGraph n hull).Connected := by
  have hnonemptySubtype : Nonempty {p // p ∈ visibleOuterBoundary n hull} := by
    rcases hnonempty with ⟨p, hp⟩
    exact ⟨⟨p, hp⟩⟩
  haveI : Nonempty {p // p ∈ visibleOuterBoundary n hull} := hnonemptySubtype
  refine ⟨?_⟩
  intro a b
  rw [visibleOuterBoundaryStarGraph_reachable_eq_reflTransGen]
  let f : GridNode → {p // p ∈ visibleOuterBoundary n hull} := fun p =>
    if hp : p ∈ visibleOuterBoundary n hull then ⟨p, hp⟩
    else Classical.choice hnonemptySubtype
  have hf :
      ∀ p q : GridNode,
        (fun p q : GridNode =>
          p ∈ visibleOuterBoundary n hull ∧
            q ∈ visibleOuterBoundary n hull ∧ gridNodeStarAdjacent p q) p q →
          visibleOuterBoundaryStarRel n hull (f p) (f q) := by
    intro p q hpq
    simp [f, hpq.1, hpq.2.1, visibleOuterBoundaryStarRel, hpq.2.2]
  have hreach :=
    Relation.ReflTransGen.lift
      (p := visibleOuterBoundaryStarRel n hull)
      f hf (hconn a.2 b.2)
  simpa [f, a.2, b.2] using hreach

theorem visibleOuterBoundary_star_reachable_of_star
    {n : ℕ} {hull : Region GridNode} {p q : GridNode}
    (hp : p ∈ visibleOuterBoundary n hull)
    (hq : q ∈ visibleOuterBoundary n hull)
    (hpq : gridNodeStarAdjacent p q) :
    Relation.ReflTransGen
      (fun a b : GridNode =>
        a ∈ visibleOuterBoundary n hull ∧
          b ∈ visibleOuterBoundary n hull ∧ gridNodeStarAdjacent a b)
      p q := by
  exact Relation.ReflTransGen.tail Relation.ReflTransGen.refl
    ⟨hp, hq, hpq⟩

theorem visibleOuterBoundary_star_reachable_via_visible_bridge
    {n : ℕ} {hull : Region GridNode} {p q t : GridNode}
    (hp : p ∈ visibleOuterBoundary n hull)
    (hq : q ∈ visibleOuterBoundary n hull)
    (ht : t ∈ visibleOuterBoundary n hull)
    (hpt : gridNodeStarAdjacent p t)
    (htq : gridNodeStarAdjacent t q) :
    Relation.ReflTransGen
      (fun a b : GridNode =>
        a ∈ visibleOuterBoundary n hull ∧
          b ∈ visibleOuterBoundary n hull ∧ gridNodeStarAdjacent a b)
      p q := by
  exact
    (visibleOuterBoundary_star_reachable_of_star hp ht hpt).trans
      (visibleOuterBoundary_star_reachable_of_star ht hq htq)

theorem visibleOuterBoundaryStarGraph_connected_of_forall_adjacent_origin
    {n : ℕ} {hull : Region GridNode}
    (hnonempty : (visibleOuterBoundary n hull).Nonempty)
    (hadj :
      ∀ p ∈ visibleOuterBoundary n hull, gridAdjacent p gridOrigin) :
    (visibleOuterBoundaryStarGraph n hull).Connected := by
  refine visibleOuterBoundaryStarGraph_connected_of_starConnected hnonempty ?_
  intro a b ha hb
  exact Relation.ReflTransGen.tail Relation.ReflTransGen.refl
    ⟨ha, hb,
      gridNodeStarAdjacent_of_gridAdjacent_origin
        (hadj a ha) (hadj b hb)⟩

theorem visibleOuterBoundaryStarGraph_connected_of_hull_eq_singleton_origin
    {n : ℕ} {hull : Region GridNode}
    (hnonempty : (visibleOuterBoundary n hull).Nonempty)
    (hhull : hull = ({gridOrigin} : Region GridNode)) :
    (visibleOuterBoundaryStarGraph n hull).Connected := by
  refine
    visibleOuterBoundaryStarGraph_connected_of_forall_adjacent_origin
      hnonempty ?_
  intro p hp
  rcases exists_hull_neighbor_of_mem_visibleOuterBoundary hp with
    ⟨q, hqHull, hpq⟩
  have hq : q = gridOrigin := by
    rw [hhull] at hqHull
    simpa using hqHull
  simpa [hq] using hpq

theorem visibleOuterBoundaryStarGraph_connected_of_originConnected_card_eq_one
    {n : ℕ} {hull : Region GridNode}
    (hnonempty : (visibleOuterBoundary n hull).Nonempty)
    (hconn : OriginConnectedRegion hull)
    (hcard : hull.card = 1) :
    (visibleOuterBoundaryStarGraph n hull).Connected := by
  rcases Finset.card_eq_one.1 hcard with ⟨p, hpEq⟩
  have hpOrigin : p = gridOrigin := by
    have horigin : gridOrigin ∈ ({p} : Region GridNode) := by
      simpa [hpEq] using hconn.1
    have hOriginEq : gridOrigin = p := by
      simpa using horigin
    exact hOriginEq.symm
  refine
    visibleOuterBoundaryStarGraph_connected_of_hull_eq_singleton_origin
      hnonempty ?_
  simp [hpEq, hpOrigin]

theorem simpleGraph_connected_of_forall_partition_adj
    {α : Type*} {G : SimpleGraph α}
    (hnonempty : Nonempty α)
    (hcross :
      ∀ U : α → Prop,
        (∃ a, U a) → (∃ b, ¬ U b) →
          ∃ a b, U a ∧ ¬ U b ∧ G.Adj a b) :
    G.Connected := by
  haveI : Nonempty α := hnonempty
  refine ⟨?_⟩
  intro u v
  by_contra huv
  let U : α → Prop := fun x => G.Reachable u x
  have hU : ∃ a, U a := ⟨u, SimpleGraph.Reachable.refl u⟩
  have hnotU : ∃ b, ¬ U b := ⟨v, huv⟩
  rcases hcross U hU hnotU with ⟨a, b, ha, hb, hab⟩
  exact hb (ha.trans hab.reachable)

theorem SimpleGraph.Connected.exists_partition_adj
    {α : Type*} {G : SimpleGraph α}
    (hconn : G.Connected)
    (U : α → Prop)
    (hpos : ∃ a, U a)
    (hneg : ∃ b, ¬ U b) :
    ∃ a b, U a ∧ ¬ U b ∧ G.Adj a b := by
  rcases hpos with ⟨u, hu⟩
  rcases hneg with ⟨v, hv⟩
  have hreachGraph : G.Reachable u v := hconn u v
  have hreach : Relation.ReflTransGen G.Adj u v := by
    rw [SimpleGraph.reachable_eq_reflTransGen] at hreachGraph
    exact hreachGraph
  have hpath_cross :
      ∀ {x y : α}, Relation.ReflTransGen G.Adj x y →
        U x → ¬ U y → ∃ a b, U a ∧ ¬ U b ∧ G.Adj a b := by
    intro x y hxy hxU hyU
    induction hxy with
    | refl =>
        exact False.elim (hyU hxU)
    | @tail z y hxz hzy ih =>
        by_cases hzU : U z
        · exact ⟨z, y, hzU, hyU, hzy⟩
        · exact ih hzU
  exact hpath_cross hreach hu hv

theorem visibleOuterBoundaryStarGraph_connected_of_forall_partition_star_crosses
    {n : ℕ} {hull : Region GridNode}
    (hnonempty : Nonempty {p // p ∈ visibleOuterBoundary n hull})
    (hcross :
      ∀ U : {p // p ∈ visibleOuterBoundary n hull} → Prop,
        (∃ a, U a) → (∃ b, ¬ U b) →
          ∃ a b, U a ∧ ¬ U b ∧ gridNodeStarAdjacent a.1 b.1) :
    (visibleOuterBoundaryStarGraph n hull).Connected := by
  refine simpleGraph_connected_of_forall_partition_adj hnonempty ?_
  intro U hU hnotU
  rcases hcross U hU hnotU with ⟨a, b, ha, hb, hab⟩
  by_cases hEq : a = b
  · exact False.elim (hb (by simpa [hEq] using ha))
  · exact ⟨a, b, ha, hb,
      visibleOuterBoundaryStarGraph_adj_of_star hab hEq⟩

theorem visibleOuterBoundaryStarGraph_connected_of_forall_node_partition_star_crosses
    {n : ℕ} {hull : Region GridNode}
    (hnonempty : (visibleOuterBoundary n hull).Nonempty)
    (hcross :
      ∀ U : GridNode → Prop,
        (∃ a ∈ visibleOuterBoundary n hull, U a) →
          (∃ b ∈ visibleOuterBoundary n hull, ¬ U b) →
            ∃ a ∈ visibleOuterBoundary n hull,
              ∃ b ∈ visibleOuterBoundary n hull,
                U a ∧ ¬ U b ∧ gridNodeStarAdjacent a b) :
    (visibleOuterBoundaryStarGraph n hull).Connected := by
  have hnonemptySubtype : Nonempty {p // p ∈ visibleOuterBoundary n hull} := by
    rcases hnonempty with ⟨p, hp⟩
    exact ⟨⟨p, hp⟩⟩
  refine
    visibleOuterBoundaryStarGraph_connected_of_forall_partition_star_crosses
      hnonemptySubtype ?_
  intro U hU hnotU
  let V : GridNode → Prop := fun p =>
    if hp : p ∈ visibleOuterBoundary n hull then U ⟨p, hp⟩ else False
  have hVpos : ∃ a ∈ visibleOuterBoundary n hull, V a := by
    rcases hU with ⟨a, ha⟩
    exact ⟨a.1, a.2, by simp [V, a.2, ha]⟩
  have hVneg : ∃ b ∈ visibleOuterBoundary n hull, ¬ V b := by
    rcases hnotU with ⟨b, hb⟩
    refine ⟨b.1, b.2, ?_⟩
    simpa [V, b.2] using hb
  rcases hcross V hVpos hVneg with
    ⟨a, haVisible, b, hbVisible, haV, hbV, hab⟩
  refine ⟨⟨a, haVisible⟩, ⟨b, hbVisible⟩, ?_, ?_, hab⟩
  · simpa [V, haVisible] using haV
  · simpa [V, hbVisible] using hbV

theorem exists_visibleOuterBoundary_star_cross_of_gridAdjacent_cross
    {n : ℕ} {hull : Region GridNode}
    {U : GridNode → Prop}
    (hcross :
      ∃ a ∈ visibleOuterBoundary n hull,
        ∃ b ∈ visibleOuterBoundary n hull,
          U a ∧ ¬ U b ∧ gridAdjacent a b) :
    ∃ a ∈ visibleOuterBoundary n hull,
      ∃ b ∈ visibleOuterBoundary n hull,
        U a ∧ ¬ U b ∧ gridNodeStarAdjacent a b := by
  rcases hcross with ⟨a, haVisible, b, hbVisible, haU, hbU, hab⟩
  exact ⟨a, haVisible, b, hbVisible, haU, hbU,
    gridNodeStarAdjacent_of_gridAdjacent hab⟩

/-- The stage-box hull obtained by deleting only the boundary-connected exterior
component of the complement. This fills interior holes while keeping the same
outer boundary. -/
noncomputable def boundaryConnectedHullRegion
    (n : ℕ) (inside : Region GridNode) : Region GridNode :=
  (gridExhaustion.region n).filter
    (fun a => a ∉ boundaryConnectedOutsideSubregion n inside)

theorem mem_boundaryConnectedHullRegion_iff
    {n : ℕ} {inside : Region GridNode} {a : GridNode} :
    a ∈ boundaryConnectedHullRegion n inside ↔
      a ∈ gridExhaustion.region n ∧
        a ∉ boundaryConnectedOutsideSubregion n inside := by
  simp [boundaryConnectedHullRegion]

theorem boundaryConnectedHullRegion_subset_stage
    {n : ℕ} {inside : Region GridNode} :
    boundaryConnectedHullRegion n inside ⊆ gridExhaustion.region n := by
  intro a ha
  exact (mem_boundaryConnectedHullRegion_iff.1 ha).1

theorem inside_subset_boundaryConnectedHullRegion
    {n : ℕ} {inside : Region GridNode}
    (hInside : inside ⊆ gridExhaustion.region n) :
    inside ⊆ boundaryConnectedHullRegion n inside := by
  intro a ha
  rw [mem_boundaryConnectedHullRegion_iff]
  exact ⟨hInside ha, fun hExt => boundaryConnectedOutsideSubregion_not_mem_inside hExt ha⟩

theorem not_mem_boundaryConnectedHullRegion_iff
    {n : ℕ} {inside : Region GridNode} {a : GridNode} :
    a ∉ boundaryConnectedHullRegion n inside ↔
      a ∉ gridExhaustion.region n ∨
        a ∈ boundaryConnectedOutsideSubregion n inside := by
  constructor
  · intro ha
    by_cases hStage : a ∈ gridExhaustion.region n
    · right
      by_contra hNotExt
      exact ha ((mem_boundaryConnectedHullRegion_iff).2 ⟨hStage, hNotExt⟩)
    · exact Or.inl hStage
  · intro ha hHull
    rcases (mem_boundaryConnectedHullRegion_iff.1 hHull) with ⟨hStage, hNotExt⟩
    cases ha with
    | inl hNotStage =>
        exact hNotStage hStage
    | inr hExt =>
        exact hNotExt hExt

theorem not_mem_boundaryConnectedHullRegion_of_not_stage
    {n : ℕ} {inside : Region GridNode} {a : GridNode}
    (ha : a ∉ gridExhaustion.region n) :
    a ∉ boundaryConnectedHullRegion n inside :=
  (not_mem_boundaryConnectedHullRegion_iff.2 (Or.inl ha))

theorem not_mem_boundaryConnectedHullRegion_of_mem_boundaryConnectedOutside
    {n : ℕ} {inside : Region GridNode} {a : GridNode}
    (ha : a ∈ boundaryConnectedOutsideSubregion n inside) :
    a ∉ boundaryConnectedHullRegion n inside :=
  (not_mem_boundaryConnectedHullRegion_iff.2 (Or.inr ha))

theorem mem_boundaryConnectedOutsideSubregion_of_mem_outside_of_adj
    {n : ℕ} {inside : Region GridNode} {a b : GridNode}
    (haOut : a ∈ outsideRegionInStage n inside)
    (hbExt : b ∈ boundaryConnectedOutsideSubregion n inside)
    (hba : gridAdjacent b a) :
    a ∈ boundaryConnectedOutsideSubregion n inside := by
  rcases mem_boundaryConnectedOutsideSubregion_iff.1 hbExt with
    ⟨hbOut, ⟨c, hcBoundary, hcOut, hreach⟩⟩
  rw [mem_boundaryConnectedOutsideSubregion_iff]
  exact ⟨haOut, ⟨c, hcBoundary, hcOut,
    Relation.ReflTransGen.tail hreach ⟨hbOut, haOut, hba⟩⟩⟩

theorem mem_visibleOuterBoundary_erase_deleted_of_visible_adj_deleted_adj_remaining
    {n : ℕ} {hull : Region GridNode}
    {v : {p // p ∈ hull}} {p u : GridNode}
    (hHull : hull ⊆ gridExhaustion.region n)
    (hp : p ∈ visibleOuterBoundary n hull)
    (hpv : gridAdjacent p v.1)
    (hu : u ∈ hull.erase v.1)
    (hvu : gridAdjacent v.1 u) :
    v.1 ∈ visibleOuterBoundary n (hull.erase v.1) := by
  have hpExtHull :
      p ∈ boundaryConnectedOutsideSubregion n hull :=
    visibleOuterBoundary_subset_boundaryConnectedOutsideSubregion hp
  have hpExtErase :
      p ∈ boundaryConnectedOutsideSubregion n (hull.erase v.1) := by
    exact boundaryConnectedOutsideSubregion_subset_of_subset
      (inside₁ := hull.erase v.1) (inside₂ := hull)
      (by
        intro x hx
        exact (Finset.mem_erase.1 hx).2)
      hpExtHull
  have hvOutErase :
      v.1 ∈ outsideRegionInStage n (hull.erase v.1) := by
    rw [mem_outsideRegionInStage_iff]
    exact ⟨hHull v.2, by simp⟩
  have hvExtErase :
      v.1 ∈ boundaryConnectedOutsideSubregion n (hull.erase v.1) :=
    mem_boundaryConnectedOutsideSubregion_of_mem_outside_of_adj
      hvOutErase hpExtErase hpv
  exact mem_visibleOuterBoundary_of_mem_boundaryConnectedOutside_of_adj_hull
    hvExtErase hu hvu

theorem visibleOuterBoundary_erase_reachable_deleted_of_visible_adj_deleted_adj_remaining
    {n : ℕ} {hull : Region GridNode}
    {v : {p // p ∈ hull}} {p q u : GridNode}
    (hHull : hull ⊆ gridExhaustion.region n)
    (hp : p ∈ visibleOuterBoundary n hull)
    (hpv : gridAdjacent p v.1)
    (hq : q ∈ hull)
    (hqne : q ≠ v.1)
    (hpq : gridAdjacent p q)
    (hu : u ∈ hull.erase v.1)
    (hvu : gridAdjacent v.1 u) :
    Relation.ReflTransGen
      (fun a b : GridNode =>
        a ∈ visibleOuterBoundary n (hull.erase v.1) ∧
          b ∈ visibleOuterBoundary n (hull.erase v.1) ∧
            gridNodeStarAdjacent a b)
      p v.1 := by
  have hpErase :
      p ∈ visibleOuterBoundary n (hull.erase v.1) :=
    mem_visibleOuterBoundary_erase_of_mem_visibleOuterBoundary_of_adj_ne
      hp hq hqne hpq
  have hvErase :
      v.1 ∈ visibleOuterBoundary n (hull.erase v.1) :=
    mem_visibleOuterBoundary_erase_deleted_of_visible_adj_deleted_adj_remaining
      hHull hp hpv hu hvu
  exact visibleOuterBoundary_star_reachable_of_star
    hpErase hvErase (gridNodeStarAdjacent_of_gridAdjacent hpv)

theorem mem_visibleOuterBoundary_erase_or_gridAdjacent_deleted
    {n : ℕ} {hull : Region GridNode}
    {v : {p // p ∈ hull}} {p : GridNode}
    (hp : p ∈ visibleOuterBoundary n hull) :
    p ∈ visibleOuterBoundary n (hull.erase v.1) ∨
      gridAdjacent p v.1 := by
  rcases exists_hull_neighbor_of_mem_visibleOuterBoundary hp with
    ⟨q, hqHull, hpq⟩
  by_cases hqv : q = v.1
  · subst hqv
    exact Or.inr hpq
  · exact Or.inl
      (mem_visibleOuterBoundary_erase_of_mem_visibleOuterBoundary_of_adj_ne
        hp hqHull hqv hpq)

theorem mem_visibleOuterBoundary_erase_or_star_deleted
    {n : ℕ} {hull : Region GridNode}
    {v : {p // p ∈ hull}} {p : GridNode}
    (hp : p ∈ visibleOuterBoundary n hull) :
    p ∈ visibleOuterBoundary n (hull.erase v.1) ∨
      gridNodeStarAdjacent p v.1 := by
  rcases mem_visibleOuterBoundary_erase_or_gridAdjacent_deleted
      (v := v) hp with hpErase | hpv
  · exact Or.inl hpErase
  · exact Or.inr (gridNodeStarAdjacent_of_gridAdjacent hpv)

theorem gridAdjacent_deleted_of_mem_visibleOuterBoundary_of_not_mem_erase
    {n : ℕ} {hull : Region GridNode}
    {v : {p // p ∈ hull}} {p : GridNode}
    (hp : p ∈ visibleOuterBoundary n hull)
    (hpNotErase : p ∉ visibleOuterBoundary n (hull.erase v.1)) :
    gridAdjacent p v.1 := by
  rcases mem_visibleOuterBoundary_erase_or_gridAdjacent_deleted
      (v := v) hp with hpErase | hpv
  · exact False.elim (hpNotErase hpErase)
  · exact hpv

theorem mem_gridStageBoundaryRegion_of_mem_stage_of_adj_not_stage
    {n : ℕ} {a b : GridNode}
    (haStage : a ∈ gridExhaustion.region n)
    (hbNotStage : b ∉ gridExhaustion.region n)
    (hab : gridAdjacent a b) :
    a ∈ gridStageBoundaryRegion n := by
  rcases a with ⟨i, j⟩
  rcases b with ⟨i', j'⟩
  have hiLt : i < n + 1 := (Finset.mem_product.1 haStage).1 |> Finset.mem_range.mp
  have hjLt : j < n + 1 := (Finset.mem_product.1 haStage).2 |> Finset.mem_range.mp
  rw [mem_gridStageBoundaryRegion_iff]
  constructor
  · exact haStage
  · rcases hab with h | h | h | h
    · have hNot : ¬ i + 1 < n + 1 := by
        intro hi1Lt
        apply hbNotStage
        exact Finset.mem_product.mpr
          ⟨Finset.mem_range.mpr (by simpa [h.1] using hi1Lt),
           Finset.mem_range.mpr (by simpa [h.2] using hjLt)⟩
      have hiEq : i = n := by omega
      exact Or.inl hiEq
    · exfalso
      apply hbNotStage
      exact Finset.mem_product.mpr
        ⟨Finset.mem_range.mpr (by omega),
         Finset.mem_range.mpr (by simpa [h.2] using hjLt)⟩
    · have hNot : ¬ j + 1 < n + 1 := by
        intro hj1Lt
        apply hbNotStage
        exact Finset.mem_product.mpr
          ⟨Finset.mem_range.mpr (by simpa [h.1] using hiLt),
           Finset.mem_range.mpr (by simpa [h.2] using hj1Lt)⟩
      have hjEq : j = n := by omega
      exact Or.inr hjEq
    · exfalso
      apply hbNotStage
      exact Finset.mem_product.mpr
        ⟨Finset.mem_range.mpr (by simpa [h.1] using hiLt),
         Finset.mem_range.mpr (by omega)⟩

theorem mem_inside_of_mem_boundaryConnectedHullRegion_of_adj_boundaryConnectedOutside
    {n : ℕ} {inside : Region GridNode} {a b : GridNode}
    (haHull : a ∈ boundaryConnectedHullRegion n inside)
    (hbExt : b ∈ boundaryConnectedOutsideSubregion n inside)
    (hab : gridAdjacent a b) :
    a ∈ inside := by
  by_contra haNotIn
  have haOut : a ∈ outsideRegionInStage n inside := by
    rw [mem_outsideRegionInStage_iff]
    exact ⟨(mem_boundaryConnectedHullRegion_iff.1 haHull).1, haNotIn⟩
  have haExt : a ∈ boundaryConnectedOutsideSubregion n inside :=
    mem_boundaryConnectedOutsideSubregion_of_mem_outside_of_adj
      haOut hbExt (gridAdjacent_symm hab)
  exact (mem_boundaryConnectedHullRegion_iff.1 haHull).2 haExt

theorem mem_inside_of_mem_boundaryConnectedHullRegion_of_adj_not_stage
    {n : ℕ} {inside : Region GridNode} {a b : GridNode}
    (haHull : a ∈ boundaryConnectedHullRegion n inside)
    (hbNotStage : b ∉ gridExhaustion.region n)
    (hab : gridAdjacent a b) :
    a ∈ inside := by
  by_contra haNotIn
  have haStage : a ∈ gridExhaustion.region n := (mem_boundaryConnectedHullRegion_iff.1 haHull).1
  have haBoundary : a ∈ gridStageBoundaryRegion n :=
    mem_gridStageBoundaryRegion_of_mem_stage_of_adj_not_stage haStage hbNotStage hab
  have haOut : a ∈ outsideRegionInStage n inside := by
    rw [mem_outsideRegionInStage_iff]
    exact ⟨haStage, haNotIn⟩
  have haExt : a ∈ boundaryConnectedOutsideSubregion n inside := by
    rw [mem_boundaryConnectedOutsideSubregion_iff]
    exact ⟨haOut, ⟨a, haBoundary, haOut, Relation.ReflTransGen.refl⟩⟩
  exact (mem_boundaryConnectedHullRegion_iff.1 haHull).2 haExt

theorem mem_boundaryConnectedOutsideSubregion_of_mem_boundary
    {n : ℕ} {inside : Region GridNode} {a : GridNode}
    (haBoundary : a ∈ gridStageBoundaryRegion n)
    (haOutside : a ∈ outsideRegionInStage n inside) :
    a ∈ boundaryConnectedOutsideSubregion n inside := by
  rw [mem_boundaryConnectedOutsideSubregion_iff]
  exact ⟨haOutside, ⟨a, haBoundary, haOutside, Relation.ReflTransGen.refl⟩⟩

theorem gridStageBoundaryRegion_subset_outsideRegionInStage_of_subset_pred
    {m : ℕ} {inside : Region GridNode}
    (hm : 1 ≤ m)
    (hInside : inside ⊆ gridExhaustion.region (m - 1)) :
    gridStageBoundaryRegion m ⊆ outsideRegionInStage m inside := by
  intro a haBoundary
  rw [mem_outsideRegionInStage_iff]
  constructor
  · exact (mem_gridStageBoundaryRegion_iff.1 haBoundary).1
  · intro haInside
    have haPred : a ∈ gridExhaustion.region (m - 1) := hInside haInside
    rcases a with ⟨i, j⟩
    rcases mem_gridStageBoundaryRegion_iff.1 haBoundary with
      ⟨_haStage, hiEq | hjEq⟩
    · rcases Finset.mem_product.1 haPred with ⟨hiPred, _hjPred⟩
      have hiLt : i < m := by
        simpa [Nat.sub_add_cancel hm] using Finset.mem_range.mp hiPred
      omega
    · rcases Finset.mem_product.1 haPred with ⟨_hiPred, hjPred⟩
      have hjLt : j < m := by
        simpa [Nat.sub_add_cancel hm] using Finset.mem_range.mp hjPred
      omega

/-- The in-stage complement is connected to the stage boundary. This is the
finite-box co-connectedness gate for single-contour hulls. -/
def StageCoConnectedRegion (n : ℕ) (inside : Region GridNode) : Prop :=
  ∀ a ∈ outsideRegionInStage n inside,
    ∃ b ∈ gridStageBoundaryRegion n,
      b ∈ outsideRegionInStage n inside ∧
        Relation.ReflTransGen
          (gridAdjacentInRegion (outsideRegionInStage n inside)) b a

theorem stageCoConnectedRegion_iff_outside_subset_boundaryConnectedOutside
    {n : ℕ} {inside : Region GridNode} :
    StageCoConnectedRegion n inside ↔
      outsideRegionInStage n inside ⊆
        boundaryConnectedOutsideSubregion n inside := by
  constructor
  · intro hconn a ha
    rcases hconn a ha with ⟨b, hbBoundary, hbOutside, hreach⟩
    rw [mem_boundaryConnectedOutsideSubregion_iff]
    exact ⟨ha, ⟨b, hbBoundary, hbOutside, hreach⟩⟩
  · intro hsub a ha
    exact (mem_boundaryConnectedOutsideSubregion_iff.1 (hsub ha)).2

theorem StageCoConnectedRegion.erase_of_visible_adj_deleted
    {n : ℕ} {hull : Region GridNode}
    {v : {p // p ∈ hull}} {p : GridNode}
    (hHull : hull ⊆ gridExhaustion.region n)
    (hco : StageCoConnectedRegion n hull)
    (hp : p ∈ visibleOuterBoundary n hull)
    (hpv : gridAdjacent p v.1) :
    StageCoConnectedRegion n (hull.erase v.1) := by
  intro a ha
  have hsub :
      outsideRegionInStage n hull ⊆
        outsideRegionInStage n (hull.erase v.1) :=
    outsideRegionInStage_subset_of_subset
      (inside₁ := hull.erase v.1) (inside₂ := hull)
      (by
        intro x hx
        exact (Finset.mem_erase.1 hx).2)
  rcases mem_outsideRegionInStage_iff.1 ha with ⟨haStage, haNotErase⟩
  by_cases haHull : a ∈ hull
  · have haEq : a = v.1 := by
      by_contra hne
      exact haNotErase (Finset.mem_erase.2 ⟨hne, haHull⟩)
    subst haEq
    have hpExt :
        p ∈ boundaryConnectedOutsideSubregion n hull :=
      visibleOuterBoundary_subset_boundaryConnectedOutsideSubregion hp
    rcases mem_boundaryConnectedOutsideSubregion_iff.1 hpExt with
      ⟨hpOutHull, b, hbBoundary, hbOutHull, hreachHull⟩
    have hpOutErase : p ∈ outsideRegionInStage n (hull.erase v.1) :=
      hsub hpOutHull
    have hbOutErase : b ∈ outsideRegionInStage n (hull.erase v.1) :=
      hsub hbOutHull
    have hvOutErase : v.1 ∈ outsideRegionInStage n (hull.erase v.1) := by
      rw [mem_outsideRegionInStage_iff]
      exact ⟨hHull v.2, by simp⟩
    have hreachErase :
        Relation.ReflTransGen
          (gridAdjacentInRegion (outsideRegionInStage n (hull.erase v.1)))
          b p :=
      reflTransGen_gridAdjacentInRegion_mono hsub hreachHull
    exact ⟨b, hbBoundary, hbOutErase,
      Relation.ReflTransGen.tail hreachErase
        ⟨hpOutErase, hvOutErase, hpv⟩⟩
  · have haOutHull : a ∈ outsideRegionInStage n hull := by
      rw [mem_outsideRegionInStage_iff]
      exact ⟨haStage, haHull⟩
    rcases hco a haOutHull with
      ⟨b, hbBoundary, hbOutHull, hreachHull⟩
    exact ⟨b, hbBoundary, hsub hbOutHull,
      reflTransGen_gridAdjacentInRegion_mono hsub hreachHull⟩

theorem mem_visibleOuterBoundary_of_mem_visibleOuterBoundary_erase_ne
    {n : ℕ} {hull : Region GridNode}
    {v : {p // p ∈ hull}} {p : GridNode}
    (hco : StageCoConnectedRegion n hull)
    (hp : p ∈ visibleOuterBoundary n (hull.erase v.1))
    (hpne : p ≠ v.1) :
    p ∈ visibleOuterBoundary n hull := by
  rcases mem_visibleOuterBoundary_iff.1 hp with
    ⟨hpExtErase, q, hqErase, hpq⟩
  have hpStage : p ∈ gridExhaustion.region n :=
    boundaryConnectedOutsideSubregion_subset_stage hpExtErase
  have hpNotHull : p ∉ hull := by
    intro hpHull
    exact visibleOuterBoundary_not_mem_hull hp
      (Finset.mem_erase.2 ⟨hpne, hpHull⟩)
  have hpOutHull : p ∈ outsideRegionInStage n hull := by
    rw [mem_outsideRegionInStage_iff]
    exact ⟨hpStage, hpNotHull⟩
  have hpExtHull : p ∈ boundaryConnectedOutsideSubregion n hull :=
    (stageCoConnectedRegion_iff_outside_subset_boundaryConnectedOutside.1
      hco) hpOutHull
  exact mem_visibleOuterBoundary_of_mem_boundaryConnectedOutside_of_adj_hull
    hpExtHull (Finset.mem_erase.1 hqErase).2 hpq

theorem visibleOuterBoundary_star_reachable_of_erase_reachable_avoiding_deleted
    {n : ℕ} {hull : Region GridNode}
    {v : {p // p ∈ hull}} {p q : GridNode}
    (hco : StageCoConnectedRegion n hull)
    (hreach :
      Relation.ReflTransGen
        (fun a b : GridNode =>
          a ∈ visibleOuterBoundary n (hull.erase v.1) ∧
            b ∈ visibleOuterBoundary n (hull.erase v.1) ∧
              a ≠ v.1 ∧ b ≠ v.1 ∧ gridNodeStarAdjacent a b)
        p q) :
    Relation.ReflTransGen
      (fun a b : GridNode =>
        a ∈ visibleOuterBoundary n hull ∧
          b ∈ visibleOuterBoundary n hull ∧ gridNodeStarAdjacent a b)
      p q := by
  induction hreach with
  | refl =>
      exact Relation.ReflTransGen.refl
  | @tail a b hprev hstep ih =>
      exact Relation.ReflTransGen.tail ih
        ⟨mem_visibleOuterBoundary_of_mem_visibleOuterBoundary_erase_ne
            hco hstep.1 hstep.2.2.1,
          mem_visibleOuterBoundary_of_mem_visibleOuterBoundary_erase_ne
            hco hstep.2.1 hstep.2.2.2.1,
          hstep.2.2.2.2⟩

theorem erase_visibleOuterBoundary_reach_avoids_deleted_or_hits_deleted
    {n : ℕ} {hull : Region GridNode}
    {v : {p // p ∈ hull}} {p q : GridNode}
    (hpne : p ≠ v.1)
    (hreach :
      Relation.ReflTransGen
        (fun a b : GridNode =>
          a ∈ visibleOuterBoundary n (hull.erase v.1) ∧
            b ∈ visibleOuterBoundary n (hull.erase v.1) ∧
              gridNodeStarAdjacent a b)
        p q) :
    Relation.ReflTransGen
        (fun a b : GridNode =>
          a ∈ visibleOuterBoundary n (hull.erase v.1) ∧
            b ∈ visibleOuterBoundary n (hull.erase v.1) ∧
              a ≠ v.1 ∧ b ≠ v.1 ∧ gridNodeStarAdjacent a b)
        p q ∨
      ∃ a,
        Relation.ReflTransGen
          (fun x y : GridNode =>
            x ∈ visibleOuterBoundary n (hull.erase v.1) ∧
              y ∈ visibleOuterBoundary n (hull.erase v.1) ∧
                x ≠ v.1 ∧ y ≠ v.1 ∧ gridNodeStarAdjacent x y)
          p a ∧
          a ∈ visibleOuterBoundary n (hull.erase v.1) ∧
            a ≠ v.1 ∧ gridNodeStarAdjacent a v.1 := by
  classical
  let R : GridNode → GridNode → Prop := fun a b =>
    a ∈ visibleOuterBoundary n (hull.erase v.1) ∧
      b ∈ visibleOuterBoundary n (hull.erase v.1) ∧
        gridNodeStarAdjacent a b
  let Avoid : GridNode → Prop := fun a => a ≠ v.1
  let RAvoid : GridNode → GridNode → Prop := fun a b =>
    a ∈ visibleOuterBoundary n (hull.erase v.1) ∧
      b ∈ visibleOuterBoundary n (hull.erase v.1) ∧
        a ≠ v.1 ∧ b ≠ v.1 ∧ gridNodeStarAdjacent a b
  by_cases havoid : Relation.ReflTransGen RAvoid p q
  · exact Or.inl havoid
  · have hstart : Avoid p := hpne
    have hreachR : Relation.ReflTransGen R p q := by
      simpa [R] using hreach
    have hnotAllowedReach :
        ¬ Relation.ReflTransGen
          (fun a b : GridNode => Avoid a ∧ Avoid b ∧ R a b) p q := by
      intro hallowed
      apply havoid
      refine Relation.ReflTransGen.lift
        (p := RAvoid) id ?_ hallowed
      intro a b hab
      simpa [RAvoid, R, Avoid] using
        ⟨hab.2.2.1, hab.2.2.2.1, hab.1, hab.2.1, hab.2.2.2.2⟩
    rcases
      exists_first_forbidden_step_of_reflTransGen
        (R := R) (Allowed := Avoid)
        (start := p) (target := q) hstart hreachR hnotAllowedReach with
      ⟨a, b, haReachAllowed, _hbNotReach, hab, hbNotAllowed⟩
    have haReachAvoid : Relation.ReflTransGen RAvoid p a := by
      refine Relation.ReflTransGen.lift
        (p := RAvoid) id ?_ haReachAllowed
      intro x y hxy
      simpa [RAvoid, R, Avoid] using
        ⟨hxy.2.2.1, hxy.2.2.2.1, hxy.1, hxy.2.1, hxy.2.2.2.2⟩
    have haAvoid : a ≠ v.1 := by
      induction haReachAllowed with
      | refl =>
          exact hpne
      | @tail x y hprev hstep _ih =>
          simpa [Avoid] using hstep.2.1
    have hbEq : b = v.1 := by
      by_contra hbne
      exact hbNotAllowed hbne
    refine Or.inr ⟨a, haReachAvoid, ?_, haAvoid, ?_⟩
    · exact hab.1
    · simpa [hbEq] using hab.2.2

