  have hvisNonempty :
      (visibleOuterBoundary m hull).Nonempty :=
    visibleOuterBoundary_nonempty_of_originConnected_stageCoConnected
      hm hHull hconn hco
  rcases visibleBoundarySeparatorEdges_nonempty_of_visibleOuterBoundary_nonempty
      hvisNonempty with
    ⟨rootEdge, hrootEdge⟩
  haveI : Nonempty {c // c ∈ s} :=
    ⟨⟨gridAdjacentClauseId rootEdge.1 rootEdge.2,
      gridAdjacentClauseId_mem_cutSet_of_visibleBoundarySeparatorEdge
        hsEq hHull hrootEdge⟩⟩
  refine ⟨?_⟩
  intro c d
  rcases exists_visibleOuterBoundary_subtype_primalEndpoint_of_mem_cutSet_eq
      hm hsEq hHull hco c with
    ⟨p, hpc⟩
  rcases exists_visibleBoundarySeparatorEdge_right_eq p.2 with
    ⟨e, he, heRight⟩
  let ce : {c // c ∈ s} :=
    ⟨gridAdjacentClauseId e.1 e.2,
      gridAdjacentClauseId_mem_cutSet_of_visibleBoundarySeparatorEdge
        hsEq hHull he⟩
  have hpce : p.1 ∈ gridClausePrimalEndpoints ce.1 := by
    dsimp [ce]
    simpa [heRight] using
      right_mem_gridClausePrimalEndpoints_gridAdjacentClauseId
        (visibleBoundarySeparatorEdges_adjacent he)
  have hcReach : (cutSetStarGraph s).Reachable c ce :=
    cutSetStarGraph_reachable_of_common_primalEndpoint_of_cutSet_eq
      (n := m - 1) (hull := hull) (s := s) hsEq hpc hpce
  rcases exists_visibleOuterBoundary_subtype_primalEndpoint_of_mem_cutSet_eq
      hm hsEq hHull hco d with
    ⟨q, hqd⟩
  rcases exists_visibleBoundarySeparatorEdge_right_eq q.2 with
    ⟨f, hf, hfRight⟩
  let cf : {c // c ∈ s} :=
    ⟨gridAdjacentClauseId f.1 f.2,
      gridAdjacentClauseId_mem_cutSet_of_visibleBoundarySeparatorEdge
        hsEq hHull hf⟩
  have hqcf : q.1 ∈ gridClausePrimalEndpoints cf.1 := by
    dsimp [cf]
    simpa [hfRight] using
      right_mem_gridClausePrimalEndpoints_gridAdjacentClauseId
        (visibleBoundarySeparatorEdges_adjacent hf)
  have hdReach : (cutSetStarGraph s).Reachable d cf :=
    cutSetStarGraph_reachable_of_common_primalEndpoint_of_cutSet_eq
      (n := m - 1) (hull := hull) (s := s) hsEq hqd hqcf
  have hsepReach :
      Relation.ReflTransGen
        (visibleBoundarySeparatorEdgesSquareAdjacent m hull) e f :=
    visibleBoundarySeparatorEdges_squareConnected
      hm hHull hconn hco he hf
  have hmid : (cutSetStarGraph s).Reachable ce cf := by
    simpa [ce, cf] using
      cutSetStarGraph_reachable_of_visibleBoundarySeparatorEdgesSquareReachable
        hsEq hHull he hf hsepReach
  exact (hcReach.trans hmid).trans hdReach.symm

