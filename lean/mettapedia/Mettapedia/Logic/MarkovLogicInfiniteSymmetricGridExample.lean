    (hc₁ : c₁ ∈ s) (hc₂ : c₂ ∈ s)
    (hshare : gridClausesSharePrimalEndpoint c₁ c₂) :
    gridClauseStarAdjacent c₁ c₂ := by
  exact
    gridClauseStarAdjacent_of_sharePrimalEndpoint_of_mem_originConnectedHullCutSetCandidatesInCutCardBox
      (mem_originConnectedHullCutSetCandidatesInCutCardBox_of_mem_axisAnchored hs)
      hc₁ hc₂ hshare

theorem rootedStarConnectedCutSet_of_sharePrimalEndpoint_chain_axisAnchored
    {m i j : ℕ} {s : Finset GridClauseId} {tail : List GridClauseId}
    (hs : s ∈ originConnectedHullCutSetCandidatesInCutCardBoxAxisAnchored m i j)
    (hchain :
      List.IsChain gridClausesSharePrimalEndpoint
        (GridClauseId.horizontal i 0 :: tail))
    (htailMem : ∀ c ∈ tail, c ∈ s)
    (hcover : ∀ x ∈ s, x = GridClauseId.horizontal i 0 ∨ x ∈ tail) :
    RootedStarConnectedCutSet (GridClauseId.horizontal i 0) s := by
  let root := GridClauseId.horizontal i 0
  have hroot : root ∈ s :=
    horizontal_root_mem_of_mem_originConnectedHullCutSetCandidatesInCutCardBoxAxisAnchored hs
  have hmemOfList : ∀ y ∈ root :: tail, y ∈ s := by
    intro y hy
    rw [List.mem_cons] at hy
    rcases hy with rfl | hy
    · exact hroot
    · exact htailMem y hy
  have hstarChain :
      List.IsChain gridClauseStarAdjacent (root :: tail) := by
    exact hchain.imp_of_mem_imp (by
      intro a b ha hb hshare
      exact gridClauseStarAdjacent_of_sharePrimalEndpoint_of_mem_axisAnchored
        hs (hmemOfList a ha) (hmemOfList b hb) hshare)
  exact rootedStarConnectedCutSet_of_clauseChain
    hroot hstarChain htailMem hcover

theorem mem_originConnectedHullCutSetCandidatesInCutCardBoxAxisAnchored_of_mem
    {m : ℕ} {s : Finset GridClauseId}
    (hs : s ∈ originConnectedHullCutSetCandidatesInCutCardBox m) :
    ∃ i j,
      s ∈ originConnectedHullCutSetCandidatesInCutCardBoxAxisAnchored m i j := by
  rcases exists_bottomHorizontalCut_leftVerticalCut_of_mem_originConnectedHullCutSetCandidatesInCutCardBox hs with
    ⟨i, j, hhor, hvør⟩
  exact ⟨i, j, Finset.mem_filter.2 ⟨hs, hhor, hvør⟩⟩

theorem mem_originConnectedHullCutSetCandidatesInCutCardBoxAxisAnchored_of_mem_bounded
    {m : ℕ} {s : Finset GridClauseId}
    (hs : s ∈ originConnectedHullCutSetCandidatesInCutCardBox m) :
    ∃ i ∈ Finset.range m, ∃ j ∈ Finset.range m,
      s ∈ originConnectedHullCutSetCandidatesInCutCardBoxAxisAnchored m i j := by
  rcases mem_originConnectedHullCutSetCandidatesInCutCardBox_iff.1 hs with
    ⟨hull, _hhull, _hcut, hsEq⟩
  rcases exists_bottomHorizontalCut_leftVerticalCut_of_mem_originConnectedHullCutSetCandidatesInCutCardBox hs with
    ⟨i, j, hhor, hvør⟩
  cases m with
  | zero =>
      have hcard : s.card = 0 := by
        simpa using card_eq_of_mem_originConnectedHullCutSetCandidatesInCutCardBox hs
      have hpos : 0 < s.card := Finset.card_pos.mpr ⟨_, hhor⟩
      exact False.elim (Nat.ne_of_gt hpos hcard)
  | succ m' =>
      have hhorSupp :
          GridClauseId.horizontal i 0 ∈ gridRegionSupport (gridExhaustion.region m') := by
        rw [hsEq] at hhor
        exact (Finset.mem_filter.1 hhor).1
      have hvertSupp :
          GridClauseId.vertical 0 j ∈ gridRegionSupport (gridExhaustion.region m') := by
        rw [hsEq] at hvør
        exact (Finset.mem_filter.1 hvør).1
      have hi : i < Nat.succ m' := by
        have hi' :
            i < m' + 1 :=
          (horizontal_mem_gridRegionSupport_gridExhaustion_region_iff
            (n := m') (i := i) (j := 0)).1 hhorSupp |>.1
        simpa using hi'
      have hj : j < Nat.succ m' := by
        have hj' :
            j < m' + 1 :=
          (vertical_mem_gridRegionSupport_gridExhaustion_region_iff
            (n := m') (i := 0) (j := j)).1 hvertSupp |>.2
        simpa using hj'
      exact ⟨i, Finset.mem_range.mpr hi, j, Finset.mem_range.mpr hj,
        Finset.mem_filter.2 ⟨hs, hhor, hvør⟩⟩

theorem originConnectedHullCutSetCandidatesInCutCardBox_subset_biUnion_axisAnchored
    (m : ℕ) :
    originConnectedHullCutSetCandidatesInCutCardBox m ⊆
      ((Finset.range m).product (Finset.range m)).biUnion
        (fun p =>
          originConnectedHullCutSetCandidatesInCutCardBoxAxisAnchored m p.1 p.2) := by
  intro s hs
  rcases mem_originConnectedHullCutSetCandidatesInCutCardBoxAxisAnchored_of_mem_bounded hs with
    ⟨i, hi, j, hj, hsroot⟩
  exact Finset.mem_biUnion.2 ⟨(i, j), Finset.mem_product.2 ⟨hi, hj⟩, hsroot⟩

theorem originConnectedHullCutSetCandidatesInCutCardBox_card_le_sum_axisAnchored
    (m : ℕ) :
    (((originConnectedHullCutSetCandidatesInCutCardBox m).card : ENNReal)) ≤
      ∑ p ∈ (Finset.range m).product (Finset.range m),
        (((originConnectedHullCutSetCandidatesInCutCardBoxAxisAnchored m p.1 p.2).card :
          ENNReal)) := by
  have hcard :
      (originConnectedHullCutSetCandidatesInCutCardBox m).card ≤
        (((Finset.range m).product (Finset.range m)).biUnion
          (fun p =>
            originConnectedHullCutSetCandidatesInCutCardBoxAxisAnchored m p.1 p.2)).card := by
    exact Finset.card_le_card
      (originConnectedHullCutSetCandidatesInCutCardBox_subset_biUnion_axisAnchored m)
  exact_mod_cast (le_trans hcard Finset.card_biUnion_le)

theorem originConnectedHullCutSetCandidatesInCutCardBox_card_le_axisAnchoredCountBound
    (m : ℕ) (countBound : ENNReal)
    (hcount :
      ∀ i ∈ Finset.range m, ∀ j ∈ Finset.range m,
        (((originConnectedHullCutSetCandidatesInCutCardBoxAxisAnchored m i j).card : ENNReal)) ≤
          countBound) :
    (((originConnectedHullCutSetCandidatesInCutCardBox m).card : ENNReal)) ≤
      ((m * m : ℕ) : ENNReal) * countBound := by
  calc
    (((originConnectedHullCutSetCandidatesInCutCardBox m).card : ENNReal)) ≤
      ∑ p ∈ (Finset.range m).product (Finset.range m),
        (((originConnectedHullCutSetCandidatesInCutCardBoxAxisAnchored m p.1 p.2).card :
          ENNReal)) :=
      originConnectedHullCutSetCandidatesInCutCardBox_card_le_sum_axisAnchored m
    _ ≤
      ∑ _p ∈ (Finset.range m).product (Finset.range m), countBound := by
        refine Finset.sum_le_sum ?_
        intro p hp
        exact hcount p.1 (Finset.mem_product.1 hp).1 p.2 (Finset.mem_product.1 hp).2
    _ = ((m * m : ℕ) : ENNReal) * countBound := by
        simp [Finset.card_product, mul_comm]

theorem nat_sq_le_four_pow (m : ℕ) : m * m ≤ 4 ^ m := by
  have hm : m ≤ 2 ^ m := m.lt_two_pow_self.le
  calc
    m * m ≤ (2 ^ m) * (2 ^ m) := Nat.mul_le_mul hm hm
    _ = 2 ^ (m + m) := by rw [← Nat.pow_add]
    _ = 2 ^ (2 * m) := by simp [two_mul]
    _ = 4 ^ m := by rw [Nat.pow_mul]

theorem originConnectedHullCutSetCandidatesInCutCardBox_card_le_axisAnchoredGeometricBound
    (m : ℕ) (C q : ENNReal)
    (hcount :
      ∀ i ∈ Finset.range m, ∀ j ∈ Finset.range m,
        (((originConnectedHullCutSetCandidatesInCutCardBoxAxisAnchored m i j).card : ENNReal)) ≤
          C * q ^ m) :
