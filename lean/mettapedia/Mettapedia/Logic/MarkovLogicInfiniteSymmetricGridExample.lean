    ⟨gridAdjacentClauseId_mem_gridRegionSupport_of_mem_right (hInside hb) hab, hcut⟩

theorem gridAdjacentClauseId_mem_cutSet_of_eq_of_mem_left
    {n : ℕ} {inside : Region GridNode} {s : Finset GridClauseId}
    {a b : GridNode}
    (hsEq :
      s =
        (gridRegionSupport (gridExhaustion.region n)).filter
          (gridBaseClauseCutsRegion inside))
    (hInside : inside ⊆ gridExhaustion.region n)
    (ha : a ∈ inside) (hab : gridAdjacent a b)
    (hcut : gridBaseClauseCutsRegion inside (gridAdjacentClauseId a b)) :
    gridAdjacentClauseId a b ∈ s := by
  rw [hsEq]
  exact gridAdjacentClauseId_mem_cutBaseClauses_of_mem_left
    hInside ha hab hcut

theorem gridAdjacentClauseId_mem_cutSet_of_eq_of_mem_right
    {n : ℕ} {inside : Region GridNode} {s : Finset GridClauseId}
    {a b : GridNode}
    (hsEq :
      s =
        (gridRegionSupport (gridExhaustion.region n)).filter
          (gridBaseClauseCutsRegion inside))
    (hInside : inside ⊆ gridExhaustion.region n)
    (hb : b ∈ inside) (hab : gridAdjacent a b)
    (hcut : gridBaseClauseCutsRegion inside (gridAdjacentClauseId a b)) :
    gridAdjacentClauseId a b ∈ s := by
