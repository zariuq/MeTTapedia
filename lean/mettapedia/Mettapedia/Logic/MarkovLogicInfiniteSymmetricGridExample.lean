theorem axisAnchoredSlackFiniteCarrier_card
    (m i j : ℕ) :
    Fintype.card (AxisAnchoredSlackFiniteCarrier m i j) =
      ((gridRegionSupport (gridExhaustion.region (m - 1))).powerset.filter
          (fun t => t.card = i + j + 2)).card *
        (gridRegionSupport (gridExhaustion.region (m - 1))).card *
        ((gridRegionSupport (gridExhaustion.region (m - 1))).powerset.filter
          (fun t => t.card = (m - (i + j + 2)) - 1)).card := by
  classical
  let e :
      AxisAnchoredSlackFiniteCarrier m i j ≃
        (AxisAnchoredSlackSkeletonCarrier m i j ×
          AxisAnchoredSlackExtraCarrier m ×
          AxisAnchoredSlackTailCarrier m i j) :=
    { toFun := fun c => ⟨c.skeleton, c.extra, c.tail⟩
      invFun := fun p => { skeleton := p.1, extra := p.2.1, tail := p.2.2 }
      left_inv := by
        intro c
        cases c
        rfl
      right_inv := by
        intro p
        cases p
        rfl }
  calc
    Fintype.card (AxisAnchoredSlackFiniteCarrier m i j)
        = Fintype.card
            (AxisAnchoredSlackSkeletonCarrier m i j ×
              AxisAnchoredSlackExtraCarrier m ×
              AxisAnchoredSlackTailCarrier m i j) := by
            exact Fintype.card_congr e
    _ = Fintype.card (AxisAnchoredSlackSkeletonCarrier m i j) *
          Fintype.card (AxisAnchoredSlackExtraCarrier m) *
          Fintype.card (AxisAnchoredSlackTailCarrier m i j) := by
            rw [Fintype.card_prod, Fintype.card_prod]
            rw [mul_assoc]
    _ = ((gridRegionSupport (gridExhaustion.region (m - 1))).powerset.filter
            (fun t => t.card = i + j + 2)).card *
          (gridRegionSupport (gridExhaustion.region (m - 1))).card *
          ((gridRegionSupport (gridExhaustion.region (m - 1))).powerset.filter
            (fun t => t.card = (m - (i + j + 2)) - 1)).card := by
            rw [Fintype.card_coe, Fintype.card_coe, Fintype.card_coe]

