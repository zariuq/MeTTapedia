theorem exists_hull_cut_edge_of_mem_originConnectedHullCutSetCandidatesInCutCardBoxAxisAnchored
    {m i j : ℕ} {s : Finset GridClauseId} {x : GridClauseId}
    (hs : s ∈ originConnectedHullCutSetCandidatesInCutCardBoxAxisAnchored m i j)
    (hx : x ∈ s) :
    ∃ hull ∈ originConnectedHullContainingSubregionsInCutCardBox m,
      originContainingSubregionCutCard (m - 1) hull = m ∧
        s =
          (gridRegionSupport (gridExhaustion.region (m - 1))).filter
            (gridBaseClauseCutsRegion hull) ∧
          ∃ a b : GridNode,
            gridAdjacent a b ∧ gridAdjacentClauseId a b = x ∧
              ((a ∈ hull ∧ b ∉ hull) ∨ (a ∉ hull ∧ b ∈ hull)) := by
  rcases
    exists_hull_cut_of_mem_originConnectedHullCutSetCandidatesInCutCardBoxAxisAnchored
      hs hx with
    ⟨hull, hhull, hcutCard, hsEq, hxCut⟩
