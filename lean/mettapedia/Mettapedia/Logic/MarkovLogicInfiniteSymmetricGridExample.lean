theorem erase_visibleOuterBoundary_reach_from_deleted_to_ne
    {n : ℕ} {hull : Region GridNode}
    {v : {p // p ∈ hull}} {q : GridNode}
    (hqne : q ≠ v.1)
    (hreach :
      Relation.ReflTransGen
        (fun a b : GridNode =>
          a ∈ visibleOuterBoundary n (hull.erase v.1) ∧
            b ∈ visibleOuterBoundary n (hull.erase v.1) ∧
              gridNodeStarAdjacent a b)
