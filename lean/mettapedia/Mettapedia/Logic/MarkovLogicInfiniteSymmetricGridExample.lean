/-- The assignment event attached to a candidate inside region in the stage box.
For regions not actually contained in the box we return the empty event, so this
family is total over all finite sets of grid sites. -/
noncomputable def originContainingSubregionAssignmentEvent
    (n : ℕ) (ξ : BoundaryCondition GridNode) (inside : Region GridNode) :
    Set (LocalAssignment GridNode (gridExhaustion.region n)) :=
  by
    classical
    exact
      if hInside : inside ⊆ gridExhaustion.region n then
        ((((Finset.univ : Finset (LocalAssignment GridNode (gridExhaustion.region n))).filter
            (fun x => FalseInsideTrueCutBoundaryRegion inside hInside x ξ)) :
            Finset (LocalAssignment GridNode (gridExhaustion.region n))) :
            Set (LocalAssignment GridNode (gridExhaustion.region n)))
      else
        ∅

theorem mem_originContainingSubregionAssignmentEvent_of_subset
    {n : ℕ} {inside : Region GridNode}
    (hInside : inside ⊆ gridExhaustion.region n)
    (ξ : BoundaryCondition GridNode)
    (x : LocalAssignment GridNode (gridExhaustion.region n)) :
    x ∈ originContainingSubregionAssignmentEvent n ξ inside ↔
      FalseInsideTrueCutBoundaryRegion inside hInside x ξ := by
  simp [originContainingSubregionAssignmentEvent, hInside]

theorem originSpinDownAssignmentEvent_subset_iUnion_originContainingSubregions
    (n : ℕ) :
    localConstraintSet (gridExhaustion.region n)
        (gridOriginSpinLocalQueryInRegion
          (gridExhaustion.region n)
          (gridOrigin_mem_gridExhaustion_region n) false) ⊆
      ⋃ inside, if inside ∈ originContainingSubregions n then
        originContainingSubregionAssignmentEvent n gridPlusBoundary inside else ∅ := by
  intro x hx
  have hxFalse :
      x ⟨gridOrigin, gridOrigin_mem_gridExhaustion_region n⟩ = false := by
    simpa [localConstraintSet, satisfiesConstraints, gridOriginSpinLocalQueryInRegion] using hx
  have horigin :
      patch (gridExhaustion.region n) x gridPlusBoundary gridOrigin = false := by
    simp [patch, gridOrigin_mem_gridExhaustion_region n, hxFalse]
  rcases exists_falseInside_trueCutBoundaryRegion_of_plusBoundary_originFalse x horigin with
    ⟨inside, hInside, horiginIn, hsep⟩
  have hmemInside : inside ∈ originContainingSubregions n := by
    rw [mem_originContainingSubregions_iff]
    exact ⟨hInside, horiginIn⟩
  refine Set.mem_iUnion.2 ⟨inside, ?_⟩
  simp [hmemInside]
  exact (mem_originContainingSubregionAssignmentEvent_of_subset hInside gridPlusBoundary x).2 hsep

theorem originSpinDownAssignmentEvent_subset_iUnion_originConnectedContainingSubregions
    (n : ℕ) :
    localConstraintSet (gridExhaustion.region n)
        (gridOriginSpinLocalQueryInRegion
          (gridExhaustion.region n)
          (gridOrigin_mem_gridExhaustion_region n) false) ⊆
      ⋃ inside, if inside ∈ originConnectedContainingSubregions n then
        originContainingSubregionAssignmentEvent n gridPlusBoundary inside else ∅ := by
  intro x hx
  have hxFalse :
      x ⟨gridOrigin, gridOrigin_mem_gridExhaustion_region n⟩ = false := by
    simpa [localConstraintSet, satisfiesConstraints, gridOriginSpinLocalQueryInRegion] using hx
  have horigin :
      patch (gridExhaustion.region n) x gridPlusBoundary gridOrigin = false := by
    simp [patch, gridOrigin_mem_gridExhaustion_region n, hxFalse]
  rcases exists_originConnected_falseInside_trueCutBoundaryRegion_of_plusBoundary_originFalse
      x horigin with
    ⟨inside, hInside, hconn, hsep⟩
  have hmemInside : inside ∈ originConnectedContainingSubregions n := by
    rw [mem_originConnectedContainingSubregions_iff]
    exact ⟨hInside, hconn⟩
  refine Set.mem_iUnion.2 ⟨inside, ?_⟩
  simp [hmemInside]
  exact (mem_originContainingSubregionAssignmentEvent_of_subset hInside gridPlusBoundary x).2 hsep

/-- The finite local-assignment event indexed by a canonical extracted hull:
the origin is false and the hull of the origin-connected false component is the
given stage-box hull. -/
noncomputable def originConnectedHullAssignmentFinset
    (n : ℕ) (hull : Region GridNode) :
    Finset (LocalAssignment GridNode (gridExhaustion.region n)) := by
  classical
  exact (Finset.univ : Finset (LocalAssignment GridNode (gridExhaustion.region n))).filter
    (fun x =>
      patch (gridExhaustion.region n) x gridPlusBoundary gridOrigin = false ∧
        hull = patchedFalseOriginConnectedHull n x)

noncomputable def originConnectedHullAssignmentEvent
    (n : ℕ) (hull : Region GridNode) :
    Set (LocalAssignment GridNode (gridExhaustion.region n)) :=
  (((originConnectedHullAssignmentFinset n hull :
      Finset (LocalAssignment GridNode (gridExhaustion.region n)))) :
      Set (LocalAssignment GridNode (gridExhaustion.region n)))

theorem mem_originConnectedHullAssignmentEvent
    {n : ℕ} {hull : Region GridNode}
    (x : LocalAssignment GridNode (gridExhaustion.region n)) :
    x ∈ originConnectedHullAssignmentEvent n hull ↔
      patch (gridExhaustion.region n) x gridPlusBoundary gridOrigin = false ∧
        hull = patchedFalseOriginConnectedHull n x := by
  simp [originConnectedHullAssignmentEvent, originConnectedHullAssignmentFinset]

theorem originSpinDownAssignmentEvent_subset_iUnion_originConnectedHullContainingSubregions
    (n : ℕ) :
    localConstraintSet (gridExhaustion.region n)
        (gridOriginSpinLocalQueryInRegion
          (gridExhaustion.region n)
          (gridOrigin_mem_gridExhaustion_region n) false) ⊆
      ⋃ hull, if hull ∈ originConnectedHullContainingSubregions n then
        originConnectedHullAssignmentEvent n hull else ∅ := by
  intro x hx
  have hxFalse :
      x ⟨gridOrigin, gridOrigin_mem_gridExhaustion_region n⟩ = false := by
    simpa [localConstraintSet, satisfiesConstraints, gridOriginSpinLocalQueryInRegion] using hx
  have horigin :
      patch (gridExhaustion.region n) x gridPlusBoundary gridOrigin = false := by
    simp [patch, gridOrigin_mem_gridExhaustion_region n, hxFalse]
  let hull := patchedFalseOriginConnectedHull n x
  have hhull : hull ∈ originConnectedHullContainingSubregions n :=
    patchedFalseOriginConnectedHull_mem_originConnectedHullContainingSubregions_of_originFalse x horigin
  refine Set.mem_iUnion.2 ⟨hull, ?_⟩
  simp [hhull, mem_originConnectedHullAssignmentEvent, horigin, hull]

noncomputable def originConnectedHullWorldEvent
    (n : ℕ) (hull : Region GridNode) :
    Set (InfiniteWorld GridNode) :=
  MeasureTheory.cylinder (gridExhaustion.region n)
    (originConnectedHullAssignmentEvent n hull)

private theorem measure_iUnion_finset_le_sum
    {α β : Type*} [MeasurableSpace α] [DecidableEq β]
    (μ : Measure α) (s : Finset β) (f : β → Set α) :
    μ (⋃ b, if b ∈ s then f b else ∅) ≤ Finset.sum s (fun b => μ (f b)) := by
  induction s using Finset.induction_on with
  | empty =>
      simp
  | insert a s ha ih =>
      have hunion :
          (⋃ b, if b ∈ insert a s then f b else ∅) =
            f a ∪ ⋃ b, if b ∈ s then f b else ∅ := by
        ext x
        simp
      rw [hunion]
      calc
        μ (f a ∪ ⋃ b, if b ∈ s then f b else ∅) ≤ μ (f a) + μ (⋃ b, if b ∈ s then f b else ∅) :=
          MeasureTheory.measure_union_le _ _
        _ ≤ μ (f a) + Finset.sum s (fun b => μ (f b)) := by
          simpa [add_comm, add_left_comm, add_assoc] using add_le_add_right ih (μ (f a))
        _ = Finset.sum (insert a s) (fun b => μ (f b)) := by
          simp [ha]

/-- The stage-box local assignment event that the origin spin is false. -/
noncomputable def originSpinDownAssignmentEvent (n : ℕ) :
    Set (LocalAssignment GridNode (gridExhaustion.region n)) :=
  localConstraintSet (gridExhaustion.region n)
    (gridOriginSpinLocalQueryInRegion
      (gridExhaustion.region n)
      (gridOrigin_mem_gridExhaustion_region n) false)

/-- The finite set of stage-box assignments with origin spin false. -/
noncomputable def originSpinDownAssignmentFinset (n : ℕ) :
    Finset (LocalAssignment GridNode (gridExhaustion.region n)) := by
  classical
  exact (Finset.univ : Finset (LocalAssignment GridNode (gridExhaustion.region n))).filter
    (fun x => patch (gridExhaustion.region n) x gridPlusBoundary gridOrigin = false)

theorem mem_originSpinDownAssignmentFinset
    {n : ℕ}
    (x : LocalAssignment GridNode (gridExhaustion.region n)) :
    x ∈ originSpinDownAssignmentFinset n ↔
      patch (gridExhaustion.region n) x gridPlusBoundary gridOrigin = false := by
  simp [originSpinDownAssignmentFinset]

/-- The finite family of canonical extracted hulls arising from actual
origin-down assignments at stage `n`. This is the sharpest witness family
currently available before contour/path counting. -/
noncomputable def originSpinDownExtractedHulls (n : ℕ) : Finset (Region GridNode) := by
  classical
  exact (originSpinDownAssignmentFinset n).image (patchedFalseOriginConnectedHull n)

theorem mem_originSpinDownExtractedHulls_iff
    {n : ℕ} {hull : Region GridNode} :
    hull ∈ originSpinDownExtractedHulls n ↔
      ∃ x ∈ originSpinDownAssignmentFinset n,
        patchedFalseOriginConnectedHull n x = hull := by
  classical
  unfold originSpinDownExtractedHulls
  constructor
  · intro h
    rcases Finset.mem_image.mp h with ⟨x, hx, rfl⟩
    exact ⟨x, hx, rfl⟩
  · intro h
    rcases h with ⟨x, hx, rfl⟩
    exact Finset.mem_image.mpr ⟨x, hx, rfl⟩

theorem mem_originSpinDownExtractedHulls_imp_mem_originConnectedHullContainingSubregions
    {n : ℕ} {hull : Region GridNode}
    (hhull : hull ∈ originSpinDownExtractedHulls n) :
    hull ∈ originConnectedHullContainingSubregions n := by
  rcases mem_originSpinDownExtractedHulls_iff.1 hhull with ⟨x, hx, hhullEq⟩
  have horigin :
      patch (gridExhaustion.region n) x gridPlusBoundary gridOrigin = false :=
    (mem_originSpinDownAssignmentFinset x).1 hx
  rw [← hhullEq]
  exact patchedFalseOriginConnectedHull_mem_originConnectedHullContainingSubregions_of_originFalse
    x horigin

theorem originSpinDownAssignmentEvent_subset_iUnion_originSpinDownExtractedHulls
    (n : ℕ) :
    localConstraintSet (gridExhaustion.region n)
        (gridOriginSpinLocalQueryInRegion
          (gridExhaustion.region n)
          (gridOrigin_mem_gridExhaustion_region n) false) ⊆
      ⋃ hull, if hull ∈ originSpinDownExtractedHulls n then
        originConnectedHullAssignmentEvent n hull else ∅ := by
  intro x hx
  have hxFalse :
      x ⟨gridOrigin, gridOrigin_mem_gridExhaustion_region n⟩ = false := by
    simpa [localConstraintSet, satisfiesConstraints, gridOriginSpinLocalQueryInRegion] using hx
  have horigin :
      patch (gridExhaustion.region n) x gridPlusBoundary gridOrigin = false := by
    simp [patch, gridOrigin_mem_gridExhaustion_region n, hxFalse]
  let hull := patchedFalseOriginConnectedHull n x
  have hhull : hull ∈ originSpinDownExtractedHulls n := by
    exact Finset.mem_image.mpr ⟨x, (mem_originSpinDownAssignmentFinset x).2 horigin, rfl⟩
  refine Set.mem_iUnion.2 ⟨hull, ?_⟩
  simp [hhull, mem_originConnectedHullAssignmentEvent, horigin, hull]

theorem originConnectedHullAssignmentEvent_subset_originSpinDownAssignmentEvent
    {n : ℕ} {hull : Region GridNode} :
    originConnectedHullAssignmentEvent n hull ⊆ originSpinDownAssignmentEvent n := by
  intro x hx
  rcases (mem_originConnectedHullAssignmentEvent x).1 hx with ⟨horigin, _hhullEq⟩
  have hxFalse :
      x ⟨gridOrigin, gridOrigin_mem_gridExhaustion_region n⟩ = false := by
    simpa [patch, gridOrigin_mem_gridExhaustion_region n] using horigin
  simpa [originSpinDownAssignmentEvent, localConstraintSet, satisfiesConstraints,
    gridOriginSpinLocalQueryInRegion] using hxFalse

theorem originConnectedHullAssignmentEvent_eq_empty_of_not_mem_originSpinDownExtractedHulls
    {n : ℕ} {hull : Region GridNode}
    (hhull : hull ∉ originSpinDownExtractedHulls n) :
    originConnectedHullAssignmentEvent n hull = ∅ := by
  ext x
  constructor
  · intro hx
    rcases (mem_originConnectedHullAssignmentEvent x).1 hx with ⟨horigin, hhullEq⟩
    have hxIn : x ∈ originSpinDownAssignmentFinset n :=
      (mem_originSpinDownAssignmentFinset x).2 horigin
    have hhullIn : hull ∈ originSpinDownExtractedHulls n := by
      rw [hhullEq]
      exact Finset.mem_image.mpr ⟨x, hxIn, rfl⟩
    exact False.elim (hhull hhullIn)
  · simp

theorem originConnectedHullAssignmentEvent_pairwiseDisjoint_on_originSpinDownExtractedHulls
    (n : ℕ) :
    Set.PairwiseDisjoint (↑(originSpinDownExtractedHulls n) : Set (Region GridNode))
      (originConnectedHullAssignmentEvent n) := by
  intro hull₁ _hhull₁ hull₂ _hhull₂ hne
  change Disjoint (originConnectedHullAssignmentEvent n hull₁)
    (originConnectedHullAssignmentEvent n hull₂)
  rw [Set.disjoint_left]
  intro x hx₁ hx₂
  rcases (mem_originConnectedHullAssignmentEvent x).1 hx₁ with ⟨_horigin₁, hhullEq₁⟩
  rcases (mem_originConnectedHullAssignmentEvent x).1 hx₂ with ⟨_horigin₂, hhullEq₂⟩
  exact hne (hhullEq₁.trans hhullEq₂.symm)

theorem originSpinDownAssignmentEvent_eq_iUnion_originSpinDownExtractedHulls
    (n : ℕ) :
    originSpinDownAssignmentEvent n =
      ⋃ hull ∈ originSpinDownExtractedHulls n, originConnectedHullAssignmentEvent n hull := by
  ext x
  constructor
  · intro hx
    have hx' := originSpinDownAssignmentEvent_subset_iUnion_originSpinDownExtractedHulls n hx
    rcases Set.mem_iUnion.1 hx' with ⟨hull, hxhull⟩
    by_cases hhull : hull ∈ originSpinDownExtractedHulls n
    · exact Set.mem_iUnion.2 ⟨hull, Set.mem_iUnion.2 ⟨hhull, by simpa [hhull] using hxhull⟩⟩
    · simp [hhull] at hxhull
  · intro hx
    rcases Set.mem_iUnion.1 hx with ⟨hull, hx⟩
    rcases Set.mem_iUnion.1 hx with ⟨_hhull, hxhull⟩
    exact originConnectedHullAssignmentEvent_subset_originSpinDownAssignmentEvent hxhull

theorem exists_mem_inside_same_row_ge_of_mem_boundaryConnectedHullRegion
    {n : ℕ} {inside : Region GridNode} {a : GridNode}
    (haHull : a ∈ boundaryConnectedHullRegion n inside) :
    ∃ i, a.1 ≤ i ∧ (i, a.2) ∈ inside := by
  by_contra hNo
  have haStage : a ∈ gridExhaustion.region n := (mem_boundaryConnectedHullRegion_iff.1 haHull).1
  have ha1Le : a.1 ≤ n := by
    exact Nat.le_of_lt_succ ((Finset.mem_product.1 haStage).1 |> Finset.mem_range.mp)
  have ha2Le : a.2 ≤ n := by
    exact Nat.le_of_lt_succ ((Finset.mem_product.1 haStage).2 |> Finset.mem_range.mp)
  have haExt : a ∈ boundaryConnectedOutsideSubregion n inside := by
    refine mem_boundaryConnectedOutsideSubregion_of_outside_row_to_boundary
      (i := a.1) (j := a.2) ha1Le ha2Le ?_
    intro k hk1 hk2 hkIn
    exact hNo ⟨k, hk1, hkIn⟩
  exact (mem_boundaryConnectedHullRegion_iff.1 haHull).2 haExt

theorem exists_mem_inside_same_col_ge_of_mem_boundaryConnectedHullRegion
    {n : ℕ} {inside : Region GridNode} {a : GridNode}
    (haHull : a ∈ boundaryConnectedHullRegion n inside) :
    ∃ j, a.2 ≤ j ∧ (a.1, j) ∈ inside := by
  by_contra hNo
  have haStage : a ∈ gridExhaustion.region n := (mem_boundaryConnectedHullRegion_iff.1 haHull).1
  have ha1Le : a.1 ≤ n := by
    exact Nat.le_of_lt_succ ((Finset.mem_product.1 haStage).1 |> Finset.mem_range.mp)
  have ha2Le : a.2 ≤ n := by
    exact Nat.le_of_lt_succ ((Finset.mem_product.1 haStage).2 |> Finset.mem_range.mp)
  have haExt : a ∈ boundaryConnectedOutsideSubregion n inside := by
    refine mem_boundaryConnectedOutsideSubregion_of_outside_col_to_boundary
      (i := a.1) (j := a.2) ha1Le ha2Le ?_
    intro k hk1 hk2 hkIn
    exact hNo ⟨k, hk1, hkIn⟩
  exact (mem_boundaryConnectedHullRegion_iff.1 haHull).2 haExt

theorem mem_boundaryConnectedHullRegion_row_segment_to_inside
    {n : ℕ} {inside : Region GridNode}
    (hInside : inside ⊆ gridExhaustion.region n)
    {a : GridNode}
    (haHull : a ∈ boundaryConnectedHullRegion n inside) :
    ∃ i, a.1 ≤ i ∧ (i, a.2) ∈ inside ∧
      ∀ k, a.1 ≤ k → k ≤ i → (k, a.2) ∈ boundaryConnectedHullRegion n inside := by
  rcases exists_mem_inside_same_row_ge_of_mem_boundaryConnectedHullRegion haHull with
    ⟨i0, hi0ge, hi0In⟩
  let P : ℕ → Prop := fun i => a.1 ≤ i ∧ (i, a.2) ∈ inside
  have hP : ∃ i, P i := ⟨i0, hi0ge, hi0In⟩
  let i := Nat.find hP
  have hai : a.1 ≤ i := (Nat.find_spec hP).1
  have hiIn : (i, a.2) ∈ inside := (Nat.find_spec hP).2
  refine ⟨i, hai, hiIn, ?_⟩
  intro k hk1 hk2
  obtain ⟨t, rfl⟩ := Nat.exists_eq_add_of_le hk1
  have hwalk :
      ∀ t, a.1 + t ≤ i →
        (a.1 + t, a.2) ∈ boundaryConnectedHullRegion n inside := by
    intro t
    induction t with
    | zero =>
        intro _
        simpa using haHull
    | succ t ih =>
        intro hle
        have hprevLe : a.1 + t ≤ i := by omega
        have hprevHull : (a.1 + t, a.2) ∈ boundaryConnectedHullRegion n inside := ih hprevLe
        have hprevNotIn : (a.1 + t, a.2) ∉ inside := by
          intro hIn
          have hfindLe : i ≤ a.1 + t := Nat.find_min' hP ⟨by omega, hIn⟩
          omega
        have hiStage : (i, a.2) ∈ gridExhaustion.region n := hInside hiIn
        rcases Finset.mem_product.1 hiStage with ⟨hiRange, hjRange⟩
        have hnextStage : (a.1 + t + 1, a.2) ∈ gridExhaustion.region n := by
          refine Finset.mem_product.mpr ?_
          constructor
          · exact Finset.mem_range.mpr (by
              have hiLt : i < n + 1 := Finset.mem_range.mp hiRange
              omega)
          · exact Finset.mem_range.mpr (Finset.mem_range.mp hjRange)
        by_cases hnextHull : (a.1 + t + 1, a.2) ∈ boundaryConnectedHullRegion n inside
        · exact hnextHull
        · have hnextExt : (a.1 + t + 1, a.2) ∈ boundaryConnectedOutsideSubregion n inside := by
            rcases not_mem_boundaryConnectedHullRegion_iff.1 hnextHull with hNotStage | hExt
            · exact False.elim (hNotStage hnextStage)
            · exact hExt
          have hprevIn : (a.1 + t, a.2) ∈ inside :=
            mem_inside_of_mem_boundaryConnectedHullRegion_of_adj_boundaryConnectedOutside
              hprevHull hnextExt (gridAdjacent_horizontal_forward (a.1 + t) a.2)
          exact False.elim (hprevNotIn hprevIn)
  simpa using hwalk t hk2

theorem mem_boundaryConnectedHullRegion_col_segment_to_inside
    {n : ℕ} {inside : Region GridNode}
    (hInside : inside ⊆ gridExhaustion.region n)
    {a : GridNode}
    (haHull : a ∈ boundaryConnectedHullRegion n inside) :
    ∃ j, a.2 ≤ j ∧ (a.1, j) ∈ inside ∧
      ∀ k, a.2 ≤ k → k ≤ j → (a.1, k) ∈ boundaryConnectedHullRegion n inside := by
  rcases exists_mem_inside_same_col_ge_of_mem_boundaryConnectedHullRegion haHull with
    ⟨j0, hj0ge, hj0In⟩
  let P : ℕ → Prop := fun j => a.2 ≤ j ∧ (a.1, j) ∈ inside
  have hP : ∃ j, P j := ⟨j0, hj0ge, hj0In⟩
  let j := Nat.find hP
  have haj : a.2 ≤ j := (Nat.find_spec hP).1
  have hjIn : (a.1, j) ∈ inside := (Nat.find_spec hP).2
  refine ⟨j, haj, hjIn, ?_⟩
  intro k hk1 hk2
  obtain ⟨t, rfl⟩ := Nat.exists_eq_add_of_le hk1
  have hwalk :
      ∀ t, a.2 + t ≤ j →
        (a.1, a.2 + t) ∈ boundaryConnectedHullRegion n inside := by
    intro t
    induction t with
    | zero =>
        intro _
        simpa using haHull
    | succ t ih =>
        intro hle
        have hprevLe : a.2 + t ≤ j := by omega
        have hprevHull : (a.1, a.2 + t) ∈ boundaryConnectedHullRegion n inside := ih hprevLe
        have hprevNotIn : (a.1, a.2 + t) ∉ inside := by
          intro hIn
          have hfindLe : j ≤ a.2 + t := Nat.find_min' hP ⟨by omega, hIn⟩
          omega
        have hjStage : (a.1, j) ∈ gridExhaustion.region n := hInside hjIn
        rcases Finset.mem_product.1 hjStage with ⟨hiRange, hjRange⟩
        have hnextStage : (a.1, a.2 + t + 1) ∈ gridExhaustion.region n := by
          refine Finset.mem_product.mpr ?_
          constructor
          · exact Finset.mem_range.mpr (Finset.mem_range.mp hiRange)
          · exact Finset.mem_range.mpr (by
              have hjLt : j < n + 1 := Finset.mem_range.mp hjRange
              omega)
        by_cases hnextHull : (a.1, a.2 + t + 1) ∈ boundaryConnectedHullRegion n inside
        · exact hnextHull
        · have hnextExt : (a.1, a.2 + t + 1) ∈ boundaryConnectedOutsideSubregion n inside := by
            rcases not_mem_boundaryConnectedHullRegion_iff.1 hnextHull with hNotStage | hExt
            · exact False.elim (hNotStage hnextStage)
            · exact hExt
          have hprevIn : (a.1, a.2 + t) ∈ inside :=
            mem_inside_of_mem_boundaryConnectedHullRegion_of_adj_boundaryConnectedOutside
              hprevHull hnextExt (gridAdjacent_vertical_forward a.1 (a.2 + t))
          exact False.elim (hprevNotIn hprevIn)
  simpa using hwalk t hk2

theorem exists_reach_inside_of_mem_boundaryConnectedHullRegion
    {n : ℕ} {inside : Region GridNode}
    (hInside : inside ⊆ gridExhaustion.region n)
    {a : GridNode}
    (haHull : a ∈ boundaryConnectedHullRegion n inside) :
    ∃ b ∈ inside,
      Relation.ReflTransGen (gridAdjacentInRegion (boundaryConnectedHullRegion n inside)) a b := by
  rcases mem_boundaryConnectedHullRegion_row_segment_to_inside hInside haHull with
    ⟨i, hai, hiIn, hseg⟩
  refine ⟨(i, a.2), hiIn, ?_⟩
  have hwalk :
      ∀ u, a.1 ≤ u → u ≤ i →
        Relation.ReflTransGen
          (gridAdjacentInRegion (boundaryConnectedHullRegion n inside))
          a (u, a.2) := by
    intro u hu1 hu2
    obtain ⟨t, rfl⟩ := Nat.exists_eq_add_of_le hu1
    induction t with
    | zero =>
        simpa using Relation.ReflTransGen.refl
    | succ t ih =>
        have hprevLe : a.1 + t ≤ i := by
          exact le_trans (Nat.le_add_right (a.1 + t) 1) hu2
        have hprev : Relation.ReflTransGen
            (gridAdjacentInRegion (boundaryConnectedHullRegion n inside))
            a (a.1 + t, a.2) := ih (Nat.le_add_right a.1 t) hprevLe
        have hprevMem : (a.1 + t, a.2) ∈ boundaryConnectedHullRegion n inside :=
          hseg _ (Nat.le_add_right a.1 t) hprevLe
        have hnextMem : (a.1 + t + 1, a.2) ∈ boundaryConnectedHullRegion n inside :=
          hseg _ (Nat.le_add_right a.1 (t + 1)) hu2
        exact Relation.ReflTransGen.tail hprev
          ⟨hprevMem, hnextMem, gridAdjacent_horizontal_forward (a.1 + t) a.2⟩
  exact hwalk i hai le_rfl

theorem originConnectedRegion_boundaryConnectedHullRegion
    {n : ℕ} {inside : Region GridNode}
    (hInside : inside ⊆ gridExhaustion.region n)
    (hconn : OriginConnectedRegion inside) :
    OriginConnectedRegion (boundaryConnectedHullRegion n inside) := by
  refine ⟨inside_subset_boundaryConnectedHullRegion hInside hconn.1, ?_⟩
  intro a ha
  rcases exists_reach_inside_of_mem_boundaryConnectedHullRegion hInside ha with
    ⟨b, hbIn, hab⟩
  have hOriginToBInside :
      Relation.ReflTransGen (gridAdjacentInRegion inside) gridOrigin b :=
    hconn.2 b hbIn
  have hOriginToBHull :
      Relation.ReflTransGen (gridAdjacentInRegion (boundaryConnectedHullRegion n inside))
        gridOrigin b :=
    reflTransGen_gridAdjacentInRegion_mono
      (inside_subset_boundaryConnectedHullRegion hInside) hOriginToBInside
  exact hOriginToBHull.trans (reflTransGen_gridAdjacentInRegion_symm hab)

theorem mem_originConnectedHullContainingSubregions_imp_originConnected
    {n : ℕ} {hull : Region GridNode}
    (hhull : hull ∈ originConnectedHullContainingSubregions n) :
    OriginConnectedRegion hull := by
  rcases mem_originConnectedHullContainingSubregions_iff.1 hhull with
    ⟨inside, hinside, rfl⟩
  rcases mem_originConnectedContainingSubregions_iff.1 hinside with ⟨hInside, hconn⟩
  exact originConnectedRegion_boundaryConnectedHullRegion hInside hconn

theorem mem_originConnectedHullContainingSubregions_imp_stageCoConnected
    {n : ℕ} {hull : Region GridNode}
    (hhull : hull ∈ originConnectedHullContainingSubregions n) :
    StageCoConnectedRegion n hull := by
  rcases mem_originConnectedHullContainingSubregions_iff.1 hhull with
    ⟨inside, _hinside, rfl⟩
  exact stageCoConnected_boundaryConnectedHullRegion n inside

theorem mem_originConnectedHullContainingSubregions_imp_connected_and_stageCoConnected
    {n : ℕ} {hull : Region GridNode}
    (hhull : hull ∈ originConnectedHullContainingSubregions n) :
    OriginConnectedRegion hull ∧ StageCoConnectedRegion n hull :=
  ⟨mem_originConnectedHullContainingSubregions_imp_originConnected hhull,
    mem_originConnectedHullContainingSubregions_imp_stageCoConnected hhull⟩

theorem eq_of_originConnectedRegion_of_cutBaseClauses_eq
    {n : ℕ} {inside₁ inside₂ : Region GridNode}
    (hInside₁ : inside₁ ⊆ gridExhaustion.region n)
    (hInside₂ : inside₂ ⊆ gridExhaustion.region n)
    (hconn₁ : OriginConnectedRegion inside₁)
    (hconn₂ : OriginConnectedRegion inside₂)
    (hcuts :
      (gridRegionSupport (gridExhaustion.region n)).filter (gridBaseClauseCutsRegion inside₁) =
        (gridRegionSupport (gridExhaustion.region n)).filter (gridBaseClauseCutsRegion inside₂)) :
    inside₁ = inside₂ := by
  ext a
  constructor
  · intro ha₁
    have hreach₁ : Relation.ReflTransGen (gridAdjacentInRegion inside₁) gridOrigin a :=
      hconn₁.2 a ha₁
    have hmem₂ :
        ∀ {b : GridNode},
          Relation.ReflTransGen (gridAdjacentInRegion inside₁) gridOrigin b →
            b ∈ inside₂ := by
      intro b hreach
      induction hreach with
      | refl =>
          exact hconn₂.1
      | @tail b c hreach hstep ih =>
          have hb₂ : b ∈ inside₂ := ih
          let j := gridAdjacentClauseId b c
          have hjSupp : j ∈ gridRegionSupport (gridExhaustion.region n) := by
            apply gridRegionSupport_complete
            exact clauseTouchesRegion_gridAdjacentClauseId_of_mem_left (hInside₁ hstep.1) hstep.2.2
          have hnotcut₁ : ¬ gridBaseClauseCutsRegion inside₁ j := by
            exact not_gridBaseClauseCutsRegion_gridAdjacentClauseId_of_mem_mem
              hstep.1 hstep.2.1 hstep.2.2
          have hnotcut₂ : ¬ gridBaseClauseCutsRegion inside₂ j := by
            intro hcut₂
            have hj₂ :
                j ∈ (gridRegionSupport (gridExhaustion.region n)).filter
                    (gridBaseClauseCutsRegion inside₂) :=
              Finset.mem_filter.2 ⟨hjSupp, hcut₂⟩
            have hj₁ :
                j ∈ (gridRegionSupport (gridExhaustion.region n)).filter
                    (gridBaseClauseCutsRegion inside₁) := by
              simpa [hcuts] using hj₂
            exact hnotcut₁ (Finset.mem_filter.1 hj₁).2
          exact
            (mem_iff_mem_of_not_gridBaseClauseCutsRegion_gridAdjacentClauseId
              hstep.2.2 hnotcut₂).1 hb₂
    exact hmem₂ hreach₁
  · intro ha₂
    have hreach₂ : Relation.ReflTransGen (gridAdjacentInRegion inside₂) gridOrigin a :=
      hconn₂.2 a ha₂
    have hmem₁ :
        ∀ {b : GridNode},
          Relation.ReflTransGen (gridAdjacentInRegion inside₂) gridOrigin b →
            b ∈ inside₁ := by
      intro b hreach
      induction hreach with
      | refl =>
          exact hconn₁.1
      | @tail b c hreach hstep ih =>
          have hb₁ : b ∈ inside₁ := ih
          let j := gridAdjacentClauseId b c
          have hjSupp : j ∈ gridRegionSupport (gridExhaustion.region n) := by
            apply gridRegionSupport_complete
            exact clauseTouchesRegion_gridAdjacentClauseId_of_mem_left (hInside₂ hstep.1) hstep.2.2
          have hnotcut₂ : ¬ gridBaseClauseCutsRegion inside₂ j := by
            exact not_gridBaseClauseCutsRegion_gridAdjacentClauseId_of_mem_mem
              hstep.1 hstep.2.1 hstep.2.2
          have hnotcut₁ : ¬ gridBaseClauseCutsRegion inside₁ j := by
            intro hcut₁
            have hj₁ :
                j ∈ (gridRegionSupport (gridExhaustion.region n)).filter
                    (gridBaseClauseCutsRegion inside₁) :=
              Finset.mem_filter.2 ⟨hjSupp, hcut₁⟩
            have hj₂ :
                j ∈ (gridRegionSupport (gridExhaustion.region n)).filter
                    (gridBaseClauseCutsRegion inside₂) := by
              simpa [hcuts] using hj₁
            exact hnotcut₂ (Finset.mem_filter.1 hj₂).2
          exact
            (mem_iff_mem_of_not_gridBaseClauseCutsRegion_gridAdjacentClauseId
              hstep.2.2 hnotcut₁).1 hb₁
    exact hmem₁ hreach₂

theorem cutBaseClauses_injOn_originConnectedHullContainingSubregions
    (n : ℕ) :
    Set.InjOn
      (fun hull : Region GridNode =>
        (gridRegionSupport (gridExhaustion.region n)).filter (gridBaseClauseCutsRegion hull))
      (↑(originConnectedHullContainingSubregions n) : Set (Region GridNode)) := by
  intro hull₁ hhull₁ hull₂ hhull₂ hEq
  exact eq_of_originConnectedRegion_of_cutBaseClauses_eq
    (hInside₁ := (mem_originContainingSubregions_iff.1
      (mem_originConnectedHullContainingSubregions_imp_originContaining hhull₁)).1)
    (hInside₂ := (mem_originContainingSubregions_iff.1
      (mem_originConnectedHullContainingSubregions_imp_originContaining hhull₂)).1)
    (hconn₁ := mem_originConnectedHullContainingSubregions_imp_originConnected hhull₁)
    (hconn₂ := mem_originConnectedHullContainingSubregions_imp_originConnected hhull₂)
    hEq

theorem fst_lt_originContainingSubregionCutCard_of_mem_originConnectedHullContainingSubregions
    {n : ℕ} {hull : Region GridNode} {a : GridNode}
    (hhull : hull ∈ originConnectedHullContainingSubregions n)
    (ha : a ∈ hull) :
    a.1 < originContainingSubregionCutCard n hull := by
  rcases mem_originConnectedHullContainingSubregions_iff.1 hhull with ⟨inside, hinside, rfl⟩
  rcases mem_originConnectedContainingSubregions_iff.1 hinside with ⟨hInside, hconn⟩
  rcases exists_mem_inside_same_row_ge_of_mem_boundaryConnectedHullRegion ha with ⟨i, hai, hiIn⟩
  have hiLt :
      i < originContainingSubregionOuterCutCard n inside :=
    fst_lt_originContainingSubregionOuterCutCard_of_mem_originConnectedContainingSubregions
      hinside hiIn
  have hcutEq :
      originContainingSubregionCutCard n (boundaryConnectedHullRegion n inside) =
        originContainingSubregionOuterCutCard n inside :=
    originContainingSubregionCutCard_boundaryConnectedHullRegion_eq_outerCutCard hInside
  exact lt_of_le_of_lt hai (by simpa [hcutEq] using hiLt)

theorem snd_lt_originContainingSubregionCutCard_of_mem_originConnectedHullContainingSubregions
    {n : ℕ} {hull : Region GridNode} {a : GridNode}
    (hhull : hull ∈ originConnectedHullContainingSubregions n)
    (ha : a ∈ hull) :
    a.2 < originContainingSubregionCutCard n hull := by
  rcases mem_originConnectedHullContainingSubregions_iff.1 hhull with ⟨inside, hinside, rfl⟩
  rcases mem_originConnectedContainingSubregions_iff.1 hinside with ⟨hInside, hconn⟩
  rcases exists_mem_inside_same_col_ge_of_mem_boundaryConnectedHullRegion ha with ⟨j, haj, hjIn⟩
  have hjLt :
      j < originContainingSubregionOuterCutCard n inside :=
    snd_lt_originContainingSubregionOuterCutCard_of_mem_originConnectedContainingSubregions
      hinside hjIn
  have hcutEq :
      originContainingSubregionCutCard n (boundaryConnectedHullRegion n inside) =
        originContainingSubregionOuterCutCard n inside :=
    originContainingSubregionCutCard_boundaryConnectedHullRegion_eq_outerCutCard hInside
  exact lt_of_le_of_lt haj (by simpa [hcutEq] using hjLt)

theorem originConnectedHullContainingSubregion_subset_cutCardBox
    {n : ℕ} {hull : Region GridNode}
    (hhull : hull ∈ originConnectedHullContainingSubregions n) :
    hull ⊆
      Finset.product
        (Finset.range (originContainingSubregionCutCard n hull))
        (Finset.range (originContainingSubregionCutCard n hull)) := by
  intro a ha
  exact Finset.mem_product.mpr
    ⟨Finset.mem_range.mpr
        (fst_lt_originContainingSubregionCutCard_of_mem_originConnectedHullContainingSubregions
          hhull ha),
      Finset.mem_range.mpr
        (snd_lt_originContainingSubregionCutCard_of_mem_originConnectedHullContainingSubregions
          hhull ha)⟩

theorem originSpinDownExtractedHull_subset_cutCardBox
    {n : ℕ} {hull : Region GridNode}
    (hhull : hull ∈ originSpinDownExtractedHulls n) :
    hull ⊆
      Finset.product
        (Finset.range (originContainingSubregionCutCard n hull))
        (Finset.range (originContainingSubregionCutCard n hull)) := by
  exact originConnectedHullContainingSubregion_subset_cutCardBox
    (mem_originSpinDownExtractedHulls_imp_mem_originConnectedHullContainingSubregions hhull)

/-- The local `m × m` box forced by a cut-card `m` extracted hull. -/
noncomputable def cutCardBoxRegion (m : ℕ) : Region GridNode :=
  Finset.product (Finset.range m) (Finset.range m)

theorem cutCardBoxRegion_eq_gridExhaustion_region_pred
    {m : ℕ} (hm : 0 < m) :
    cutCardBoxRegion m = gridExhaustion.region (m - 1) := by
  have hmEq : m - 1 + 1 = m := Nat.succ_pred_eq_of_pos hm
  ext a
  rcases a with ⟨i, j⟩
  simp [cutCardBoxRegion, gridExhaustion, hmEq]

/-- Stage-independent candidate regions for cut-card `m`: any origin-containing
subset of the local `m × m` box. Extracted hull fibers inject into this family. -/
noncomputable def originContainingSubregionsInCutCardBox (m : ℕ) : Finset (Region GridNode) :=
  (cutCardBoxRegion m).powerset.filter (fun hull => gridOrigin ∈ hull)

/-- A sharper local candidate family for cut-card `m`: canonical
boundary-connected hulls already realized in the local `m × m` box viewed as
stage `m - 1`. -/
noncomputable def originConnectedHullContainingSubregionsInCutCardBox
    (m : ℕ) : Finset (Region GridNode) :=
  originConnectedHullContainingSubregions (m - 1)

theorem mem_originConnectedHullContainingSubregionsInCutCardBox_imp_subset_stage
    {m : ℕ} {hull : Region GridNode}
    (hhull : hull ∈ originConnectedHullContainingSubregionsInCutCardBox m) :
    hull ⊆ gridExhaustion.region (m - 1) := by
  have hhull' : hull ∈ originConnectedHullContainingSubregions (m - 1) := by
    simpa [originConnectedHullContainingSubregionsInCutCardBox] using hhull
  exact (mem_originContainingSubregions_iff.1
    (mem_originConnectedHullContainingSubregions_imp_originContaining hhull')).1

theorem visibleOuterBoundary_nonempty_of_mem_originConnectedHullContainingSubregionsInCutCardBox
    {m : ℕ} {hull : Region GridNode}
    (hm : 1 ≤ m)
    (hhull : hull ∈ originConnectedHullContainingSubregionsInCutCardBox m) :
    (visibleOuterBoundary m hull).Nonempty := by
  have hhull' : hull ∈ originConnectedHullContainingSubregions (m - 1) := by
    simpa [originConnectedHullContainingSubregionsInCutCardBox] using hhull
  have horigin :
      hull ∈ originContainingSubregions (m - 1) :=
    mem_originConnectedHullContainingSubregions_imp_originContaining hhull'
  rcases originContainingSubregion_exists_horizontalCut horigin with
    ⟨i, j, hcutMem⟩
  have hcut :
      gridBaseClauseCutsRegion hull (GridClauseId.horizontal i j) :=
    (Finset.mem_filter.1 hcutMem).2
  have hHull :
      hull ⊆ gridExhaustion.region (m - 1) :=
    mem_originConnectedHullContainingSubregionsInCutCardBox_imp_subset_stage hhull
  have hco : StageCoConnectedRegion (m - 1) hull :=
    mem_originConnectedHullContainingSubregions_imp_stageCoConnected hhull'
  rcases exists_visibleOuterBoundary_primalEndpoint_of_gridBaseClauseCutsRegion
      hm hHull hco hcut with
    ⟨p, hpVisible, _hpEndpoint, _hpNotHull⟩
  exact ⟨p, hpVisible⟩

theorem mem_originContainingSubregionsInCutCardBox_iff
    {m : ℕ} {hull : Region GridNode} :
    hull ∈ originContainingSubregionsInCutCardBox m ↔
      hull ⊆ cutCardBoxRegion m ∧ gridOrigin ∈ hull := by
  classical
  simp [originContainingSubregionsInCutCardBox, cutCardBoxRegion, Finset.mem_powerset]

theorem originSpinDownExtractedHulls_filter_cutCard_subset_cutCardBoxCandidates
    (n m : ℕ) :
    (originSpinDownExtractedHulls n).filter
        (fun hull => originContainingSubregionCutCard n hull = m) ⊆
      originContainingSubregionsInCutCardBox m := by
  intro hull hhull
  rcases Finset.mem_filter.1 hhull with ⟨hhull0, hcutEq⟩
  rw [mem_originContainingSubregionsInCutCardBox_iff]
  constructor
  · intro a ha
    have hbox :
        a ∈ Finset.product
          (Finset.range (originContainingSubregionCutCard n hull))
          (Finset.range (originContainingSubregionCutCard n hull)) :=
      originSpinDownExtractedHull_subset_cutCardBox hhull0 ha
    simpa [cutCardBoxRegion, hcutEq] using hbox
  · have hHullFam :
        hull ∈ originConnectedHullContainingSubregions n :=
      mem_originSpinDownExtractedHulls_imp_mem_originConnectedHullContainingSubregions hhull0
    have hOriginContaining :
        hull ∈ originContainingSubregions n :=
      mem_originConnectedHullContainingSubregions_imp_originContaining hHullFam
    exact (mem_originContainingSubregions_iff.1 hOriginContaining).2

theorem originSpinDownExtractedHulls_cutCard_count_le_cutCardBoxCandidateCount
    (n m : ℕ) :
    (((originSpinDownExtractedHulls n).filter
        (fun hull => originContainingSubregionCutCard n hull = m)).card : ENNReal) ≤
      ((originContainingSubregionsInCutCardBox m).card : ENNReal) := by
  have hcard :
      ((originSpinDownExtractedHulls n).filter
          (fun hull => originContainingSubregionCutCard n hull = m)).card ≤
        (originContainingSubregionsInCutCardBox m).card :=
    Finset.card_le_card
      (originSpinDownExtractedHulls_filter_cutCard_subset_cutCardBoxCandidates n m)
  exact_mod_cast hcard

theorem originSpinDownExtractedHulls_filter_cutCard_subset_cutCardBoxHullCandidates
    (n m : ℕ) (hm : 2 ≤ m) :
    (originSpinDownExtractedHulls n).filter
        (fun hull => originContainingSubregionCutCard n hull = m) ⊆
      (originConnectedHullContainingSubregionsInCutCardBox m).filter
        (fun hull => originContainingSubregionCutCard (m - 1) hull = m) := by
  intro hull hhull
  rcases Finset.mem_filter.1 hhull with ⟨hhull0, hcutEq⟩
  have hmPos : 0 < m := lt_of_lt_of_le (by decide : 0 < 2) hm
  have hHullSmall :
      hull ⊆ gridExhaustion.region (m - 1) := by
    intro a ha
    have hbox := originSpinDownExtractedHull_subset_cutCardBox hhull0 ha
    rcases Finset.mem_product.1 hbox with ⟨ha1, ha2⟩
    have hmEq : m - 1 + 1 = m := Nat.succ_pred_eq_of_pos hmPos
    exact Finset.mem_product.mpr <|
      ⟨by simpa [gridExhaustion, hmEq, hcutEq] using ha1,
       by simpa [gridExhaustion, hmEq, hcutEq] using ha2⟩
  have hHullFamBig :
      hull ∈ originConnectedHullContainingSubregions n :=
    mem_originSpinDownExtractedHulls_imp_mem_originConnectedHullContainingSubregions hhull0
  have hHullFamSmall :
      hull ∈ originConnectedHullContainingSubregionsInCutCardBox m := by
    rcases mem_originConnectedHullContainingSubregions_iff.1 hHullFamBig with
      ⟨inside, hinsideBig, hHullEq⟩
    rcases mem_originConnectedContainingSubregions_iff.1 hinsideBig with
      ⟨hInsideBig, hconn⟩
    have hInsideHull :
        inside ⊆ hull := by
      intro a ha
      simpa [hHullEq] using
        (inside_subset_boundaryConnectedHullRegion hInsideBig ha)
    have hInsideSmall :
        inside ⊆ gridExhaustion.region (m - 1) := by
      intro a ha
      exact hHullSmall (hInsideHull ha)
    have hHullEqSmall :
        boundaryConnectedHullRegion (m - 1) inside = hull := by
      rw [← hHullEq]
      exact (boundaryConnectedHullRegion_eq_of_stage_subsets hInsideSmall hInsideBig).symm
    unfold originConnectedHullContainingSubregionsInCutCardBox
    exact mem_originConnectedHullContainingSubregions_iff.2
      ⟨inside,
        (mem_originConnectedContainingSubregions_iff.2 ⟨hInsideSmall, hconn⟩),
        hHullEqSmall⟩
  have hHullStageBig :
      hull ⊆ gridExhaustion.region n := by
    exact (mem_originContainingSubregions_iff.1
      (mem_originConnectedHullContainingSubregions_imp_originContaining hHullFamBig)).1
  have hcutEqSmall :
      originContainingSubregionCutCard (m - 1) hull = m := by
    have hcutStages :
        originContainingSubregionCutCard n hull =
          originContainingSubregionCutCard (m - 1) hull :=
      originContainingSubregionCutCard_eq_of_stage_subsets hHullSmall hHullStageBig
    simpa [hcutStages] using hcutEq
  exact Finset.mem_filter.2 ⟨hHullFamSmall, hcutEqSmall⟩

theorem originSpinDownExtractedHulls_cutCard_count_le_cutCardBoxHullCandidateCount
    (n m : ℕ) (hm : 2 ≤ m) :
    (((originSpinDownExtractedHulls n).filter
        (fun hull => originContainingSubregionCutCard n hull = m)).card : ENNReal) ≤
      ((((originConnectedHullContainingSubregionsInCutCardBox m).filter
          (fun hull => originContainingSubregionCutCard (m - 1) hull = m)).card) : ENNReal) := by
  have hcard :
      ((originSpinDownExtractedHulls n).filter
          (fun hull => originContainingSubregionCutCard n hull = m)).card ≤
        ((originConnectedHullContainingSubregionsInCutCardBox m).filter
          (fun hull => originContainingSubregionCutCard (m - 1) hull = m)).card :=
    Finset.card_le_card
      (originSpinDownExtractedHulls_filter_cutCard_subset_cutCardBoxHullCandidates n m hm)
  exact_mod_cast hcard

/-- A still sharper local candidate family for cut-card `m`: the actual stage
`m - 1` cut sets realized by canonical boundary-connected hulls of cut-card
exactly `m`. Counting these cut sets is enough once we know the hull is
determined by its cut set. -/
noncomputable def originConnectedHullCutSetCandidatesInCutCardBox
    (m : ℕ) : Finset (Finset GridClauseId) :=
  ((originConnectedHullContainingSubregionsInCutCardBox m).filter
      (fun hull => originContainingSubregionCutCard (m - 1) hull = m)).image
    (fun hull =>
      (gridRegionSupport (gridExhaustion.region (m - 1))).filter
        (gridBaseClauseCutsRegion hull))

theorem mem_originConnectedHullCutSetCandidatesInCutCardBox_iff
    {m : ℕ} {s : Finset GridClauseId} :
    s ∈ originConnectedHullCutSetCandidatesInCutCardBox m ↔
      ∃ hull ∈ originConnectedHullContainingSubregionsInCutCardBox m,
        originContainingSubregionCutCard (m - 1) hull = m ∧
          s =
            (gridRegionSupport (gridExhaustion.region (m - 1))).filter
              (gridBaseClauseCutsRegion hull) := by
  classical
  unfold originConnectedHullCutSetCandidatesInCutCardBox
  constructor
  · intro hs
    rcases Finset.mem_image.1 hs with ⟨hull, hhull, rfl⟩
    exact ⟨hull, (Finset.mem_filter.1 hhull).1, (Finset.mem_filter.1 hhull).2, rfl⟩
  · intro hs
    rcases hs with ⟨hull, hhull, hcut, rfl⟩
    exact Finset.mem_image.2 ⟨hull, Finset.mem_filter.2 ⟨hhull, hcut⟩, rfl⟩

theorem card_eq_of_mem_originConnectedHullCutSetCandidatesInCutCardBox
    {m : ℕ} {s : Finset GridClauseId}
    (hs : s ∈ originConnectedHullCutSetCandidatesInCutCardBox m) :
    s.card = m := by
  rcases mem_originConnectedHullCutSetCandidatesInCutCardBox_iff.1 hs with
    ⟨hull, _hhull, hcut, hsEq⟩
  rw [hsEq]
  simpa [originContainingSubregionCutCard] using hcut

theorem gridClauseStarAdjacent_of_sharePrimalEndpoint_of_mem_originConnectedHullCutSetCandidatesInCutCardBox
    {m : ℕ} {s : Finset GridClauseId} {c₁ c₂ : GridClauseId}
    (hs : s ∈ originConnectedHullCutSetCandidatesInCutCardBox m)
    (hc₁ : c₁ ∈ s) (hc₂ : c₂ ∈ s)
    (hshare : gridClausesSharePrimalEndpoint c₁ c₂) :
    gridClauseStarAdjacent c₁ c₂ := by
  rcases mem_originConnectedHullCutSetCandidatesInCutCardBox_iff.1 hs with
    ⟨hull, _hhull, _hcut, hsEq⟩
  have hcut₁ : gridBaseClauseCutsRegion hull c₁ := by
    rw [hsEq] at hc₁
    exact (Finset.mem_filter.1 hc₁).2
  have hcut₂ : gridBaseClauseCutsRegion hull c₂ := by
    rw [hsEq] at hc₂
    exact (Finset.mem_filter.1 hc₂).2
  exact gridClauseStarAdjacent_of_sharePrimalEndpoint_of_cuts
    hcut₁ hcut₂ hshare

theorem exists_bottomHorizontalCut_leftVerticalCut_of_mem_originConnectedHullCutSetCandidatesInCutCardBox
    {m : ℕ} {s : Finset GridClauseId}
    (hs : s ∈ originConnectedHullCutSetCandidatesInCutCardBox m) :
    ∃ i j,
      GridClauseId.horizontal i 0 ∈ s ∧
        GridClauseId.vertical 0 j ∈ s := by
  rcases mem_originConnectedHullCutSetCandidatesInCutCardBox_iff.1 hs with
    ⟨hull, hhullBox, _hcutCard, hsEq⟩
  have hhull :
      hull ∈ originConnectedHullContainingSubregions (m - 1) := by
    simpa [originConnectedHullContainingSubregionsInCutCardBox] using hhullBox
  rcases mem_originConnectedHullContainingSubregions_iff.1 hhull with
    ⟨inside, hinsideConn, hHullEq⟩
  rcases mem_originConnectedContainingSubregions_iff.1 hinsideConn with
    ⟨hInside, hconn⟩
  have hinsideOrigin :
      inside ∈ originContainingSubregions (m - 1) := by
    exact mem_originContainingSubregions_iff.2 ⟨hInside, hconn.1⟩
  have hrow0 : ∃ i, (i, 0) ∈ inside := by
    refine ⟨0, ?_⟩
    simpa [gridOrigin] using hconn.1
  have hcol0 : ∃ j, (0, j) ∈ inside := by
    refine ⟨0, ?_⟩
    simpa [gridOrigin] using hconn.1
  rcases originContainingSubregion_exists_outerHorizontalCut_on_row
      (n := m - 1) (j := 0) hinsideOrigin hrow0 with ⟨i, hhorOuter⟩
  rcases originContainingSubregion_exists_outerVerticalCut_on_col
      (n := m - 1) (i := 0) hinsideOrigin hcol0 with ⟨j, hvertOuter⟩
  have hcutEq :
      (gridRegionSupport (gridExhaustion.region (m - 1))).filter
          (gridBaseClauseCutsRegion hull) =
        originContainingSubregionOuterCutBaseClauses (m - 1) inside := by
    simpa [hHullEq] using
      originContainingSubregionCutBaseClauses_boundaryConnectedHullRegion_eq_outerCutBaseClauses
        (n := m - 1) hInside
  refine ⟨i, j, ?_, ?_⟩
  · rw [hsEq, hcutEq]
    exact hhorOuter
  · rw [hsEq, hcutEq]
    exact hvertOuter

theorem outerCutCard_lower_of_insideEndpoints
    {n : ℕ} {inside : Region GridNode}
    (hinside : inside ∈ originConnectedContainingSubregions n)
    {a b : GridNode}
    (ha : a ∈ inside) (hb : b ∈ inside) :
    a.1 + b.2 + 2 ≤ originContainingSubregionOuterCutCard n inside := by
  classical
  rcases mem_originConnectedContainingSubregions_iff.1 hinside with ⟨hInside, hconn⟩
  have hinside' : inside ∈ originContainingSubregions n :=
    mem_originContainingSubregions_iff.2 ⟨hInside, hconn.1⟩
  let fV : Fin (a.1 + 1) → GridClauseId := fun k =>
    GridClauseId.vertical
      k.1
      (Classical.choose
        (originContainingSubregion_exists_outerVerticalCut_on_col
          (n := n) (i := k.1) (inside := inside) hinside'
          (exists_mem_col_of_originConnected hconn ha k.1 (Nat.le_of_lt_succ k.2))))
  let fH : Fin (b.2 + 1) → GridClauseId := fun k =>
    GridClauseId.horizontal
      (Classical.choose
        (originContainingSubregion_exists_outerHorizontalCut_on_row
          (n := n) (j := k.1) (inside := inside) hinside'
          (exists_mem_row_of_originConnected hconn hb k.1 (Nat.le_of_lt_succ k.2))))
      k.1
  have hsubsetV :
      (Finset.univ.image fV) ⊆ originContainingSubregionOuterCutBaseClauses n inside := by
    intro j hj
    rcases Finset.mem_image.1 hj with ⟨k, _hk, rfl⟩
    exact Classical.choose_spec
      (originContainingSubregion_exists_outerVerticalCut_on_col
        (n := n) (i := k.1) (inside := inside) hinside'
        (exists_mem_col_of_originConnected hconn ha k.1 (Nat.le_of_lt_succ k.2)))
  have hsubsetH :
      (Finset.univ.image fH) ⊆ originContainingSubregionOuterCutBaseClauses n inside := by
    intro j hj
    rcases Finset.mem_image.1 hj with ⟨k, _hk, rfl⟩
    exact Classical.choose_spec
      (originContainingSubregion_exists_outerHorizontalCut_on_row
        (n := n) (j := k.1) (inside := inside) hinside'
        (exists_mem_row_of_originConnected hconn hb k.1 (Nat.le_of_lt_succ k.2)))
  have hinjV : Function.Injective fV := by
    intro k₁ k₂ hEq
    have hfst :
        (match fV k₁ with
          | GridClauseId.vertical i _ => i
          | _ => 0) =
        (match fV k₂ with
          | GridClauseId.vertical i _ => i
          | _ => 0) := by
      simpa [fV] using congrArg
        (fun c =>
          match c with
          | GridClauseId.vertical i _ => i
          | _ => 0) hEq
    exact Fin.ext hfst
  have hinjH : Function.Injective fH := by
    intro k₁ k₂ hEq
    have hsnd :
        (match fH k₁ with
          | GridClauseId.horizontal _ j => j
          | _ => 0) =
        (match fH k₂ with
          | GridClauseId.horizontal _ j => j
          | _ => 0) := by
      simpa [fH] using congrArg
        (fun c =>
          match c with
          | GridClauseId.horizontal _ j => j
          | _ => 0) hEq
    exact Fin.ext hsnd
  have hdisj :
      Disjoint (Finset.univ.image fV) (Finset.univ.image fH) := by
    rw [Finset.disjoint_left]
    intro j hjV hjH
    rcases Finset.mem_image.1 hjV with ⟨kV, _hkV, hEqV⟩
    rcases Finset.mem_image.1 hjH with ⟨kH, _hkH, hEqH⟩
    have hEq : fV kV = fH kH := hEqV.trans hEqH.symm
    simp [fV, fH] at hEq
  have hcard :
      ((Finset.univ : Finset (Fin (a.1 + 1))).card +
        (Finset.univ : Finset (Fin (b.2 + 1))).card) ≤
      (originContainingSubregionOuterCutBaseClauses n inside).card := by
    calc
      ((Finset.univ : Finset (Fin (a.1 + 1))).card +
          (Finset.univ : Finset (Fin (b.2 + 1))).card)
          = ((Finset.univ.image fV).card + (Finset.univ.image fH).card) := by
              rw [Finset.card_image_of_injective _ hinjV,
                Finset.card_image_of_injective _ hinjH]
      _ = ((Finset.univ.image fV) ∪ (Finset.univ.image fH)).card := by
              exact (Finset.card_union_of_disjoint hdisj).symm
      _ ≤ (originContainingSubregionOuterCutBaseClauses n inside).card := by
              apply Finset.card_le_card
              intro j hj
              rcases Finset.mem_union.1 hj with hjV | hjH
              · exact hsubsetV hjV
              · exact hsubsetH hjH
  unfold originContainingSubregionOuterCutCard
  simpa [Nat.add_assoc, Nat.add_left_comm, Nat.add_comm] using hcard

theorem exists_outerCutRowColSkeleton_of_insideEndpoints
    {n : ℕ} {inside : Region GridNode}
    (hinside : inside ∈ originConnectedContainingSubregions n)
    {a b : GridNode}
    (ha : a ∈ inside) (hb : b ∈ inside) :
    ∃ skel : Finset GridClauseId,
      skel ⊆ originContainingSubregionOuterCutBaseClauses n inside ∧
        skel.card = a.1 + b.2 + 2 := by
  classical
  rcases mem_originConnectedContainingSubregions_iff.1 hinside with ⟨hInside, hconn⟩
  have hinside' : inside ∈ originContainingSubregions n :=
    mem_originContainingSubregions_iff.2 ⟨hInside, hconn.1⟩
  let fV : Fin (a.1 + 1) → GridClauseId := fun k =>
    GridClauseId.vertical
      k.1
      (Classical.choose
        (originContainingSubregion_exists_outerVerticalCut_on_col
          (n := n) (i := k.1) (inside := inside) hinside'
          (exists_mem_col_of_originConnected hconn ha k.1 (Nat.le_of_lt_succ k.2))))
  let fH : Fin (b.2 + 1) → GridClauseId := fun k =>
    GridClauseId.horizontal
      (Classical.choose
        (originContainingSubregion_exists_outerHorizontalCut_on_row
          (n := n) (j := k.1) (inside := inside) hinside'
          (exists_mem_row_of_originConnected hconn hb k.1 (Nat.le_of_lt_succ k.2))))
      k.1
  let skel : Finset GridClauseId := (Finset.univ.image fV) ∪ (Finset.univ.image fH)
  have hsubsetV :
      (Finset.univ.image fV) ⊆ originContainingSubregionOuterCutBaseClauses n inside := by
    intro j hj
    rcases Finset.mem_image.1 hj with ⟨k, _hk, rfl⟩
    exact Classical.choose_spec
      (originContainingSubregion_exists_outerVerticalCut_on_col
        (n := n) (i := k.1) (inside := inside) hinside'
        (exists_mem_col_of_originConnected hconn ha k.1 (Nat.le_of_lt_succ k.2)))
  have hsubsetH :
      (Finset.univ.image fH) ⊆ originContainingSubregionOuterCutBaseClauses n inside := by
    intro j hj
    rcases Finset.mem_image.1 hj with ⟨k, _hk, rfl⟩
    exact Classical.choose_spec
      (originContainingSubregion_exists_outerHorizontalCut_on_row
        (n := n) (j := k.1) (inside := inside) hinside'
        (exists_mem_row_of_originConnected hconn hb k.1 (Nat.le_of_lt_succ k.2)))
  have hinjV : Function.Injective fV := by
    intro k₁ k₂ hEq
    have hfst :
        (match fV k₁ with
          | GridClauseId.vertical i _ => i
          | _ => 0) =
        (match fV k₂ with
          | GridClauseId.vertical i _ => i
          | _ => 0) := by
      simpa [fV] using congrArg
        (fun c =>
          match c with
          | GridClauseId.vertical i _ => i
          | _ => 0) hEq
    exact Fin.ext hfst
  have hinjH : Function.Injective fH := by
    intro k₁ k₂ hEq
    have hsnd :
        (match fH k₁ with
          | GridClauseId.horizontal _ j => j
          | _ => 0) =
        (match fH k₂ with
          | GridClauseId.horizontal _ j => j
          | _ => 0) := by
      simpa [fH] using congrArg
        (fun c =>
          match c with
          | GridClauseId.horizontal _ j => j
          | _ => 0) hEq
    exact Fin.ext hsnd
  have hdisj :
      Disjoint (Finset.univ.image fV) (Finset.univ.image fH) := by
    rw [Finset.disjoint_left]
    intro j hjV hjH
    rcases Finset.mem_image.1 hjV with ⟨kV, _hkV, hEqV⟩
    rcases Finset.mem_image.1 hjH with ⟨kH, _hkH, hEqH⟩
    have hEq : fV kV = fH kH := hEqV.trans hEqH.symm
    simp [fV, fH] at hEq
  have hsubset : skel ⊆ originContainingSubregionOuterCutBaseClauses n inside := by
    intro j hj
    have hj' : j ∈ (Finset.univ.image fV) ∪ (Finset.univ.image fH) := by
      simpa [skel] using hj
    rcases Finset.mem_union.1 hj' with hjV | hjH
    · exact hsubsetV hjV
    · exact hsubsetH hjH
  have hcard :
      skel.card = a.1 + b.2 + 2 := by
    calc
      skel.card = ((Finset.univ.image fV) ∪ (Finset.univ.image fH)).card := by
        rfl
      _ = (Finset.univ.image fV).card + (Finset.univ.image fH).card := by
        exact Finset.card_union_of_disjoint hdisj
      _ = (Finset.univ : Finset (Fin (a.1 + 1))).card +
            (Finset.univ : Finset (Fin (b.2 + 1))).card := by
        rw [Finset.card_image_of_injective _ hinjV, Finset.card_image_of_injective _ hinjH]
      _ = a.1 + b.2 + 2 := by
        rw [Finset.card_univ, Fintype.card_fin, Finset.card_univ, Fintype.card_fin]
        omega
  exact ⟨skel, hsubset, hcard⟩

theorem exists_outerCutRowColSkeleton_of_insideEndpoints_bounded
