theorem exists_adjacent_hull_of_gridBaseClauseCutsRegion_outside_primalEndpoint
    {hull : Region GridNode} {c : GridClauseId} {p : GridNode}
    (hcut : gridBaseClauseCutsRegion hull c)
    (hp : p ∈ gridClausePrimalEndpoints c)
    (hpNotHull : p ∉ hull) :
    ∃ q ∈ hull, gridAdjacent p q := by
  cases c with
  | prior i j =>
      cases hcut
  | horizontal i j =>
      simp [gridClausePrimalEndpoints] at hp
      rcases hcut with hcut | hcut
      · rcases hcut with ⟨hLeftHull, _hRightNotHull⟩
        rcases hp with hp | hp
        · subst hp
          exact False.elim (hpNotHull hLeftHull)
        · subst hp
          exact ⟨(i, j), hLeftHull, gridAdjacent_horizontal_backward i j⟩
      · rcases hcut with ⟨_hLeftNotHull, hRightHull⟩
        rcases hp with hp | hp
        · subst hp
          exact ⟨(i + 1, j), hRightHull, gridAdjacent_horizontal_forward i j⟩
        · subst hp
          exact False.elim (hpNotHull hRightHull)
  | vertical i j =>
      simp [gridClausePrimalEndpoints] at hp
      rcases hcut with hcut | hcut
      · rcases hcut with ⟨hDownHull, _hUpNotHull⟩
        rcases hp with hp | hp
        · subst hp
          exact False.elim (hpNotHull hDownHull)
        · subst hp
          exact ⟨(i, j), hDownHull, gridAdjacent_vertical_backward i j⟩
      · rcases hcut with ⟨_hDownNotHull, hUpHull⟩
        rcases hp with hp | hp
        · subst hp
          exact ⟨(i, j + 1), hUpHull, gridAdjacent_vertical_forward i j⟩
        · subst hp
          exact False.elim (hpNotHull hUpHull)

