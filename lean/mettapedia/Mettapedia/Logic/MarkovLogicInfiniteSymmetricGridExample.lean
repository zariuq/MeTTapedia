theorem mem_symmetricGridFlipGainAssignmentFinset_gridOriginSingletonCornerAxisSeparator_iff
    (n : ℕ) (ξ : BoundaryCondition GridNode)
    (x : LocalAssignment GridNode (gridExhaustion.region n)) :
    x ∈ symmetricGridFlipGainAssignmentFinset
          (gridOriginSingletonCornerAxisSeparator n).inside
          (gridOriginSingletonCornerAxisSeparator n).inside_subset ξ ↔
      patch (gridExhaustion.region n) x ξ gridOrigin = false ∧
        patch (gridExhaustion.region n) x ξ gridOriginEast = true ∧
        patch (gridExhaustion.region n) x ξ gridOriginNorth = true := by
  classical
  let sep := gridOriginSingletonCornerAxisSeparator n
  unfold symmetricGridFlipGainAssignmentFinset
  rw [Finset.mem_filter]
  constructor
  · intro hx
    have hcond := hx.2
    have hhor :=
      hcond (GridClauseId.horizontal 0 0)
        (cornerAxisSeparator_horizontalOrigin_mem_cutBaseClauses (sep := sep))
    have hvør :=
      hcond (GridClauseId.vertical 0 0)
        (cornerAxisSeparator_verticalOrigin_mem_cutBaseClauses (sep := sep))
    have horiginEast :
        patch (gridExhaustion.region n) x ξ gridOrigin = false ∧
          patch (gridExhaustion.region n) x ξ gridOriginEast = true := by
      simpa [sep, gridOriginSingletonCornerAxisSeparator,
        symmetricGridBaseClauseFlipGainCondition, gridOrigin, gridOriginEast]
        using hhor
    have horiginNorth :
        patch (gridExhaustion.region n) x ξ gridOrigin = false ∧
          patch (gridExhaustion.region n) x ξ gridOriginNorth = true := by
      simpa [sep, gridOriginSingletonCornerAxisSeparator,
        symmetricGridBaseClauseFlipGainCondition, gridOrigin, gridOriginNorth]
        using hvør
    exact ⟨horiginEast.1, horiginEast.2, horiginNorth.2⟩
  · intro hx
    refine ⟨by simp, ?_⟩
    intro j hj
    have hjcut : j ∈ sep.cutBaseClauses := by
      simpa [sep, CornerAxisSeparator.cutBaseClauses] using hj
    have hj' : j = GridClauseId.horizontal 0 0 ∨ j = GridClauseId.vertical 0 0 := by
      rw [gridOriginSingletonCornerAxisSeparator_cutBaseClauses] at hjcut
      simpa using hjcut
    rcases hj' with rfl | rfl
    · simpa [sep, gridOriginSingletonCornerAxisSeparator,
        symmetricGridBaseClauseFlipGainCondition, gridOrigin, gridOriginEast,
        hx.1, hx.2.1] using
          (show patch (gridExhaustion.region n) x ξ gridOrigin = false ∧
              patch (gridExhaustion.region n) x ξ gridOriginEast = true from
            ⟨hx.1, hx.2.1⟩)
    · simpa [sep, gridOriginSingletonCornerAxisSeparator,
        symmetricGridBaseClauseFlipGainCondition, gridOrigin, gridOriginNorth,
        hx.1, hx.2.2] using
          (show patch (gridExhaustion.region n) x ξ gridOrigin = false ∧
              patch (gridExhaustion.region n) x ξ gridOriginNorth = true from
            ⟨hx.1, hx.2.2⟩)

theorem gridOriginSingletonCornerAxisSeparator_falseInside_trueCutBoundary_iff
    (n : ℕ) (ξ : BoundaryCondition GridNode)
    (x : LocalAssignment GridNode (gridExhaustion.region n)) :
    CornerSeparatorFalseInsideTrueCutBoundary
        (gridOriginSingletonCornerAxisSeparator n) x ξ ↔
      patch (gridExhaustion.region n) x ξ gridOrigin = false ∧
        patch (gridExhaustion.region n) x ξ gridOriginEast = true ∧
        patch (gridExhaustion.region n) x ξ gridOriginNorth = true := by
  let sep := gridOriginSingletonCornerAxisSeparator n
  constructor
  · intro hsep
    rcases hsep with ⟨hinsideFalse, hcutTrue⟩
    have horigin :
        patch (gridExhaustion.region n) x ξ gridOrigin = false := by
      exact hinsideFalse gridOrigin (by simp [gridOriginSingletonCornerAxisSeparator, gridOrigin])
    have heast :
        patch (gridExhaustion.region n) x ξ gridOriginEast = true := by
      have hhor :=
        hcutTrue (GridClauseId.horizontal 0 0)
          (by
            simpa [CornerAxisSeparator.cutBaseClauses] using
              (cornerAxisSeparator_horizontalOrigin_mem_cutBaseClauses (sep := sep)))
      exact hhor.1 (by simp [gridOriginSingletonCornerAxisSeparator, gridOrigin])
    have hnorth :
        patch (gridExhaustion.region n) x ξ gridOriginNorth = true := by
      have hvør :=
        hcutTrue (GridClauseId.vertical 0 0)
          (by
            simpa [CornerAxisSeparator.cutBaseClauses] using
              (cornerAxisSeparator_verticalOrigin_mem_cutBaseClauses (sep := sep)))
      exact hvør.1 (by simp [gridOriginSingletonCornerAxisSeparator, gridOrigin])
    exact ⟨horigin, heast, hnorth⟩
  · intro hx
    refine ⟨?_, ?_⟩
    · intro a ha
      have ha' : a = gridOrigin := by
        simpa [sep, gridOriginSingletonCornerAxisSeparator, gridOrigin] using ha
      simpa [ha'] using hx.1
    · intro j hj
      have hj' : j = GridClauseId.horizontal 0 0 ∨ j = GridClauseId.vertical 0 0 := by
        have hjcut : j ∈ sep.cutBaseClauses := by
          simpa [CornerAxisSeparator.cutBaseClauses] using hj
        rw [gridOriginSingletonCornerAxisSeparator_cutBaseClauses] at hjcut
        simpa using hjcut
      rcases hj' with rfl | rfl
      · refine ⟨?_, ?_⟩
        · intro _hin
          simpa [gridOriginEast] using hx.2.1
        · intro hin
          exfalso
          simp [gridOriginSingletonCornerAxisSeparator, gridOrigin] at hin
      · refine ⟨?_, ?_⟩
        · intro _hin
          simpa [gridOriginNorth] using hx.2.2
        · intro hin
          exfalso
          simp [gridOriginSingletonCornerAxisSeparator, gridOrigin] at hin

