theorem CutWalkReplayPrefix.exists_appendStarAdjacentFresh_cover_insert
    {i : ℕ} {s t : Finset GridClauseId}
    (pref : CutWalkReplayPrefix i) (hpos : 0 < pref.len)
    {c : GridClauseId}
    (hstar : gridClauseStarAdjacent (pref.lastStep hpos) c)
    (hc : c ∈ s)
    (hmem :
      ∀ k : Fin pref.len,
        pref.tag k = CutWalkVisitTag.fresh →
          pref.step k ∈ s)
    (hcover :
      ∀ x ∈ t,
        ∃ k : Fin pref.len,
          pref.tag k = CutWalkVisitTag.fresh ∧
            pref.step k = x) :
    ∃ pref' : CutWalkReplayPrefix i,
      pref'.len ≤ pref.len + 4 ∧
        (∀ hpos' : 0 < pref'.len, pref'.lastStep hpos' = c) ∧
          (∀ hpos' : 0 < pref'.len,
            pref'.step ⟨0, hpos'⟩ = pref.step ⟨0, hpos⟩ ∧
              pref'.tag ⟨0, hpos'⟩ = pref.tag ⟨0, hpos⟩) ∧
            (∀ k : Fin pref'.len,
              pref'.tag k = CutWalkVisitTag.fresh →
                pref'.step k ∈ s) ∧
              (∀ x ∈ insert c t,
                ∃ k : Fin pref'.len,
                  pref'.tag k = CutWalkVisitTag.fresh ∧
                    pref'.step k = x) := by
  rcases exists_valid_cutWalkMoveListTarget_of_gridClauseStarAdjacent_endpoint
      (pref.terminal_mem hpos) hstar with
    ⟨q, hq, moves, hmovesLen, hvalidMoves, htargetMoves⟩
  rcases pref.exists_appendMoveListRevisit moves hpos hvalidMoves hmem hcover with
    ⟨bridge, hbridgeLen, hbridgeNode, hfirstBridge, hmemBridge, hcoverBridge⟩
  have hbridgePos : 0 < bridge.len := by omega
  have hqBridge : bridge.node bridge.len ∈ gridClauseDualEndpoints c := by
    simpa [hbridgeNode, htargetMoves] using hq
  let next := bridge.appendTagged c CutWalkVisitTag.fresh hqBridge
  refine ⟨next, ?_, ?_, ?_, ?_, ?_⟩
  · simp [next]
    omega
  · intro hposNext
    exact bridge.appendTagged_lastStep c CutWalkVisitTag.fresh hqBridge hposNext
  · intro hposNext
    have hstepNext : next.step ⟨0, hposNext⟩ = bridge.step ⟨0, hbridgePos⟩ :=
      bridge.appendTagged_step_zero c CutWalkVisitTag.fresh hqBridge hbridgePos
    have htagNext : next.tag ⟨0, hposNext⟩ = bridge.tag ⟨0, hbridgePos⟩ :=
      bridge.appendTagged_tag_zero c CutWalkVisitTag.fresh hqBridge hbridgePos
    rcases hfirstBridge hbridgePos with ⟨hstepBridge, htagBridge⟩
    exact ⟨hstepNext.trans hstepBridge, htagNext.trans htagBridge⟩
  · exact bridge.appendFresh_fresh_step_mem c hqBridge hc hmemBridge
  · exact bridge.appendFresh_fresh_cover_insert c hqBridge hcoverBridge

theorem CutWalkReplayPrefix.exists_appendStarChain_fresh_cover
    {i : ℕ} {s t : Finset GridClauseId}
    (tail : List GridClauseId)
    (pref : CutWalkReplayPrefix i) (hpos : 0 < pref.len)
    (hchain : List.IsChain gridClauseStarAdjacent (pref.lastStep hpos :: tail))
    (htailMem : ∀ c ∈ tail, c ∈ s)
    (hmem :
      ∀ k : Fin pref.len,
        pref.tag k = CutWalkVisitTag.fresh →
          pref.step k ∈ s)
    (hcover :
      ∀ x ∈ t,
        ∃ k : Fin pref.len,
          pref.tag k = CutWalkVisitTag.fresh ∧
            pref.step k = x) :
    ∃ pref' : CutWalkReplayPrefix i,
      pref'.len ≤ pref.len + 4 * tail.length ∧
        (∀ hpos' : 0 < pref'.len,
          pref'.step ⟨0, hpos'⟩ = pref.step ⟨0, hpos⟩ ∧
            pref'.tag ⟨0, hpos'⟩ = pref.tag ⟨0, hpos⟩) ∧
          (∀ k : Fin pref'.len,
            pref'.tag k = CutWalkVisitTag.fresh →
              pref'.step k ∈ s) ∧
            (∀ x, x ∈ t ∨ x ∈ tail →
              ∃ k : Fin pref'.len,
                pref'.tag k = CutWalkVisitTag.fresh ∧
                  pref'.step k = x) := by
  induction tail generalizing pref t with
  | nil =>
      refine ⟨pref, by simp, ?_, hmem, ?_⟩
      · intro hpos'
        constructor <;> rfl
      · intro x hx
        rcases hx with hx | hx
        · exact hcover x hx
        · simp at hx
  | cons c rest ih =>
      have hpair :
          gridClauseStarAdjacent (pref.lastStep hpos) c ∧
            List.IsChain gridClauseStarAdjacent (c :: rest) := by
        simpa using (List.isChain_cons_cons.mp hchain)
      have hc : c ∈ s := htailMem c (by simp)
      have hrestMem : ∀ x ∈ rest, x ∈ s := by
        intro x hx
        exact htailMem x (by simp [hx])
      rcases pref.exists_appendStarAdjacentFresh_cover_insert
          hpos hpair.1 hc hmem hcover with
        ⟨pref₁, hlen₁, hlast₁, hfirst₁, hmem₁, hcover₁⟩
      have hpos₁ : 0 < pref₁.len := by
        rcases hcover₁ c (by simp) with ⟨k, _htag, _hstep⟩
        exact Nat.pos_iff_ne_zero.2 (by
          intro hzero
          exact Fin.elim0 (hzero ▸ k))
      have hchain₁ :
          List.IsChain gridClauseStarAdjacent (pref₁.lastStep hpos₁ :: rest) := by
        simpa [hlast₁ hpos₁] using hpair.2
      rcases ih (pref := pref₁) (t := insert c t) hpos₁
          hchain₁ hrestMem hmem₁ hcover₁ with
        ⟨pref₂, hlen₂, hfirst₂, hmem₂, hcover₂⟩
      refine ⟨pref₂, ?_, ?_, hmem₂, ?_⟩
      · calc
          pref₂.len ≤ pref₁.len + 4 * rest.length := hlen₂
          _ ≤ pref.len + 4 * (c :: rest).length := by
            simp
            omega
      · intro hpos₂
        rcases hfirst₂ hpos₂ with ⟨hstep₂, htag₂⟩
        rcases hfirst₁ hpos₁ with ⟨hstep₁, htag₁⟩
        exact ⟨hstep₂.trans hstep₁, htag₂.trans htag₁⟩
      · intro x hx
        apply hcover₂ x
        rcases hx with hxT | hxTail
        · left
          exact Finset.mem_insert_of_mem hxT
        · simp at hxTail
          rcases hxTail with rfl | hxRest
          · left
            simp
          · right
            exact hxRest

theorem CutWalkReplayPrefix.exists_appendAdjacent
    {i : ℕ} (pref : CutWalkReplayPrefix i) (hlen : 0 < pref.len)
    {c : GridClauseId}
    (hadj : gridClauseDualAdjacent (pref.lastStep hlen) c) :
    ∃ pref' : CutWalkReplayPrefix i,
      (pref'.len = pref.len + 1 ∨ pref'.len = pref.len + 2) ∧
        ∀ hpos : 0 < pref'.len, pref'.lastStep hpos = c := by
  rcases pref.terminal_source_or_backtrack_mem hlen hadj with hdirect | hback
  · refine ⟨pref.appendDirect c hdirect, ?_, ?_⟩
    · left
      rfl
    · intro hpos
      exact (pref.appendDirect_lastStep c hdirect hpos)
  · let back : CutWalkReplayPrefix i :=
      pref.appendDirect (pref.lastStep hlen) (pref.terminal_mem hlen)
    have hbackNode : back.node back.len ∈ gridClauseDualEndpoints c := by
      rw [CutWalkReplayPrefix.appendDirect_terminal_node]
      exact hback
    refine ⟨back.appendDirect c hbackNode, ?_, ?_⟩
    · right
      simp [back]
    · intro hpos
      exact (back.appendDirect_lastStep c hbackNode hpos)

theorem CutWalkReplayPrefix.exists_appendAdjacentFresh_cover_insert
    {i : ℕ} {s t : Finset GridClauseId}
    (pref : CutWalkReplayPrefix i) (hlen : 0 < pref.len)
    {c : GridClauseId}
    (hadj : gridClauseDualAdjacent (pref.lastStep hlen) c)
    (hc : c ∈ s)
    (hmem :
      ∀ k : Fin pref.len,
        pref.tag k = CutWalkVisitTag.fresh →
          pref.step k ∈ s)
    (hcover :
      ∀ x ∈ t,
        ∃ k : Fin pref.len,
          pref.tag k = CutWalkVisitTag.fresh ∧
            pref.step k = x) :
    ∃ pref' : CutWalkReplayPrefix i,
      (pref'.len = pref.len + 1 ∨ pref'.len = pref.len + 2) ∧
        (∀ hpos : 0 < pref'.len, pref'.lastStep hpos = c) ∧
          (∀ hpos : 0 < pref'.len,
            pref'.step ⟨0, hpos⟩ = pref.step ⟨0, hlen⟩ ∧
              pref'.tag ⟨0, hpos⟩ = pref.tag ⟨0, hlen⟩) ∧
            (∀ k : Fin pref'.len,
              pref'.tag k = CutWalkVisitTag.fresh →
                pref'.step k ∈ s) ∧
              (∀ x ∈ insert c t,
                ∃ k : Fin pref'.len,
                  pref'.tag k = CutWalkVisitTag.fresh ∧
                    pref'.step k = x) := by
  rcases pref.terminal_source_or_backtrack_mem hlen hadj with hdirect | hback
  · let next := pref.appendTagged c CutWalkVisitTag.fresh hdirect
    refine ⟨next, ?_, ?_, ?_, ?_, ?_⟩
    · left
      rfl
    · intro hpos
      exact (pref.appendTagged_lastStep c CutWalkVisitTag.fresh hdirect hpos)
    · intro hpos
      exact ⟨pref.appendTagged_step_zero c CutWalkVisitTag.fresh hdirect hlen,
        pref.appendTagged_tag_zero c CutWalkVisitTag.fresh hdirect hlen⟩
    · exact pref.appendFresh_fresh_step_mem c hdirect hc hmem
    · exact pref.appendFresh_fresh_cover_insert c hdirect hcover
  · let back : CutWalkReplayPrefix i :=
      pref.appendTagged (pref.lastStep hlen) CutWalkVisitTag.revisit
        (pref.terminal_mem hlen)
    have hbackNode : back.node back.len ∈ gridClauseDualEndpoints c := by
      rw [CutWalkReplayPrefix.appendTagged_terminal_node]
      exact hback
    have hmemBack :
        ∀ k : Fin back.len,
          back.tag k = CutWalkVisitTag.fresh →
            back.step k ∈ s :=
      pref.appendRevisit_fresh_step_mem
        (pref.lastStep hlen) (pref.terminal_mem hlen) hmem
    have hcoverBack :
        ∀ x ∈ t,
          ∃ k : Fin back.len,
            back.tag k = CutWalkVisitTag.fresh ∧
              back.step k = x :=
      pref.appendRevisit_fresh_cover
        (pref.lastStep hlen) (pref.terminal_mem hlen) hcover
    let next := back.appendTagged c CutWalkVisitTag.fresh hbackNode
    refine ⟨next, ?_, ?_, ?_, ?_, ?_⟩
    · right
      simp [next, back]
    · intro hpos
      exact (back.appendTagged_lastStep c CutWalkVisitTag.fresh hbackNode hpos)
    · intro hpos
      have hbackPos : 0 < back.len := by simp [back]
      have hstepBack :
          back.step ⟨0, hbackPos⟩ = pref.step ⟨0, hlen⟩ :=
        pref.appendTagged_step_zero
          (pref.lastStep hlen) CutWalkVisitTag.revisit
          (pref.terminal_mem hlen) hlen
      have htagBack :
          back.tag ⟨0, hbackPos⟩ = pref.tag ⟨0, hlen⟩ :=
        pref.appendTagged_tag_zero
          (pref.lastStep hlen) CutWalkVisitTag.revisit
          (pref.terminal_mem hlen) hlen
      constructor
      · calc
          next.step ⟨0, hpos⟩ = back.step ⟨0, hbackPos⟩ :=
            back.appendTagged_step_zero c CutWalkVisitTag.fresh hbackNode hbackPos
          _ = pref.step ⟨0, hlen⟩ := hstepBack
      · calc
          next.tag ⟨0, hpos⟩ = back.tag ⟨0, hbackPos⟩ :=
            back.appendTagged_tag_zero c CutWalkVisitTag.fresh hbackNode hbackPos
          _ = pref.tag ⟨0, hlen⟩ := htagBack
    · exact back.appendFresh_fresh_step_mem c hbackNode hc hmemBack
    · exact back.appendFresh_fresh_cover_insert c hbackNode hcoverBack

theorem CutWalkReplayPrefix.exists_appendAdjacentRevisit_cover
    {i : ℕ} {s t : Finset GridClauseId}
    (pref : CutWalkReplayPrefix i) (hlen : 0 < pref.len)
    {c : GridClauseId}
    (hadj : gridClauseDualAdjacent (pref.lastStep hlen) c)
    (hmem :
      ∀ k : Fin pref.len,
        pref.tag k = CutWalkVisitTag.fresh →
          pref.step k ∈ s)
    (hcover :
      ∀ x ∈ t,
        ∃ k : Fin pref.len,
          pref.tag k = CutWalkVisitTag.fresh ∧
            pref.step k = x) :
    ∃ pref' : CutWalkReplayPrefix i,
      (pref'.len = pref.len + 1 ∨ pref'.len = pref.len + 2) ∧
        (∀ hpos : 0 < pref'.len, pref'.lastStep hpos = c) ∧
          (∀ hpos : 0 < pref'.len,
            pref'.step ⟨0, hpos⟩ = pref.step ⟨0, hlen⟩ ∧
              pref'.tag ⟨0, hpos⟩ = pref.tag ⟨0, hlen⟩) ∧
            (∀ k : Fin pref'.len,
              pref'.tag k = CutWalkVisitTag.fresh →
                pref'.step k ∈ s) ∧
              (∀ x ∈ t,
                ∃ k : Fin pref'.len,
                  pref'.tag k = CutWalkVisitTag.fresh ∧
                    pref'.step k = x) := by
  rcases pref.terminal_source_or_backtrack_mem hlen hadj with hdirect | hback
  · let next := pref.appendTagged c CutWalkVisitTag.revisit hdirect
    refine ⟨next, ?_, ?_, ?_, ?_, ?_⟩
    · left
      rfl
    · intro hpos
      exact (pref.appendTagged_lastStep c CutWalkVisitTag.revisit hdirect hpos)
    · intro hpos
      exact ⟨pref.appendTagged_step_zero c CutWalkVisitTag.revisit hdirect hlen,
        pref.appendTagged_tag_zero c CutWalkVisitTag.revisit hdirect hlen⟩
    · exact pref.appendRevisit_fresh_step_mem c hdirect hmem
    · exact pref.appendRevisit_fresh_cover c hdirect hcover
  · let back : CutWalkReplayPrefix i :=
      pref.appendTagged (pref.lastStep hlen) CutWalkVisitTag.revisit
        (pref.terminal_mem hlen)
    have hbackNode : back.node back.len ∈ gridClauseDualEndpoints c := by
      rw [CutWalkReplayPrefix.appendTagged_terminal_node]
      exact hback
    have hmemBack :
        ∀ k : Fin back.len,
          back.tag k = CutWalkVisitTag.fresh →
            back.step k ∈ s :=
      pref.appendRevisit_fresh_step_mem
        (pref.lastStep hlen) (pref.terminal_mem hlen) hmem
    have hcoverBack :
        ∀ x ∈ t,
          ∃ k : Fin back.len,
            back.tag k = CutWalkVisitTag.fresh ∧
              back.step k = x :=
      pref.appendRevisit_fresh_cover
        (pref.lastStep hlen) (pref.terminal_mem hlen) hcover
    let next := back.appendTagged c CutWalkVisitTag.revisit hbackNode
    refine ⟨next, ?_, ?_, ?_, ?_, ?_⟩
    · right
      simp [next, back]
    · intro hpos
      exact (back.appendTagged_lastStep c CutWalkVisitTag.revisit hbackNode hpos)
    · intro hpos
      have hbackPos : 0 < back.len := by simp [back]
      have hstepBack :
          back.step ⟨0, hbackPos⟩ = pref.step ⟨0, hlen⟩ :=
        pref.appendTagged_step_zero
          (pref.lastStep hlen) CutWalkVisitTag.revisit
          (pref.terminal_mem hlen) hlen
      have htagBack :
          back.tag ⟨0, hbackPos⟩ = pref.tag ⟨0, hlen⟩ :=
        pref.appendTagged_tag_zero
          (pref.lastStep hlen) CutWalkVisitTag.revisit
          (pref.terminal_mem hlen) hlen
      constructor
      · calc
          next.step ⟨0, hpos⟩ = back.step ⟨0, hbackPos⟩ :=
            back.appendTagged_step_zero c CutWalkVisitTag.revisit hbackNode hbackPos
          _ = pref.step ⟨0, hlen⟩ := hstepBack
      · calc
          next.tag ⟨0, hpos⟩ = back.tag ⟨0, hbackPos⟩ :=
            back.appendTagged_tag_zero c CutWalkVisitTag.revisit hbackNode hbackPos
          _ = pref.tag ⟨0, hlen⟩ := htagBack
    · exact back.appendRevisit_fresh_step_mem c hbackNode hmemBack
    · exact back.appendRevisit_fresh_cover c hbackNode hcoverBack

theorem CutWalkReplayPrefix.exists_appendAdjacent_fresh_cover_insert
    {i : ℕ} {s t : Finset GridClauseId}
    (pref : CutWalkReplayPrefix i) (hlen : 0 < pref.len)
    {c : GridClauseId}
    (hadj : gridClauseDualAdjacent (pref.lastStep hlen) c)
    (hlast : pref.lastStep hlen ∈ s)
    (hc : c ∈ s)
    (hmem :
      ∀ k : Fin pref.len,
        pref.tag k = CutWalkVisitTag.fresh →
          pref.step k ∈ s)
    (hcover :
      ∀ x ∈ t,
        ∃ k : Fin pref.len,
          pref.tag k = CutWalkVisitTag.fresh ∧
            pref.step k = x) :
    ∃ pref' : CutWalkReplayPrefix i,
      (pref'.len = pref.len + 1 ∨ pref'.len = pref.len + 2) ∧
        (∀ hpos : 0 < pref'.len, pref'.lastStep hpos = c) ∧
          (∀ hpos : 0 < pref'.len,
            pref'.step ⟨0, hpos⟩ = pref.step ⟨0, hlen⟩ ∧
              pref'.tag ⟨0, hpos⟩ = pref.tag ⟨0, hlen⟩) ∧
            (∀ k : Fin pref'.len,
              pref'.tag k = CutWalkVisitTag.fresh →
                pref'.step k ∈ s) ∧
              (∀ x ∈ insert c t,
                ∃ k : Fin pref'.len,
                  pref'.tag k = CutWalkVisitTag.fresh ∧
                    pref'.step k = x) := by
  rcases pref.terminal_source_or_backtrack_mem hlen hadj with hdirect | hback
  · let next := pref.appendDirect c hdirect
    refine ⟨next, ?_, ?_, ?_, ?_, ?_⟩
    · left
      rfl
    · intro hpos
      exact (pref.appendDirect_lastStep c hdirect hpos)
    · intro hpos
      exact ⟨pref.appendDirect_step_zero c hdirect hlen,
        pref.appendDirect_tag_zero c hdirect hlen⟩
    · exact pref.appendDirect_fresh_step_mem c hdirect hc hmem
    · exact pref.appendDirect_fresh_cover_insert c hdirect hcover
  · let back : CutWalkReplayPrefix i :=
      pref.appendDirect (pref.lastStep hlen) (pref.terminal_mem hlen)
    have hbackNode : back.node back.len ∈ gridClauseDualEndpoints c := by
      rw [CutWalkReplayPrefix.appendDirect_terminal_node]
      exact hback
    have hmemBack :
        ∀ k : Fin back.len,
          back.tag k = CutWalkVisitTag.fresh →
            back.step k ∈ s :=
      pref.appendDirect_fresh_step_mem
        (pref.lastStep hlen) (pref.terminal_mem hlen) hlast hmem
    have hcoverBack :
        ∀ x ∈ insert (pref.lastStep hlen) t,
          ∃ k : Fin back.len,
            back.tag k = CutWalkVisitTag.fresh ∧
              back.step k = x :=
      pref.appendDirect_fresh_cover_insert
        (pref.lastStep hlen) (pref.terminal_mem hlen) hcover
    let next := back.appendDirect c hbackNode
    have hcoverNext :
        ∀ x ∈ insert c (insert (pref.lastStep hlen) t),
          ∃ k : Fin next.len,
            next.tag k = CutWalkVisitTag.fresh ∧
              next.step k = x :=
      back.appendDirect_fresh_cover_insert c hbackNode hcoverBack
    refine ⟨next, ?_, ?_, ?_, ?_, ?_⟩
    · right
      simp [next, back]
    · intro hpos
      exact (back.appendDirect_lastStep c hbackNode hpos)
    · intro hpos
      have hbackPos : 0 < back.len := by simp [back]
      have hstepBack :
          back.step ⟨0, hbackPos⟩ = pref.step ⟨0, hlen⟩ :=
        pref.appendDirect_step_zero
          (pref.lastStep hlen) (pref.terminal_mem hlen) hlen
      have htagBack :
          back.tag ⟨0, hbackPos⟩ = pref.tag ⟨0, hlen⟩ :=
        pref.appendDirect_tag_zero
          (pref.lastStep hlen) (pref.terminal_mem hlen) hlen
      constructor
      · calc
          next.step ⟨0, hpos⟩ = back.step ⟨0, hbackPos⟩ :=
            back.appendDirect_step_zero c hbackNode hbackPos
          _ = pref.step ⟨0, hlen⟩ := hstepBack
      · calc
          next.tag ⟨0, hpos⟩ = back.tag ⟨0, hbackPos⟩ :=
            back.appendDirect_tag_zero c hbackNode hbackPos
          _ = pref.tag ⟨0, hlen⟩ := htagBack
    · exact back.appendDirect_fresh_step_mem c hbackNode hc hmemBack
    · intro x hx
      apply hcoverNext x
      rw [Finset.mem_insert] at hx ⊢
      rcases hx with rfl | hx
      · exact Or.inl rfl
      · exact Or.inr (Finset.mem_insert_of_mem hx)

theorem CutWalkReplayPrefix.exists_appendChain_fresh_cover
    {i : ℕ} {s t : Finset GridClauseId}
    (tail : List GridClauseId)
    (pref : CutWalkReplayPrefix i) (hlen : 0 < pref.len)
    (hchain : List.IsChain gridClauseDualAdjacent (pref.lastStep hlen :: tail))
    (hlast : pref.lastStep hlen ∈ s)
    (htailMem : ∀ c ∈ tail, c ∈ s)
    (hmem :
      ∀ k : Fin pref.len,
        pref.tag k = CutWalkVisitTag.fresh →
          pref.step k ∈ s)
    (hcover :
      ∀ x ∈ t,
        ∃ k : Fin pref.len,
          pref.tag k = CutWalkVisitTag.fresh ∧
            pref.step k = x) :
    ∃ pref' : CutWalkReplayPrefix i,
      pref'.len ≤ pref.len + 2 * tail.length ∧
        (∀ hpos : 0 < pref'.len,
          pref'.step ⟨0, hpos⟩ = pref.step ⟨0, hlen⟩ ∧
            pref'.tag ⟨0, hpos⟩ = pref.tag ⟨0, hlen⟩) ∧
          (∀ k : Fin pref'.len,
            pref'.tag k = CutWalkVisitTag.fresh →
              pref'.step k ∈ s) ∧
            (∀ x, x ∈ t ∨ x ∈ tail →
              ∃ k : Fin pref'.len,
                pref'.tag k = CutWalkVisitTag.fresh ∧
                  pref'.step k = x) := by
  induction tail generalizing pref t with
  | nil =>
      refine ⟨pref, by simp, ?_, hmem, ?_⟩
      · intro hpos
        constructor <;> rfl
      intro x hx
      rcases hx with hx | hx
      · exact hcover x hx
      · simp at hx
  | cons c rest ih =>
      have hpair :
          gridClauseDualAdjacent (pref.lastStep hlen) c ∧
            List.IsChain gridClauseDualAdjacent (c :: rest) := by
        simpa using (List.isChain_cons_cons.mp hchain)
      have hc : c ∈ s := htailMem c (by simp)
      have hrestMem : ∀ x ∈ rest, x ∈ s := by
        intro x hx
        exact htailMem x (by simp [hx])
      rcases
        pref.exists_appendAdjacent_fresh_cover_insert
          hlen hpair.1 hlast hc hmem hcover with
        ⟨pref₁, hlen₁eq, hlast₁, hfirst₁, hmem₁, hcover₁⟩
      have hlen₁pos : 0 < pref₁.len := by
        rcases hlen₁eq with hlenEq | hlenEq <;> omega
      have hlast₁mem : pref₁.lastStep hlen₁pos ∈ s := by
        simpa [hlast₁ hlen₁pos] using hc
      have hchain₁ :
          List.IsChain gridClauseDualAdjacent (pref₁.lastStep hlen₁pos :: rest) := by
        simpa [hlast₁ hlen₁pos] using hpair.2
      rcases ih (pref := pref₁) (t := insert c t) hlen₁pos
          hchain₁ hlast₁mem hrestMem hmem₁ hcover₁ with
        ⟨pref₂, hlen₂, hfirst₂, hmem₂, hcover₂⟩
      refine ⟨pref₂, ?_, ?_, hmem₂, ?_⟩
      · have hlen₁le : pref₁.len ≤ pref.len + 2 := by
          rcases hlen₁eq with hlenEq | hlenEq <;> omega
        calc
          pref₂.len ≤ pref₁.len + 2 * rest.length := hlen₂
          _ ≤ pref.len + 2 * (c :: rest).length := by
            simp
            omega
      · intro hpos
        rcases hfirst₂ hpos with ⟨hstep₂, htag₂⟩
        rcases hfirst₁ hlen₁pos with ⟨hstep₁, htag₁⟩
        exact ⟨hstep₂.trans hstep₁, htag₂.trans htag₁⟩
      · intro x hx
        apply hcover₂ x
        rcases hx with hxT | hxTail
        · left
          exact Finset.mem_insert_of_mem hxT
        · simp at hxTail
          rcases hxTail with rfl | hxRest
          · left
            simp
          · right
            exact hxRest

theorem CutWalkReplayPrefix.exists_appendTaggedChain_fresh_cover
    {i : ℕ} {s t : Finset GridClauseId}
    (tail : List (GridClauseId × CutWalkVisitTag))
    (pref : CutWalkReplayPrefix i) (hlen : 0 < pref.len)
    (hchain :
      List.IsChain gridClauseDualAdjacent
        (pref.lastStep hlen :: tail.map Prod.fst))
    (hfreshMem :
      ∀ c, (c, CutWalkVisitTag.fresh) ∈ tail → c ∈ s)
    (hmem :
      ∀ k : Fin pref.len,
        pref.tag k = CutWalkVisitTag.fresh →
          pref.step k ∈ s)
    (hcover :
      ∀ x ∈ t,
        ∃ k : Fin pref.len,
          pref.tag k = CutWalkVisitTag.fresh ∧
            pref.step k = x) :
    ∃ pref' : CutWalkReplayPrefix i,
      pref'.len ≤ pref.len + 2 * tail.length ∧
        (∀ hpos : 0 < pref'.len,
          pref'.step ⟨0, hpos⟩ = pref.step ⟨0, hlen⟩ ∧
            pref'.tag ⟨0, hpos⟩ = pref.tag ⟨0, hlen⟩) ∧
          (∀ k : Fin pref'.len,
            pref'.tag k = CutWalkVisitTag.fresh →
              pref'.step k ∈ s) ∧
            (∀ x, x ∈ t ∨ (x, CutWalkVisitTag.fresh) ∈ tail →
              ∃ k : Fin pref'.len,
                pref'.tag k = CutWalkVisitTag.fresh ∧
                  pref'.step k = x) := by
  induction tail generalizing pref t with
  | nil =>
      refine ⟨pref, by simp, ?_, hmem, ?_⟩
      · intro hpos
        constructor <;> rfl
      intro x hx
      rcases hx with hx | hx
      · exact hcover x hx
      · simp at hx
  | cons head rest ih =>
      rcases head with ⟨c, tag⟩
      have hpair :
          gridClauseDualAdjacent (pref.lastStep hlen) c ∧
            List.IsChain gridClauseDualAdjacent (c :: rest.map Prod.fst) := by
        simpa using (List.isChain_cons_cons.mp hchain)
      have hrestFreshMem :
          ∀ x, (x, CutWalkVisitTag.fresh) ∈ rest → x ∈ s := by
        intro x hx
        exact hfreshMem x (by simp [hx])
      cases tag with
      | fresh =>
          have hc : c ∈ s := hfreshMem c (by simp)
          rcases
            pref.exists_appendAdjacentFresh_cover_insert
              hlen hpair.1 hc hmem hcover with
            ⟨pref₁, hlen₁eq, hlast₁, hfirst₁, hmem₁, hcover₁⟩
          have hlen₁pos : 0 < pref₁.len := by
            rcases hlen₁eq with hlenEq | hlenEq <;> omega
          have hchain₁ :
              List.IsChain gridClauseDualAdjacent
                (pref₁.lastStep hlen₁pos :: rest.map Prod.fst) := by
            simpa [hlast₁ hlen₁pos] using hpair.2
          rcases ih (pref := pref₁) (t := insert c t) hlen₁pos
              hchain₁ hrestFreshMem hmem₁ hcover₁ with
            ⟨pref₂, hlen₂, hfirst₂, hmem₂, hcover₂⟩
          refine ⟨pref₂, ?_, ?_, hmem₂, ?_⟩
          · have hlen₁le : pref₁.len ≤ pref.len + 2 := by
              rcases hlen₁eq with hlenEq | hlenEq <;> omega
            calc
              pref₂.len ≤ pref₁.len + 2 * rest.length := hlen₂
              _ ≤ pref.len + 2 * ((c, CutWalkVisitTag.fresh) :: rest).length := by
                simp
                omega
          · intro hpos
            rcases hfirst₂ hpos with ⟨hstep₂, htag₂⟩
            rcases hfirst₁ hlen₁pos with ⟨hstep₁, htag₁⟩
            exact ⟨hstep₂.trans hstep₁, htag₂.trans htag₁⟩
          · intro x hx
            apply hcover₂ x
            rcases hx with hxT | hxTail
            · left
              exact Finset.mem_insert_of_mem hxT
            · simp at hxTail
              rcases hxTail with hxc | hxRest
              · left
                simp [hxc]
              · right
                exact hxRest
      | revisit =>
          rcases
            pref.exists_appendAdjacentRevisit_cover
              hlen hpair.1 hmem hcover with
            ⟨pref₁, hlen₁eq, hlast₁, hfirst₁, hmem₁, hcover₁⟩
          have hlen₁pos : 0 < pref₁.len := by
            rcases hlen₁eq with hlenEq | hlenEq <;> omega
          have hchain₁ :
              List.IsChain gridClauseDualAdjacent
                (pref₁.lastStep hlen₁pos :: rest.map Prod.fst) := by
            simpa [hlast₁ hlen₁pos] using hpair.2
          rcases ih (pref := pref₁) (t := t) hlen₁pos
              hchain₁ hrestFreshMem hmem₁ hcover₁ with
            ⟨pref₂, hlen₂, hfirst₂, hmem₂, hcover₂⟩
          refine ⟨pref₂, ?_, ?_, hmem₂, ?_⟩
          · have hlen₁le : pref₁.len ≤ pref.len + 2 := by
              rcases hlen₁eq with hlenEq | hlenEq <;> omega
            calc
              pref₂.len ≤ pref₁.len + 2 * rest.length := hlen₂
              _ ≤ pref.len + 2 * ((c, CutWalkVisitTag.revisit) :: rest).length := by
                simp
                omega
          · intro hpos
            rcases hfirst₂ hpos with ⟨hstep₂, htag₂⟩
            rcases hfirst₁ hlen₁pos with ⟨hstep₁, htag₁⟩
            exact ⟨hstep₂.trans hstep₁, htag₂.trans htag₁⟩
          · intro x hx
            apply hcover₂ x
            rcases hx with hxT | hxTail
            · left
              exact hxT
            · right
              simpa using hxTail

def cutWalkRootPrefix (i : ℕ) : CutWalkReplayPrefix i where
  len := 1
  node := cutWalkBounceNode (GridClauseId.horizontal i 0) (cutWalkRoot i)
  step := fun _ => GridClauseId.horizontal i 0
  tag := fun _ => CutWalkVisitTag.fresh
  node_zero := rfl
  source_mem := by
    intro k
    exact cutWalkBounceNode_mem_dualEndpoints
      (cutWalkRoot_mem_horizontal_zero_dualEndpoints i) k.1
  node_succ := by
    intro k
    rfl

@[simp] theorem cutWalkRootPrefix_len (i : ℕ) :
    (cutWalkRootPrefix i).len = 1 :=
  rfl

@[simp] theorem cutWalkRootPrefix_lastStep (i : ℕ) {h : 0 < (cutWalkRootPrefix i).len} :
    (cutWalkRootPrefix i).lastStep h = GridClauseId.horizontal i 0 := by
  rfl

/-- Package an already-oriented dual-edge contour segment as a replay prefix.
This is the adapter needed for the final DFS/Euler contour theorem: once the
geometric work produces nodes and crossed clauses with the correct source and
successor equations, the existing decoder/injection shell can consume it as a
`CutWalkReplayPrefix` without routing through the coarser clause-chain adapter. -/
theorem exists_rootedPrefix_of_orientedCutWalk
    {m i : ℕ} {s : Finset GridClauseId}
    {len : ℕ} {node : ℕ → GridNode} {step : Fin len → GridClauseId}
    (hpos : 0 < len) (hlen : len ≤ 2 * m)
    (hnode0 : node 0 = cutWalkRoot i)
    (hsource :
      ∀ k : Fin len, node k.1 ∈ gridClauseDualEndpoints (step k))
    (hnext :
      ∀ k : Fin len,
        node (k.1 + 1) =
          cutWalkMoveTarget (node k.1)
            (cutWalkMoveFromClauseEndpoint (step k) (node k.1)))
    (hstep0 : step ⟨0, hpos⟩ = GridClauseId.horizontal i 0)
    (hmem : ∀ k : Fin len, step k ∈ s)
    (hcover : ∀ x ∈ s, ∃ k : Fin len, step k = x) :
    ∃ pref : CutWalkReplayPrefix i,
      ∃ hpos' : 0 < pref.len,
        pref.len ≤ 2 * m ∧
          pref.step ⟨0, hpos'⟩ = GridClauseId.horizontal i 0 ∧
            pref.tag ⟨0, hpos'⟩ = CutWalkVisitTag.fresh ∧
              (∀ k : Fin pref.len,
                pref.tag k = CutWalkVisitTag.fresh →
                  pref.step k ∈ s) ∧
                (∀ x ∈ s,
                  ∃ k : Fin pref.len,
                    pref.tag k = CutWalkVisitTag.fresh ∧
                      pref.step k = x) := by
  let pref : CutWalkReplayPrefix i :=
    { len := len
      node := node
      step := step
      tag := fun _ => CutWalkVisitTag.fresh
      node_zero := hnode0
      source_mem := hsource
      node_succ := hnext }
  refine ⟨pref, hpos, hlen, ?_, ?_, ?_, ?_⟩
  · simpa [pref] using hstep0
  · simp [pref]
  · intro k _htag
    simpa [pref] using hmem k
  · intro x hx
    rcases hcover x hx with ⟨k, hk⟩
    exact ⟨⟨k.1, by simp [pref, k.2]⟩, by simp [pref],
      by simpa [pref] using hk⟩

/-- Package a tag-aware oriented dual-edge walk as a replay prefix.  Fresh steps
are exactly the clauses recovered by the decoder; revisit steps may be used as
geometric bridge moves and need not belong to the recovered cut set. -/
theorem exists_rootedPrefix_of_taggedOrientedCutWalk
    {m i : ℕ} {s : Finset GridClauseId}
    {len : ℕ} {node : ℕ → GridNode} {step : Fin len → GridClauseId}
    {tag : Fin len → CutWalkVisitTag}
    (hpos : 0 < len) (hlen : len ≤ 2 * m)
    (hnode0 : node 0 = cutWalkRoot i)
    (hsource :
      ∀ k : Fin len, node k.1 ∈ gridClauseDualEndpoints (step k))
    (hnext :
      ∀ k : Fin len,
        node (k.1 + 1) =
          cutWalkMoveTarget (node k.1)
            (cutWalkMoveFromClauseEndpoint (step k) (node k.1)))
    (hstep0 : step ⟨0, hpos⟩ = GridClauseId.horizontal i 0)
    (htag0 : tag ⟨0, hpos⟩ = CutWalkVisitTag.fresh)
    (hmem :
      ∀ k : Fin len,
        tag k = CutWalkVisitTag.fresh →
          step k ∈ s)
    (hcover :
      ∀ x ∈ s,
        ∃ k : Fin len,
          tag k = CutWalkVisitTag.fresh ∧
            step k = x) :
    ∃ pref : CutWalkReplayPrefix i,
      ∃ hpos' : 0 < pref.len,
        pref.len ≤ 2 * m ∧
          pref.step ⟨0, hpos'⟩ = GridClauseId.horizontal i 0 ∧
            pref.tag ⟨0, hpos'⟩ = CutWalkVisitTag.fresh ∧
              (∀ k : Fin pref.len,
                pref.tag k = CutWalkVisitTag.fresh →
                  pref.step k ∈ s) ∧
                (∀ x ∈ s,
                  ∃ k : Fin pref.len,
                    pref.tag k = CutWalkVisitTag.fresh ∧
                      pref.step k = x) := by
  let pref : CutWalkReplayPrefix i :=
    { len := len
      node := node
      step := step
      tag := tag
      node_zero := hnode0
      source_mem := hsource
      node_succ := hnext }
  refine ⟨pref, hpos, hlen, ?_, ?_, ?_, ?_⟩
  · simpa [pref] using hstep0
  · simpa [pref] using htag0
  · intro k htag
    simpa [pref] using hmem ⟨k.1, by simp [pref, k.2]⟩ (by simpa [pref] using htag)
  · intro x hx
    rcases hcover x hx with ⟨k, htag, hstep⟩
    exact ⟨⟨k.1, by simp [pref, k.2]⟩, by simpa [pref] using htag,
      by simpa [pref] using hstep⟩

theorem rootedDualConnectedCutSet_of_orientedCutWalk
    {i : ℕ} {s : Finset GridClauseId}
    {len : ℕ} {node : ℕ → GridNode} {step : Fin len → GridClauseId}
    (hpos : 0 < len)
    (hsource :
      ∀ k : Fin len, node k.1 ∈ gridClauseDualEndpoints (step k))
    (hnext :
      ∀ k : Fin len,
        node (k.1 + 1) =
          cutWalkMoveTarget (node k.1)
            (cutWalkMoveFromClauseEndpoint (step k) (node k.1)))
    (hstep0 : step ⟨0, hpos⟩ = GridClauseId.horizontal i 0)
    (hmem : ∀ k : Fin len, step k ∈ s)
    (hcover : ∀ x ∈ s, ∃ k : Fin len, step k = x) :
    RootedDualConnectedCutSet (GridClauseId.horizontal i 0) s := by
  let R := fun a b : GridClauseId =>
    a ∈ s ∧ b ∈ s ∧ gridClauseDualAdjacent a b
  have hrootMem : GridClauseId.horizontal i 0 ∈ s := by
    simpa [hstep0] using hmem ⟨0, hpos⟩
  refine ⟨hrootMem, ?_⟩
  intro x hx
  rcases hcover x hx with ⟨k, hk⟩
  have hreach :
      ∀ n, ∀ hn : n < len,
        Relation.ReflTransGen R (step ⟨0, hpos⟩) (step ⟨n, hn⟩) := by
    intro n
    induction n with
    | zero =>
        intro hn
        exact Relation.ReflTransGen.refl
    | succ n ih =>
        intro hn
        have hnPrev : n < len := Nat.lt_trans (Nat.lt_succ_self n) hn
        have htarget :
            node (n + 1) ∈ gridClauseDualEndpoints (step ⟨n, hnPrev⟩) := by
          rw [hnext ⟨n, hnPrev⟩]
          exact cutWalkMoveFromClauseEndpoint_target_mem_dualEndpoints
            (hsource ⟨n, hnPrev⟩)
        exact Relation.ReflTransGen.tail (ih hnPrev)
          ⟨hmem ⟨n, hnPrev⟩, hmem ⟨n + 1, hn⟩,
            ⟨node (n + 1), htarget, hsource ⟨n + 1, hn⟩⟩⟩
  simpa [R, hstep0, hk] using hreach k.1 k.2

def CutWalkReplayPrefix.toTrace
    {m i : ℕ} (pref : CutWalkReplayPrefix i)
    (hpos : 0 < pref.len) (_hlen : pref.len ≤ 2 * m) :
    CutWalkReplayTrace m i where
  node := fun n =>
    if h : n ≤ pref.len then
      pref.node n
    else
      cutWalkBounceNode (pref.lastStep hpos) (pref.node pref.len) (n - pref.len)
  step := fun k =>
    if h : k.1 < pref.len then
      pref.step ⟨k.1, h⟩
    else
      pref.lastStep hpos
  tag := fun k =>
    if h : k.1 < pref.len then
      pref.tag ⟨k.1, h⟩
    else
      CutWalkVisitTag.revisit
  node_zero := by
    simp [pref.node_zero]
  source_mem := by
    intro k
    by_cases hk : k.1 < pref.len
    · have hle : k.1 ≤ pref.len := Nat.le_of_lt hk
      simp [hk, hle, pref.source_mem ⟨k.1, hk⟩]
    · by_cases hle : k.1 ≤ pref.len
      · have hkEq : k.1 = pref.len := by omega
        simp [hkEq, pref.terminal_mem hpos]
      · simpa [hk, hle] using
          cutWalkBounceNode_mem_dualEndpoints (pref.terminal_mem hpos) (k.1 - pref.len)
  node_succ := by
    intro k
    by_cases hnext : k.1 + 1 ≤ pref.len
    · have hk : k.1 < pref.len := Nat.lt_of_succ_le hnext
      have hle : k.1 ≤ pref.len := Nat.le_of_lt hk
      simp [hk, hle, hnext, pref.node_succ ⟨k.1, hk⟩]
    · have hkNot : ¬ k.1 < pref.len := by omega
      by_cases hcur : k.1 ≤ pref.len
      · have hkEq : k.1 = pref.len := by omega
        simp [hkEq, cutWalkBounceNode]
      · have hsub :
            k.1 + 1 - pref.len = k.1 - pref.len + 1 := by
          omega
        simp [hcur, hnext, hkNot, hsub, cutWalkBounceNode_succ]

theorem CutWalkReplayPrefix.toTrace_step_of_lt
    {m i : ℕ} (pref : CutWalkReplayPrefix i)
    (hpos : 0 < pref.len) (hlen : pref.len ≤ 2 * m)
    {k : Fin (2 * m)} (hk : k.1 < pref.len) :
    (pref.toTrace hpos hlen).step k = pref.step ⟨k.1, hk⟩ := by
  simp [CutWalkReplayPrefix.toTrace, hk]

theorem CutWalkReplayPrefix.toTrace_tag_of_lt
    {m i : ℕ} (pref : CutWalkReplayPrefix i)
    (hpos : 0 < pref.len) (hlen : pref.len ≤ 2 * m)
    {k : Fin (2 * m)} (hk : k.1 < pref.len) :
    (pref.toTrace hpos hlen).tag k = pref.tag ⟨k.1, hk⟩ := by
  simp [CutWalkReplayPrefix.toTrace, hk]

theorem CutWalkReplayPrefix.toTrace_tag_of_not_lt
    {m i : ℕ} (pref : CutWalkReplayPrefix i)
    (hpos : 0 < pref.len) (hlen : pref.len ≤ 2 * m)
    {k : Fin (2 * m)} (hk : ¬ k.1 < pref.len) :
    (pref.toTrace hpos hlen).tag k = CutWalkVisitTag.revisit := by
  simp [CutWalkReplayPrefix.toTrace, hk]

theorem exists_rooted_replayTrace_of_prefix
    {m i : ℕ} {s : Finset GridClauseId} {h0 : 0 < 2 * m}
    (pref : CutWalkReplayPrefix i)
    (hpos : 0 < pref.len) (hlen : pref.len ≤ 2 * m)
    (hstep0 : pref.step ⟨0, hpos⟩ = GridClauseId.horizontal i 0)
    (htag0 : pref.tag ⟨0, hpos⟩ = CutWalkVisitTag.fresh)
    (hmem :
      ∀ k : Fin pref.len,
        pref.tag k = CutWalkVisitTag.fresh →
          pref.step k ∈ s)
    (hcover :
      ∀ x ∈ s,
        ∃ k : Fin pref.len,
          pref.tag k = CutWalkVisitTag.fresh ∧
            pref.step k = x) :
    ∃ trace : CutWalkReplayTrace m i,
      trace.step ⟨0, h0⟩ = GridClauseId.horizontal i 0 ∧
        trace.tag ⟨0, h0⟩ = CutWalkVisitTag.fresh ∧
          (∀ k : Fin (2 * m),
            trace.tag k = CutWalkVisitTag.fresh →
              trace.step k ∈ s) ∧
            (∀ x ∈ s,
              ∃ k : Fin (2 * m),
                trace.tag k = CutWalkVisitTag.fresh ∧
                  trace.step k = x) := by
  let trace := pref.toTrace hpos hlen
  refine ⟨trace, ?_, ?_, ?_, ?_⟩
  · simpa [trace, CutWalkReplayPrefix.toTrace, hpos] using hstep0
  · simpa [trace, CutWalkReplayPrefix.toTrace, hpos] using htag0
  · intro k htag
    by_cases hk : k.1 < pref.len
    · have htagPref : pref.tag ⟨k.1, hk⟩ = CutWalkVisitTag.fresh := by
        simpa [trace, CutWalkReplayPrefix.toTrace, hk] using htag
      simpa [trace, CutWalkReplayPrefix.toTrace, hk] using
        hmem ⟨k.1, hk⟩ htagPref
    · have htagRevisit :
          trace.tag k = CutWalkVisitTag.revisit := by
        simpa [trace] using pref.toTrace_tag_of_not_lt hpos hlen hk
      rw [htagRevisit] at htag
      cases htag
  · intro x hx
    rcases hcover x hx with ⟨k, htag, hstep⟩
    have hk2 : k.1 < 2 * m := lt_of_lt_of_le k.2 hlen
    refine ⟨⟨k.1, hk2⟩, ?_, ?_⟩
    · simpa [trace, CutWalkReplayPrefix.toTrace, k.2] using htag
    · simpa [trace, CutWalkReplayPrefix.toTrace, k.2] using hstep

def cutWalkRootBounceTrace (m i : ℕ) : CutWalkReplayTrace m i where
  node := cutWalkBounceNode (GridClauseId.horizontal i 0) (cutWalkRoot i)
  step := fun _ => GridClauseId.horizontal i 0
  tag := fun k =>
    if k.1 = 0 then CutWalkVisitTag.fresh else CutWalkVisitTag.revisit
  node_zero := rfl
  source_mem := by
    intro k
    exact cutWalkBounceNode_mem_dualEndpoints
      (cutWalkRoot_mem_horizontal_zero_dualEndpoints i) k.1
  node_succ := by
    intro k
    rfl

@[simp] theorem cutWalkRootBounceTrace_step
    (m i : ℕ) (k : Fin (2 * m)) :
    (cutWalkRootBounceTrace m i).step k = GridClauseId.horizontal i 0 :=
  rfl

@[simp] theorem cutWalkRootBounceTrace_tag_zero
    {m i : ℕ} {h0 : 0 < 2 * m} :
    (cutWalkRootBounceTrace m i).tag ⟨0, h0⟩ = CutWalkVisitTag.fresh := by
  simp [cutWalkRootBounceTrace]

@[simp] theorem cutWalkRootBounceTrace_tag_pos
    {m i : ℕ} {k : Fin (2 * m)}
    (hk : k.1 ≠ 0) :
    (cutWalkRootBounceTrace m i).tag k = CutWalkVisitTag.revisit := by
  simp [cutWalkRootBounceTrace, hk]

def cutWalkRootNeighborDirectNode (i : ℕ) (c : GridClauseId) : ℕ → GridNode
  | 0 => cutWalkRoot i
  | n + 1 =>
      cutWalkBounceNode c
        (cutWalkMoveTarget (cutWalkRoot i)
          (cutWalkMoveFromClauseEndpoint (GridClauseId.horizontal i 0) (cutWalkRoot i))) n

def cutWalkRootNeighborDirectStep (i : ℕ) (c : GridClauseId) : ℕ → GridClauseId
  | 0 => GridClauseId.horizontal i 0
  | _ + 1 => c

def cutWalkRootNeighborDirectTag : ℕ → CutWalkVisitTag
  | 0 => CutWalkVisitTag.fresh
  | 1 => CutWalkVisitTag.fresh
  | _ + 2 => CutWalkVisitTag.revisit

def cutWalkRootNeighborDirectTrace
    (m i : ℕ) (c : GridClauseId)
    (hc :
      cutWalkMoveTarget (cutWalkRoot i)
          (cutWalkMoveFromClauseEndpoint (GridClauseId.horizontal i 0) (cutWalkRoot i)) ∈
        gridClauseDualEndpoints c) :
    CutWalkReplayTrace m i where
  node := cutWalkRootNeighborDirectNode i c
  step := fun k => cutWalkRootNeighborDirectStep i c k.1
  tag := fun k => cutWalkRootNeighborDirectTag k.1
  node_zero := rfl
  source_mem := by
    intro k
    rcases k with ⟨n, hn⟩
    cases n with
    | zero =>
        exact cutWalkRoot_mem_horizontal_zero_dualEndpoints i
    | succ n =>
        exact cutWalkBounceNode_mem_dualEndpoints hc n
  node_succ := by
    intro k
    rcases k with ⟨n, hn⟩
    cases n with
    | zero =>
        simp [cutWalkRootNeighborDirectNode, cutWalkRootNeighborDirectStep,
          cutWalkBounceNode]
    | succ n =>
        rfl

def cutWalkRootNeighborBacktrackNode (i : ℕ) (c : GridClauseId) : ℕ → GridNode
  | 0 => cutWalkRoot i
  | 1 =>
      cutWalkMoveTarget (cutWalkRoot i)
        (cutWalkMoveFromClauseEndpoint (GridClauseId.horizontal i 0) (cutWalkRoot i))
  | n + 2 => cutWalkBounceNode c (cutWalkRoot i) n

def cutWalkRootNeighborBacktrackStep (i : ℕ) (c : GridClauseId) : ℕ → GridClauseId
  | 0 => GridClauseId.horizontal i 0
  | 1 => GridClauseId.horizontal i 0
  | _ + 2 => c

def cutWalkRootNeighborBacktrackTag : ℕ → CutWalkVisitTag
  | 0 => CutWalkVisitTag.fresh
  | 1 => CutWalkVisitTag.revisit
  | 2 => CutWalkVisitTag.fresh
  | _ + 3 => CutWalkVisitTag.revisit

def cutWalkRootNeighborBacktrackTrace
    (m i : ℕ) (c : GridClauseId)
    (hc : cutWalkRoot i ∈ gridClauseDualEndpoints c) :
    CutWalkReplayTrace m i where
  node := cutWalkRootNeighborBacktrackNode i c
  step := fun k => cutWalkRootNeighborBacktrackStep i c k.1
  tag := fun k => cutWalkRootNeighborBacktrackTag k.1
  node_zero := rfl
  source_mem := by
    intro k
    rcases k with ⟨n, hn⟩
    cases n with
    | zero =>
        exact cutWalkRoot_mem_horizontal_zero_dualEndpoints i
    | succ n =>
        cases n with
        | zero =>
            rw [cutWalkRootNeighborBacktrackNode]
            exact cutWalkMoveFromClauseEndpoint_target_mem_dualEndpoints
              (cutWalkRoot_mem_horizontal_zero_dualEndpoints i)
        | succ n =>
            exact cutWalkBounceNode_mem_dualEndpoints hc n
  node_succ := by
    intro k
    rcases k with ⟨n, hn⟩
    cases n with
    | zero =>
        simp [cutWalkRootNeighborBacktrackNode, cutWalkRootNeighborBacktrackStep]
    | succ n =>
        cases n with
        | zero =>
            simp [cutWalkRootNeighborBacktrackNode, cutWalkRootNeighborBacktrackStep,
              cutWalkRoot, cutWalkMoveFromClauseEndpoint, cutWalkMoveTarget,
              cutWalkBounceNode]
        | succ n =>
            rfl

theorem CutWalkReplayTrace.step_dualAdjacent_succ
    {m i : ℕ} (trace : CutWalkReplayTrace m i) {n : ℕ}
    (hn : n + 1 < 2 * m) :
    gridClauseDualAdjacent
      (trace.step ⟨n, Nat.lt_trans (Nat.lt_succ_self n) hn⟩)
      (trace.step ⟨n + 1, hn⟩) := by
  have hprev : n < 2 * m := Nat.lt_trans (Nat.lt_succ_self n) hn
  refine ⟨trace.node (n + 1), ?_, ?_⟩
  · rw [trace.node_succ ⟨n, hprev⟩]
    exact cutWalkMoveFromClauseEndpoint_target_mem_dualEndpoints
      (trace.source_mem ⟨n, hprev⟩)
  · exact trace.source_mem ⟨n + 1, hn⟩

theorem CutWalkReplayTrace.step_reachable_from_first
    {m i : ℕ} (trace : CutWalkReplayTrace m i)
    {s : Finset GridClauseId} (h0 : 0 < 2 * m)
    (hmem : ∀ k : Fin (2 * m), trace.step k ∈ s) :
    ∀ (n : ℕ) (hn : n < 2 * m),
      Relation.ReflTransGen
        (fun a b => a ∈ s ∧ b ∈ s ∧ gridClauseDualAdjacent a b)
        (trace.step ⟨0, h0⟩) (trace.step ⟨n, hn⟩) := by
  intro n
  induction n with
  | zero =>
      intro hn
      simpa using
        (Relation.ReflTransGen.refl :
          Relation.ReflTransGen
            (fun a b => a ∈ s ∧ b ∈ s ∧ gridClauseDualAdjacent a b)
            (trace.step ⟨0, h0⟩) (trace.step ⟨0, h0⟩))
  | succ n ih =>
      intro hn
      have hprev : n < 2 * m := Nat.lt_trans (Nat.lt_succ_self n) hn
      exact Relation.ReflTransGen.tail (ih hprev)
        ⟨hmem ⟨n, hprev⟩, hmem ⟨n + 1, hn⟩,
          trace.step_dualAdjacent_succ hn⟩

theorem rootedDualConnectedCutSet_of_replayTrace_all_steps
    {m i : ℕ} {root : GridClauseId} {s : Finset GridClauseId}
    {h0 : 0 < 2 * m}
    (trace : CutWalkReplayTrace m i)
    (hroot : trace.step ⟨0, h0⟩ = root)
    (hmem : ∀ k : Fin (2 * m), trace.step k ∈ s)
    (hcover : ∀ x ∈ s, ∃ k : Fin (2 * m), trace.step k = x) :
    RootedDualConnectedCutSet root s := by
  refine ⟨?_, ?_⟩
  · simpa [← hroot] using hmem ⟨0, h0⟩
  · intro x hx
    rcases hcover x hx with ⟨k, hk⟩
    have hreach :=
      trace.step_reachable_from_first h0 hmem k.1 k.2
    simpa [hroot, hk] using hreach

def cutWalkReplayTraceCode {m i : ℕ}
    (trace : CutWalkReplayTrace m i) : CutWalkCode m :=
  fun k =>
    (cutWalkMoveFromClauseEndpoint (trace.step k) (trace.node k.1),
      trace.tag k)

theorem cutWalkReplayTraceCode_first_of_horizontal_zero
    {m i : ℕ} (trace : CutWalkReplayTrace m i) {h0 : 0 < 2 * m}
    (hstep : trace.step ⟨0, h0⟩ = GridClauseId.horizontal i 0)
    (htag : trace.tag ⟨0, h0⟩ = CutWalkVisitTag.fresh) :
    cutWalkReplayTraceCode trace ⟨0, h0⟩ =
      (CutWalkMove.north, CutWalkVisitTag.fresh) := by
  unfold cutWalkReplayTraceCode
  rw [hstep, htag, trace.node_zero]
  simp

theorem cutWalkTraceNode_eq_replayTrace_node
    {m i : ℕ} (trace : CutWalkReplayTrace m i) :
    ∀ n, n ≤ 2 * m →
      cutWalkTraceNode m (cutWalkRoot i)
        (cutWalkReplayTraceCode trace) n = trace.node n := by
  intro n
  induction n with
  | zero =>
      intro _hn
      simp [cutWalkTraceNode, trace.node_zero]
  | succ n ih =>
      intro hn
      have hprev : n < 2 * m := Nat.lt_of_succ_le hn
      have hle : n ≤ 2 * m := Nat.le_of_lt hprev
      rw [cutWalkTraceNode_succ_of_lt
        (root := cutWalkRoot i) (code := cutWalkReplayTraceCode trace) hprev]
      rw [ih hle]
      simp [cutWalkReplayTraceCode]
      exact (trace.node_succ ⟨n, hprev⟩).symm

theorem cutWalkStepClause_cutWalkReplayTraceCode
    {m i : ℕ} (trace : CutWalkReplayTrace m i)
    (k : Fin (2 * m)) :
    cutWalkStepClause m i (cutWalkReplayTraceCode trace) k =
      trace.step k := by
  unfold cutWalkStepClause
  have hnode :
      cutWalkTraceNode m (cutWalkRoot i)
          (cutWalkReplayTraceCode trace) k.1 =
        trace.node k.1 :=
    cutWalkTraceNode_eq_replayTrace_node trace k.1 (Nat.le_of_lt k.2)
  rw [hnode]
  simp [cutWalkReplayTraceCode]
  exact cutWalkMoveClause_cutWalkMoveFromClauseEndpoint (trace.source_mem k)

theorem cutWalkDecode_cutWalkReplayTraceCode_eq
    {m i j : ℕ} {s : Finset GridClauseId}
    (trace : CutWalkReplayTrace m i)
    (hmem :
      ∀ k : Fin (2 * m),
        trace.tag k = CutWalkVisitTag.fresh →
          trace.step k ∈ s)
    (hcover :
      ∀ x ∈ s,
        ∃ k : Fin (2 * m),
          trace.tag k = CutWalkVisitTag.fresh ∧
            trace.step k = x) :
    cutWalkDecode m i j (cutWalkReplayTraceCode trace) = s := by
  apply cutWalkDecode_eq_of_fresh_step_mem_and_cover
  · intro k hfresh
    have htag : trace.tag k = CutWalkVisitTag.fresh := by
      simpa [cutWalkReplayTraceCode] using hfresh
    simpa [cutWalkStepClause_cutWalkReplayTraceCode] using hmem k htag
  · intro x hx
    rcases hcover x hx with ⟨k, htag, hstep⟩
    refine ⟨k, ?_, ?_⟩
    · simpa [cutWalkReplayTraceCode] using htag
    · simpa [cutWalkStepClause_cutWalkReplayTraceCode] using hstep

theorem exists_cutWalkCode_decode_eq_of_replayTrace
    {m i j : ℕ} {s : Finset GridClauseId}
    (trace : CutWalkReplayTrace m i)
    (hmem :
      ∀ k : Fin (2 * m),
        trace.tag k = CutWalkVisitTag.fresh →
          trace.step k ∈ s)
    (hcover :
      ∀ x ∈ s,
        ∃ k : Fin (2 * m),
          trace.tag k = CutWalkVisitTag.fresh ∧
            trace.step k = x) :
    ∃ code : CutWalkCode m, cutWalkDecode m i j code = s :=
  ⟨cutWalkReplayTraceCode trace,
    cutWalkDecode_cutWalkReplayTraceCode_eq trace hmem hcover⟩

theorem exists_rooted_cutWalkCode_decode_eq_of_replayTrace
    {m i j : ℕ} {s : Finset GridClauseId} {h0 : 0 < 2 * m}
    (trace : CutWalkReplayTrace m i)
    (hstep : trace.step ⟨0, h0⟩ = GridClauseId.horizontal i 0)
    (htag : trace.tag ⟨0, h0⟩ = CutWalkVisitTag.fresh)
    (hmem :
      ∀ k : Fin (2 * m),
        trace.tag k = CutWalkVisitTag.fresh →
          trace.step k ∈ s)
    (hcover :
      ∀ x ∈ s,
        ∃ k : Fin (2 * m),
          trace.tag k = CutWalkVisitTag.fresh ∧
            trace.step k = x) :
    ∃ code : CutWalkCode m,
      code ⟨0, h0⟩ = (CutWalkMove.north, CutWalkVisitTag.fresh) ∧
        cutWalkDecode m i j code = s :=
  ⟨cutWalkReplayTraceCode trace,
    cutWalkReplayTraceCode_first_of_horizontal_zero trace hstep htag,
    cutWalkDecode_cutWalkReplayTraceCode_eq trace hmem hcover⟩

theorem exists_rooted_cutWalkCode_decode_eq_of_prefix
    {m i j : ℕ} {s : Finset GridClauseId} {h0 : 0 < 2 * m}
    (pref : CutWalkReplayPrefix i)
    (hpos : 0 < pref.len) (hlen : pref.len ≤ 2 * m)
    (hstep0 : pref.step ⟨0, hpos⟩ = GridClauseId.horizontal i 0)
    (htag0 : pref.tag ⟨0, hpos⟩ = CutWalkVisitTag.fresh)
    (hmem :
