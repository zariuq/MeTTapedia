  exact exists_rooted_cutWalkCode_decode_eq_of_prefix
    (m := hookSlackHullCutCard) (i := 1) (j := 1) (s := hookSlackHullCutSet)
    (h0 := by rw [hookSlackHullCutCard_eq_six]; norm_num)
    pref hprefPos hprefLen hprefStep0 hprefTag0 hprefMem hprefCover

theorem cutWalkCodeInjection_family_of_clauseChain_exists
    (hchain :
      ∀ m, 2 ≤ m → ∀ i ∈ Finset.range m, ∀ j ∈ Finset.range (m - (i + 1)),
        ∀ s :
          {s // s ∈ originConnectedHullCutSetCandidatesInCutCardBoxAxisAnchored m i j},
          ∃ tail : List GridClauseId,
            1 + 2 * tail.length ≤ 2 * m ∧
              List.IsChain gridClauseDualAdjacent
                (GridClauseId.horizontal i 0 :: tail) ∧
                (∀ c ∈ tail, c ∈ s.1) ∧
                  (∀ x ∈ s.1, x = GridClauseId.horizontal i 0 ∨ x ∈ tail)) :
    ∀ m, 2 ≤ m → ∀ i ∈ Finset.range m, ∀ j ∈ Finset.range (m - (i + 1)),
      ∃ f :
        {s // s ∈ originConnectedHullCutSetCandidatesInCutCardBoxAxisAnchored m i j} →
          CutWalkCode m,
        Function.Injective f := by
  refine cutWalkCodeInjection_family_of_rootedCutWalkDecode_exists ?_
  intro m hm i hi j hj h0 s
  rcases hchain m hm i hi j hj s with
    ⟨tail, hlen, hchainTail, htailMem, hcover⟩
  exact exists_rooted_cutWalkCode_decode_eq_of_clauseChain
    (m := m) (i := i) (j := j) (s := s.1) (h0 := h0)
    tail hlen hchainTail
    (horizontal_root_mem_of_mem_originConnectedHullCutSetCandidatesInCutCardBoxAxisAnchored s.2)
    htailMem hcover

theorem cutWalkCodeInjection_family_of_taggedClauseChain_exists
    (hchain :
      ∀ m, 2 ≤ m → ∀ i ∈ Finset.range m, ∀ j ∈ Finset.range (m - (i + 1)),
        ∀ s :
          {s // s ∈ originConnectedHullCutSetCandidatesInCutCardBoxAxisAnchored m i j},
          ∃ tail : List (GridClauseId × CutWalkVisitTag),
            1 + 2 * tail.length ≤ 2 * m ∧
              List.IsChain gridClauseDualAdjacent
                (GridClauseId.horizontal i 0 :: tail.map Prod.fst) ∧
                (∀ c, (c, CutWalkVisitTag.fresh) ∈ tail → c ∈ s.1) ∧
                  (∀ x ∈ s.1,
                    x = GridClauseId.horizontal i 0 ∨
                      (x, CutWalkVisitTag.fresh) ∈ tail)) :
    ∀ m, 2 ≤ m → ∀ i ∈ Finset.range m, ∀ j ∈ Finset.range (m - (i + 1)),
      ∃ f :
        {s // s ∈ originConnectedHullCutSetCandidatesInCutCardBoxAxisAnchored m i j} →
          CutWalkCode m,
        Function.Injective f := by
  refine cutWalkCodeInjection_family_of_rootedCutWalkDecode_exists ?_
  intro m hm i hi j hj h0 s
  rcases hchain m hm i hi j hj s with
    ⟨tail, hlen, hchainTail, hfreshMem, hcover⟩
  exact exists_rooted_cutWalkCode_decode_eq_of_taggedClauseChain
    (m := m) (i := i) (j := j) (s := s.1) (h0 := h0)
    tail hlen hchainTail
      (horizontal_root_mem_of_mem_originConnectedHullCutSetCandidatesInCutCardBoxAxisAnchored s.2)
    hfreshMem hcover

/-- The remaining contour-construction content for the F4 route, isolated as one
named hypothesis: every axis-anchored cut-set candidate has a dual-adjacent
tagged clause chain whose fresh entries are exactly the candidate clauses. -/
abbrev AxisAnchoredTaggedClauseChainFamily : Prop :=
  ∀ m, 2 ≤ m → ∀ i ∈ Finset.range m, ∀ j ∈ Finset.range (m - (i + 1)),
    ∀ s :
      {s // s ∈ originConnectedHullCutSetCandidatesInCutCardBoxAxisAnchored m i j},
      ∃ tail : List (GridClauseId × CutWalkVisitTag),
        1 + 2 * tail.length ≤ 2 * m ∧
          List.IsChain gridClauseDualAdjacent
            (GridClauseId.horizontal i 0 :: tail.map Prod.fst) ∧
            (∀ c, (c, CutWalkVisitTag.fresh) ∈ tail → c ∈ s.1) ∧
          (∀ x ∈ s.1,
                x = GridClauseId.horizontal i 0 ∨
                  (x, CutWalkVisitTag.fresh) ∈ tail)

/- Impossibility witness, NOT a dependency: the tagged-chain family hypothesis
is false on the hook candidate. It remains only to keep the dead `CutWalkCode`
route from being reused as the public F4 path. -/
set_option maxRecDepth 10000 in
theorem not_axisAnchoredTaggedClauseChainFamily :
    ¬ AxisAnchoredTaggedClauseChainFamily := by
  intro hchain
  let root := GridClauseId.horizontal 1 0
  let s : {s // s ∈
      originConnectedHullCutSetCandidatesInCutCardBoxAxisAnchored
        hookSlackHullCutCard 1 1} :=
    ⟨hookSlackHullCutSet,
      hookSlackHullCutSet_mem_originConnectedHullCutSetCandidatesInCutCardBoxAxisAnchored⟩
  have hm : 2 ≤ hookSlackHullCutCard := by
    rw [hookSlackHullCutCard_eq_six]
    norm_num
  have hi : 1 ∈ Finset.range hookSlackHullCutCard := by
    rw [hookSlackHullCutCard_eq_six]
    simp
  have hj : 1 ∈ Finset.range (hookSlackHullCutCard - (1 + 1)) := by
    rw [hookSlackHullCutCard_eq_six]
    simp
  rcases hchain hookSlackHullCutCard hm 1 hi 1 hj s with
    ⟨tail, hlen, hchainTail, hfreshMem, hcover⟩
  have htailLen : tail.length ≤ 5 := by
    rw [hookSlackHullCutCard_eq_six] at hlen
    omega
  have h11 : (GridClauseId.horizontal 1 1, CutWalkVisitTag.fresh) ∈ tail := by
    have hx : GridClauseId.horizontal 1 1 ∈ hookSlackHullCutSet := by
      rw [hookSlackHullCutSet_eq_explicit]
      simp
    rcases hcover (GridClauseId.horizontal 1 1) hx with hroot | ht
    · simp at hroot
    · exact ht
  have h12 : (GridClauseId.horizontal 1 2, CutWalkVisitTag.fresh) ∈ tail := by
    have hx : GridClauseId.horizontal 1 2 ∈ hookSlackHullCutSet := by
      rw [hookSlackHullCutSet_eq_explicit]
      simp
    rcases hcover (GridClauseId.horizontal 1 2) hx with hroot | ht
    · simp at hroot
    · exact ht
  have h02 : (GridClauseId.horizontal 0 2, CutWalkVisitTag.fresh) ∈ tail := by
    have hx : GridClauseId.horizontal 0 2 ∈ hookSlackHullCutSet := by
      rw [hookSlackHullCutSet_eq_explicit]
      simp
    rcases hcover (GridClauseId.horizontal 0 2) hx with hroot | ht
    · simp at hroot
    · exact ht
  have hv01 : (GridClauseId.vertical 0 1, CutWalkVisitTag.fresh) ∈ tail := by
    have hx : GridClauseId.vertical 0 1 ∈ hookSlackHullCutSet := by
      rw [hookSlackHullCutSet_eq_explicit]
      simp
    rcases hcover (GridClauseId.vertical 0 1) hx with hroot | ht
    · simp at hroot
    · exact ht
  have hv12 : (GridClauseId.vertical 1 2, CutWalkVisitTag.fresh) ∈ tail := by
    have hx : GridClauseId.vertical 1 2 ∈ hookSlackHullCutSet := by
      rw [hookSlackHullCutSet_eq_explicit]
      simp
    rcases hcover (GridClauseId.vertical 1 2) hx with hroot | ht
    · simp at hroot
    · exact ht
  let required : Finset (GridClauseId × CutWalkVisitTag) :=
    ({ (GridClauseId.horizontal 1 1, CutWalkVisitTag.fresh),
       (GridClauseId.horizontal 1 2, CutWalkVisitTag.fresh),
       (GridClauseId.horizontal 0 2, CutWalkVisitTag.fresh),
       (GridClauseId.vertical 0 1, CutWalkVisitTag.fresh),
       (GridClauseId.vertical 1 2, CutWalkVisitTag.fresh) } :
      Finset (GridClauseId × CutWalkVisitTag))
  have hrequiredCard : required.card = 5 := by
    simp [required]
  have hrequiredSubset : required ⊆ tail.toFinset := by
    intro p hp
    simp [required] at hp
    rcases hp with rfl | rfl | rfl | rfl | rfl
    · exact List.mem_toFinset.2 h11
    · exact List.mem_toFinset.2 h12
    · exact List.mem_toFinset.2 h02
    · exact List.mem_toFinset.2 hv01
    · exact List.mem_toFinset.2 hv12
  have htailToFinsetSubset : tail.toFinset ⊆ required := by
    have hcardTail : tail.toFinset.card ≤ required.card := by
      calc
        tail.toFinset.card ≤ tail.length := List.toFinset_card_le tail
        _ ≤ required.card := by
          simpa [hrequiredCard] using htailLen
    have heq : required = tail.toFinset :=
      Finset.eq_of_subset_of_card_le hrequiredSubset hcardTail
    intro p hp
    rw [heq]
    exact hp
  have htailMem :
      ∀ c ∈ tail.map Prod.fst, c ∈ hookSlackHullCutSet := by
    intro c hc
    rcases List.mem_map.1 hc with ⟨p, hpTail, hpEq⟩
    have hpReq : p ∈ required :=
      htailToFinsetSubset (List.mem_toFinset.2 hpTail)
    simp [required] at hpReq
    rcases hpReq with rfl | rfl | rfl | rfl | rfl
    · rw [← hpEq, hookSlackHullCutSet_eq_explicit]
      simp
    · rw [← hpEq, hookSlackHullCutSet_eq_explicit]
      simp
    · rw [← hpEq, hookSlackHullCutSet_eq_explicit]
      simp
    · rw [← hpEq, hookSlackHullCutSet_eq_explicit]
      simp
    · rw [← hpEq, hookSlackHullCutSet_eq_explicit]
      simp
  have hcoverMap :
      ∀ x ∈ hookSlackHullCutSet, x = root ∨ x ∈ tail.map Prod.fst := by
    intro x hx
    rcases hcover x hx with hroot | ht
    · exact Or.inl hroot
    · exact Or.inr (List.mem_map.2
        ⟨(x, CutWalkVisitTag.fresh), ht, rfl⟩)
  have hconn :
      RootedDualConnectedCutSet root hookSlackHullCutSet :=
    rootedDualConnectedCutSet_of_clauseChain
      (root := root) (s := hookSlackHullCutSet) (tail := tail.map Prod.fst)
      (by simpa [root] using horizontal10_mem_hookSlackHullCutSet)
      (by simpa [root] using hchainTail)
      htailMem hcoverMap
  exact not_rootedDualConnectedCutSet_hookSlackHullCutSet (by
    simpa [root] using hconn)

/-- Quarantined/dead implication: `not_axisAnchoredTaggedClauseChainFamily`
shows this hypothesis is false for the current candidate carrier. Keep this
adapter only as an impossibility witness; do not build the F4 route on it. -/
theorem cutWalkCodeInjection_family_of_axisAnchoredTaggedClauseChain
    (hchain : AxisAnchoredTaggedClauseChainFamily) :
    ∀ m, 2 ≤ m → ∀ i ∈ Finset.range m, ∀ j ∈ Finset.range (m - (i + 1)),
      ∃ f :
        {s // s ∈ originConnectedHullCutSetCandidatesInCutCardBoxAxisAnchored m i j} →
          CutWalkCode m,
        Function.Injective f :=
  cutWalkCodeInjection_family_of_taggedClauseChain_exists hchain

/-- Corrected contour-code carrier with an explicit length multiplier. The
future traversal theorem must prove a real bound `len ≤ κ*m`; this carrier only
records the resulting finite alphabet count. -/
abbrev ContourCode (κ m : ℕ) := Fin (κ * m) → (CutWalkMove × CutWalkVisitTag)

def contourTraceNode (κ m : ℕ) (root : GridNode) (code : ContourCode κ m) :
    ℕ → GridNode
  | 0 => root
  | n + 1 =>
      if h : n < κ * m then
        cutWalkMoveTarget (contourTraceNode κ m root code n) (code ⟨n, h⟩).1
      else
        contourTraceNode κ m root code n

theorem contourTraceNode_succ_of_lt
    {κ m : ℕ} {root : GridNode} {code : ContourCode κ m} {n : ℕ}
    (hn : n < κ * m) :
    contourTraceNode κ m root code (n + 1) =
      cutWalkMoveTarget (contourTraceNode κ m root code n) (code ⟨n, hn⟩).1 := by
  simp [contourTraceNode, hn]

def contourStepClause (κ m i : ℕ) (code : ContourCode κ m)
    (k : Fin (κ * m)) : GridClauseId :=
  cutWalkMoveClause (contourTraceNode κ m (cutWalkRoot i) code k.1) (code k).1

noncomputable def contourDecode (κ m i _j : ℕ) (code : ContourCode κ m) :
    Finset GridClauseId :=
  ((Finset.univ : Finset (Fin (κ * m))).filter
      (fun k => (code k).2 = CutWalkVisitTag.fresh)).image
    (contourStepClause κ m i code)

theorem contourStepClause_mem_contourDecode_of_fresh
    {κ m i j : ℕ} {code : ContourCode κ m} {k : Fin (κ * m)}
    (hfresh : (code k).2 = CutWalkVisitTag.fresh) :
    contourStepClause κ m i code k ∈ contourDecode κ m i j code := by
  unfold contourDecode
  refine Finset.mem_image.2 ?_
  exact ⟨k, by simp [hfresh], rfl⟩

theorem contourDecode_subset_of_fresh_step_mem
    {κ m i j : ℕ} {code : ContourCode κ m} {s : Finset GridClauseId}
    (hmem :
      ∀ k : Fin (κ * m),
        (code k).2 = CutWalkVisitTag.fresh →
          contourStepClause κ m i code k ∈ s) :
    contourDecode κ m i j code ⊆ s := by
  intro x hx
  unfold contourDecode at hx
  rcases Finset.mem_image.1 hx with ⟨k, hk, rfl⟩
  exact hmem k (Finset.mem_filter.1 hk).2

theorem subset_contourDecode_of_fresh_step_cover
    {κ m i j : ℕ} {code : ContourCode κ m} {s : Finset GridClauseId}
    (hcover :
      ∀ x ∈ s,
        ∃ k : Fin (κ * m),
          (code k).2 = CutWalkVisitTag.fresh ∧
            contourStepClause κ m i code k = x) :
    s ⊆ contourDecode κ m i j code := by
  intro x hx
  rcases hcover x hx with ⟨k, hfresh, hstep⟩
  rw [← hstep]
  exact contourStepClause_mem_contourDecode_of_fresh
    (κ := κ) (m := m) (i := i) (j := j) (code := code) (k := k) hfresh

theorem contourDecode_eq_of_fresh_step_mem_and_cover
    {κ m i j : ℕ} {code : ContourCode κ m} {s : Finset GridClauseId}
    (hmem :
      ∀ k : Fin (κ * m),
        (code k).2 = CutWalkVisitTag.fresh →
          contourStepClause κ m i code k ∈ s)
    (hcover :
      ∀ x ∈ s,
        ∃ k : Fin (κ * m),
          (code k).2 = CutWalkVisitTag.fresh ∧
            contourStepClause κ m i code k = x) :
    contourDecode κ m i j code = s :=
  Finset.Subset.antisymm
    (contourDecode_subset_of_fresh_step_mem hmem)
    (subset_contourDecode_of_fresh_step_cover hcover)

/-- Replay a finite prefix in the first slots of a contour code; all padding
slots are revisit-tagged and therefore invisible to `contourDecode`. -/
def CutWalkReplayPrefix.toContourCode {κ m i : ℕ}
    (pref : CutWalkReplayPrefix i) : ContourCode κ m :=
  fun k =>
    if h : k.1 < pref.len then
      (cutWalkMoveFromClauseEndpoint (pref.step ⟨k.1, h⟩) (pref.node k.1),
        pref.tag ⟨k.1, h⟩)
    else
      (CutWalkMove.north, CutWalkVisitTag.revisit)

theorem CutWalkReplayPrefix.toContourCode_tag_of_lt
    {κ m i : ℕ} (pref : CutWalkReplayPrefix i)
    {k : Fin (κ * m)} (hk : k.1 < pref.len) :
    (pref.toContourCode (κ := κ) (m := m) k).2 =
      pref.tag ⟨k.1, hk⟩ := by
  simp [CutWalkReplayPrefix.toContourCode, hk]

theorem CutWalkReplayPrefix.toContourCode_tag_of_not_lt
    {κ m i : ℕ} (pref : CutWalkReplayPrefix i)
    {k : Fin (κ * m)} (hk : ¬ k.1 < pref.len) :
    (pref.toContourCode (κ := κ) (m := m) k).2 =
      CutWalkVisitTag.revisit := by
  simp [CutWalkReplayPrefix.toContourCode, hk]

theorem CutWalkReplayPrefix.contourTraceNode_toContourCode_eq_of_le
    {κ m i : ℕ} (pref : CutWalkReplayPrefix i)
    (hlen : pref.len ≤ κ * m) :
    ∀ n, n ≤ pref.len →
      contourTraceNode κ m (cutWalkRoot i)
        (pref.toContourCode (κ := κ) (m := m)) n = pref.node n := by
  intro n hn
  induction n with
  | zero =>
      simp [contourTraceNode, pref.node_zero]
  | succ n ih =>
      have hnPref : n < pref.len := Nat.lt_of_succ_le hn
      have hnBound : n < κ * m := Nat.lt_of_lt_of_le hnPref hlen
      have hnLe : n ≤ pref.len := Nat.le_of_lt hnPref
      rw [contourTraceNode_succ_of_lt
        (root := cutWalkRoot i)
        (code := pref.toContourCode (κ := κ) (m := m)) hnBound]
      rw [ih hnLe]
      simp [CutWalkReplayPrefix.toContourCode, hnPref]
      exact (pref.node_succ ⟨n, hnPref⟩).symm

theorem CutWalkReplayPrefix.contourStepClause_toContourCode_of_lt
    {κ m i : ℕ} (pref : CutWalkReplayPrefix i)
    (hlen : pref.len ≤ κ * m)
    {k : Fin (κ * m)} (hk : k.1 < pref.len) :
    contourStepClause κ m i (pref.toContourCode (κ := κ) (m := m)) k =
      pref.step ⟨k.1, hk⟩ := by
  unfold contourStepClause
  have hnode :
      contourTraceNode κ m (cutWalkRoot i)
          (pref.toContourCode (κ := κ) (m := m)) k.1 =
        pref.node k.1 :=
    pref.contourTraceNode_toContourCode_eq_of_le hlen k.1 (Nat.le_of_lt hk)
  rw [hnode]
  simp [CutWalkReplayPrefix.toContourCode, hk]
  exact cutWalkMoveClause_cutWalkMoveFromClauseEndpoint (pref.source_mem ⟨k.1, hk⟩)

theorem CutWalkReplayPrefix.contourDecode_toContourCode_eq
    {κ m i j : ℕ} {s : Finset GridClauseId}
    (pref : CutWalkReplayPrefix i)
    (hlen : pref.len ≤ κ * m)
    (hmem :
      ∀ k : Fin pref.len,
        pref.tag k = CutWalkVisitTag.fresh →
          pref.step k ∈ s)
    (hcover :
      ∀ x ∈ s,
        ∃ k : Fin pref.len,
          pref.tag k = CutWalkVisitTag.fresh ∧
            pref.step k = x) :
    contourDecode κ m i j (pref.toContourCode (κ := κ) (m := m)) = s := by
  apply contourDecode_eq_of_fresh_step_mem_and_cover
  · intro k hfresh
    by_cases hk : k.1 < pref.len
    · have htag : pref.tag ⟨k.1, hk⟩ = CutWalkVisitTag.fresh := by
        simpa [CutWalkReplayPrefix.toContourCode, hk] using hfresh
      simpa [pref.contourStepClause_toContourCode_of_lt hlen hk] using
        hmem ⟨k.1, hk⟩ htag
    · have htagRevisit :
          (pref.toContourCode (κ := κ) (m := m) k).2 =
            CutWalkVisitTag.revisit :=
        pref.toContourCode_tag_of_not_lt hk
      rw [htagRevisit] at hfresh
      cases hfresh
  · intro x hx
    rcases hcover x hx with ⟨k, htag, hstep⟩
    have hkBound : k.1 < κ * m := lt_of_lt_of_le k.2 hlen
    let kk : Fin (κ * m) := ⟨k.1, hkBound⟩
    refine ⟨kk, ?_, ?_⟩
    · simp [CutWalkReplayPrefix.toContourCode, kk, k.2, htag]
    · have hstepClause :
          contourStepClause κ m i (pref.toContourCode (κ := κ) (m := m)) kk =
            pref.step k := by
        simpa [kk] using
          (pref.contourStepClause_toContourCode_of_lt hlen (k := kk)
            (by simp [kk, k.2]))
      exact hstepClause.trans hstep

theorem exists_contourDecode_eq_of_prefix
    {κ m i j : ℕ} {s : Finset GridClauseId}
    (pref : CutWalkReplayPrefix i)
    (hlen : pref.len ≤ κ * m)
    (hmem :
      ∀ k : Fin pref.len,
        pref.tag k = CutWalkVisitTag.fresh →
          pref.step k ∈ s)
    (hcover :
      ∀ x ∈ s,
        ∃ k : Fin pref.len,
          pref.tag k = CutWalkVisitTag.fresh ∧
            pref.step k = x) :
    ∃ code : ContourCode κ m, contourDecode κ m i j code = s :=
  ⟨pref.toContourCode (κ := κ) (m := m),
    pref.contourDecode_toContourCode_eq hlen hmem hcover⟩

theorem exists_rootedPrefix_of_starClauseChain
    {κ m i : ℕ} {s : Finset GridClauseId}
    (tail : List GridClauseId)
    (hlen : 1 + 4 * tail.length ≤ κ * m)
    (hchain : List.IsChain gridClauseStarAdjacent
      (GridClauseId.horizontal i 0 :: tail))
    (hroot : GridClauseId.horizontal i 0 ∈ s)
    (htailMem : ∀ c ∈ tail, c ∈ s)
    (hcover :
      ∀ x ∈ s, x = GridClauseId.horizontal i 0 ∨ x ∈ tail) :
    ∃ pref : CutWalkReplayPrefix i,
      ∃ hpos : 0 < pref.len,
        pref.len ≤ κ * m ∧
          pref.step ⟨0, hpos⟩ = GridClauseId.horizontal i 0 ∧
            pref.tag ⟨0, hpos⟩ = CutWalkVisitTag.fresh ∧
              (∀ k : Fin pref.len,
                pref.tag k = CutWalkVisitTag.fresh →
                  pref.step k ∈ s) ∧
                (∀ x ∈ s,
                  ∃ k : Fin pref.len,
                    pref.tag k = CutWalkVisitTag.fresh ∧
                      pref.step k = x) := by
  let pref₀ := cutWalkRootPrefix i
  have hpos₀ : 0 < pref₀.len := by
    simp [pref₀]
  have hchain₀ :
      List.IsChain gridClauseStarAdjacent (pref₀.lastStep hpos₀ :: tail) := by
    simpa [pref₀] using hchain
  have hmem₀ :
      ∀ k : Fin pref₀.len,
        pref₀.tag k = CutWalkVisitTag.fresh →
          pref₀.step k ∈ s := by
    intro k _htag
    simpa [pref₀, cutWalkRootPrefix] using hroot
  have hcover₀ :
      ∀ x ∈ ({GridClauseId.horizontal i 0} : Finset GridClauseId),
        ∃ k : Fin pref₀.len,
          pref₀.tag k = CutWalkVisitTag.fresh ∧
            pref₀.step k = x := by
    intro x hx
    simp at hx
    subst hx
    exact ⟨⟨0, hpos₀⟩, by simp [pref₀, cutWalkRootPrefix],
      by simp [pref₀, cutWalkRootPrefix]⟩
  rcases
    CutWalkReplayPrefix.exists_appendStarChain_fresh_cover
      (i := i) (s := s)
      (t := ({GridClauseId.horizontal i 0} : Finset GridClauseId))
      tail pref₀ hpos₀ hchain₀ htailMem hmem₀ hcover₀ with
    ⟨pref, hprefLen, hfirst, hmem, hcoverPrefix⟩
  have hprefLe : pref.len ≤ κ * m := by
    calc
      pref.len ≤ pref₀.len + 4 * tail.length := hprefLen
      _ ≤ κ * m := by
        simpa [pref₀] using hlen
  have hrootCovered :
      ∃ k : Fin pref.len,
        pref.tag k = CutWalkVisitTag.fresh ∧
          pref.step k = GridClauseId.horizontal i 0 :=
    hcoverPrefix (GridClauseId.horizontal i 0) (Or.inl (by simp))
  rcases hrootCovered with ⟨kroot, _htagRoot, _hstepRoot⟩
  have hpos : 0 < pref.len := Nat.lt_of_le_of_lt (Nat.zero_le _) kroot.2
  rcases hfirst hpos with ⟨hstepFirst, htagFirst⟩
  have hstep0 :
      pref.step ⟨0, hpos⟩ = GridClauseId.horizontal i 0 := by
    simpa [pref₀, cutWalkRootPrefix] using hstepFirst
  have htag0 :
      pref.tag ⟨0, hpos⟩ = CutWalkVisitTag.fresh := by
    simpa [pref₀, cutWalkRootPrefix] using htagFirst
  refine ⟨pref, hpos, hprefLe, hstep0, htag0, hmem, ?_⟩
  intro x hx
  apply hcoverPrefix x
  rcases hcover x hx with rfl | hxTail
  · left
    simp
  · right
    exact hxTail

theorem exists_contourDecode_eq_of_starClauseChain
    {κ m i j : ℕ} {s : Finset GridClauseId}
    (tail : List GridClauseId)
    (hlen : 1 + 4 * tail.length ≤ κ * m)
    (hchain : List.IsChain gridClauseStarAdjacent
      (GridClauseId.horizontal i 0 :: tail))
    (hroot : GridClauseId.horizontal i 0 ∈ s)
    (htailMem : ∀ c ∈ tail, c ∈ s)
    (hcover :
      ∀ x ∈ s, x = GridClauseId.horizontal i 0 ∨ x ∈ tail) :
    ∃ code : ContourCode κ m, contourDecode κ m i j code = s := by
  rcases exists_rootedPrefix_of_starClauseChain
      (κ := κ) (m := m) (i := i) (s := s)
      tail hlen hchain hroot htailMem hcover with
    ⟨pref, _hpos, hprefLe, _hstep0, _htag0, hmem, hcoverPrefix⟩
  exact exists_contourDecode_eq_of_prefix
    (κ := κ) (m := m) (i := i) (j := j) (s := s)
    pref hprefLe hmem hcoverPrefix

theorem exists_contourDecode_eq_of_starClauseChain_eight
