/-- The canonical boundary-connected hull induced by the five-site hook witness
at stage `4`. This is the first bridge from the raw inside witness to the
actual hull-based counting carrier. -/
noncomputable def hookSlackHull : Region GridNode :=
  boundaryConnectedHullRegion 4 hookSlackInside

/-- The stage-`4` cut-card of the hook-induced canonical hull. -/
noncomputable def hookSlackHullCutCard : ℕ :=
  originContainingSubregionCutCard 4 hookSlackHull

theorem hookSlackInside_subset_stage4 :
    hookSlackInside ⊆ gridExhaustion.region 4 :=
  (mem_originConnectedContainingSubregions_iff.1
    hookSlackInside_mem_originConnectedContainingSubregions).1

