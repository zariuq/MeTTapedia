      hs hx with
    ⟨_hull, _hhull, _hcutCard, _hsEq, hxCut⟩
  cases x with
  | prior a b =>
      cases hxCut
  | horizontal a b =>
      exact ⟨(a, b), by simp [gridClauseDualEndpoints]⟩
  | vertical a b =>
      exact ⟨(a, b), by simp [gridClauseDualEndpoints]⟩

