    (m := m) (i := i) (j := j) hm (s := s)
    tail ?_ hchain ?_ htailMem htailCover
  · omega
  · exact hmem (GridClauseId.horizontal i 0) p.start_mem_support

theorem RootedStarConnectedCutSet.subtype_reachable
    {root : GridClauseId} {s : Finset GridClauseId}
    (hstar : RootedStarConnectedCutSet root s)
    (x : {c // c ∈ s}) :
    Relation.ReflTransGen
      (fun a b : {c // c ∈ s} => gridClauseStarAdjacent a.1 b.1)
      ⟨root, hstar.root_mem⟩ x := by
  classical
  let f : GridClauseId → {c // c ∈ s} :=
    fun c => if hc : c ∈ s then ⟨c, hc⟩ else ⟨root, hstar.root_mem⟩
  have hf :
      ∀ a b,
        (fun a b : GridClauseId =>
          a ∈ s ∧ b ∈ s ∧ gridClauseStarAdjacent a b) a b →
          (fun a b : {c // c ∈ s} => gridClauseStarAdjacent a.1 b.1)
            (f a) (f b) := by
    intro a b hab
    simp [f, hab.1, hab.2.1, hab.2.2]
  have hrt :=
    Relation.ReflTransGen.lift
      (p := fun a b : {c // c ∈ s} => gridClauseStarAdjacent a.1 b.1)
      f hf (hstar.2 x.1 x.2)
  simpa [f, hstar.root_mem, x.2] using hrt

theorem RootedStarConnectedCutSet.subtype_starGraph_connected
    {root : GridClauseId} {s : Finset GridClauseId}
    (hstar : RootedStarConnectedCutSet root s) :
    let R : {c // c ∈ s} → {c // c ∈ s} → Prop :=
      fun a b => gridClauseStarAdjacent a.1 b.1
    let hRsymm : Std.Symm R := ⟨fun _ _ hab => gridClauseStarAdjacent_symm hab⟩
    (SimpleGraph.fromEdgeSet (Sym2.fromRel hRsymm)).Connected := by
  intro R hRsymm
  let rootSub : {c // c ∈ s} := ⟨root, hstar.root_mem⟩
  haveI : Nonempty {c // c ∈ s} := ⟨rootSub⟩
  have hrootReach :
      ∀ x : {c // c ∈ s},
        (SimpleGraph.fromEdgeSet (Sym2.fromRel hRsymm)).Reachable rootSub x := by
    intro x
    rw [SimpleGraph.reachable_fromEdgeSet_fromRel_eq_reflTransGen hRsymm]
    exact hstar.subtype_reachable x
  refine ⟨?_⟩
  intro a b
  exact (hrootReach a).symm.trans (hrootReach b)

theorem RootedStarConnectedCutSet.of_subtype_starGraph_connected
    {root : GridClauseId} {s : Finset GridClauseId}
    (hroot : root ∈ s)
    (hconn :
      let R : {c // c ∈ s} → {c // c ∈ s} → Prop :=
        fun a b => gridClauseStarAdjacent a.1 b.1
      let hRsymm : Std.Symm R := ⟨fun _ _ hab => gridClauseStarAdjacent_symm hab⟩
      (SimpleGraph.fromEdgeSet (Sym2.fromRel hRsymm)).Connected) :
    RootedStarConnectedCutSet root s := by
  let R : {c // c ∈ s} → {c // c ∈ s} → Prop :=
    fun a b => gridClauseStarAdjacent a.1 b.1
  let hRsymm : Std.Symm R := ⟨fun _ _ hab => gridClauseStarAdjacent_symm hab⟩
  have hconn' :
      (SimpleGraph.fromEdgeSet (Sym2.fromRel hRsymm)).Connected := by
    simpa [R, hRsymm] using hconn
  refine ⟨hroot, ?_⟩
  intro x hx
  have hreach :
      Relation.ReflTransGen R ⟨root, hroot⟩ ⟨x, hx⟩ := by
    have hgraph :
        (SimpleGraph.fromEdgeSet (Sym2.fromRel hRsymm)).Reachable
          ⟨root, hroot⟩ ⟨x, hx⟩ :=
      hconn' ⟨root, hroot⟩ ⟨x, hx⟩
    rw [SimpleGraph.reachable_fromEdgeSet_fromRel_eq_reflTransGen hRsymm] at hgraph
    simpa [R] using hgraph
  have hmap :
      ∀ a b : {c // c ∈ s},
        R a b →
          (fun a b : GridClauseId => a ∈ s ∧ b ∈ s ∧ gridClauseStarAdjacent a b)
            a.1 b.1 := by
    intro a b hab
    exact ⟨a.2, b.2, hab⟩
  simpa using
    Relation.ReflTransGen.lift
      (p := fun a b : GridClauseId =>
        a ∈ s ∧ b ∈ s ∧ gridClauseStarAdjacent a b)
      Subtype.val hmap hreach

theorem rootedStarConnectedCutSet_iff_subtype_starGraph_connected
    {root : GridClauseId} {s : Finset GridClauseId}
    (hroot : root ∈ s) :
    RootedStarConnectedCutSet root s ↔
      let R : {c // c ∈ s} → {c // c ∈ s} → Prop :=
        fun a b => gridClauseStarAdjacent a.1 b.1
      let hRsymm : Std.Symm R := ⟨fun _ _ hab => gridClauseStarAdjacent_symm hab⟩
      (SimpleGraph.fromEdgeSet (Sym2.fromRel hRsymm)).Connected := by
  constructor
  · intro hstar
    exact hstar.subtype_starGraph_connected
  · intro hconn
    exact RootedStarConnectedCutSet.of_subtype_starGraph_connected hroot hconn

