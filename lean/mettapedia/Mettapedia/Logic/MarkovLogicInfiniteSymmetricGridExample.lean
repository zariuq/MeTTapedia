theorem mem_boundaryConnectedOutsideSubregion_of_mem_stage_of_not_mem_stage
    {m n : ℕ} {inside : Region GridNode} {a : GridNode}
    (hInside : inside ⊆ gridExhaustion.region m)
    (haStage : a ∈ gridExhaustion.region n)
    (haNotStage : a ∉ gridExhaustion.region m) :
    a ∈ boundaryConnectedOutsideSubregion n inside := by
  rcases a with ⟨i, j⟩
  rcases Finset.mem_product.1 haStage with ⟨hiN, hjN⟩
  have hiLeN : i ≤ n := Nat.le_of_lt_succ (Finset.mem_range.mp hiN)
  have hjLeN : j ≤ n := Nat.le_of_lt_succ (Finset.mem_range.mp hjN)
  by_cases hmLtI : m < i
  · refine mem_boundaryConnectedOutsideSubregion_of_outside_row_to_boundary
        (i := i) (j := j) hiLeN hjLeN ?_
    intro k hk1 hk2 hkIn
    by_cases hkEq : k = i
    · subst hkEq
      exact haNotStage (hInside hkIn)
    · have hkStageM := hInside hkIn
      rcases Finset.mem_product.1 hkStageM with ⟨hkM, _⟩
      have hkLtM : k < m + 1 := Finset.mem_range.mp hkM
      omega
  · refine mem_boundaryConnectedOutsideSubregion_of_outside_col_to_boundary
        (i := i) (j := j) hiLeN hjLeN ?_
    have hiLeM : i ≤ m := by omega
    have hmLtJ : m < j := by
      by_contra hmNotLtJ
      have hjLeM : j ≤ m := Nat.le_of_not_gt hmNotLtJ
      apply haNotStage
      exact Finset.mem_product.mpr
        ⟨Finset.mem_range.mpr (lt_of_le_of_lt hiLeM (Nat.lt_succ_self m)),
         Finset.mem_range.mpr (lt_of_le_of_lt hjLeM (Nat.lt_succ_self m))⟩
    intro k hk1 hk2 hkIn
    by_cases hkEq : k = j
    · subst hkEq
      exact haNotStage (hInside hkIn)
    · have hkStageM := hInside hkIn
      rcases Finset.mem_product.1 hkStageM with ⟨_, hkM⟩
      have hkLtM : k < m + 1 := Finset.mem_range.mp hkM
      omega

theorem mem_boundaryConnectedOutsideSubregion_of_le
    {m n : ℕ} {inside : Region GridNode} {a : GridNode}
    (hmn : m ≤ n)
    (hInside : inside ⊆ gridExhaustion.region m)
    (ha : a ∈ boundaryConnectedOutsideSubregion m inside) :
    a ∈ boundaryConnectedOutsideSubregion n inside := by
  rcases mem_boundaryConnectedOutsideSubregion_iff.1 ha with
    ⟨_, ⟨b, hbBoundary, hbOut, hreach⟩⟩
  have hbExt : b ∈ boundaryConnectedOutsideSubregion n inside := by
    rcases mem_gridStageBoundaryRegion_iff.1 hbBoundary with ⟨hbStage, hbRow | hbCol⟩
    · have hb2Le : b.2 ≤ n := by
        rcases Finset.mem_product.1 hbStage with ⟨_, hb2⟩
        exact Nat.le_of_lt_succ
          (lt_of_lt_of_le (Finset.mem_range.mp hb2) (Nat.succ_le_succ hmn))
      refine mem_boundaryConnectedOutsideSubregion_of_outside_row_to_boundary
          (i := b.1) (j := b.2) (by simpa [hbRow] using hmn) hb2Le ?_
      intro k hk1 hk2 hkIn
      by_cases hkEq : k = b.1
      · subst hkEq
        exact (mem_outsideRegionInStage_iff.1 hbOut).2 hkIn
      · have hkStage := hInside hkIn
        rcases Finset.mem_product.1 hkStage with ⟨hkM, _⟩
        have hkLtM : k < m + 1 := Finset.mem_range.mp hkM
        omega
    · have hb1Le : b.1 ≤ n := by
        rcases Finset.mem_product.1 hbStage with ⟨hb1, _⟩
        exact Nat.le_of_lt_succ
          (lt_of_lt_of_le (Finset.mem_range.mp hb1) (Nat.succ_le_succ hmn))
      refine mem_boundaryConnectedOutsideSubregion_of_outside_col_to_boundary
          (i := b.1) (j := b.2) hb1Le (by simpa [hbCol] using hmn) ?_
      intro k hk1 hk2 hkIn
      by_cases hkEq : k = b.2
      · subst hkEq
        exact (mem_outsideRegionInStage_iff.1 hbOut).2 hkIn
      · have hkStage := hInside hkIn
        rcases Finset.mem_product.1 hkStage with ⟨_, hkM⟩
        have hkLtM : k < m + 1 := Finset.mem_range.mp hkM
        omega
  have haux :
      ∀ {c : GridNode},
        Relation.ReflTransGen (gridAdjacentInRegion (outsideRegionInStage m inside)) b c →
          c ∈ boundaryConnectedOutsideSubregion n inside := by
    intro c hreachc
    induction hreachc with
    | refl =>
        simpa using hbExt
    | @tail c d hreachcd hstep ih =>
        have hdOut : d ∈ outsideRegionInStage n inside :=
          mem_outsideRegionInStage_of_le hmn hstep.2.1
        exact mem_boundaryConnectedOutsideSubregion_of_mem_outside_of_adj
          hdOut ih hstep.2.2
  exact haux hreach

theorem mem_visibleOuterBoundary_of_adj_hull_of_stageCoConnected
    {m : ℕ} {hull : Region GridNode} {p q : GridNode}
    (hm : 1 ≤ m)
    (hHull : hull ⊆ gridExhaustion.region (m - 1))
    (hco : StageCoConnectedRegion (m - 1) hull)
    (hpNotHull : p ∉ hull)
    (hqHull : q ∈ hull)
    (hpq : gridAdjacent p q) :
    p ∈ visibleOuterBoundary m hull := by
  have hqStage : q ∈ gridExhaustion.region (m - 1) := hHull hqHull
  have hpStageSucc :
      p ∈ gridExhaustion.region ((m - 1) + 1) :=
    gridAdjacent_mem_gridExhaustion_region_succ_of_mem
      hqStage (gridAdjacent_symm hpq)
  have hmPos : 0 < m := lt_of_lt_of_le (by decide : 0 < 1) hm
  have hmEq : (m - 1) + 1 = m := Nat.succ_pred_eq_of_pos hmPos
  have hpStageM : p ∈ gridExhaustion.region m := by
    simpa [hmEq] using hpStageSucc
  have hpExtM : p ∈ boundaryConnectedOutsideSubregion m hull := by
    by_cases hpStagePred : p ∈ gridExhaustion.region (m - 1)
    · have hpOutPred : p ∈ outsideRegionInStage (m - 1) hull := by
        rw [mem_outsideRegionInStage_iff]
        exact ⟨hpStagePred, hpNotHull⟩
      have hpExtPred : p ∈ boundaryConnectedOutsideSubregion (m - 1) hull := by
        exact (stageCoConnectedRegion_iff_outside_subset_boundaryConnectedOutside.1
          hco) hpOutPred
      exact mem_boundaryConnectedOutsideSubregion_of_le
        (m := m - 1) (n := m) (by omega) hHull hpExtPred
    · exact mem_boundaryConnectedOutsideSubregion_of_mem_stage_of_not_mem_stage
        hHull hpStageM hpStagePred
  rw [mem_visibleOuterBoundary_iff]
  exact ⟨hpExtM, q, hqHull, hpq⟩

theorem mem_visibleBoundarySeparatorEdges_iff_stageCoConnected
    {m : ℕ} {hull : Region GridNode} {e : GridNode × GridNode}
    (hm : 1 ≤ m)
    (hHull : hull ⊆ gridExhaustion.region (m - 1))
    (hco : StageCoConnectedRegion (m - 1) hull) :
    e ∈ visibleBoundarySeparatorEdges m hull ↔
      e.1 ∈ hull ∧ e.2 ∈ gridExhaustion.region m ∧
        e.2 ∉ hull ∧ gridAdjacent e.1 e.2 := by
  constructor
  · intro he
    exact ⟨visibleBoundarySeparatorEdges_left_mem he,
      visibleOuterBoundary_subset_stage
        (visibleBoundarySeparatorEdges_right_mem he),
      visibleBoundarySeparatorEdges_right_not_mem_hull he,
      visibleBoundarySeparatorEdges_adjacent he⟩
  · rintro ⟨hleft, hrightStage, hrightNotHull, hadj⟩
    rw [mem_visibleBoundarySeparatorEdges_iff]
    exact ⟨hleft,
      mem_visibleOuterBoundary_of_adj_hull_of_stageCoConnected
        hm hHull hco hrightNotHull hleft (gridAdjacent_symm hadj),
      hadj⟩

theorem visibleBoundarySeparatorEdges_basicSquare_card_even_of_stageCoConnected
    {m : ℕ} {hull : Region GridNode}
    (hm : 1 ≤ m)
    (hHull : hull ⊆ gridExhaustion.region (m - 1))
    (hco : StageCoConnectedRegion (m - 1) hull)
    (i j : ℕ) :
    Even
      (((visibleBoundarySeparatorEdges m hull).filter
        (fun e => e ∈ gridBasicSquareDirectedEdges i j)).card) := by
  classical
  have hEq :
      (visibleBoundarySeparatorEdges m hull).filter
          (fun e => e ∈ gridBasicSquareDirectedEdges i j) =
        (gridBasicSquareDirectedEdges i j).filter
          (fun e => e.1 ∈ hull ∧ e.2 ∉ hull) := by
    ext e
    constructor
    · intro he
      rcases Finset.mem_filter.1 he with ⟨heSep, heSq⟩
      exact Finset.mem_filter.2
        ⟨heSq, visibleBoundarySeparatorEdges_left_mem heSep,
          visibleBoundarySeparatorEdges_right_not_mem_hull heSep⟩
    · intro he
      rcases Finset.mem_filter.1 he with ⟨heSq, hleft, hrightNotHull⟩
      rcases
        (mem_gridBasicSquareDirectedEdges_iff_vertices_adjacent.1 heSq) with
        ⟨_hleftSq, _hrightSq, hadj⟩
      have hrightStage : e.2 ∈ gridExhaustion.region m := by
        have hrightStageSucc :
            e.2 ∈ gridExhaustion.region ((m - 1) + 1) :=
          gridAdjacent_mem_gridExhaustion_region_succ_of_mem
            (hHull hleft) hadj
        have hmPos : 0 < m := lt_of_lt_of_le (by decide : 0 < 1) hm
        have hmEq : (m - 1) + 1 = m := Nat.succ_pred_eq_of_pos hmPos
        simpa [hmEq] using hrightStageSucc
      exact Finset.mem_filter.2
        ⟨(mem_visibleBoundarySeparatorEdges_iff_stageCoConnected
            hm hHull hco).2
            ⟨hleft, hrightStage, hrightNotHull, hadj⟩,
          heSq⟩
  rw [hEq]
  exact gridBasicSquareDirectedEdges_crossing_card_even hull i j

theorem exists_ne_visibleBoundarySeparatorEdge_in_basicSquare_of_stageCoConnected
    {m : ℕ} {hull : Region GridNode}
    (hm : 1 ≤ m)
    (hHull : hull ⊆ gridExhaustion.region (m - 1))
    (hco : StageCoConnectedRegion (m - 1) hull)
    {i j : ℕ} {e : GridNode × GridNode}
    (he : e ∈ visibleBoundarySeparatorEdges m hull)
    (heSq : e ∈ gridBasicSquareDirectedEdges i j) :
    ∃ f ∈ visibleBoundarySeparatorEdges m hull,
      f ∈ gridBasicSquareDirectedEdges i j ∧ f ≠ e := by
  classical
  exact
    exists_ne_mem_of_even_filter_card_of_mem
      (s := visibleBoundarySeparatorEdges m hull)
      (P := fun f => f ∈ gridBasicSquareDirectedEdges i j)
      he heSq
      (visibleBoundarySeparatorEdges_basicSquare_card_even_of_stageCoConnected
        hm hHull hco i j)

theorem exists_gridBasicSquareDirectedEdges_of_mem_visibleBoundarySeparatorEdges
    {m : ℕ} {hull : Region GridNode} {e : GridNode × GridNode}
    (he : e ∈ visibleBoundarySeparatorEdges m hull) :
    ∃ i j, e ∈ gridBasicSquareDirectedEdges i j :=
  exists_gridBasicSquareDirectedEdges_of_gridAdjacent
    (visibleBoundarySeparatorEdges_adjacent he)

theorem exists_same_partition_visibleBoundarySeparatorEdge_in_basicSquare_of_no_cross
    {m : ℕ} {hull : Region GridNode} {U : GridNode × GridNode → Prop}
    [DecidablePred U]
    {i j : ℕ} {e : GridNode × GridNode}
    (hm : 1 ≤ m)
    (hHull : hull ⊆ gridExhaustion.region (m - 1))
    (hco : StageCoConnectedRegion (m - 1) hull)
    (hno :
      ¬ ∃ e₁ ∈ visibleBoundarySeparatorEdges m hull,
          ∃ e₂ ∈ visibleBoundarySeparatorEdges m hull,
            U e₁ ∧ ¬ U e₂ ∧
              e₁ ∈ gridBasicSquareDirectedEdges i j ∧
                e₂ ∈ gridBasicSquareDirectedEdges i j)
    (he : e ∈ visibleBoundarySeparatorEdges m hull)
    (heSq : e ∈ gridBasicSquareDirectedEdges i j)
    (hUe : U e) :
    ∃ f ∈ visibleBoundarySeparatorEdges m hull,
      f ∈ gridBasicSquareDirectedEdges i j ∧ f ≠ e ∧ U f := by
  rcases
    exists_ne_visibleBoundarySeparatorEdge_in_basicSquare_of_stageCoConnected
      hm hHull hco he heSq with
    ⟨f, hf, hfSq, hfe⟩
  by_cases hUf : U f
  · exact ⟨f, hf, hfSq, hfe, hUf⟩
  · exact False.elim (hno
      ⟨e, he, f, hf, hUe, hUf, heSq, hfSq⟩)

theorem visibleBoundarySeparatorEdges_same_partition_of_no_basicSquare_cross
    {m : ℕ} {hull : Region GridNode} {U : GridNode × GridNode → Prop}
    [DecidablePred U]
    (hno :
      ¬ ∃ i j,
          ∃ e₁ ∈ visibleBoundarySeparatorEdges m hull,
            ∃ e₂ ∈ visibleBoundarySeparatorEdges m hull,
              U e₁ ∧ ¬ U e₂ ∧
                e₁ ∈ gridBasicSquareDirectedEdges i j ∧
                  e₂ ∈ gridBasicSquareDirectedEdges i j)
    {i j : ℕ} {e f : GridNode × GridNode}
    (he : e ∈ visibleBoundarySeparatorEdges m hull)
    (hf : f ∈ visibleBoundarySeparatorEdges m hull)
