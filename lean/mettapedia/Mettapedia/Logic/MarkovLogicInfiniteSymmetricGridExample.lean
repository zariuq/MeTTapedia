theorem boundaryConnectedHullCutSet_eq_outerCutBaseClauses_of_stage_subsets
    {n m : ℕ} {inside : Region GridNode}
    (hInsideN : inside ⊆ gridExhaustion.region n)
    (hInsideM : inside ⊆ gridExhaustion.region m) :
    (gridRegionSupport (gridExhaustion.region m)).filter
        (gridBaseClauseCutsRegion (boundaryConnectedHullRegion m inside)) =
      originContainingSubregionOuterCutBaseClauses n inside := by
  have hHullEq :
      boundaryConnectedHullRegion m inside = boundaryConnectedHullRegion n inside := by
    symm
    exact boundaryConnectedHullRegion_eq_of_stage_subsets hInsideM hInsideN
  have hHullStageN :
      boundaryConnectedHullRegion n inside ⊆ gridExhaustion.region n := by
    exact boundaryConnectedHullRegion_subset_stage
  have hHullStageM :
      boundaryConnectedHullRegion n inside ⊆ gridExhaustion.region m := by
    rw [← hHullEq]
    exact boundaryConnectedHullRegion_subset_stage
  calc
    (gridRegionSupport (gridExhaustion.region m)).filter
        (gridBaseClauseCutsRegion (boundaryConnectedHullRegion m inside))
        =
      (gridRegionSupport (gridExhaustion.region m)).filter
        (gridBaseClauseCutsRegion (boundaryConnectedHullRegion n inside)) := by
          simp [hHullEq]
    _ =
      (gridRegionSupport (gridExhaustion.region n)).filter
        (gridBaseClauseCutsRegion (boundaryConnectedHullRegion n inside)) := by
          simpa using originContainingSubregionCutBaseClauses_eq_of_stage_subsets
            hHullStageN hHullStageM
    _ = originContainingSubregionOuterCutBaseClauses n inside := by
          exact originContainingSubregionCutBaseClauses_boundaryConnectedHullRegion_eq_outerCutBaseClauses
            hInsideN

theorem exists_extra_boundaryConnectedHullCutSet_of_insideEndpoints_of_slack
    {n m : ℕ} {inside : Region GridNode}
    (hinside : inside ∈ originConnectedContainingSubregions n)
    (hInsideM : inside ⊆ gridExhaustion.region m)
    {a b : GridNode}
    (ha : a ∈ inside) (hb : b ∈ inside)
    (hslack : a.1 + b.2 + 2 < originContainingSubregionOuterCutCard n inside) :
    ∃ skel : Finset GridClauseId,
      skel ⊆
          (gridRegionSupport (gridExhaustion.region m)).filter
            (gridBaseClauseCutsRegion (boundaryConnectedHullRegion m inside)) ∧
        skel.card = a.1 + b.2 + 2 ∧
          ∃ j ∈
              (gridRegionSupport (gridExhaustion.region m)).filter
                (gridBaseClauseCutsRegion (boundaryConnectedHullRegion m inside)),
            j ∉ skel := by
  rcases mem_originConnectedContainingSubregions_iff.1 hinside with ⟨hInsideN, _hconn⟩
  rcases exists_extra_outerCut_of_insideEndpoints_of_slack hinside ha hb hslack with
    ⟨skel, hsubset, hcard, j, hjCut, hjNot⟩
  have hEq :
      (gridRegionSupport (gridExhaustion.region m)).filter
          (gridBaseClauseCutsRegion (boundaryConnectedHullRegion m inside)) =
        originContainingSubregionOuterCutBaseClauses n inside :=
    boundaryConnectedHullCutSet_eq_outerCutBaseClauses_of_stage_subsets hInsideN hInsideM
  refine ⟨skel, ?_, hcard, ?_⟩
  · intro x hx
    rw [hEq]
    exact hsubset hx
  · rw [hEq]
    exact ⟨j, hjCut, hjNot⟩

theorem outerCutCard_lower_of_bottomHorizontal_leftVertical
    {n i j : ℕ} {inside : Region GridNode}
    (hinside : inside ∈ originConnectedContainingSubregions n)
    (hhor :
      GridClauseId.horizontal i 0 ∈ originContainingSubregionOuterCutBaseClauses n inside)
    (hvert :
      GridClauseId.vertical 0 j ∈ originContainingSubregionOuterCutBaseClauses n inside) :
    i + j + 2 ≤ originContainingSubregionOuterCutCard n inside := by
  have hhorCut : gridBaseClauseCutsOuterRegion n inside (GridClauseId.horizontal i 0) :=
    (Finset.mem_filter.1 hhor).2
  have hvertCut : gridBaseClauseCutsOuterRegion n inside (GridClauseId.vertical 0 j) :=
    (Finset.mem_filter.1 hvert).2
  rcases hhorCut with h | h
  · have hi : (i, 0) ∈ inside := h.1
    rcases hvertCut with h' | h'
    · exact outerCutCard_lower_of_insideEndpoints hinside hi h'.1
    · have hbase := outerCutCard_lower_of_insideEndpoints hinside hi h'.2
      omega
  · have hi : (i + 1, 0) ∈ inside := h.2
    rcases hvertCut with h' | h'
    · have hbase := outerCutCard_lower_of_insideEndpoints hinside hi h'.1
      omega
    · have hbase := outerCutCard_lower_of_insideEndpoints hinside hi h'.2
      omega

/-- Explicit five-site hook used as a sanity check for the rooted cut-set
counting frontier. It is origin-connected, but its outer cut is strictly larger
than the bare axis-root lower bound coming from the row-0 / col-0 roots. -/
def hookSlackInside : Region GridNode :=
  ({(0, 0), (1, 0), (0, 1), (1, 1), (1, 2)} : Finset GridNode)

theorem hookSlackInside_mem_originConnectedContainingSubregions :
    hookSlackInside ∈ originConnectedContainingSubregions 4 := by
  rw [mem_originConnectedContainingSubregions_iff]
  refine ⟨?_, ?_⟩
  · intro a ha
    rcases a with ⟨i, j⟩
    simp [hookSlackInside] at ha
    rcases ha with h | h | h | h | h
    all_goals
      rcases h with ⟨rfl, rfl⟩
      exact Finset.mem_product.mpr
        ⟨Finset.mem_range.mpr (by decide), Finset.mem_range.mpr (by decide)⟩
  · refine ⟨?_, ?_⟩
    · simp [hookSlackInside, gridOrigin]
    · intro a ha
      rcases a with ⟨i, j⟩
      simp [hookSlackInside] at ha
      rcases ha with h | h | h | h | h
      · rcases h with ⟨rfl, rfl⟩
        exact Relation.ReflTransGen.refl
      · rcases h with ⟨rfl, rfl⟩
        exact
          Relation.ReflTransGen.tail Relation.ReflTransGen.refl
            ⟨by simp [hookSlackInside, gridOrigin],
              by simp [hookSlackInside],
              gridAdjacent_horizontal_forward 0 0⟩
      · rcases h with ⟨rfl, rfl⟩
        exact
          Relation.ReflTransGen.tail Relation.ReflTransGen.refl
            ⟨by simp [hookSlackInside, gridOrigin],
              by simp [hookSlackInside],
              gridAdjacent_vertical_forward 0 0⟩
      · rcases h with ⟨rfl, rfl⟩
        have h10 :
            Relation.ReflTransGen (gridAdjacentInRegion hookSlackInside)
              gridOrigin (1, 0) := by
            exact
              Relation.ReflTransGen.tail Relation.ReflTransGen.refl
                ⟨by simp [hookSlackInside, gridOrigin],
                  by simp [hookSlackInside],
                  gridAdjacent_horizontal_forward 0 0⟩
        exact
          Relation.ReflTransGen.tail h10
            ⟨by simp [hookSlackInside], by simp [hookSlackInside],
              gridAdjacent_vertical_forward 1 0⟩
      · rcases h with ⟨rfl, rfl⟩
        have h11 :
            Relation.ReflTransGen (gridAdjacentInRegion hookSlackInside)
              gridOrigin (1, 1) := by
            have h10 :
                Relation.ReflTransGen (gridAdjacentInRegion hookSlackInside)
                  gridOrigin (1, 0) := by
                exact
                  Relation.ReflTransGen.tail Relation.ReflTransGen.refl
                    ⟨by simp [hookSlackInside, gridOrigin],
                      by simp [hookSlackInside],
                      gridAdjacent_horizontal_forward 0 0⟩
            exact
              Relation.ReflTransGen.tail h10
                ⟨by simp [hookSlackInside], by simp [hookSlackInside],
                  gridAdjacent_vertical_forward 1 0⟩
        exact
          Relation.ReflTransGen.tail h11
            ⟨by simp [hookSlackInside], by simp [hookSlackInside],
              gridAdjacent_vertical_forward 1 1⟩

