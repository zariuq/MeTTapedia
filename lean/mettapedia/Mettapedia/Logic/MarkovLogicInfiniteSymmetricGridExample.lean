theorem symmetricGridZeroField_originSpin_queryMass_add_complement
    (w : ℝ) (Λ : Region GridNode) (hOrigin : gridOrigin ∈ Λ)
    (ξ : BoundaryCondition GridNode) (b : Bool) :
