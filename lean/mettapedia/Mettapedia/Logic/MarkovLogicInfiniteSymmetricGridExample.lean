noncomputable def contourEncode {κ m i j : ℕ} :
    {s // s ∈ originConnectedHullCutSetCandidatesInCutCardBoxAxisAnchored m i j} →
      ContourCode κ m :=
  fun s =>
    if h : ∃ code : ContourCode κ m, contourDecode κ m i j code = s.1 then
      Classical.choose h
    else
      fun _ => (CutWalkMove.north, CutWalkVisitTag.revisit)

theorem contourDecode_contourEncode_of_exists {κ m i j : ℕ}
    (s :
      {s // s ∈ originConnectedHullCutSetCandidatesInCutCardBoxAxisAnchored m i j})
    (h : ∃ code : ContourCode κ m, contourDecode κ m i j code = s.1) :
    contourDecode κ m i j (contourEncode (κ := κ) (m := m) (i := i) (j := j) s) =
      s.1 := by
  unfold contourEncode
  rw [dif_pos h]
  exact Classical.choose_spec h

theorem contourEncode_injective_of_decode_exists {κ m i j : ℕ}
    (hdecode :
      ∀ s :
        {s // s ∈ originConnectedHullCutSetCandidatesInCutCardBoxAxisAnchored m i j},
        ∃ code : ContourCode κ m, contourDecode κ m i j code = s.1) :
    Function.Injective
      (contourEncode (κ := κ) (m := m) (i := i) (j := j)) := by
  intro sx sy hcode
  apply Subtype.ext
  calc
    sx.1 = contourDecode κ m i j
        (contourEncode (κ := κ) (m := m) (i := i) (j := j) sx) :=
      (contourDecode_contourEncode_of_exists sx (hdecode sx)).symm
    _ = contourDecode κ m i j
        (contourEncode (κ := κ) (m := m) (i := i) (j := j) sy) := by
      rw [hcode]
    _ = sy.1 :=
      contourDecode_contourEncode_of_exists sy (hdecode sy)

theorem contourCodeInjection_of_contourDecode_exists {κ m i j : ℕ}
    (hdecode :
      ∀ s :
        {s // s ∈ originConnectedHullCutSetCandidatesInCutCardBoxAxisAnchored m i j},
        ∃ code : ContourCode κ m, contourDecode κ m i j code = s.1) :
    ∃ f :
      {s // s ∈ originConnectedHullCutSetCandidatesInCutCardBoxAxisAnchored m i j} →
        ContourCode κ m,
      Function.Injective f := by
  exact ⟨contourEncode (κ := κ) (m := m) (i := i) (j := j),
    contourEncode_injective_of_decode_exists hdecode⟩

theorem contourCode_card (κ m : ℕ) :
    Fintype.card (ContourCode κ m) = (8 ^ κ) ^ m := by
  have hmove : Fintype.card CutWalkMove = 4 := by decide
  have htag : Fintype.card CutWalkVisitTag = 2 := by decide
  calc
    Fintype.card (ContourCode κ m)
        = Fintype.card (CutWalkMove × CutWalkVisitTag) ^ (κ * m) := by
            simp [ContourCode]
    _ = 8 ^ (κ * m) := by
          simp [Fintype.card_prod, hmove, htag]
    _ = (8 ^ κ) ^ m := by
          simpa using (pow_mul 8 κ m)

theorem contourCode_card_ennreal (κ m : ℕ) :
    ((Fintype.card (ContourCode κ m) : ℕ) : ENNReal) =
      ((8 ^ κ : ℕ) : ENNReal) ^ m := by
  exact_mod_cast contourCode_card κ m

theorem originConnectedHullCutSetCandidatesInCutCardBoxAxisAnchored_card_le_contourCode_of_injective
    {κ m i j : ℕ}
    (f :
      {s // s ∈ originConnectedHullCutSetCandidatesInCutCardBoxAxisAnchored m i j} →
        ContourCode κ m)
    (hf : Function.Injective f) :
    (((originConnectedHullCutSetCandidatesInCutCardBoxAxisAnchored m i j).card : ENNReal)) ≤
      ((8 ^ κ : ℕ) : ENNReal) ^ m := by
  let S := originConnectedHullCutSetCandidatesInCutCardBoxAxisAnchored m i j
  have hcardSubtype : Fintype.card S = S.card := Fintype.card_coe S
  have hnat :
      S.card ≤ Fintype.card (ContourCode κ m) := by
    calc
      S.card = Fintype.card S := hcardSubtype.symm
      _ ≤ Fintype.card (ContourCode κ m) := Fintype.card_le_of_injective f hf
  have henn :
      ((S.card : ℕ) : ENNReal) ≤ ((Fintype.card (ContourCode κ m) : ℕ) : ENNReal) := by
    exact_mod_cast hnat
  calc
    (((originConnectedHullCutSetCandidatesInCutCardBoxAxisAnchored m i j).card : ENNReal))
        = ((S.card : ℕ) : ENNReal) := by rfl
    _ ≤ ((Fintype.card (ContourCode κ m) : ℕ) : ENNReal) := henn
    _ = ((8 ^ κ : ℕ) : ENNReal) ^ m := contourCode_card_ennreal κ m

