        (w := w) (Λ := Λ) hull hHull gridPlusBoundary)
  have hcut_ne_zero : cutFactor ≠ 0 := by
    simp [cutFactor, Real.exp_pos]
  have hcut_ne_top : cutFactor ≠ ⊤ := by
    exact ENNReal.pow_ne_top ENNReal.coe_ne_top
