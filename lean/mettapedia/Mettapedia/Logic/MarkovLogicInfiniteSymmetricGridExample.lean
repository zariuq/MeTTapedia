theorem hookSlackInside_horizontal_outerCut_cases
    {i j : ℕ}
    (hcut :
      gridBaseClauseCutsOuterRegion 4 hookSlackInside
        (GridClauseId.horizontal i j)) :
    (i = 1 ∧ (j = 0 ∨ j = 1 ∨ j = 2)) ∨ (i = 0 ∧ j = 2) := by
  rcases hcut with h | h
  · rcases h with ⟨hleft, hright⟩
    simp [hookSlackInside] at hleft
    rcases hleft with hleft | hleft | hleft | hleft | hleft
    · rcases hleft with ⟨rfl, rfl⟩
      rcases hright with hnotStage | hext
      · exfalso
        exact hnotStage (by simp [gridExhaustion])
      · exfalso
        exact boundaryConnectedOutsideSubregion_not_mem_inside hext (by simp [hookSlackInside])
    · rcases hleft with ⟨rfl, rfl⟩
      exact Or.inl ⟨rfl, Or.inl rfl⟩
    · rcases hleft with ⟨rfl, rfl⟩
      rcases hright with hnotStage | hext
      · exfalso
        exact hnotStage (by simp [gridExhaustion])
      · exfalso
        exact boundaryConnectedOutsideSubregion_not_mem_inside hext (by simp [hookSlackInside])
    · rcases hleft with ⟨rfl, rfl⟩
      exact Or.inl ⟨rfl, Or.inr (Or.inl rfl)⟩
    · rcases hleft with ⟨rfl, rfl⟩
      exact Or.inl ⟨rfl, Or.inr (Or.inr rfl)⟩
  · rcases h with ⟨hleft, hright⟩
    simp [hookSlackInside] at hright
    rcases hright with hright | hright | hright
    · rcases hright with ⟨rfl, rfl⟩
      rcases hleft with hnotStage | hext
      · exfalso
        exact hnotStage (by simp [gridExhaustion])
      · exfalso
        exact boundaryConnectedOutsideSubregion_not_mem_inside hext (by simp [hookSlackInside])
    · rcases hright with ⟨rfl, rfl⟩
      rcases hleft with hnotStage | hext
      · exfalso
        exact hnotStage (by simp [gridExhaustion])
      · exfalso
        exact boundaryConnectedOutsideSubregion_not_mem_inside hext (by simp [hookSlackInside])
    · rcases hright with ⟨rfl, rfl⟩
      exact Or.inr ⟨rfl, rfl⟩

theorem hookSlackInside_vertical_outerCut_cases
    {i j : ℕ}
    (hcut :
      gridBaseClauseCutsOuterRegion 4 hookSlackInside
        (GridClauseId.vertical i j)) :
    (i = 0 ∧ j = 1) ∨ (i = 1 ∧ j = 2) := by
  rcases hcut with h | h
  · rcases h with ⟨hdown, hup⟩
    simp [hookSlackInside] at hdown
    rcases hdown with hdown | hdown | hdown | hdown | hdown
    · rcases hdown with ⟨rfl, rfl⟩
