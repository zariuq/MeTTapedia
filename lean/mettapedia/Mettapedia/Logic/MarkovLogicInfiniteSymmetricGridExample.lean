                      (∀ k : Fin len,
                        node k.1 ∈ gridClauseDualEndpoints (step k)) ∧
                        (∀ k : Fin len,
                          node (k.1 + 1) =
                            cutWalkMoveTarget (node k.1)
                              (cutWalkMoveFromClauseEndpoint (step k) (node k.1))) ∧
                          step ⟨0, hpos⟩ = GridClauseId.horizontal i 0 ∧
                            (∀ k : Fin len, step k ∈ s.1) ∧
                              (∀ x ∈ s.1, ∃ k : Fin len, step k = x)) :
    ∀ m, 2 ≤ m → ∀ i ∈ Finset.range m, ∀ j ∈ Finset.range (m - (i + 1)),
      ∃ f :
        {s // s ∈ originConnectedHullCutSetCandidatesInCutCardBoxAxisAnchored m i j} →
          CutWalkCode m,
