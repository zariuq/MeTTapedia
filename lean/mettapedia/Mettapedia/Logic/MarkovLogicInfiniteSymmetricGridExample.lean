theorem visibleOuterBoundaryStarGraph_connected_of_erase_connected_of_deleted_fan_resolver
    {n : ℕ} {hull : Region GridNode} {v : {p // p ∈ hull}}
    (hnonempty : (visibleOuterBoundary n hull).Nonempty)
    (hco : StageCoConnectedRegion n hull)
    (herase : (visibleOuterBoundaryStarGraph n (hull.erase v.1)).Connected)
    (hresolve :
      ∀ {a q : GridNode},
        a ∈ visibleOuterBoundary n hull →
          q ∈ visibleOuterBoundary n hull →
            gridNodeStarAdjacent a v.1 →
              Relation.ReflTransGen
                (fun x y : GridNode =>
                  x ∈ visibleOuterBoundary n hull ∧
                    y ∈ visibleOuterBoundary n hull ∧ gridNodeStarAdjacent x y)
                a q) :
    (visibleOuterBoundaryStarGraph n hull).Connected := by
  let Rorig : GridNode → GridNode → Prop := fun x y =>
    x ∈ visibleOuterBoundary n hull ∧
      y ∈ visibleOuterBoundary n hull ∧ gridNodeStarAdjacent x y
  let Rerase : GridNode → GridNode → Prop := fun x y =>
    x ∈ visibleOuterBoundary n (hull.erase v.1) ∧
      y ∈ visibleOuterBoundary n (hull.erase v.1) ∧ gridNodeStarAdjacent x y
  have hsymm :
      Symmetric Rorig := by
    intro x y hxy
    exact ⟨hxy.2.1, hxy.1, gridNodeStarAdjacent_symm hxy.2.2⟩
  refine visibleOuterBoundaryStarGraph_connected_of_starConnected hnonempty ?_
  intro p q hp hq
  change Relation.ReflTransGen Rorig p q
  have hpne : p ≠ v.1 := by
    intro hpEq
    exact visibleOuterBoundary_not_mem_hull hp (by simp [hpEq, v.2])
  rcases mem_visibleOuterBoundary_erase_or_star_deleted (v := v) hp with
    hpErase | hpFan
  · rcases mem_visibleOuterBoundary_erase_or_star_deleted (v := v) hq with
      hqErase | hqFan
    · have hreachGraph :
          (visibleOuterBoundaryStarGraph n (hull.erase v.1)).Reachable
            ⟨p, hpErase⟩ ⟨q, hqErase⟩ :=
        herase ⟨p, hpErase⟩ ⟨q, hqErase⟩
      have hreachSubtype :
          Relation.ReflTransGen
            (visibleOuterBoundaryStarRel n (hull.erase v.1))
            ⟨p, hpErase⟩ ⟨q, hqErase⟩ := by
        rw [visibleOuterBoundaryStarGraph_reachable_eq_reflTransGen] at hreachGraph
        exact hreachGraph
      have hreachErase : Relation.ReflTransGen Rerase p q := by
        let f : {x // x ∈ visibleOuterBoundary n (hull.erase v.1)} → GridNode :=
          fun x => x.1
        have hf :
            ∀ a b : {x // x ∈ visibleOuterBoundary n (hull.erase v.1)},
              visibleOuterBoundaryStarRel n (hull.erase v.1) a b →
                Rerase (f a) (f b) := by
          intro a b hab
          exact ⟨a.2, b.2, hab⟩
        have hlift :=
          Relation.ReflTransGen.lift
            (p := Rerase) f hf hreachSubtype
        simpa [f] using hlift
      have hreachOrig :
          Relation.ReflTransGen
            (fun x y : GridNode =>
              x ∈ visibleOuterBoundary n hull ∧
                y ∈ visibleOuterBoundary n hull ∧ gridNodeStarAdjacent x y)
            p q :=
        visibleOuterBoundary_star_reachable_of_erase_reachable_of_deleted_hits_resolved
          (n := n) (hull := hull) (v := v) hco hpne
          (by simpa [Rerase] using hreachErase)
          (by
            intro a ha hav
            exact hresolve ha hq hav)
      simpa [Rorig] using hreachOrig
    · have hqp : Relation.ReflTransGen Rorig q p := by
        simpa [Rorig] using hresolve hq hp hqFan
      exact reflTransGen_symm_of_symmetric hsymm hqp
  · simpa [Rorig] using hresolve hp hq hpFan

