          (fun a c : GridNode =>
            (a ∈ boundaryConnectedOutsideSubregion n hull ∨ a ∈ hull) ∧
              (c ∈ boundaryConnectedOutsideSubregion n hull ∨ c ∈ hull) ∧
                gridAdjacent a c)
