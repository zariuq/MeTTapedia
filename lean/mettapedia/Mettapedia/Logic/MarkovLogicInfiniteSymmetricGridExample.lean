theorem exists_rootedPrefix_of_rootedDualConnectedCutSet_card_two
    {m i : ℕ} (hm : 2 ≤ m) {s : Finset GridClauseId}
    (hroot : GridClauseId.horizontal i 0 ∈ s)
    (hcard : s.card = 2)
    (hconn : RootedDualConnectedCutSet (GridClauseId.horizontal i 0) s) :
    ∃ pref : CutWalkReplayPrefix i,
      ∃ hpos : 0 < pref.len,
        pref.len ≤ 2 * m ∧
          pref.step ⟨0, hpos⟩ = GridClauseId.horizontal i 0 ∧
            pref.tag ⟨0, hpos⟩ = CutWalkVisitTag.fresh ∧
              (∀ k : Fin pref.len,
                pref.tag k = CutWalkVisitTag.fresh →
                  pref.step k ∈ s) ∧
                (∀ x ∈ s,
                  ∃ k : Fin pref.len,
                    pref.tag k = CutWalkVisitTag.fresh ∧
                      pref.step k = x) := by
  let root := GridClauseId.horizontal i 0
  rcases finset_eq_pair_of_card_eq_two_of_mem
      (s := s) (a := root) hroot hcard with
    ⟨c, hcNeRoot, hsEq⟩
  have hcMem : c ∈ s := by
    rw [hsEq]
    simp
  have hreach := hconn.2 c hcMem
  have hadj : gridClauseDualAdjacent root c := by
    have hreach_to_adj :
        ∀ {x : GridClauseId}, x ∈ s → x ≠ root →
          Relation.ReflTransGen
            (fun a b => a ∈ s ∧ b ∈ s ∧ gridClauseDualAdjacent a b)
            root x →
            gridClauseDualAdjacent root x := by
      intro x hx hxNeRoot hreachx
      induction hreachx with
      | refl =>
          exact False.elim (hxNeRoot rfl)
      | @tail y z hprev hstep ih =>
          rcases hstep with ⟨hyMem, hzMem, hyzAdj⟩
          by_cases hyRoot : y = root
          · simpa [hyRoot] using hyzAdj
          · have hyAdj : gridClauseDualAdjacent root y := ih hyMem hyRoot
            have hyEqC : y = c := by
              have hyPair : y = root ∨ y = c := by
                simpa [root, hsEq] using hyMem
              rcases hyPair with hyEqRoot | hyEqC
              · exact False.elim (hyRoot hyEqRoot)
              · exact hyEqC
            have hzEqC : z = c := by
              have hzPair : z = root ∨ z = c := by
                simpa [root, hsEq] using hzMem
              rcases hzPair with hzEqRoot | hzEqC
              · exact False.elim (hxNeRoot hzEqRoot)
              · exact hzEqC
            simpa [hyEqC, hzEqC] using hyAdj
    exact hreach_to_adj hcMem hcNeRoot hreach
  refine exists_rootedPrefix_of_clauseChain
    (m := m) (i := i) (s := s) [c] ?_ ?_ hroot ?_ ?_
  · simp
    omega
  · simpa [root] using hadj
  · intro x hx
    simp at hx
    simpa [hx] using hcMem
  · intro x hx
    have hxPair : x = root ∨ x = c := by
      simpa [root, hsEq] using hx
    rcases hxPair with hxRoot | hxC
    · exact Or.inl (by simpa [root] using hxRoot)
    · exact Or.inr (by simp [hxC])

