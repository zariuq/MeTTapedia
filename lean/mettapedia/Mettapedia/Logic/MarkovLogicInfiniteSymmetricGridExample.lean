theorem Connected.exists_closedWalk_cover_length_le
    {V : Type u} [Fintype V] [DecidableEq V] {G : SimpleGraph V}
    (hconn : G.Connected) (root : V) :
    ∃ p : G.Walk root root,
      (∀ x : V, x ∈ p.support) ∧
        p.length ≤ 2 * (Fintype.card V - 1) := by
  classical
  have hmain :
      ∀ n : ℕ, ∀ (V : Type u) [Fintype V] [DecidableEq V]
          (G : SimpleGraph V),
        Fintype.card V = n → G.Connected → ∀ root : V,
          ∃ p : G.Walk root root,
            (∀ x : V, x ∈ p.support) ∧
              p.length ≤ 2 * (Fintype.card V - 1) := by
    intro n
    induction n using Nat.strong_induction_on with
    | h n ih =>
        intro V _ _ G hcard hconn root
        by_cases hcardOne : Fintype.card V = 1
        · haveI : Subsingleton V :=
            Fintype.card_le_one_iff_subsingleton.mp (by omega)
          refine ⟨SimpleGraph.Walk.nil, ?_, ?_⟩
          · intro x
            have hx : x = root := Subsingleton.elim x root
            subst x
            simp
          · simp
        · haveI : Nonempty V := hconn.nonempty
          have hpos : 0 < Fintype.card V := Fintype.card_pos
          have hcardGt : 1 < Fintype.card V := by omega
          haveI : Nontrivial V := Fintype.one_lt_card_iff_nontrivial.mp hcardGt
          rcases hconn.exists_preconnected_induce_compl_singleton_of_finite with
            ⟨v, hpre⟩
          rcases hconn.preconnected.exists_adj_of_nontrivial v with ⟨y, hvy⟩
          by_cases hvroot : v = root
          · subst v
            let S : Set V := {root}ᶜ
            let H := G.induce S
            have hyS : y ∈ S := by
              show y ≠ root
              exact hvy.ne.symm
            let ySub : S := ⟨y, hyS⟩
            haveI : Nonempty S := ⟨ySub⟩
            have hconnSub : H.Connected := by
              exact ⟨by simpa [H, S] using hpre⟩
            have hcardS : Fintype.card S = Fintype.card V - 1 := by
              simpa [S] using fintype_card_compl_singleton_set root
            have hcardSLt : Fintype.card S < n := by
              rw [← hcard]
              rw [hcardS]
              omega
            rcases ih (Fintype.card S) hcardSLt S H rfl hconnSub ySub with
              ⟨pSub, hcoverSub, hlenSub⟩
            let pLift : G.Walk y y :=
              pSub.map (SimpleGraph.Embedding.induce S).toHom
            have hcoverLift : ∀ x : V, x ∈ S → x ∈ pLift.support := by
              intro x hx
              have hxSub : (⟨x, hx⟩ : S) ∈ pSub.support :=
                hcoverSub ⟨x, hx⟩
              change x ∈
                (pSub.map (SimpleGraph.Embedding.induce S).toHom).support
              rw [SimpleGraph.Walk.support_map]
              simpa using
                (List.mem_map_of_mem (f := fun z : S => (z : V)) hxSub)
            have hyLift : y ∈ pLift.support := hcoverLift y hyS
            let pIns :=
              SimpleGraph.Walk.insertLeafAtSupport pLift hyLift hvy.symm
            have hrootIns : root ∈ pIns.support := by
              simpa [pIns] using
                SimpleGraph.Walk.leaf_mem_insertLeafAtSupport
                  pLift hyLift hvy.symm
            refine ⟨pIns.rotate root hrootIns, ?_, ?_⟩
            · intro x
              rw [SimpleGraph.Walk.mem_support_rotate_iff pIns root hrootIns]
              by_cases hxroot : x = root
              · subst x
                exact hrootIns
              · exact
                  SimpleGraph.Walk.support_subset_insertLeafAtSupport
                    pLift hyLift hvy.symm
                    (hcoverLift x (by
                      show x ≠ root
                      exact hxroot))
            · have hlenLift : pLift.length = pSub.length := by
                exact SimpleGraph.Walk.length_map _ _
              have hlenIns : pIns.length = pLift.length + 2 := by
                simpa [pIns] using
                  SimpleGraph.Walk.insertLeafAtSupport_length
                    pLift hyLift hvy.symm
              calc
                (pIns.rotate root hrootIns).length = pIns.length :=
                  SimpleGraph.Walk.rotate_length pIns hrootIns
                _ = pLift.length + 2 := hlenIns
                _ = pSub.length + 2 := by omega
                _ ≤ 2 * (Fintype.card S - 1) + 2 := by omega
                _ ≤ 2 * (Fintype.card V - 1) := by
                  rw [hcardS]
                  omega
          · let S : Set V := {v}ᶜ
            let H := G.induce S
            have hrootS : root ∈ S := by
              show root ≠ v
              intro h
              exact hvroot h.symm
            have hyS : y ∈ S := by
              show y ≠ v
              exact hvy.ne.symm
            let rootSub : S := ⟨root, hrootS⟩
            haveI : Nonempty S := ⟨rootSub⟩
            have hconnSub : H.Connected := by
              exact ⟨by simpa [H, S] using hpre⟩
            have hcardS : Fintype.card S = Fintype.card V - 1 := by
              simpa [S] using fintype_card_compl_singleton_set v
            have hcardSLt : Fintype.card S < n := by
              rw [← hcard]
              rw [hcardS]
              omega
            rcases ih (Fintype.card S) hcardSLt S H rfl hconnSub rootSub with
              ⟨pSub, hcoverSub, hlenSub⟩
            let pLift : G.Walk root root :=
              pSub.map (SimpleGraph.Embedding.induce S).toHom
            have hcoverLift : ∀ x : V, x ∈ S → x ∈ pLift.support := by
              intro x hx
              have hxSub : (⟨x, hx⟩ : S) ∈ pSub.support :=
                hcoverSub ⟨x, hx⟩
              change x ∈
                (pSub.map (SimpleGraph.Embedding.induce S).toHom).support
              rw [SimpleGraph.Walk.support_map]
              simpa using
                (List.mem_map_of_mem (f := fun z : S => (z : V)) hxSub)
            have hyLift : y ∈ pLift.support := hcoverLift y hyS
            let pIns :=
              SimpleGraph.Walk.insertLeafAtSupport pLift hyLift hvy.symm
            refine ⟨pIns, ?_, ?_⟩
            · intro x
              by_cases hxv : x = v
              · subst x
                simpa [pIns] using
                  SimpleGraph.Walk.leaf_mem_insertLeafAtSupport
                    pLift hyLift hvy.symm
              · exact
                  SimpleGraph.Walk.support_subset_insertLeafAtSupport
                    pLift hyLift hvy.symm
                    (hcoverLift x (by
                      show x ≠ v
                      exact hxv))
            · have hlenLift : pLift.length = pSub.length := by
                exact SimpleGraph.Walk.length_map _ _
              have hlenIns : pIns.length = pLift.length + 2 := by
                simpa [pIns] using
                  SimpleGraph.Walk.insertLeafAtSupport_length
                    pLift hyLift hvy.symm
              calc
                pIns.length = pLift.length + 2 := hlenIns
                _ = pSub.length + 2 := by omega
                _ ≤ 2 * (Fintype.card S - 1) + 2 := by omega
                _ ≤ 2 * (Fintype.card V - 1) := by
                  rw [hcardS]
                  omega
  exact hmain (Fintype.card V) V G rfl hconn root

end SimpleGraph

theorem exists_clauseChain_of_simpleGraph_closedWalk
    {α : Type*} {R : α → α → Prop} {G : SimpleGraph α} {root : α}
    (p : G.Walk root root)
    (hAdj : ∀ a b, G.Adj a b → R a b)
    {s : Finset α}
    (hmem : ∀ x ∈ p.support, x ∈ s)
    (hcover : ∀ x ∈ s, x ∈ p.support) :
    ∃ tail : List α,
      tail.length = p.length ∧
        List.IsChain R (root :: tail) ∧
          (∀ c ∈ tail, c ∈ s) ∧
            (∀ x ∈ s, x = root ∨ x ∈ tail) := by
  let tail := p.support.tail
  have hsupport : p.support = root :: tail := by
    simpa [tail] using p.support_eq_cons
  refine ⟨tail, ?_, ?_, ?_, ?_⟩
  · have hlen := p.length_support
    rw [hsupport] at hlen
    exact Nat.succ.inj hlen
  · have hchainAdj : List.IsChain G.Adj p.support := p.isChain_adj_support
    have hchainR : List.IsChain R p.support :=
      hchainAdj.imp (by intro a b; exact hAdj a b)
    rw [← hsupport]
    exact hchainR
  · intro c hc
    have hcSupp : c ∈ p.support := by
      rw [hsupport]
      exact List.mem_cons_of_mem root hc
    exact hmem c hcSupp
  · intro x hx
    have hxSupp : x ∈ p.support := hcover x hx
    rw [hsupport] at hxSupp
    simpa using hxSupp

theorem finset_eq_pair_of_card_eq_two_of_mem
    {α : Type*} [DecidableEq α] {s : Finset α} {a : α}
    (ha : a ∈ s) (hcard : s.card = 2) :
    ∃ b, b ≠ a ∧ s = ({a, b} : Finset α) := by
  have hcardErase : (s.erase a).card = 1 := by
    rw [Finset.card_erase_of_mem ha, hcard]
  rcases Finset.card_eq_one.1 hcardErase with ⟨b, hbEq⟩
  have hbErase : b ∈ s.erase a := by
    rw [hbEq]
    simp
  have hba : b ≠ a := (Finset.mem_erase.1 hbErase).1
  refine ⟨b, hba, ?_⟩
  calc
    s = insert a (s.erase a) := (Finset.insert_erase ha).symm
    _ = ({a, b} : Finset α) := by
      rw [hbEq]

@[simp] theorem gridClauseDualAdjacent_horizontal_succ
    (i j : ℕ) :
    gridClauseDualAdjacent
      (GridClauseId.horizontal i j)
      (GridClauseId.horizontal i (j + 1)) := by
  refine ⟨(i, j + 1), ?_, ?_⟩ <;> simp [gridClauseDualEndpoints]

@[simp] theorem gridClauseDualAdjacent_vertical_succ
    (i j : ℕ) :
    gridClauseDualAdjacent
      (GridClauseId.vertical i j)
      (GridClauseId.vertical (i + 1) j) := by
  refine ⟨(i + 1, j), ?_, ?_⟩
  · change (i + 1, j) ∈ ({(i, j), (i + 1, j)} : Finset GridNode)
    exact Finset.mem_insert_of_mem (Finset.mem_singleton_self _)
  · change (i + 1, j) ∈ ({(i + 1, j), (i + 1 + 1, j)} : Finset GridNode)
    exact Finset.mem_insert_self _ _

@[simp] theorem gridClauseDualAdjacent_horizontal_vertical_left
