  have hHullStage : hull ⊆ gridExhaustion.region (m - 1) := by
    exact
      (mem_originContainingSubregions_iff.1
        (mem_originConnectedHullContainingSubregions_imp_originContaining
          (by simpa [originConnectedHullContainingSubregionsInCutCardBox] using hhullBox))).1
  have hColExact :
      ∀ k t, (k.1, t) ∈ hull ↔ t ≤ gV k := by
    intro k t
    constructor
    · intro htHull
      by_contra htGt
      have htGt' : gV k < t := by omega
      let P : ℕ → Prop := fun u => gV k < u ∧ u ≤ t ∧ (k.1, u) ∈ hull
      have hP : ∃ u, P u := ⟨t, htGt', le_rfl, htHull⟩
      let u := Nat.find hP
      have huGt : gV k < u := (Nat.find_spec hP).1
      have huLe : u ≤ t := (Nat.find_spec hP).2.1
      have huHull : (k.1, u) ∈ hull := (Nat.find_spec hP).2.2
      have huPos : 0 < u := by omega
      have huGap : gV k + 1 < u := by
        by_contra huNot
        have huEq : u = gV k + 1 := by omega
        exact (hVExact k).2.1 (by simpa [huEq] using huHull)
      have huPrevNot : (k.1, u - 1) ∉ hull := by
        intro huPrevHull
        have huPrevGt : gV k < u - 1 := by omega
        have hmin :
            u ≤ u - 1 :=
          Nat.find_min' hP ⟨huPrevGt, by omega, huPrevHull⟩
        omega
      have hmPos : 0 < m := by omega
      have hmEq : m - 1 + 1 = m := Nat.succ_pred_eq_of_pos hmPos
      have huStage : (k.1, u) ∈ gridExhaustion.region (m - 1) := hHullStage huHull
      rcases Finset.mem_product.1 huStage with ⟨hkStage, huStage'⟩
      have hCutMem :
          GridClauseId.vertical k.1 (u - 1) ∈ s := by
        have hClauseSupp :
            GridClauseId.vertical k.1 (u - 1) ∈
              gridRegionSupport (gridExhaustion.region (m - 1)) := by
          exact
            (vertical_mem_gridRegionSupport_gridExhaustion_region_iff
              (n := m - 1) (i := k.1) (j := u - 1)).2
              ⟨Finset.mem_range.mp hkStage, by
                have huLt : u < m := by
                  simpa [hmEq] using Finset.mem_range.mp huStage'
                omega⟩
        have huStepEq : u - 1 + 1 = u := Nat.succ_pred_eq_of_pos huPos
        have hClauseCut :
            gridBaseClauseCutsRegion hull (GridClauseId.vertical k.1 (u - 1)) := by
          exact Or.inr ⟨huPrevNot, by simpa [huStepEq] using huHull⟩
        rw [hsEq]
        exact Finset.mem_filter.2 ⟨hClauseSupp, hClauseCut⟩
      rw [hEq] at hCutMem
      rcases Finset.mem_union.1 hCutMem with hV | hH
      · rcases Finset.mem_image.1 hV with ⟨c, _hc, hEqClause⟩
        have hcEq : c = k := by
          apply Fin.ext
          simpa using congrArg
            (fun d =>
              match d with
              | GridClauseId.vertical ii _ => ii
              | _ => 0) hEqClause
        have huEqC : gV c = u - 1 := by
          simpa using congrArg
            (fun d =>
              match d with
              | GridClauseId.vertical _ jj => jj
              | _ => 0) hEqClause
        have huEq : u - 1 = gV k := by
          have : gV k = u - 1 := by simpa [hcEq] using huEqC
          omega
        have hgap : (k.1, gV k + 1) ∉ hull := (hVExact k).2.1
        have huSucc : u = gV k + 1 := by omega
        exact hgap (by simpa [huSucc] using huHull)
      · rcases Finset.mem_image.1 hH with ⟨r, _hr, hEqClause⟩
        cases hEqClause
    · intro htLe
      exact (hVExact k).2.2 t htLe
  have hRowExact :
      ∀ k t, (t, k.1) ∈ hull ↔ t ≤ gH k := by
    intro k t
    constructor
    · intro htHull
      by_contra htGt
      have htGt' : gH k < t := by omega
      let P : ℕ → Prop := fun u => gH k < u ∧ u ≤ t ∧ (u, k.1) ∈ hull
      have hP : ∃ u, P u := ⟨t, htGt', le_rfl, htHull⟩
      let u := Nat.find hP
      have huGt : gH k < u := (Nat.find_spec hP).1
      have huLe : u ≤ t := (Nat.find_spec hP).2.1
      have huHull : (u, k.1) ∈ hull := (Nat.find_spec hP).2.2
      have huPos : 0 < u := by omega
      have huGap : gH k + 1 < u := by
        by_contra huNot
        have huEq : u = gH k + 1 := by omega
        exact (hHExact k).2.1 (by simpa [huEq] using huHull)
      have huPrevNot : (u - 1, k.1) ∉ hull := by
        intro huPrevHull
        have huPrevGt : gH k < u - 1 := by omega
        have hmin :
            u ≤ u - 1 :=
          Nat.find_min' hP ⟨huPrevGt, by omega, huPrevHull⟩
        omega
      have hmPos : 0 < m := by omega
      have hmEq : m - 1 + 1 = m := Nat.succ_pred_eq_of_pos hmPos
      have huStage : (u, k.1) ∈ gridExhaustion.region (m - 1) := hHullStage huHull
      rcases Finset.mem_product.1 huStage with ⟨huStage', hkStage⟩
      have hCutMem :
          GridClauseId.horizontal (u - 1) k.1 ∈ s := by
        have hClauseSupp :
            GridClauseId.horizontal (u - 1) k.1 ∈
              gridRegionSupport (gridExhaustion.region (m - 1)) := by
          exact
            (horizontal_mem_gridRegionSupport_gridExhaustion_region_iff
              (n := m - 1) (i := u - 1) (j := k.1)).2
              ⟨by
                  have huLt : u < m := by
                    simpa [hmEq] using Finset.mem_range.mp huStage'
                  omega,
                Finset.mem_range.mp hkStage⟩
        have huStepEq : u - 1 + 1 = u := Nat.succ_pred_eq_of_pos huPos
        have hClauseCut :
            gridBaseClauseCutsRegion hull (GridClauseId.horizontal (u - 1) k.1) := by
          exact Or.inr ⟨huPrevNot, by simpa [huStepEq] using huHull⟩
        rw [hsEq]
        exact Finset.mem_filter.2 ⟨hClauseSupp, hClauseCut⟩
      rw [hEq] at hCutMem
      rcases Finset.mem_union.1 hCutMem with hV | hH
      · rcases Finset.mem_image.1 hV with ⟨c, _hc, hEqClause⟩
        cases hEqClause
      · rcases Finset.mem_image.1 hH with ⟨r, _hr, hEqClause⟩
        have hrEq : r = k := by
          apply Fin.ext
          simpa using congrArg
            (fun d =>
              match d with
              | GridClauseId.horizontal _ jj => jj
              | _ => 0) hEqClause
        have huEqR : gH r = u - 1 := by
          simpa using congrArg
            (fun d =>
              match d with
              | GridClauseId.horizontal ii _ => ii
              | _ => 0) hEqClause
        have huEq : u - 1 = gH k := by
          have : gH k = u - 1 := by simpa [hrEq] using huEqR
          omega
        have hgap : (gH k + 1, k.1) ∉ hull := (hHExact k).2.1
        have huSucc : u = gH k + 1 := by omega
        exact hgap (by simpa [huSucc] using huHull)
    · intro htLe
      exact (hHExact k).2.2 t htLe
  exact ⟨hull, hhullBox, hcutCard, hsEq, gV, gH, hEq, hVBound, hHBound, hColExact, hRowExact⟩

theorem originConnectedHullCutSetCandidatesInCutCardBoxAxisAnchored_exists_hullMonotonePrefixRowColDecomposition_of_diag
    {m i j : ℕ} {s : Finset GridClauseId}
    (hs : s ∈ originConnectedHullCutSetCandidatesInCutCardBoxAxisAnchored m i j)
    (hdiag : m = i + j + 2) :
    ∃ hull, hull ∈ originConnectedHullContainingSubregionsInCutCardBox m ∧
      originContainingSubregionCutCard (m - 1) hull = m ∧
      s =
        (gridRegionSupport (gridExhaustion.region (m - 1))).filter
          (gridBaseClauseCutsRegion hull) ∧
      ∃ gV : Fin (i + 1) → ℕ,
      ∃ gH : Fin (j + 1) → ℕ,
        s =
          (Finset.univ.image (fun k : Fin (i + 1) => GridClauseId.vertical k.1 (gV k))) ∪
            (Finset.univ.image (fun k : Fin (j + 1) => GridClauseId.horizontal (gH k) k.1)) ∧
          (∀ k, gV k ≤ j) ∧
          (∀ k, gH k ≤ i) ∧
          (∀ k t, (k.1, t) ∈ hull ↔ t ≤ gV k) ∧
          (∀ k t, (t, k.1) ∈ hull ↔ t ≤ gH k) ∧
          (∀ a b : Fin (i + 1), a.1 ≤ b.1 → gV b ≤ gV a) ∧
          (∀ a b : Fin (j + 1), a.1 ≤ b.1 → gH b ≤ gH a) := by
  classical
  rcases
    originConnectedHullCutSetCandidatesInCutCardBoxAxisAnchored_exists_hullExactPrefixRowColDecomposition_of_diag
      hs hdiag with
    ⟨hull, hhullBox, hcutCard, hsEq, gV, gH, hEq, hVBound, hHBound, hColExact, hRowExact⟩
  have hVMono :
      ∀ a b : Fin (i + 1), a.1 ≤ b.1 → gV b ≤ gV a := by
    intro a b hab
    let r : Fin (j + 1) := ⟨gV b, lt_of_le_of_lt (hVBound b) (Nat.lt_succ_self j)⟩
    have hbIn : (b.1, r.1) ∈ hull := by
      change (b.1, gV b) ∈ hull
      exact (hColExact b (gV b)).2 le_rfl
    have hbLe : b.1 ≤ gH r := (hRowExact r b.1).1 hbIn
    have haIn : (a.1, r.1) ∈ hull := (hRowExact r a.1).2 (le_trans hab hbLe)
    have : r.1 ≤ gV a := (hColExact a r.1).1 haIn
    simpa [r] using this
  have hHMono :
      ∀ a b : Fin (j + 1), a.1 ≤ b.1 → gH b ≤ gH a := by
    intro a b hab
    let c : Fin (i + 1) := ⟨gH b, lt_of_le_of_lt (hHBound b) (Nat.lt_succ_self i)⟩
    have hbIn : (c.1, b.1) ∈ hull := by
      change (gH b, b.1) ∈ hull
      exact (hRowExact b (gH b)).2 le_rfl
    have hbLe : b.1 ≤ gV c := (hColExact c b.1).1 hbIn
    have haIn : (c.1, a.1) ∈ hull := (hColExact c a.1).2 (le_trans hab hbLe)
    have : c.1 ≤ gH a := (hRowExact a c.1).1 haIn
    simpa [c] using this
  exact ⟨hull, hhullBox, hcutCard, hsEq, gV, gH, hEq, hVBound, hHBound,
    hColExact, hRowExact, hVMono, hHMono⟩

structure AxisAnchoredDiagHullProfile
    (m i j : ℕ) (s : Finset GridClauseId) where
  hull : Region GridNode
  hhullBox : hull ∈ originConnectedHullContainingSubregionsInCutCardBox m
  hcutCard : originContainingSubregionCutCard (m - 1) hull = m
  hsEq :
    s =
      (gridRegionSupport (gridExhaustion.region (m - 1))).filter
        (gridBaseClauseCutsRegion hull)
  gV : Fin (i + 1) → ℕ
  gH : Fin (j + 1) → ℕ
  hEq :
    s =
      (Finset.univ.image (fun k : Fin (i + 1) => GridClauseId.vertical k.1 (gV k))) ∪
        (Finset.univ.image (fun k : Fin (j + 1) => GridClauseId.horizontal (gH k) k.1))
  hVBound : ∀ k, gV k ≤ j
  hHBound : ∀ k, gH k ≤ i
  hColExact : ∀ k t, (k.1, t) ∈ hull ↔ t ≤ gV k
  hRowExact : ∀ k t, (t, k.1) ∈ hull ↔ t ≤ gH k
  hVMono : ∀ a b : Fin (i + 1), a.1 ≤ b.1 → gV b ≤ gV a
  hHMono : ∀ a b : Fin (j + 1), a.1 ≤ b.1 → gH b ≤ gH a

theorem AxisAnchoredDiagHullProfile.vertical_mem
    {m i j : ℕ} {s : Finset GridClauseId}
    (prof : AxisAnchoredDiagHullProfile m i j s)
    (k : Fin (i + 1)) :
    GridClauseId.vertical k.1 (prof.gV k) ∈ s := by
  let c := GridClauseId.vertical k.1 (prof.gV k)
  change c ∈ s
  rw [prof.hEq]
  exact Finset.mem_union.2 <| Or.inl <|
    Finset.mem_image.2 ⟨k, Finset.mem_univ _, rfl⟩

theorem AxisAnchoredDiagHullProfile.horizontal_mem
    {m i j : ℕ} {s : Finset GridClauseId}
    (prof : AxisAnchoredDiagHullProfile m i j s)
    (k : Fin (j + 1)) :
    GridClauseId.horizontal (prof.gH k) k.1 ∈ s := by
  let c := GridClauseId.horizontal (prof.gH k) k.1
  change c ∈ s
  rw [prof.hEq]
  exact Finset.mem_union.2 <| Or.inr <|
    Finset.mem_image.2 ⟨k, Finset.mem_univ _, rfl⟩

theorem AxisAnchoredDiagHullProfile.gV_zero_eq_of_axisAnchored
    {m i j : ℕ} {s : Finset GridClauseId}
    (prof : AxisAnchoredDiagHullProfile m i j s)
    (hs : s ∈ originConnectedHullCutSetCandidatesInCutCardBoxAxisAnchored m i j) :
    prof.gV 0 = j := by
  have hvert :
      GridClauseId.vertical 0 j ∈ s :=
    vertical_root_mem_of_mem_originConnectedHullCutSetCandidatesInCutCardBoxAxisAnchored hs
  rw [prof.hEq] at hvert
  rcases Finset.mem_union.1 hvert with hvert | hhor
  · rcases Finset.mem_image.1 hvert with ⟨c, _hc, hcEq⟩
    have hcZero : c.1 = 0 :=
      congrArg
        (fun d =>
          match d with
          | GridClauseId.vertical ii _ => ii
          | _ => 0) hcEq
    have hg : prof.gV c = j :=
      congrArg
        (fun d =>
          match d with
          | GridClauseId.vertical _ jj => jj
          | _ => 0) hcEq
    have hc : c = 0 := Fin.ext hcZero
    simpa [hc] using hg
  · rcases Finset.mem_image.1 hhor with ⟨r, _hr, hrEq⟩
    cases hrEq

theorem AxisAnchoredDiagHullProfile.gH_zero_eq_of_axisAnchored
    {m i j : ℕ} {s : Finset GridClauseId}
    (prof : AxisAnchoredDiagHullProfile m i j s)
    (hs : s ∈ originConnectedHullCutSetCandidatesInCutCardBoxAxisAnchored m i j) :
    prof.gH 0 = i := by
  have hhor :
      GridClauseId.horizontal i 0 ∈ s :=
    horizontal_root_mem_of_mem_originConnectedHullCutSetCandidatesInCutCardBoxAxisAnchored hs
  rw [prof.hEq] at hhor
  rcases Finset.mem_union.1 hhor with hvert | hhor
  · rcases Finset.mem_image.1 hvert with ⟨c, _hc, hcEq⟩
    cases hcEq
  · rcases Finset.mem_image.1 hhor with ⟨r, _hr, hrEq⟩
    have hrZero : r.1 = 0 :=
      congrArg
        (fun d =>
          match d with
          | GridClauseId.horizontal _ jj => jj
          | _ => 0) hrEq
    have hg : prof.gH r = i :=
      congrArg
        (fun d =>
          match d with
          | GridClauseId.horizontal ii _ => ii
          | _ => 0) hrEq
    have hr : r = 0 := Fin.ext hrZero
    simpa [hr] using hg

theorem AxisAnchoredDiagHullProfile.horizontal_mem_of_between_adjacent_gV
    {m i j : ℕ} {s : Finset GridClauseId}
    (prof : AxisAnchoredDiagHullProfile m i j s)
    (hdiag : m = i + j + 2)
    (k : Fin i) {t : ℕ}
    (hlo :
      prof.gV ⟨k.1 + 1, Nat.succ_lt_succ k.2⟩ < t)
    (hhi :
      t ≤ prof.gV ⟨k.1, Nat.lt_trans k.2 (Nat.lt_succ_self i)⟩) :
    GridClauseId.horizontal k.1 t ∈ s := by
  let kL : Fin (i + 1) := ⟨k.1, Nat.lt_trans k.2 (Nat.lt_succ_self i)⟩
  let kR : Fin (i + 1) := ⟨k.1 + 1, Nat.succ_lt_succ k.2⟩
  have hLeft : (k.1, t) ∈ prof.hull := by
    exact (prof.hColExact kL t).2 (by simpa [kL] using hhi)
  have hRight : (k.1 + 1, t) ∉ prof.hull := by
    intro hIn
    have htLe : t ≤ prof.gV kR := (prof.hColExact kR t).1 hIn
    exact (not_lt_of_ge htLe) (by simpa [kR] using hlo)
  have htLeJ : t ≤ j := by
    exact le_trans (by simpa [kL] using hhi) (prof.hVBound kL)
  have hmPos : 0 < m := by omega
  have hmEq : m - 1 + 1 = m := Nat.succ_pred_eq_of_pos hmPos
  have hClauseSupp :
      GridClauseId.horizontal k.1 t ∈
        gridRegionSupport (gridExhaustion.region (m - 1)) := by
    exact
      (horizontal_mem_gridRegionSupport_gridExhaustion_region_iff
        (n := m - 1) (i := k.1) (j := t)).2
        ⟨by
            have : k.1 < m := by omega
            simpa [hmEq] using this,
          by
            have : t < m := by omega
            simpa [hmEq] using this⟩
  rw [prof.hsEq]
  exact Finset.mem_filter.2
    ⟨hClauseSupp, Or.inl ⟨hLeft, hRight⟩⟩

theorem AxisAnchoredDiagHullProfile.vertical_mem_of_between_adjacent_gH
    {m i j : ℕ} {s : Finset GridClauseId}
    (prof : AxisAnchoredDiagHullProfile m i j s)
    (hdiag : m = i + j + 2)
    (k : Fin j) {t : ℕ}
    (hlo :
      prof.gH ⟨k.1 + 1, Nat.succ_lt_succ k.2⟩ < t)
    (hhi :
      t ≤ prof.gH ⟨k.1, Nat.lt_trans k.2 (Nat.lt_succ_self j)⟩) :
    GridClauseId.vertical t k.1 ∈ s := by
  let kD : Fin (j + 1) := ⟨k.1, Nat.lt_trans k.2 (Nat.lt_succ_self j)⟩
  let kU : Fin (j + 1) := ⟨k.1 + 1, Nat.succ_lt_succ k.2⟩
  have hDown : (t, k.1) ∈ prof.hull := by
    exact (prof.hRowExact kD t).2 (by simpa [kD] using hhi)
  have hUp : (t, k.1 + 1) ∉ prof.hull := by
    intro hIn
    have htLe : t ≤ prof.gH kU := (prof.hRowExact kU t).1 hIn
    exact (not_lt_of_ge htLe) (by simpa [kU] using hlo)
  have htLeI : t ≤ i := by
    exact le_trans (by simpa [kD] using hhi) (prof.hHBound kD)
  have hmPos : 0 < m := by omega
  have hmEq : m - 1 + 1 = m := Nat.succ_pred_eq_of_pos hmPos
  have hClauseSupp :
      GridClauseId.vertical t k.1 ∈
        gridRegionSupport (gridExhaustion.region (m - 1)) := by
    exact
      (vertical_mem_gridRegionSupport_gridExhaustion_region_iff
        (n := m - 1) (i := t) (j := k.1)).2
        ⟨by
            have : t < m := by omega
            simpa [hmEq] using this,
          by
            have : k.1 < m := by omega
            simpa [hmEq] using this⟩
  rw [prof.hsEq]
  exact Finset.mem_filter.2
    ⟨hClauseSupp, Or.inl ⟨hDown, hUp⟩⟩

theorem AxisAnchoredDiagHullProfile.horizontal_bridge_top_mem_of_gV_drop
    {m i j : ℕ} {s : Finset GridClauseId}
    (prof : AxisAnchoredDiagHullProfile m i j s)
