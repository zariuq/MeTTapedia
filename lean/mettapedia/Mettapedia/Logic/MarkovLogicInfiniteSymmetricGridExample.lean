theorem exists_rootedPrefix_of_clauseChain
    {m i : ℕ} {s : Finset GridClauseId}
    (tail : List GridClauseId)
    (hlen : 1 + 2 * tail.length ≤ 2 * m)
    (hchain : List.IsChain gridClauseDualAdjacent
      (GridClauseId.horizontal i 0 :: tail))
    (hroot : GridClauseId.horizontal i 0 ∈ s)
    (htailMem : ∀ c ∈ tail, c ∈ s)
    (hcover :
      ∀ x ∈ s, x = GridClauseId.horizontal i 0 ∨ x ∈ tail) :
    ∃ pref : CutWalkReplayPrefix i,
      ∃ hpos : 0 < pref.len,
        pref.len ≤ 2 * m ∧
          pref.step ⟨0, hpos⟩ = GridClauseId.horizontal i 0 ∧
            pref.tag ⟨0, hpos⟩ = CutWalkVisitTag.fresh ∧
              (∀ k : Fin pref.len,
                pref.tag k = CutWalkVisitTag.fresh →
                  pref.step k ∈ s) ∧
                (∀ x ∈ s,
                  ∃ k : Fin pref.len,
                    pref.tag k = CutWalkVisitTag.fresh ∧
                      pref.step k = x) := by
  let pref₀ := cutWalkRootPrefix i
  have hpos₀ : 0 < pref₀.len := by
    simp [pref₀]
  have hchain₀ :
      List.IsChain gridClauseDualAdjacent (pref₀.lastStep hpos₀ :: tail) := by
    simpa [pref₀] using hchain
  have hmem₀ :
      ∀ k : Fin pref₀.len,
        pref₀.tag k = CutWalkVisitTag.fresh →
          pref₀.step k ∈ s := by
    intro k _htag
    simpa [pref₀, cutWalkRootPrefix] using hroot
  have hcover₀ :
      ∀ x ∈ ({GridClauseId.horizontal i 0} : Finset GridClauseId),
        ∃ k : Fin pref₀.len,
          pref₀.tag k = CutWalkVisitTag.fresh ∧
            pref₀.step k = x := by
    intro x hx
    simp at hx
    subst hx
    exact ⟨⟨0, hpos₀⟩, by simp [pref₀, cutWalkRootPrefix],
      by simp [pref₀, cutWalkRootPrefix]⟩
  rcases
    CutWalkReplayPrefix.exists_appendChain_fresh_cover
      (i := i) (s := s)
      (t := ({GridClauseId.horizontal i 0} : Finset GridClauseId))
      tail pref₀ hpos₀ hchain₀ (by simpa [pref₀] using hroot)
      htailMem hmem₀ hcover₀ with
    ⟨pref, hprefLen, hfirst, hmem, hcoverPrefix⟩
  have hprefLe : pref.len ≤ 2 * m := by
    calc
      pref.len ≤ pref₀.len + 2 * tail.length := hprefLen
      _ ≤ 2 * m := by
        simpa [pref₀] using hlen
  have hrootCovered :
      ∃ k : Fin pref.len,
        pref.tag k = CutWalkVisitTag.fresh ∧
          pref.step k = GridClauseId.horizontal i 0 :=
    hcoverPrefix (GridClauseId.horizontal i 0) (Or.inl (by simp))
  rcases hrootCovered with ⟨kroot, _htagRoot, _hstepRoot⟩
  have hpos : 0 < pref.len := Nat.lt_of_le_of_lt (Nat.zero_le _) kroot.2
  rcases hfirst hpos with ⟨hstepFirst, htagFirst⟩
  have hstep0 :
      pref.step ⟨0, hpos⟩ = GridClauseId.horizontal i 0 := by
    simpa [pref₀, cutWalkRootPrefix] using hstepFirst
  have htag0 :
      pref.tag ⟨0, hpos⟩ = CutWalkVisitTag.fresh := by
    simpa [pref₀, cutWalkRootPrefix] using htagFirst
  refine ⟨pref, hpos, hprefLe, hstep0, htag0, hmem, ?_⟩
  intro x hx
  apply hcoverPrefix x
  rcases hcover x hx with rfl | hxTail
  · left
    simp
  · right
    exact hxTail

