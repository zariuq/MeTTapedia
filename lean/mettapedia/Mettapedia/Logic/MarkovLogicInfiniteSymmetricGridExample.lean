theorem card_eq_of_mem_originConnectedHullCutSetCandidatesInCutCardBoxAxisAnchored
    {m i j : ℕ} {s : Finset GridClauseId}
    (hs : s ∈ originConnectedHullCutSetCandidatesInCutCardBoxAxisAnchored m i j) :
    s.card = m :=
  card_eq_of_mem_originConnectedHullCutSetCandidatesInCutCardBox
    (mem_originConnectedHullCutSetCandidatesInCutCardBox_of_mem_axisAnchored hs)

theorem exists_hull_cut_eq_of_mem_originConnectedHullCutSetCandidatesInCutCardBoxAxisAnchored
    {m i j : ℕ} {s : Finset GridClauseId}
    (hs : s ∈ originConnectedHullCutSetCandidatesInCutCardBoxAxisAnchored m i j) :
    ∃ hull ∈ originConnectedHullContainingSubregionsInCutCardBox m,
      originContainingSubregionCutCard (m - 1) hull = m ∧
        s =
          (gridRegionSupport (gridExhaustion.region (m - 1))).filter
            (gridBaseClauseCutsRegion hull) ∧
        GridClauseId.horizontal i 0 ∈
          (gridRegionSupport (gridExhaustion.region (m - 1))).filter
            (gridBaseClauseCutsRegion hull) ∧
        GridClauseId.vertical 0 j ∈
          (gridRegionSupport (gridExhaustion.region (m - 1))).filter
            (gridBaseClauseCutsRegion hull) := by
  rcases Finset.mem_filter.1 hs with ⟨hsCut, hroots⟩
  rcases mem_originConnectedHullCutSetCandidatesInCutCardBox_iff.1 hsCut with
    ⟨hull, hhull, hcutCard, hsEq⟩
  refine ⟨hull, hhull, hcutCard, hsEq, ?_, ?_⟩
  · simpa [hsEq] using hroots.1
  · simpa [hsEq] using hroots.2

theorem exists_connected_stageCoConnected_hull_cut_eq_of_mem_axisAnchored
    {m i j : ℕ} {s : Finset GridClauseId}
    (hs : s ∈ originConnectedHullCutSetCandidatesInCutCardBoxAxisAnchored m i j) :
    ∃ hull ∈ originConnectedHullContainingSubregionsInCutCardBox m,
      OriginConnectedRegion hull ∧
        StageCoConnectedRegion (m - 1) hull ∧
          originContainingSubregionCutCard (m - 1) hull = m ∧
            s =
              (gridRegionSupport (gridExhaustion.region (m - 1))).filter
                (gridBaseClauseCutsRegion hull) ∧
              GridClauseId.horizontal i 0 ∈
                (gridRegionSupport (gridExhaustion.region (m - 1))).filter
                  (gridBaseClauseCutsRegion hull) ∧
                GridClauseId.vertical 0 j ∈
                  (gridRegionSupport (gridExhaustion.region (m - 1))).filter
                    (gridBaseClauseCutsRegion hull) := by
  rcases
    exists_hull_cut_eq_of_mem_originConnectedHullCutSetCandidatesInCutCardBoxAxisAnchored
      hs with
    ⟨hull, hhullBox, hcutCard, hsEq, hhor, hvert⟩
  have hhull :
      hull ∈ originConnectedHullContainingSubregions (m - 1) := by
    simpa [originConnectedHullContainingSubregionsInCutCardBox] using hhullBox
  refine ⟨hull, hhullBox, ?_, ?_, hcutCard, hsEq, hhor, hvert⟩
  · exact mem_originConnectedHullContainingSubregions_imp_originConnected hhull
  · exact mem_originConnectedHullContainingSubregions_imp_stageCoConnected hhull

