def spinFlipWorld {Atom : Type*} (ω : InfiniteWorld Atom) : InfiniteWorld Atom :=
  fun a => !ω a

def spinFlipLocalAssignment {Atom : Type*} {Λ : Region Atom}
    (x : LocalAssignment Atom Λ) : LocalAssignment Atom Λ :=
  fun a => !x a

@[simp] theorem spinFlipWorld_apply {Atom : Type*}
    (ω : InfiniteWorld Atom) (a : Atom) :
    spinFlipWorld ω a = !ω a := rfl

@[simp] theorem spinFlipLocalAssignment_apply {Atom : Type*} {Λ : Region Atom}
    (x : LocalAssignment Atom Λ) (a : RegionAtom Atom Λ) :
    spinFlipLocalAssignment x a = !x a := rfl

theorem spinFlipWorld_involutive {Atom : Type*}
    (ω : InfiniteWorld Atom) :
    spinFlipWorld (spinFlipWorld ω) = ω := by
  funext a
  simp [spinFlipWorld]

theorem spinFlipLocalAssignment_involutive {Atom : Type*} {Λ : Region Atom}
    (x : LocalAssignment Atom Λ) :
    spinFlipLocalAssignment (spinFlipLocalAssignment x) = x := by
  funext a
  simp [spinFlipLocalAssignment]

theorem spinFlipLocalAssignment_bijective {Atom : Type*} {Λ : Region Atom} :
    Function.Bijective (@spinFlipLocalAssignment Atom Λ) := by
  constructor
  · intro a b h
    have hflip := congrArg spinFlipLocalAssignment h
    simpa [spinFlipLocalAssignment_involutive] using hflip
  · intro a
    exact ⟨spinFlipLocalAssignment a, by simp [spinFlipLocalAssignment_involutive]⟩

theorem spinFlipWorld_patch {Atom : Type*} [DecidableEq Atom]
    (Λ : Region Atom) (x : LocalAssignment Atom Λ) (ξ : BoundaryCondition Atom) :
    spinFlipWorld (patch Λ x ξ) =
      patch Λ (spinFlipLocalAssignment x) (spinFlipWorld ξ) := by
  funext a
  by_cases ha : a ∈ Λ <;> simp [spinFlipWorld, spinFlipLocalAssignment, patch, ha]

@[simp] theorem spinFlipWorld_gridPlusBoundary :
    spinFlipWorld gridPlusBoundary = gridMinusBoundary := by
  funext a
  simp [spinFlipWorld, gridPlusBoundary, gridMinusBoundary]

@[simp] theorem spinFlipWorld_gridMinusBoundary :
    spinFlipWorld gridMinusBoundary = gridPlusBoundary := by
  funext a
  simp [spinFlipWorld, gridPlusBoundary, gridMinusBoundary]

theorem spinFlipLocalAssignment_mem_originSpinUp_iff_not
    (x : LocalAssignment GridNode ({gridOrigin} : Region GridNode)) :
    spinFlipLocalAssignment x ∈
        localConstraintSet ({gridOrigin} : Region GridNode)
          gridOriginSpinUpLocalQuery ↔
      x ∉
        localConstraintSet ({gridOrigin} : Region GridNode)
          gridOriginSpinUpLocalQuery := by
  rw [gridOriginSpinUpLocalConstraintSet_eq]
  simp [singletonTrueAssignmentSet, spinFlipLocalAssignment]

/-- One-site origin-spin query viewed inside any finite region that contains
the origin.  The `true` instance is the positive/up event; the `false` instance
is its negative/down companion. -/
def gridOriginSpinLocalQueryInRegion
    (Λ : Region GridNode) (hOrigin : gridOrigin ∈ Λ) (b : Bool) :
    LocalConstraintQuery GridNode Λ :=
  [⟨⟨gridOrigin, hOrigin⟩, b⟩]

theorem spinFlipLocalAssignment_satisfies_originSpinInRegion_iff
    (Λ : Region GridNode) (hOrigin : gridOrigin ∈ Λ) (b : Bool)
    (x : LocalAssignment GridNode Λ) :
    satisfiesConstraints (spinFlipLocalAssignment x)
        (gridOriginSpinLocalQueryInRegion Λ hOrigin b) ↔
      satisfiesConstraints x
        (gridOriginSpinLocalQueryInRegion Λ hOrigin (!b)) := by
  cases b <;> simp [satisfiesConstraints, gridOriginSpinLocalQueryInRegion,
    spinFlipLocalAssignment]

theorem gridOrigin_mem_gridExhaustion_region (n : ℕ) :
    gridOrigin ∈ gridExhaustion.region n := by
  simp [gridExhaustion, gridOrigin]

theorem localQueryEvent_gridOriginSpinLocalQueryInRegion_eq_originSpinUp
    (Λ : Region GridNode) (hOrigin : gridOrigin ∈ Λ) :
    localQueryEvent Λ (gridOriginSpinLocalQueryInRegion Λ hOrigin true) =
      localQueryEvent ({gridOrigin} : Region GridNode) gridOriginSpinUpLocalQuery := by
  ext ω
  simp [localQueryEvent, worldRestriction, satisfiesConstraints,
    gridOriginSpinLocalQueryInRegion, gridOriginSpinUpLocalQuery]

/-- The eastern nearest neighbour of the origin in the quarter-plane grid. -/
def gridOriginEast : GridNode := (1, 0)

/-- The northern nearest neighbour of the origin in the quarter-plane grid. -/
def gridOriginNorth : GridNode := (0, 1)

/-- The two boundary-support neighbours of the corner origin. -/
def gridOriginNeighborPairRegion : Region GridNode :=
  ({gridOriginEast, gridOriginNorth} : Finset GridNode)

@[simp] theorem gridOriginEast_mem_neighborPairRegion :
    gridOriginEast ∈ gridOriginNeighborPairRegion := by
  simp [gridOriginNeighborPairRegion]

@[simp] theorem gridOriginNorth_mem_neighborPairRegion :
    gridOriginNorth ∈ gridOriginNeighborPairRegion := by
  simp [gridOriginNeighborPairRegion]

/-- The local assignment on the east/north origin-neighbour pair with the
prescribed truth values. -/
def gridOriginNeighborPairAssignment (bEast bNorth : Bool) :
    LocalAssignment GridNode gridOriginNeighborPairRegion :=
  fun a => if a.1 = gridOriginEast then bEast else bNorth

@[simp] theorem gridOriginNeighborPairAssignment_apply_east
    (bEast bNorth : Bool) :
    gridOriginNeighborPairAssignment bEast bNorth
      ⟨gridOriginEast, gridOriginEast_mem_neighborPairRegion⟩ = bEast := by
  simp [gridOriginNeighborPairAssignment, gridOriginEast]

@[simp] theorem gridOriginNeighborPairAssignment_apply_north
    (bEast bNorth : Bool) :
    gridOriginNeighborPairAssignment bEast bNorth
      ⟨gridOriginNorth, gridOriginNorth_mem_neighborPairRegion⟩ = bNorth := by
  simp [gridOriginNeighborPairAssignment, gridOriginEast, gridOriginNorth]

@[simp] theorem gridOriginNeighborPairAssignment_eta
    (x : LocalAssignment GridNode gridOriginNeighborPairRegion) :
    gridOriginNeighborPairAssignment
        (x ⟨gridOriginEast, gridOriginEast_mem_neighborPairRegion⟩)
        (x ⟨gridOriginNorth, gridOriginNorth_mem_neighborPairRegion⟩) =
      x := by
  funext a
  rcases a with ⟨a, ha⟩
  have haCases : a = gridOriginEast ∨ a = gridOriginNorth := by
    simpa [gridOriginNeighborPairRegion, gridOriginEast, gridOriginNorth] using ha
  rcases haCases with rfl | rfl
  · simp [gridOriginNeighborPairAssignment]
  · simp [gridOriginNeighborPairAssignment, gridOriginEast, gridOriginNorth]

def gridOriginNeighborPairFF : LocalAssignment GridNode gridOriginNeighborPairRegion :=
  gridOriginNeighborPairAssignment false false

def gridOriginNeighborPairFT : LocalAssignment GridNode gridOriginNeighborPairRegion :=
  gridOriginNeighborPairAssignment false true

def gridOriginNeighborPairTF : LocalAssignment GridNode gridOriginNeighborPairRegion :=
  gridOriginNeighborPairAssignment true false

def gridOriginNeighborPairTT : LocalAssignment GridNode gridOriginNeighborPairRegion :=
  gridOriginNeighborPairAssignment true true

@[simp] theorem gridOriginNeighborPairAssignment_univ :
    (Finset.univ : Finset (LocalAssignment GridNode gridOriginNeighborPairRegion)) =
      ({gridOriginNeighborPairFF, gridOriginNeighborPairFT,
        gridOriginNeighborPairTF, gridOriginNeighborPairTT} :
          Finset (LocalAssignment GridNode gridOriginNeighborPairRegion)) := by
  ext x
  constructor
  · intro _hx
    rw [← gridOriginNeighborPairAssignment_eta x]
    cases hEast : x ⟨gridOriginEast, gridOriginEast_mem_neighborPairRegion⟩ <;>
      cases hNorth : x ⟨gridOriginNorth, gridOriginNorth_mem_neighborPairRegion⟩ <;>
      simp [gridOriginNeighborPairFF, gridOriginNeighborPairFT,
        gridOriginNeighborPairTF, gridOriginNeighborPairTT]
  · intro hx
    simp at hx
    simp

/-- The origin together with its two corner-support neighbours. -/
def gridOriginCornerTripleRegion : Region GridNode :=
  ({gridOrigin, gridOriginEast, gridOriginNorth} : Finset GridNode)

@[simp] theorem gridOrigin_mem_cornerTripleRegion :
    gridOrigin ∈ gridOriginCornerTripleRegion := by
  simp [gridOriginCornerTripleRegion, gridOrigin]

@[simp] theorem gridOriginEast_mem_cornerTripleRegion :
    gridOriginEast ∈ gridOriginCornerTripleRegion := by
  simp [gridOriginCornerTripleRegion, gridOriginEast]

@[simp] theorem gridOriginNorth_mem_cornerTripleRegion :
    gridOriginNorth ∈ gridOriginCornerTripleRegion := by
  simp [gridOriginCornerTripleRegion, gridOriginNorth]

/-- Three-site corner pattern query on the origin/east/north triple. -/
def gridOriginCornerTripleLocalQuery
    (bOrigin bEast bNorth : Bool) :
    LocalConstraintQuery GridNode gridOriginCornerTripleRegion :=
  [⟨⟨gridOrigin, gridOrigin_mem_cornerTripleRegion⟩, bOrigin⟩,
    ⟨⟨gridOriginEast, gridOriginEast_mem_cornerTripleRegion⟩, bEast⟩,
    ⟨⟨gridOriginNorth, gridOriginNorth_mem_cornerTripleRegion⟩, bNorth⟩]

theorem patch_mem_localQueryEvent_gridOriginCornerTripleLocalQuery_iff
    {Λ : Region GridNode} (x : LocalAssignment GridNode Λ)
    (ξ : BoundaryCondition GridNode)
    (bOrigin bEast bNorth : Bool) :
    patch Λ x ξ ∈
        localQueryEvent gridOriginCornerTripleRegion
          (gridOriginCornerTripleLocalQuery bOrigin bEast bNorth) ↔
      patch Λ x ξ gridOrigin = bOrigin ∧
        patch Λ x ξ gridOriginEast = bEast ∧
        patch Λ x ξ gridOriginNorth = bNorth := by
  simp only [localQueryEvent, worldRestriction, satisfiesConstraints,
    gridOriginCornerTripleLocalQuery, gridOriginCornerTripleRegion, Set.mem_setOf_eq]
  constructor
  · intro h
    exact ⟨h _ List.mem_cons_self,
      h _ (List.mem_cons_of_mem _ List.mem_cons_self),
      h _ (List.mem_cons_of_mem _ (List.mem_cons_of_mem _ List.mem_cons_self))⟩
  · rintro ⟨h1, h2, h3⟩ c hc
    rcases List.mem_cons.1 hc with rfl | hc
    · exact h1
    rcases List.mem_cons.1 hc with rfl | hc
    · exact h2
    rcases List.mem_cons.1 hc with rfl | hc
    · exact h3
    exact absurd hc (List.not_mem_nil)

/-- Current finite carrier for a corner separator witness: a region inside the
square box whose cut separates the corner origin from both axis directions
through the east and north neighbours. The later extraction/counting layer can
add connectivity/path structure on top of this region witness. -/
structure CornerAxisSeparator (n : ℕ) where
  inside : Region GridNode
  inside_subset : inside ⊆ gridExhaustion.region n
  origin_mem : gridOrigin ∈ inside
  east_not_mem : gridOriginEast ∉ inside
  north_not_mem : gridOriginNorth ∉ inside

/-- The finite-volume cut predicate for an oriented grid base clause relative to
an inside region. Priors never cut; an edge cuts exactly when its endpoints lie
on opposite sides of the region boundary. -/
def gridBaseClauseCutsRegion (inside : Region GridNode) : GridClauseId → Prop
  | .prior _ _ => False
  | .horizontal i j =>
      ((i, j) ∈ inside ∧ (i + 1, j) ∉ inside) ∨
        ((i, j) ∉ inside ∧ (i + 1, j) ∈ inside)
  | .vertical i j =>
      ((i, j) ∈ inside ∧ (i, j + 1) ∉ inside) ∨
        ((i, j) ∉ inside ∧ (i, j + 1) ∈ inside)

noncomputable instance (inside : Region GridNode) :
    DecidablePred (gridBaseClauseCutsRegion inside) :=
  Classical.decPred _

/-- The base-clause cut set associated to a corner separator inside a finite
volume box. -/
noncomputable def CornerAxisSeparator.cutBaseClauses
    {n : ℕ} (sep : CornerAxisSeparator n) : Finset GridClauseId :=
  by
    classical
    exact (gridRegionSupport (gridExhaustion.region n)).filter
      (gridBaseClauseCutsRegion sep.inside)

theorem cornerAxisSeparator_horizontalOrigin_mem_cutBaseClauses
    {n : ℕ} (sep : CornerAxisSeparator n) :
    GridClauseId.horizontal 0 0 ∈ sep.cutBaseClauses := by
  classical
  unfold CornerAxisSeparator.cutBaseClauses
  rw [Finset.mem_filter]
  constructor
  · apply gridRegionSupport_complete
    refine ⟨gridOrigin, ?_, gridOrigin_mem_gridExhaustion_region n⟩
    simp [gridClause, gridOrigin]
  · exact Or.inl ⟨sep.origin_mem, sep.east_not_mem⟩

theorem cornerAxisSeparator_verticalOrigin_mem_cutBaseClauses
    {n : ℕ} (sep : CornerAxisSeparator n) :
    GridClauseId.vertical 0 0 ∈ sep.cutBaseClauses := by
  classical
  unfold CornerAxisSeparator.cutBaseClauses
  rw [Finset.mem_filter]
  constructor
  · apply gridRegionSupport_complete
    refine ⟨gridOrigin, ?_, gridOrigin_mem_gridExhaustion_region n⟩
    simp [gridClause, gridOrigin]
  · exact Or.inl ⟨sep.origin_mem, sep.north_not_mem⟩

/-- Minimal corner separator with only the origin inside. This is the smallest
explicit witness carrier for the future corner extraction/counting route. -/
def gridOriginSingletonCornerAxisSeparator (n : ℕ) : CornerAxisSeparator n where
  inside := ({gridOrigin} : Region GridNode)
  inside_subset := by
    intro a ha
    have hpair : a = gridOrigin := by
      simpa [gridOrigin] using ha
    simpa [hpair] using gridOrigin_mem_gridExhaustion_region n
  origin_mem := by
    simp [gridOrigin]
  east_not_mem := by
    simp [gridOrigin, gridOriginEast]
  north_not_mem := by
    simp [gridOrigin, gridOriginNorth]

theorem gridOriginSingletonCornerAxisSeparator_cutBaseClauses
    (n : ℕ) :
    (gridOriginSingletonCornerAxisSeparator n).cutBaseClauses =
      ({GridClauseId.horizontal 0 0, GridClauseId.vertical 0 0} :
        Finset GridClauseId) := by
  classical
  ext j
  constructor
  · intro hj
    unfold CornerAxisSeparator.cutBaseClauses at hj
    rw [Finset.mem_filter] at hj
    rcases hj with ⟨_hsupp, hcut⟩
    cases j with
    | prior i j =>
        cases hcut
    | horizontal i j =>
        rcases hcut with hcut | hcut
        · rcases hcut with ⟨hin, _hout⟩
          have hpair : (i, j) = gridOrigin := by
            simpa [gridOriginSingletonCornerAxisSeparator, gridOrigin] using hin
          have hi0 : i = 0 := by
            simpa [gridOrigin] using congrArg Prod.fst hpair
          have hj0 : j = 0 := by
            simpa [gridOrigin] using congrArg Prod.snd hpair
          subst hi0
          subst hj0
          simp
        · exfalso
          rcases hcut with ⟨_hout, hin⟩
          have hpair : (i + 1, j) = gridOrigin := by
            simp [gridOriginSingletonCornerAxisSeparator, gridOrigin] at hin
          have hsucc : i + 1 = 0 := by
            simpa [gridOrigin] using congrArg Prod.fst hpair
          omega
    | vertical i j =>
        rcases hcut with hcut | hcut
        · rcases hcut with ⟨hin, _hout⟩
          have hpair : (i, j) = gridOrigin := by
            simpa [gridOriginSingletonCornerAxisSeparator, gridOrigin] using hin
          have hi0 : i = 0 := by
            simpa [gridOrigin] using congrArg Prod.fst hpair
          have hj0 : j = 0 := by
            simpa [gridOrigin] using congrArg Prod.snd hpair
          subst hi0
          subst hj0
          simp
        · exfalso
          rcases hcut with ⟨_hout, hin⟩
          have hpair : (i, j + 1) = gridOrigin := by
            simp [gridOriginSingletonCornerAxisSeparator, gridOrigin] at hin
          have hsucc : j + 1 = 0 := by
            simpa [gridOrigin] using congrArg Prod.snd hpair
          omega
  · intro hj
    simp at hj
    rcases hj with rfl | rfl
    · exact
        cornerAxisSeparator_horizontalOrigin_mem_cutBaseClauses
          (sep := gridOriginSingletonCornerAxisSeparator n)
    · exact
        cornerAxisSeparator_verticalOrigin_mem_cutBaseClauses
          (sep := gridOriginSingletonCornerAxisSeparator n)

theorem gridOriginSingletonCornerAxisSeparator_cutBaseClauses_card
    (n : ℕ) :
    (gridOriginSingletonCornerAxisSeparator n).cutBaseClauses.card = 2 := by
  rw [gridOriginSingletonCornerAxisSeparator_cutBaseClauses]
  simp

/-- Flip a finite local assignment on a chosen inside region, leaving the
outside part of the box unchanged. -/
noncomputable def flipInsideLocalAssignment
    {Λ : Region GridNode} (inside : Region GridNode) (hInsideΛ : inside ⊆ Λ)
    (x : LocalAssignment GridNode Λ) : LocalAssignment GridNode Λ :=
  Mettapedia.Logic.MarkovLogicInfiniteFixedRegionDLR.mergeAssignments (Atom := GridNode)
    (spinFlipLocalAssignment
      (Mettapedia.Logic.MarkovLogicInfiniteFixedRegionDLR.restrictAssignment
        (Atom := GridNode) hInsideΛ x))
    (Mettapedia.Logic.MarkovLogicInfiniteFixedRegionDLR.restrictOutsideAssignment
      (Atom := GridNode) (Λ := inside) (Δ := Λ) x)

@[simp] theorem flipInsideLocalAssignment_apply_mem
    {Λ : Region GridNode} {inside : Region GridNode} {hInsideΛ : inside ⊆ Λ}
    (x : LocalAssignment GridNode Λ)
    (a : RegionAtom GridNode Λ)
    (ha : a.1 ∈ inside) :
    flipInsideLocalAssignment inside hInsideΛ x a = !x ⟨a.1, hInsideΛ ha⟩ := by
  simp [flipInsideLocalAssignment,
    Mettapedia.Logic.MarkovLogicInfiniteFixedRegionDLR.mergeAssignments,
    Mettapedia.Logic.MarkovLogicInfiniteFixedRegionDLR.restrictAssignment,
    spinFlipLocalAssignment, ha]

@[simp] theorem flipInsideLocalAssignment_apply_not_mem
    {Λ : Region GridNode} {inside : Region GridNode} {hInsideΛ : inside ⊆ Λ}
    (x : LocalAssignment GridNode Λ)
    (a : RegionAtom GridNode Λ)
    (ha : a.1 ∉ inside) :
    flipInsideLocalAssignment inside hInsideΛ x a = x a := by
  simp [flipInsideLocalAssignment,
    Mettapedia.Logic.MarkovLogicInfiniteFixedRegionDLR.mergeAssignments,
    Mettapedia.Logic.MarkovLogicInfiniteFixedRegionDLR.restrictOutsideAssignment, ha]

theorem flipInsideLocalAssignment_involutive
    {Λ : Region GridNode} (inside : Region GridNode) (hInsideΛ : inside ⊆ Λ)
    (x : LocalAssignment GridNode Λ) :
    flipInsideLocalAssignment inside hInsideΛ
        (flipInsideLocalAssignment inside hInsideΛ x) = x := by
  funext a
  by_cases ha : a.1 ∈ inside
  · simp [flipInsideLocalAssignment_apply_mem, ha]
  · simp [flipInsideLocalAssignment_apply_not_mem, ha]

theorem patch_flipInsideLocalAssignment_eq_not_of_mem
    {Λ : Region GridNode} {inside : Region GridNode} {hInsideΛ : inside ⊆ Λ}
    (x : LocalAssignment GridNode Λ) (ξ : BoundaryCondition GridNode)
    {a : GridNode} (ha : a ∈ inside) :
    patch Λ (flipInsideLocalAssignment inside hInsideΛ x) ξ a =
      !(patch Λ x ξ a) := by
  have haΛ : a ∈ Λ := hInsideΛ ha
  simp [patch, ha, haΛ, flipInsideLocalAssignment,
    Mettapedia.Logic.MarkovLogicInfiniteFixedRegionDLR.mergeAssignments,
    Mettapedia.Logic.MarkovLogicInfiniteFixedRegionDLR.restrictAssignment,
    spinFlipLocalAssignment]

theorem patch_flipInsideLocalAssignment_eq_of_not_mem
    {Λ : Region GridNode} {inside : Region GridNode} {hInsideΛ : inside ⊆ Λ}
    (x : LocalAssignment GridNode Λ) (ξ : BoundaryCondition GridNode)
    {a : GridNode} (ha : a ∉ inside) :
    patch Λ (flipInsideLocalAssignment inside hInsideΛ x) ξ a =
      patch Λ x ξ a := by
  by_cases haΛ : a ∈ Λ
  · simp [patch, ha, haΛ, flipInsideLocalAssignment,
      Mettapedia.Logic.MarkovLogicInfiniteFixedRegionDLR.mergeAssignments,
      Mettapedia.Logic.MarkovLogicInfiniteFixedRegionDLR.restrictOutsideAssignment]
  · simp [patch, haΛ]

/-- Local separator condition saying that a cut base clause sees a minus spin on
the inside side and a plus spin on the outside side, so flipping the inside
turns that disagreement into an agreement. -/
def symmetricGridBaseClauseFlipGainCondition
    {Λ : Region GridNode} (inside : Region GridNode) (_hInsideΛ : inside ⊆ Λ)
    (x : LocalAssignment GridNode Λ) (ξ : BoundaryCondition GridNode) :
    GridClauseId → Prop
  | .prior _ _ => False
  | .horizontal i j =>
      (((i, j) ∈ inside ∧ (i + 1, j) ∉ inside) ∧
          patch Λ x ξ (i, j) = false ∧
          patch Λ x ξ (i + 1, j) = true) ∨
        (((i, j) ∉ inside ∧ (i + 1, j) ∈ inside) ∧
          patch Λ x ξ (i, j) = true ∧
          patch Λ x ξ (i + 1, j) = false)
  | .vertical i j =>
      (((i, j) ∈ inside ∧ (i, j + 1) ∉ inside) ∧
          patch Λ x ξ (i, j) = false ∧
          patch Λ x ξ (i, j + 1) = true) ∨
        (((i, j) ∉ inside ∧ (i, j + 1) ∈ inside) ∧
          patch Λ x ξ (i, j) = true ∧
          patch Λ x ξ (i, j + 1) = false)

theorem symmetricGridBaseClauseFlipGainCondition_imp_cutsRegion
    {Λ : Region GridNode} {inside : Region GridNode} {hInsideΛ : inside ⊆ Λ}
    {x : LocalAssignment GridNode Λ} {ξ : BoundaryCondition GridNode}
    {j : GridClauseId}
    (hj : symmetricGridBaseClauseFlipGainCondition inside hInsideΛ x ξ j) :
    gridBaseClauseCutsRegion inside j := by
  cases j with
  | prior i j =>
      cases hj
  | horizontal i j =>
      rcases hj with h | h
      · exact Or.inl h.1
      · exact Or.inr h.1
  | vertical i j =>
      rcases hj with h | h
      · exact Or.inl h.1
      · exact Or.inr h.1

/-- Generic finite-region separator event: every inside spin is false, and every
cut clause sees a true spin on its outside endpoint. This is the honest event
shape behind the Peierls flip-gain route; corner separators are a special case. -/
def FalseInsideTrueCutBoundaryRegion
    {Λ : Region GridNode} (inside : Region GridNode) (_hInsideΛ : inside ⊆ Λ)
    (x : LocalAssignment GridNode Λ) (ξ : BoundaryCondition GridNode) : Prop :=
  (∀ a ∈ inside, patch Λ x ξ a = false) ∧
    (∀ j ∈ (gridRegionSupport Λ).filter (gridBaseClauseCutsRegion inside),
      match j with
      | .prior _ _ => True
      | .horizontal i j =>
          ((i, j) ∈ inside →
              patch Λ x ξ (i + 1, j) = true) ∧
            ((i + 1, j) ∈ inside →
              patch Λ x ξ (i, j) = true)
      | .vertical i j =>
          ((i, j) ∈ inside →
              patch Λ x ξ (i, j + 1) = true) ∧
            ((i, j + 1) ∈ inside →
              patch Λ x ξ (i, j) = true))

theorem falseInside_trueCutBoundaryRegion_imp_flipGainCondition
    {Λ : Region GridNode} {inside : Region GridNode} {hInsideΛ : inside ⊆ Λ}
    {x : LocalAssignment GridNode Λ} {ξ : BoundaryCondition GridNode}
    (hsep : FalseInsideTrueCutBoundaryRegion inside hInsideΛ x ξ) :
    ∀ j ∈ (gridRegionSupport Λ).filter (gridBaseClauseCutsRegion inside),
      symmetricGridBaseClauseFlipGainCondition inside hInsideΛ x ξ j := by
  intro j hj
  rcases hsep with ⟨hinsideFalse, hcutTrue⟩
  have hjcut : gridBaseClauseCutsRegion inside j := (Finset.mem_filter.mp hj).2
  have hout := hcutTrue j hj
  cases j with
  | prior i j =>
      cases hjcut
  | horizontal i j =>
      rcases hjcut with hcut | hcut
      · rcases hcut with ⟨hLeftIn, hRightOut⟩
        exact Or.inl
          ⟨⟨hLeftIn, hRightOut⟩, hinsideFalse _ hLeftIn, hout.1 hLeftIn⟩
      · rcases hcut with ⟨hLeftOut, hRightIn⟩
        exact Or.inr
          ⟨⟨hLeftOut, hRightIn⟩, hout.2 hRightIn, hinsideFalse _ hRightIn⟩
  | vertical i j =>
      rcases hjcut with hcut | hcut
      · rcases hcut with ⟨hDownIn, hUpOut⟩
        exact Or.inl
          ⟨⟨hDownIn, hUpOut⟩, hinsideFalse _ hDownIn, hout.1 hDownIn⟩
      · rcases hcut with ⟨hDownOut, hUpIn⟩
        exact Or.inr
          ⟨⟨hDownOut, hUpIn⟩, hout.2 hUpIn, hinsideFalse _ hUpIn⟩

/-- Concrete separator event for the future Peierls extraction route: every
inside spin is false, and every cut clause sees a true spin on its outside
endpoint. This is stronger than the clause-by-clause gain condition and is the
intended geometric target for extraction from an origin-down configuration. -/
def CornerSeparatorFalseInsideTrueCutBoundary
    {n : ℕ} (sep : CornerAxisSeparator n)
    (x : LocalAssignment GridNode (gridExhaustion.region n))
    (ξ : BoundaryCondition GridNode) : Prop :=
  FalseInsideTrueCutBoundaryRegion sep.inside sep.inside_subset x ξ

theorem cornerAxisSeparator_falseInside_trueCutBoundary_imp_flipGainCondition
    {n : ℕ} {sep : CornerAxisSeparator n}
    {x : LocalAssignment GridNode (gridExhaustion.region n)}
    {ξ : BoundaryCondition GridNode}
    (hsep : CornerSeparatorFalseInsideTrueCutBoundary sep x ξ) :
    ∀ j ∈ sep.cutBaseClauses,
      symmetricGridBaseClauseFlipGainCondition sep.inside sep.inside_subset x ξ j := by
  intro j hj
  exact falseInside_trueCutBoundaryRegion_imp_flipGainCondition hsep j (by
    simpa [CornerAxisSeparator.cutBaseClauses] using hj)

/-- The finite region of sites in the box whose patched spin is false. -/
noncomputable def patchedFalseRegion
    {Λ : Region GridNode}
    (x : LocalAssignment GridNode Λ) (ξ : BoundaryCondition GridNode) :
    Region GridNode :=
  Λ.filter (fun a => patch Λ x ξ a = false)

theorem patchedFalseRegion_subset
    {Λ : Region GridNode}
    (x : LocalAssignment GridNode Λ) (ξ : BoundaryCondition GridNode) :
    patchedFalseRegion x ξ ⊆ Λ := by
  intro a ha
  simpa [patchedFalseRegion] using (Finset.mem_filter.mp ha).1

theorem mem_patchedFalseRegion_iff
    {Λ : Region GridNode}
    (x : LocalAssignment GridNode Λ) (ξ : BoundaryCondition GridNode)
    (a : GridNode) :
    a ∈ patchedFalseRegion x ξ ↔ a ∈ Λ ∧ patch Λ x ξ a = false := by
  simp [patchedFalseRegion]

/-- Undirected nearest-neighbour adjacency in the quarter-plane grid. -/
def gridAdjacent : GridNode → GridNode → Prop
  | (i, j), (i', j') =>
      (i + 1 = i' ∧ j = j') ∨
        (i' + 1 = i ∧ j = j') ∨
        (i = i' ∧ j + 1 = j') ∨
        (i = i' ∧ j' + 1 = j)

theorem gridAdjacent_horizontal_forward (i j : ℕ) :
    gridAdjacent (i, j) (i + 1, j) := by
  exact Or.inl ⟨rfl, rfl⟩

theorem gridAdjacent_horizontal_backward (i j : ℕ) :
    gridAdjacent (i + 1, j) (i, j) := by
  exact Or.inr <| Or.inl ⟨rfl, rfl⟩

theorem gridAdjacent_vertical_forward (i j : ℕ) :
    gridAdjacent (i, j) (i, j + 1) := by
  exact Or.inr <| Or.inr <| Or.inl ⟨rfl, rfl⟩

theorem gridAdjacent_vertical_backward (i j : ℕ) :
    gridAdjacent (i, j + 1) (i, j) := by
  exact Or.inr <| Or.inr <| Or.inr ⟨rfl, rfl⟩

theorem gridAdjacent_symm {a b : GridNode} :
    gridAdjacent a b → gridAdjacent b a := by
  rcases a with ⟨i, j⟩
  rcases b with ⟨i', j'⟩
  intro h
  rcases h with h | h | h | h
  · exact Or.inr <| Or.inl ⟨h.1, h.2.symm⟩
  · exact Or.inl ⟨h.1, h.2.symm⟩
  · exact Or.inr <| Or.inr <| Or.inr ⟨h.1.symm, h.2⟩
  · exact Or.inr <| Or.inr <| Or.inl ⟨h.1.symm, h.2⟩

/-- The oriented base-clause id attached to an undirected nearest-neighbour
edge. For vertical edges we use the lower endpoint; for horizontal edges, the
left endpoint. -/
def gridAdjacentClauseId (a b : GridNode) : GridClauseId :=
  if _hcol : a.1 = b.1 then
    GridClauseId.vertical a.1 (min a.2 b.2)
  else
    GridClauseId.horizontal (min a.1 b.1) a.2

@[simp] theorem gridAdjacentClauseId_horizontal_forward (i j : ℕ) :
    gridAdjacentClauseId (i, j) (i + 1, j) = GridClauseId.horizontal i j := by
  simp [gridAdjacentClauseId]

@[simp] theorem gridAdjacentClauseId_horizontal_backward (i j : ℕ) :
    gridAdjacentClauseId (i + 1, j) (i, j) = GridClauseId.horizontal i j := by
  simp [gridAdjacentClauseId]

@[simp] theorem gridAdjacentClauseId_vertical_forward (i j : ℕ) :
    gridAdjacentClauseId (i, j) (i, j + 1) = GridClauseId.vertical i j := by
  simp [gridAdjacentClauseId]

@[simp] theorem gridAdjacentClauseId_vertical_backward (i j : ℕ) :
    gridAdjacentClauseId (i, j + 1) (i, j) = GridClauseId.vertical i j := by
  simp [gridAdjacentClauseId]

@[simp] theorem gridAdjacentClauseId_symm
    {a b : GridNode} (hab : gridAdjacent a b) :
    gridAdjacentClauseId a b = gridAdjacentClauseId b a := by
  rcases a with ⟨i, j⟩
  rcases b with ⟨i', j'⟩
  rcases hab with h | h | h | h
  · rcases h with ⟨hi, hj⟩
    subst hi
    subst hj
    simp [gridAdjacentClauseId]
  · rcases h with ⟨hi, hj⟩
    subst hi
    subst hj
    simp [gridAdjacentClauseId]
  · rcases h with ⟨hi, hj⟩
    subst hi
    subst hj
    simp [gridAdjacentClauseId]
  · rcases h with ⟨hi, hj⟩
    subst hi
    subst hj
    simp [gridAdjacentClauseId]

/-- The primal endpoints touched by a base clause. Priors touch one site but
never participate in cut boundaries. -/
noncomputable def gridClausePrimalEndpoints : GridClauseId → Finset GridNode
  | .prior i j => ({(i, j)} : Finset GridNode)
  | .horizontal i j => ({(i, j), (i + 1, j)} : Finset GridNode)
  | .vertical i j => ({(i, j), (i, j + 1)} : Finset GridNode)

theorem left_mem_gridClausePrimalEndpoints_gridAdjacentClauseId
    {a b : GridNode} (hab : gridAdjacent a b) :
    a ∈ gridClausePrimalEndpoints (gridAdjacentClauseId a b) := by
  rcases a with ⟨i, j⟩
  rcases b with ⟨i', j'⟩
  rcases hab with h | h | h | h <;> rcases h with ⟨hi, hj⟩ <;>
    subst hi <;> subst hj <;> simp [gridClausePrimalEndpoints]

theorem right_mem_gridClausePrimalEndpoints_gridAdjacentClauseId
    {a b : GridNode} (hab : gridAdjacent a b) :
    b ∈ gridClausePrimalEndpoints (gridAdjacentClauseId a b) := by
  rw [gridAdjacentClauseId_symm hab]
  exact left_mem_gridClausePrimalEndpoints_gridAdjacentClauseId (gridAdjacent_symm hab)

/-- The dual-lattice endpoints of a grid base clause. Horizontal clauses become
vertical dual edges and vertical clauses become horizontal dual edges. Priors
have no dual boundary content. -/
noncomputable def gridClauseDualEndpoints : GridClauseId → Finset GridNode
  | .prior _ _ => ∅
  | .horizontal i j => ({(i, j), (i, j + 1)} : Finset GridNode)
  | .vertical i j => ({(i, j), (i + 1, j)} : Finset GridNode)

/-- Two grid base clauses are dual-adjacent when their dual edges share a dual
endpoint. This is the natural contour adjacency for boundary cut sets. -/
def gridClauseDualAdjacent (j₁ j₂ : GridClauseId) : Prop :=
  ∃ p, p ∈ gridClauseDualEndpoints j₁ ∧ p ∈ gridClauseDualEndpoints j₂

theorem gridClauseDualAdjacent_symm
    {j₁ j₂ : GridClauseId} :
    gridClauseDualAdjacent j₁ j₂ → gridClauseDualAdjacent j₂ j₁ := by
  rintro ⟨p, hp₁, hp₂⟩
  exact ⟨p, hp₂, hp₁⟩

theorem reflTransGen_symm_of_symmetric
    {α : Type*} {R : α → α → Prop}
    (hR : Symmetric R) {a b : α}
    (hreach : Relation.ReflTransGen R a b) :
    Relation.ReflTransGen R b a := by
  induction hreach with
  | refl =>
      exact Relation.ReflTransGen.refl
  | @tail b c hreach hstep ih =>
      exact Relation.ReflTransGen.head (hR hstep) ih

theorem reflTransGen_gridClauseDualAdjacent_symm
    {j₁ j₂ : GridClauseId}
    (hreach : Relation.ReflTransGen gridClauseDualAdjacent j₁ j₂) :
    Relation.ReflTransGen gridClauseDualAdjacent j₂ j₁ := by
  exact reflTransGen_symm_of_symmetric
    (fun _ _ => gridClauseDualAdjacent_symm) hreach

theorem gridClauseDualAdjacent_self_of_mem_dualEndpoints
    {j : GridClauseId} {p : GridNode}
    (hp : p ∈ gridClauseDualEndpoints j) :
    gridClauseDualAdjacent j j :=
  ⟨p, hp, hp⟩

/-- Corner-inclusive adjacency on dual-lattice nodes. This is the `*`/king
adjacency used for Peierls contours at pinch points. -/
def gridNodeStarAdjacent (p q : GridNode) : Prop :=
  p.1 ≤ q.1 + 1 ∧ q.1 ≤ p.1 + 1 ∧ p.2 ≤ q.2 + 1 ∧ q.2 ≤ p.2 + 1

theorem gridNodeStarAdjacent_refl (p : GridNode) :
    gridNodeStarAdjacent p p := by
  rcases p with ⟨i, j⟩
  simp [gridNodeStarAdjacent]

theorem gridNodeStarAdjacent_symm
    {p q : GridNode} :
    gridNodeStarAdjacent p q → gridNodeStarAdjacent q p := by
  rintro ⟨h₁, h₂, h₃, h₄⟩
  exact ⟨h₂, h₁, h₄, h₃⟩

theorem gridNodeStarAdjacent_of_gridAdjacent
    {p q : GridNode} (hpq : gridAdjacent p q) :
    gridNodeStarAdjacent p q := by
  rcases p with ⟨i, j⟩
  rcases q with ⟨i', j'⟩
  rcases hpq with h | h | h | h <;>
    rcases h with ⟨hi, hj⟩ <;>
      subst hi <;> subst hj <;>
        simp [gridNodeStarAdjacent] <;> omega

theorem gridNodeStarAdjacent_of_gridAdjacent_origin
    {p q : GridNode}
    (hp : gridAdjacent p gridOrigin) (hq : gridAdjacent q gridOrigin) :
    gridNodeStarAdjacent p q := by
  rcases p with ⟨i, j⟩
  rcases q with ⟨i', j'⟩
  simp [gridOrigin, gridAdjacent, gridNodeStarAdjacent] at hp hq ⊢
  omega

theorem exists_gridAdjacent_common_center_star_bridge
    {p q r : GridNode}
    (hpr : gridAdjacent p r) (hqr : gridAdjacent q r) :
    ∃ t, gridAdjacent t r ∧
      gridNodeStarAdjacent p t ∧ gridNodeStarAdjacent t q := by
  by_cases hpq : gridNodeStarAdjacent p q
  · exact ⟨p, hpr, gridNodeStarAdjacent_refl p, hpq⟩
  · by_cases hsame : p.1 = q.1
    · refine ⟨(r.1 + 1, r.2), ?_, ?_, ?_⟩
      · exact gridAdjacent_horizontal_backward r.1 r.2
      · rcases p with ⟨pi, pj⟩
        rcases q with ⟨qi, qj⟩
        rcases r with ⟨ri, rj⟩
        simp [gridAdjacent, gridNodeStarAdjacent] at hpr hqr hpq hsame ⊢
        omega
      · rcases p with ⟨pi, pj⟩
        rcases q with ⟨qi, qj⟩
        rcases r with ⟨ri, rj⟩
        simp [gridAdjacent, gridNodeStarAdjacent] at hpr hqr hpq hsame ⊢
        omega
    · refine ⟨(r.1, r.2 + 1), ?_, ?_, ?_⟩
      · exact gridAdjacent_vertical_backward r.1 r.2
      · rcases p with ⟨pi, pj⟩
        rcases q with ⟨qi, qj⟩
        rcases r with ⟨ri, rj⟩
        simp [gridAdjacent, gridNodeStarAdjacent] at hpr hqr hpq hsame ⊢
        omega
      · rcases p with ⟨pi, pj⟩
        rcases q with ⟨qi, qj⟩
        rcases r with ⟨ri, rj⟩
        simp [gridAdjacent, gridNodeStarAdjacent] at hpr hqr hpq hsame ⊢
        omega

theorem reflTransGen_gridNodeStarAdjacent_of_common_gridAdjacent
    {p q r : GridNode}
    (hpr : gridAdjacent p r) (hqr : gridAdjacent q r) :
    Relation.ReflTransGen gridNodeStarAdjacent p q := by
  rcases exists_gridAdjacent_common_center_star_bridge hpr hqr with
    ⟨t, _htr, hpt, htq⟩
  exact Relation.ReflTransGen.tail
    (Relation.ReflTransGen.tail Relation.ReflTransGen.refl hpt) htq

/-- The four vertices around one elementary square of the grid. These are the
basic 4-cycles that generate the square-grid cycle space in the Timár boundary
connectivity route. -/
def gridBasicSquareVertices (i j : ℕ) : Finset GridNode :=
  ({(i, j), (i + 1, j), (i, j + 1), (i + 1, j + 1)} :
    Finset GridNode)

/-- The eight directed side-edges of one elementary square as a walk-like list. -/
def gridBasicSquareDirectedEdgeList (i j : ℕ) :
    List (GridNode × GridNode) :=
  [((i, j), (i + 1, j)), ((i + 1, j), (i, j)),
    ((i, j), (i, j + 1)), ((i, j + 1), (i, j)),
    ((i + 1, j), (i + 1, j + 1)),
    ((i + 1, j + 1), (i + 1, j)),
    ((i, j + 1), (i + 1, j + 1)),
    ((i + 1, j + 1), (i, j + 1))]

/-- The eight directed side-edges of one elementary square.  This is the local
carrier for the finite-box Timár parity argument: a hull/complement cut crosses
an elementary square in an even number of directed sides. -/
def gridBasicSquareDirectedEdges (i j : ℕ) :
    Finset (GridNode × GridNode) :=
  (gridBasicSquareDirectedEdgeList i j).toFinset

theorem mem_gridBasicSquareVertices_iff
    {i j : ℕ} {p : GridNode} :
    p ∈ gridBasicSquareVertices i j ↔
      p = (i, j) ∨ p = (i + 1, j) ∨
        p = (i, j + 1) ∨ p = (i + 1, j + 1) := by
  simp [gridBasicSquareVertices]

theorem mem_gridBasicSquareDirectedEdges_iff
    {i j : ℕ} {e : GridNode × GridNode} :
    e ∈ gridBasicSquareDirectedEdges i j ↔
      e = ((i, j), (i + 1, j)) ∨
      e = ((i + 1, j), (i, j)) ∨
      e = ((i, j), (i, j + 1)) ∨
      e = ((i, j + 1), (i, j)) ∨
      e = ((i + 1, j), (i + 1, j + 1)) ∨
      e = ((i + 1, j + 1), (i + 1, j)) ∨
      e = ((i, j + 1), (i + 1, j + 1)) ∨
      e = ((i + 1, j + 1), (i, j + 1)) := by
  simp [gridBasicSquareDirectedEdges, gridBasicSquareDirectedEdgeList]

theorem mem_gridBasicSquareDirectedEdges_iff_vertices_adjacent
    {i j : ℕ} {e : GridNode × GridNode} :
    e ∈ gridBasicSquareDirectedEdges i j ↔
      e.1 ∈ gridBasicSquareVertices i j ∧
        e.2 ∈ gridBasicSquareVertices i j ∧ gridAdjacent e.1 e.2 := by
  constructor
  · intro he
    rw [mem_gridBasicSquareDirectedEdges_iff] at he
    rcases he with rfl | rfl | rfl | rfl | rfl | rfl | rfl | rfl <;>
      simp [gridBasicSquareVertices, gridAdjacent]
  · rcases e with ⟨a, b⟩
    rintro ⟨hleft, hright, hadj⟩
    rw [mem_gridBasicSquareDirectedEdges_iff]
    rw [mem_gridBasicSquareVertices_iff] at hleft hright
    rcases hleft with rfl | rfl | rfl | rfl <;>
      rcases hright with rfl | rfl | rfl | rfl <;>
      simp [gridAdjacent] at hadj ⊢

theorem gridBasicSquareDirectedEdgeList_crossing_length_even
    (inside : Region GridNode) (i j : ℕ) :
    Even
      ((gridBasicSquareDirectedEdgeList i j).filter
        (fun e => e.1 ∈ inside ∧ e.2 ∉ inside)).length := by
  classical
  by_cases h00 : ((i, j) ∈ inside) <;>
    by_cases h10 : ((i + 1, j) ∈ inside) <;>
    by_cases h01 : ((i, j + 1) ∈ inside) <;>
    by_cases h11 : ((i + 1, j + 1) ∈ inside) <;>
    norm_num [gridBasicSquareDirectedEdgeList, h00, h10, h01, h11]

theorem gridBasicSquareDirectedEdges_crossing_card_even
    (inside : Region GridNode) (i j : ℕ) :
    Even
      ((gridBasicSquareDirectedEdges i j).filter
        (fun e => e.1 ∈ inside ∧ e.2 ∉ inside)).card := by
  classical
  have hnodup :
      ((gridBasicSquareDirectedEdgeList i j).filter
        (fun e => e.1 ∈ inside ∧ e.2 ∉ inside)).Nodup := by
    apply List.Nodup.filter
    simp [gridBasicSquareDirectedEdgeList]
  have hcard :
      ((gridBasicSquareDirectedEdges i j).filter
        (fun e => e.1 ∈ inside ∧ e.2 ∉ inside)).card =
        ((gridBasicSquareDirectedEdgeList i j).filter
          (fun e => e.1 ∈ inside ∧ e.2 ∉ inside)).length := by
    rw [gridBasicSquareDirectedEdges]
    simpa [List.toFinset_filter, hnodup] using
      (List.toFinset_card_of_nodup (l :=
        (gridBasicSquareDirectedEdgeList i j).filter
          (fun e => e.1 ∈ inside ∧ e.2 ∉ inside)) hnodup)
  rw [hcard]
  exact gridBasicSquareDirectedEdgeList_crossing_length_even inside i j

/-- The mod-2 indicator of an undirected grid edge represented by a directed
edge set. -/
noncomputable def edgeBit
    (C : Finset (GridNode × GridNode)) (a b : GridNode) : ZMod 2 :=
  if (a, b) ∈ C ∨ (b, a) ∈ C then 1 else 0

theorem edgeBit_symm
    (C : Finset (GridNode × GridNode)) (a b : GridNode) :
    edgeBit C a b = edgeBit C b a := by
  by_cases h : (a, b) ∈ C ∨ (b, a) ∈ C
  · have h' : (b, a) ∈ C ∨ (a, b) ∈ C := by
      exact h.elim Or.inr Or.inl
    simp [edgeBit, h, h']
  · have h' : ¬ ((b, a) ∈ C ∨ (a, b) ∈ C) := by
      intro hba
      exact h (hba.elim Or.inr Or.inl)
    simp [edgeBit, h, h']

theorem edgeBit_eq_one_of_mem_left
    {C : Finset (GridNode × GridNode)} {a b : GridNode}
    (h : (a, b) ∈ C) :
    edgeBit C a b = 1 := by
  simp [edgeBit, h]

theorem edgeBit_eq_one_of_mem_right
    {C : Finset (GridNode × GridNode)} {a b : GridNode}
    (h : (b, a) ∈ C) :
    edgeBit C a b = 1 := by
  simp [edgeBit, h]

theorem edgeBit_eq_zero_of_not_mem
    {C : Finset (GridNode × GridNode)} {a b : GridNode}
    (hab : (a, b) ∉ C) (hba : (b, a) ∉ C) :
    edgeBit C a b = 0 := by
  simp [edgeBit, hab, hba]

/-- The two directed orientations of one undirected edge. -/
def undirectedEdgePair (a b : GridNode) : Finset (GridNode × GridNode) :=
  ({(a, b), (b, a)} : Finset (GridNode × GridNode))

theorem gridBasicSquareDirectedEdges_eq_undirectedEdgePair_union
    (i j : ℕ) :
    gridBasicSquareDirectedEdges i j =
      undirectedEdgePair (i, j) (i + 1, j) ∪
        undirectedEdgePair (i + 1, j) (i + 1, j + 1) ∪
          undirectedEdgePair (i + 1, j + 1) (i, j + 1) ∪
            undirectedEdgePair (i, j + 1) (i, j) := by
  ext e
  simp [gridBasicSquareDirectedEdges, gridBasicSquareDirectedEdgeList,
    undirectedEdgePair]
  tauto

theorem gridBasicSquare_undirectedEdgePair_disjoint₁₂
    (i j : ℕ) :
    Disjoint
      (undirectedEdgePair (i, j) (i + 1, j))
      (undirectedEdgePair (i + 1, j) (i + 1, j + 1)) := by
  rw [Finset.disjoint_left]
  intro e he ht
  simp [undirectedEdgePair] at he ht
  rcases he with rfl | rfl <;> simp at ht

theorem gridBasicSquare_undirectedEdgePair_disjoint₁₃
    (i j : ℕ) :
    Disjoint
      (undirectedEdgePair (i, j) (i + 1, j))
      (undirectedEdgePair (i + 1, j + 1) (i, j + 1)) := by
  rw [Finset.disjoint_left]
  intro e he ht
  simp [undirectedEdgePair] at he ht
  rcases he with rfl | rfl <;> simp at ht

theorem gridBasicSquare_undirectedEdgePair_disjoint₁₄
    (i j : ℕ) :
    Disjoint
      (undirectedEdgePair (i, j) (i + 1, j))
      (undirectedEdgePair (i, j + 1) (i, j)) := by
  rw [Finset.disjoint_left]
  intro e he ht
  simp [undirectedEdgePair] at he ht
  rcases he with rfl | rfl <;> simp at ht

theorem gridBasicSquare_undirectedEdgePair_disjoint₂₃
    (i j : ℕ) :
    Disjoint
      (undirectedEdgePair (i + 1, j) (i + 1, j + 1))
      (undirectedEdgePair (i + 1, j + 1) (i, j + 1)) := by
  rw [Finset.disjoint_left]
  intro e he ht
  simp [undirectedEdgePair] at he ht
  rcases he with rfl | rfl <;> simp at ht

theorem gridBasicSquare_undirectedEdgePair_disjoint₂₄
    (i j : ℕ) :
    Disjoint
      (undirectedEdgePair (i + 1, j) (i + 1, j + 1))
      (undirectedEdgePair (i, j + 1) (i, j)) := by
  rw [Finset.disjoint_left]
  intro e he ht
  simp [undirectedEdgePair] at he ht
  rcases he with rfl | rfl <;> simp at ht

theorem gridBasicSquare_undirectedEdgePair_disjoint₃₄
    (i j : ℕ) :
    Disjoint
      (undirectedEdgePair (i + 1, j + 1) (i, j + 1))
      (undirectedEdgePair (i, j + 1) (i, j)) := by
  rw [Finset.disjoint_left]
  intro e he ht
  simp [undirectedEdgePair] at he ht
  rcases he with rfl | rfl <;> simp at ht

theorem gridBasicSquareDirectedEdges_filter_card_eq_sidePair_filter_card_sum
    (C : Finset (GridNode × GridNode)) (i j : ℕ) :
    (C.filter (fun e => e ∈ gridBasicSquareDirectedEdges i j)).card =
      ((undirectedEdgePair (i, j) (i + 1, j)).filter
          (fun e => e ∈ C)).card +
        ((undirectedEdgePair (i + 1, j) (i + 1, j + 1)).filter
          (fun e => e ∈ C)).card +
          ((undirectedEdgePair (i + 1, j + 1) (i, j + 1)).filter
            (fun e => e ∈ C)).card +
            ((undirectedEdgePair (i, j + 1) (i, j)).filter
              (fun e => e ∈ C)).card := by
  classical
  let s₁ := undirectedEdgePair (i, j) (i + 1, j)
  let s₂ := undirectedEdgePair (i + 1, j) (i + 1, j + 1)
  let s₃ := undirectedEdgePair (i + 1, j + 1) (i, j + 1)
  let s₄ := undirectedEdgePair (i, j + 1) (i, j)
  let P : GridNode × GridNode → Prop := fun e => e ∈ C
  have hfilter :
      C.filter (fun e => e ∈ gridBasicSquareDirectedEdges i j) =
        (((s₁ ∪ s₂) ∪ s₃) ∪ s₄).filter P := by
    ext e
    simp [P, s₁, s₂, s₃, s₄, gridBasicSquareDirectedEdges,
      gridBasicSquareDirectedEdgeList, undirectedEdgePair, and_comm]
    tauto
  have h₁₂ : Disjoint (s₁.filter P) (s₂.filter P) :=
    Finset.disjoint_filter_filter
      (by
        simpa [s₁, s₂] using
          gridBasicSquare_undirectedEdgePair_disjoint₁₂ i j)
  have h₁₃ : Disjoint (s₁.filter P) (s₃.filter P) :=
    Finset.disjoint_filter_filter
      (by
        simpa [s₁, s₃] using
          gridBasicSquare_undirectedEdgePair_disjoint₁₃ i j)
  have h₁₄ : Disjoint (s₁.filter P) (s₄.filter P) :=
    Finset.disjoint_filter_filter
      (by
        simpa [s₁, s₄] using
          gridBasicSquare_undirectedEdgePair_disjoint₁₄ i j)
  have h₂₃ : Disjoint (s₂.filter P) (s₃.filter P) :=
    Finset.disjoint_filter_filter
      (by
        simpa [s₂, s₃] using
          gridBasicSquare_undirectedEdgePair_disjoint₂₃ i j)
  have h₂₄ : Disjoint (s₂.filter P) (s₄.filter P) :=
    Finset.disjoint_filter_filter
      (by
        simpa [s₂, s₄] using
          gridBasicSquare_undirectedEdgePair_disjoint₂₄ i j)
  have h₃₄ : Disjoint (s₃.filter P) (s₄.filter P) :=
    Finset.disjoint_filter_filter
      (by
        simpa [s₃, s₄] using
          gridBasicSquare_undirectedEdgePair_disjoint₃₄ i j)
  have h₁₂₃ : Disjoint ((s₁.filter P ∪ s₂.filter P)) (s₃.filter P) := by
    rw [Finset.disjoint_union_left]
    exact ⟨h₁₃, h₂₃⟩
  have h₁₂₄ : Disjoint ((s₁.filter P ∪ s₂.filter P)) (s₄.filter P) := by
    rw [Finset.disjoint_union_left]
    exact ⟨h₁₄, h₂₄⟩
  have h₁₂₃₄ :
      Disjoint (((s₁.filter P ∪ s₂.filter P) ∪ s₃.filter P))
        (s₄.filter P) := by
    rw [Finset.disjoint_union_left]
    exact ⟨h₁₂₄, h₃₄⟩
  rw [hfilter]
  calc
    ((((s₁ ∪ s₂) ∪ s₃) ∪ s₄).filter P).card
        = (((s₁.filter P ∪ s₂.filter P) ∪ s₃.filter P) ∪
            s₄.filter P).card := by
          simp [Finset.filter_union]
    _ = ((s₁.filter P ∪ s₂.filter P) ∪ s₃.filter P).card +
          (s₄.filter P).card := by
          exact Finset.card_union_of_disjoint h₁₂₃₄
    _ = (s₁.filter P ∪ s₂.filter P).card +
          (s₃.filter P).card + (s₄.filter P).card := by
          rw [Finset.card_union_of_disjoint h₁₂₃]
    _ = (s₁.filter P).card + (s₂.filter P).card +
          (s₃.filter P).card + (s₄.filter P).card := by
          rw [Finset.card_union_of_disjoint h₁₂]

theorem undirectedEdgePair_filter_eq_left_of_mem
    {C : Finset (GridNode × GridNode)} {a b : GridNode}
    (hab : (a, b) ∈ C) (hba : (b, a) ∉ C) :
    (undirectedEdgePair a b).filter (fun e => e ∈ C) =
      ({(a, b)} : Finset (GridNode × GridNode)) := by
  ext e
  constructor
  · intro he
    simp [undirectedEdgePair] at he ⊢
    rcases he with ⟨heq | heq, heC⟩
    · exact heq
    · exact False.elim (hba (by simpa [heq] using heC))
  · intro he
    simp [undirectedEdgePair] at he ⊢
    exact ⟨Or.inl he, by simpa [he] using hab⟩

theorem undirectedEdgePair_filter_eq_right_of_mem
    {C : Finset (GridNode × GridNode)} {a b : GridNode}
    (hab : (a, b) ∉ C) (hba : (b, a) ∈ C) :
    (undirectedEdgePair a b).filter (fun e => e ∈ C) =
      ({(b, a)} : Finset (GridNode × GridNode)) := by
  ext e
  constructor
  · intro he
    simp [undirectedEdgePair] at he ⊢
    rcases he with ⟨heq | heq, heC⟩
    · exact False.elim (hab (by simpa [heq] using heC))
    · exact heq
  · intro he
    simp [undirectedEdgePair] at he ⊢
    exact ⟨Or.inr he, by simpa [he] using hba⟩

theorem undirectedEdgePair_filter_eq_empty_of_not_mem
    {C : Finset (GridNode × GridNode)} {a b : GridNode}
    (hab : (a, b) ∉ C) (hba : (b, a) ∉ C) :
    (undirectedEdgePair a b).filter (fun e => e ∈ C) =
      (∅ : Finset (GridNode × GridNode)) := by
  ext e
  constructor
  · intro he
    simp [undirectedEdgePair] at he
    rcases he with ⟨heq | heq, heC⟩
    · exact False.elim (hab (by simpa [heq] using heC))
    · exact False.elim (hba (by simpa [heq] using heC))
  · intro he
    simp at he

theorem edgeBit_eq_undirectedEdgePair_filter_card
    {C : Finset (GridNode × GridNode)}
    (hNoReverse : ∀ e ∈ C, (e.2, e.1) ∉ C)
    {a b : GridNode} :
    edgeBit C a b =
      (((undirectedEdgePair a b).filter
        (fun e => e ∈ C)).card : ZMod 2) := by
  classical
  by_cases hab : (a, b) ∈ C
  · have hba : (b, a) ∉ C := hNoReverse _ hab
    rw [edgeBit_eq_one_of_mem_left hab,
      undirectedEdgePair_filter_eq_left_of_mem hab hba]
    simp
  · by_cases hba : (b, a) ∈ C
    · rw [edgeBit_eq_one_of_mem_right hba,
        undirectedEdgePair_filter_eq_right_of_mem hab hba]
      simp
    · rw [edgeBit_eq_zero_of_not_mem hab hba,
        undirectedEdgePair_filter_eq_empty_of_not_mem hab hba]
      simp

/-- A mod-2 edge field is square-even in the stage box when its four undirected
side bits around every elementary square in the box sum to zero. -/
def squareEvenBits (m : ℕ) (C : Finset (GridNode × GridNode)) : Prop :=
  ∀ i j, i < m → j < m →
    edgeBit C (i, j) (i + 1, j) +
      edgeBit C (i + 1, j) (i + 1, j + 1) +
        edgeBit C (i + 1, j + 1) (i, j + 1) +
          edgeBit C (i, j + 1) (i, j) = 0

theorem squareEvenBits_empty (m : ℕ) :
    squareEvenBits m (∅ : Finset (GridNode × GridNode)) := by
  intro i j _hi _hj
  simp [edgeBit]

theorem squareEvenBits_of_basicSquare_card_even
    {m : ℕ} {C : Finset (GridNode × GridNode)}
    (hNoReverse : ∀ e ∈ C, (e.2, e.1) ∉ C)
    (hEven :
      ∀ i j, i < m → j < m →
        Even ((C.filter
          (fun e => e ∈ gridBasicSquareDirectedEdges i j)).card)) :
    squareEvenBits m C := by
  intro i j hi hj
  have hcardNat :=
    gridBasicSquareDirectedEdges_filter_card_eq_sidePair_filter_card_sum C i j
  have hcardZ :
      (((C.filter
          (fun e => e ∈ gridBasicSquareDirectedEdges i j)).card : ℕ) :
          ZMod 2) =
        (((undirectedEdgePair (i, j) (i + 1, j)).filter
          (fun e => e ∈ C)).card : ZMod 2) +
          (((undirectedEdgePair (i + 1, j) (i + 1, j + 1)).filter
            (fun e => e ∈ C)).card : ZMod 2) +
            (((undirectedEdgePair (i + 1, j + 1) (i, j + 1)).filter
              (fun e => e ∈ C)).card : ZMod 2) +
              (((undirectedEdgePair (i, j + 1) (i, j)).filter
                (fun e => e ∈ C)).card : ZMod 2) := by
    rw [hcardNat]
    simp
  rcases hEven i j hi hj with ⟨k, hk⟩
  have hcast :
      (((C.filter
          (fun e => e ∈ gridBasicSquareDirectedEdges i j)).card : ℕ) :
          ZMod 2) = 0 := by
    rw [hk]
    have htwo : (2 : ZMod 2) = 0 := by
      simpa using (ZMod.natCast_self 2)
    ring_nf
    simp [htwo]
  rw [hcardZ] at hcast
  rw [edgeBit_eq_undirectedEdgePair_filter_card hNoReverse,
    edgeBit_eq_undirectedEdgePair_filter_card hNoReverse,
    edgeBit_eq_undirectedEdgePair_filter_card hNoReverse,
    edgeBit_eq_undirectedEdgePair_filter_card hNoReverse]
  exact hcast

/-- Canonical bottom-row-then-column potential for a mod-2 edge field. -/
noncomputable def stagePotential
    (C : Finset (GridNode × GridNode)) (p : GridNode) : ZMod 2 :=
  (Finset.range p.1).sum
      (fun u => edgeBit C (u, 0) (u + 1, 0)) +
    (Finset.range p.2).sum
      (fun v => edgeBit C (p.1, v) (p.1, v + 1))

theorem edgeBit_eq_stagePotential_add_vertical_succ
    (C : Finset (GridNode × GridNode)) (x y : ℕ) :
    edgeBit C (x, y) (x, y + 1) =
      stagePotential C (x, y) + stagePotential C (x, y + 1) := by
  simp [stagePotential, Finset.sum_range_succ, add_left_comm, add_comm]
  ring_nf
  have htwo : (2 : ZMod 2) = 0 := by
    simpa using (ZMod.natCast_self 2)
  simp [htwo]

theorem edgeBit_eq_stagePotential_add_vertical_pred
    (C : Finset (GridNode × GridNode)) (x y : ℕ) :
    edgeBit C (x, y + 1) (x, y) =
      stagePotential C (x, y + 1) + stagePotential C (x, y) := by
  rw [edgeBit_symm]
  rw [edgeBit_eq_stagePotential_add_vertical_succ]
  abel

theorem edgeBit_eq_stagePotential_add_horizontal_base
    (C : Finset (GridNode × GridNode)) (x : ℕ) :
    edgeBit C (x, 0) (x + 1, 0) =
      stagePotential C (x, 0) + stagePotential C (x + 1, 0) := by
  simp [stagePotential, Finset.sum_range_succ, add_left_comm, add_comm]
  ring_nf
  have htwo : (2 : ZMod 2) = 0 := by
    simpa using (ZMod.natCast_self 2)
  simp [htwo]

theorem edgeBit_eq_stagePotential_add_horizontal_succ_of_squareEven
    {m : ℕ} {C : Finset (GridNode × GridNode)}
    (hEven : squareEvenBits m C) {x y : ℕ}
    (hx : x < m) (hy : y < m)
    (hgrad :
      edgeBit C (x, y) (x + 1, y) =
        stagePotential C (x, y) + stagePotential C (x + 1, y)) :
    edgeBit C (x, y + 1) (x + 1, y + 1) =
      stagePotential C (x, y + 1) +
        stagePotential C (x + 1, y + 1) := by
  have hsq := hEven x y hx hy
  rw [edgeBit_symm C (x + 1, y + 1) (x, y + 1),
    edgeBit_symm C (x, y + 1) (x, y)] at hsq
  have hleft := edgeBit_eq_stagePotential_add_vertical_succ C x y
  have hright := edgeBit_eq_stagePotential_add_vertical_succ C (x + 1) y
  have htwo : (2 : ZMod 2) = 0 := by
    simpa using (ZMod.natCast_self 2)
  calc
    edgeBit C (x, y + 1) (x + 1, y + 1)
        = edgeBit C (x, y + 1) (x + 1, y + 1) +
            (edgeBit C (x, y) (x + 1, y) +
              edgeBit C (x + 1, y) (x + 1, y + 1) +
                edgeBit C (x, y + 1) (x + 1, y + 1) +
                  edgeBit C (x, y) (x, y + 1)) := by
          simp [hsq]
    _ = stagePotential C (x, y + 1) +
          stagePotential C (x + 1, y + 1) := by
          rw [hgrad, hleft, hright]
          ring_nf
          simp [htwo]

theorem edgeBit_eq_stagePotential_add_horizontal_of_squareEven
    {m : ℕ} {C : Finset (GridNode × GridNode)}
    (hEven : squareEvenBits m C) {x y : ℕ}
    (hx : x < m) (hy : y ≤ m) :
    edgeBit C (x, y) (x + 1, y) =
      stagePotential C (x, y) + stagePotential C (x + 1, y) := by
  induction y with
  | zero =>
      exact edgeBit_eq_stagePotential_add_horizontal_base C x
  | succ y ih =>
      have hyPred : y ≤ m := by omega
      have hyLt : y < m := by omega
      exact
        edgeBit_eq_stagePotential_add_horizontal_succ_of_squareEven
          hEven hx hyLt (ih hyPred)

theorem edgeBit_eq_potential_add_of_squareEven
    {m : ℕ} {C : Finset (GridNode × GridNode)}
    (hEven : squareEvenBits m C)
    {a b : GridNode}
    (ha : a ∈ gridExhaustion.region m)
    (hb : b ∈ gridExhaustion.region m)
    (hab : gridAdjacent a b) :
    edgeBit C a b = stagePotential C a + stagePotential C b := by
  rcases a with ⟨i, j⟩
  rcases b with ⟨i', j'⟩
  rcases hab with h | h | h | h
  · rcases h with ⟨hi, hj⟩
    subst i'
    subst j'
    have hx : i < m := by
      rcases Finset.mem_product.1 hb with ⟨hiStage, _hjStage⟩
      have hiLt : i + 1 < m + 1 := Finset.mem_range.1 hiStage
      omega
    have hy : j ≤ m := by
      rcases Finset.mem_product.1 ha with ⟨_hiStage, hjStage⟩
      have hjLt : j < m + 1 := Finset.mem_range.1 hjStage
      omega
    exact edgeBit_eq_stagePotential_add_horizontal_of_squareEven
      hEven hx hy
  · rcases h with ⟨hi, hj⟩
    subst i
    subst j'
    have hx : i' < m := by
      rcases Finset.mem_product.1 ha with ⟨hiStage, _hjStage⟩
      have hiLt : i' + 1 < m + 1 := Finset.mem_range.1 hiStage
      omega
    have hy : j ≤ m := by
      rcases Finset.mem_product.1 hb with ⟨_hiStage, hjStage⟩
      have hjLt : j < m + 1 := Finset.mem_range.1 hjStage
      omega
    rw [edgeBit_symm C (i' + 1, j) (i', j)]
    rw [edgeBit_eq_stagePotential_add_horizontal_of_squareEven
      hEven hx hy]
    abel
  · rcases h with ⟨hi, hj⟩
    subst i'
    subst j'
    exact edgeBit_eq_stagePotential_add_vertical_succ C i j
  · rcases h with ⟨hi, hj⟩
    subst i'
    subst j
    exact edgeBit_eq_stagePotential_add_vertical_pred C i j'

/-- Mod-2 crossing count of a list walk. Singleton and empty walks cross
nothing; longer walks add the bit of their first step. -/
noncomputable def walkCrossBit
    (C : Finset (GridNode × GridNode)) : List GridNode → ZMod 2
  | [] => 0
  | [_] => 0
  | a :: b :: rest => edgeBit C a b + walkCrossBit C (b :: rest)

theorem walkCrossBit_eq_endpoint_potential_cons
    {m : ℕ} {C : Finset (GridNode × GridNode)}
    (hEven : squareEvenBits m C) :
    ∀ {start : GridNode} {tail : List GridNode},
      (∀ p ∈ start :: tail, p ∈ gridExhaustion.region m) →
      List.IsChain gridAdjacent (start :: tail) →
      walkCrossBit C (start :: tail) =
        stagePotential C start +
          stagePotential C ((start :: tail).getLast (by simp)) := by
  intro start tail
  induction tail generalizing start with
  | nil =>
      intro _hstage _hchain
      simp [walkCrossBit]
      ring_nf
      have htwo : (2 : ZMod 2) = 0 := by
        simpa using (ZMod.natCast_self 2)
      simp [htwo]
  | cons next rest ih =>
      intro hstage hchain
      have hstart : start ∈ gridExhaustion.region m := hstage start (by simp)
      have hnext : next ∈ gridExhaustion.region m := hstage next (by simp)
      have htailStage :
          ∀ p ∈ next :: rest, p ∈ gridExhaustion.region m := by
        intro p hp
        exact hstage p (by simp [hp])
      have hchainPair := (List.isChain_cons_cons.mp hchain)
      have hstep : gridAdjacent start next := hchainPair.1
      have htailChain : List.IsChain gridAdjacent (next :: rest) :=
        hchainPair.2
      have htail := ih htailStage htailChain
      rw [walkCrossBit]
      rw [List.getLast_cons_cons]
      rw [htail]
      rw [edgeBit_eq_potential_add_of_squareEven
        hEven hstart hnext hstep]
      ring_nf
      have htwo : (2 : ZMod 2) = 0 := by
        simpa using (ZMod.natCast_self 2)
      simp [htwo]

theorem walkCrossBit_eq_of_same_endpoints_cons
    {m : ℕ} {C : Finset (GridNode × GridNode)}
    (hEven : squareEvenBits m C)
    {start : GridNode} {tail₁ tail₂ : List GridNode}
    (hstage₁ : ∀ p ∈ start :: tail₁, p ∈ gridExhaustion.region m)
    (hchain₁ : List.IsChain gridAdjacent (start :: tail₁))
    (hstage₂ : ∀ p ∈ start :: tail₂, p ∈ gridExhaustion.region m)
    (hchain₂ : List.IsChain gridAdjacent (start :: tail₂))
    (hend :
      (start :: tail₁).getLast (by simp) =
        (start :: tail₂).getLast (by simp)) :
    walkCrossBit C (start :: tail₁) =
      walkCrossBit C (start :: tail₂) := by
  rw [walkCrossBit_eq_endpoint_potential_cons hEven hstage₁ hchain₁]
  rw [walkCrossBit_eq_endpoint_potential_cons hEven hstage₂ hchain₂]
  rw [hend]

theorem walkCrossBit_append_cons_of_getLast
    (C : Finset (GridNode × GridNode)) :
    ∀ {left : List GridNode} {a b : GridNode} {right : List GridNode},
      left.getLast? = some a →
      walkCrossBit C (left ++ (b :: right)) =
        walkCrossBit C left + edgeBit C a b +
          walkCrossBit C (b :: right) := by
  intro left
  induction left with
  | nil =>
      intro a b right hlast
      simp at hlast
  | cons x xs ih =>
      cases xs with
      | nil =>
          intro a b right hlast
          simp at hlast
          subst hlast
          simp [walkCrossBit]
      | cons y ys =>
          intro a b right hlast
          have htailLast : (y :: ys).getLast? = some a := by
            simpa [List.getLast?_cons] using hlast
          rw [List.cons_append]
          change edgeBit C x y +
              walkCrossBit C ((y :: ys) ++ (b :: right)) =
            edgeBit C x y + walkCrossBit C (y :: ys) +
              edgeBit C a b + walkCrossBit C (b :: right)
          rw [ih htailLast]
          abel

theorem walkCrossBit_append_singleton_of_getLast
    (C : Finset (GridNode × GridNode))
    {left : List GridNode} {a b : GridNode}
    (hlast : left.getLast? = some a) :
    walkCrossBit C (left ++ [b]) =
      walkCrossBit C left + edgeBit C a b := by
  rw [walkCrossBit_append_cons_of_getLast C hlast]
  simp [walkCrossBit]

theorem list_isChain_append_cons_of_getLast
    {α : Type*} {R : α → α → Prop}
    {left : List α} {a b : α} {right : List α}
    (hleft : List.IsChain R left)
    (hright : List.IsChain R (a :: b :: right))
    (hlast : left.getLast? = some a) :
    List.IsChain R (left ++ (b :: right)) := by
  rw [List.isChain_append]
  refine ⟨hleft, (List.isChain_cons_cons.mp hright).2, ?_⟩
  intro x hx y hy
  simp at hy
  subst hy
  have hax : a = x := by
    simpa [hlast] using hx
  subst hax
  exact (List.isChain_cons_cons.mp hright).1

theorem list_isChain_append_singleton_of_getLast
    {α : Type*} {R : α → α → Prop}
    {left : List α} {a b : α}
    (hleft : List.IsChain R left)
    (hab : R a b)
    (hlast : left.getLast? = some a) :
    List.IsChain R (left ++ [b]) := by
  exact list_isChain_append_cons_of_getLast
    hleft
    ((List.isChain_cons_cons).2
      ⟨hab, List.IsChain.singleton b⟩)
    hlast

theorem exists_list_walk_of_reflTransGen
    {α : Type*} {R : α → α → Prop} {a b : α}
    (h : Relation.ReflTransGen R a b) :
    ∃ walk : List α,
      walk.head? = some a ∧ walk.getLast? = some b ∧
        List.IsChain R walk := by
  induction h with
  | refl =>
      exact ⟨[a], by simp, by simp, List.IsChain.singleton a⟩
  | @tail x y _hprev hstep ih =>
      rcases ih with ⟨walk, hhead, hlast, hchain⟩
      refine ⟨walk ++ [y], ?_, ?_, ?_⟩
      · cases walk with
        | nil =>
            simp at hhead
        | cons _z _zs =>
            simpa using hhead
      · simp
      · rw [List.isChain_append]
        refine ⟨hchain, List.IsChain.singleton y, ?_⟩
        intro u hu v hv
        simp at hv
        subst hv
        have hxu : x = u := by
          simpa [hlast] using hu
        subst hxu
        exact hstep

theorem exists_list_walk_of_reflTransGen_with_mem
    {α : Type*} {R : α → α → Prop} {P : α → Prop}
    {a b : α}
    (ha : P a)
    (hRmem : ∀ {x y : α}, R x y → P x ∧ P y)
    (h : Relation.ReflTransGen R a b) :
    ∃ walk : List α,
      walk.head? = some a ∧ walk.getLast? = some b ∧
        List.IsChain R walk ∧ ∀ p ∈ walk, P p := by
  induction h with
  | refl =>
      exact ⟨[a], by simp, by simp, List.IsChain.singleton a,
        by
          intro p hp
          simp at hp
          subst hp
          exact ha⟩
  | @tail x y _hprev hstep ih =>
      rcases ih with ⟨walk, hhead, hlast, hchain, hmem⟩
      refine ⟨walk ++ [y], ?_, ?_, ?_, ?_⟩
      · cases walk with
        | nil =>
            simp at hhead
        | cons _z _zs =>
            simpa using hhead
      · simp
      · rw [List.isChain_append]
        refine ⟨hchain, List.IsChain.singleton y, ?_⟩
        intro u hu v hv
        simp at hv
        subst hv
        have hxu : x = u := by
          simpa [hlast] using hu
        subst hxu
        exact hstep
      · intro p hp
        rw [List.mem_append] at hp
        rcases hp with hp | hp
        · exact hmem p hp
        · simp at hp
          subst hp
          exact (hRmem hstep).2

theorem exists_ne_mem_of_even_filter_card_of_mem
    {α : Type*} [DecidableEq α] {s : Finset α}
    {P : α → Prop} [DecidablePred P] {a : α}
    (ha : a ∈ s) (hPa : P a)
    (heven : Even (s.filter P).card) :
    ∃ b ∈ s, P b ∧ b ≠ a := by
  let t := s.filter P
  have haT : a ∈ t := Finset.mem_filter.2 ⟨ha, hPa⟩
  have hpos : 0 < t.card := Finset.card_pos.2 ⟨a, haT⟩
  rcases heven with ⟨k, hk⟩
  have hone : 1 < t.card := by
    rw [hk] at hpos ⊢
    omega
  rcases Finset.one_lt_card.1 hone with
    ⟨x, hx, y, hy, hxy⟩
  by_cases hxa : x = a
  · refine ⟨y, (Finset.mem_filter.1 hy).1,
      (Finset.mem_filter.1 hy).2, ?_⟩
    intro hya
    exact hxy (by simp [hxa, hya])
  · exact ⟨x, (Finset.mem_filter.1 hx).1,
      (Finset.mem_filter.1 hx).2, hxa⟩

theorem gridBasicSquareVertices_pair_starAdjacent
    {i j : ℕ} {p q : GridNode}
    (hp : p ∈ gridBasicSquareVertices i j)
    (hq : q ∈ gridBasicSquareVertices i j) :
    gridNodeStarAdjacent p q := by
  rw [mem_gridBasicSquareVertices_iff] at hp hq
  rcases hp with hp | hp | hp | hp <;>
    rcases hq with hq | hq | hq | hq <;>
      subst hp <;> subst hq <;>
        simp [gridNodeStarAdjacent] <;> omega

theorem exists_gridBasicSquareVertices_of_gridAdjacent
    {p q : GridNode} (hpq : gridAdjacent p q) :
    ∃ i j,
      p ∈ gridBasicSquareVertices i j ∧
        q ∈ gridBasicSquareVertices i j := by
  rcases p with ⟨i, j⟩
  rcases q with ⟨i', j'⟩
  rcases hpq with hpq | hpq | hpq | hpq <;>
    rcases hpq with ⟨hi, hj⟩ <;>
      subst hi <;> subst hj
  · exact ⟨i, j, by simp [gridBasicSquareVertices],
      by simp [gridBasicSquareVertices]⟩
  · exact ⟨i', j, by simp [gridBasicSquareVertices],
      by simp [gridBasicSquareVertices]⟩
  · exact ⟨i, j, by simp [gridBasicSquareVertices],
      by simp [gridBasicSquareVertices]⟩
  · exact ⟨i, j', by simp [gridBasicSquareVertices],
      by simp [gridBasicSquareVertices]⟩

theorem exists_gridBasicSquareDirectedEdges_of_gridAdjacent
    {e : GridNode × GridNode} (he : gridAdjacent e.1 e.2) :
    ∃ i j, e ∈ gridBasicSquareDirectedEdges i j := by
  rcases exists_gridBasicSquareVertices_of_gridAdjacent he with
    ⟨i, j, hleft, hright⟩
  exact ⟨i, j,
    mem_gridBasicSquareDirectedEdges_iff_vertices_adjacent.2
      ⟨hleft, hright, he⟩⟩

theorem exists_gridBasicSquareDirectedEdges_of_common_right_starAdjacent
    {a b c : GridNode}
    (hab : gridAdjacent a b) (hcb : gridAdjacent c b)
    (hac : gridNodeStarAdjacent a c) :
    ∃ i j, (a, b) ∈ gridBasicSquareDirectedEdges i j ∧
      (c, b) ∈ gridBasicSquareDirectedEdges i j := by
  let i := min (min a.1 b.1) c.1
  let j := min (min a.2 b.2) c.2
  have haSq : a ∈ gridBasicSquareVertices i j := by
    rcases a with ⟨ai, aj⟩
    rcases b with ⟨bi, bj⟩
    rcases c with ⟨ci, cj⟩
    simp [i, j, gridBasicSquareVertices, gridAdjacent,
      gridNodeStarAdjacent] at hab hcb hac ⊢
    omega
  have hbSq : b ∈ gridBasicSquareVertices i j := by
    rcases a with ⟨ai, aj⟩
    rcases b with ⟨bi, bj⟩
    rcases c with ⟨ci, cj⟩
    simp [i, j, gridBasicSquareVertices, gridAdjacent,
      gridNodeStarAdjacent] at hab hcb hac ⊢
    omega
  have hcSq : c ∈ gridBasicSquareVertices i j := by
    rcases a with ⟨ai, aj⟩
    rcases b with ⟨bi, bj⟩
    rcases c with ⟨ci, cj⟩
    simp [i, j, gridBasicSquareVertices, gridAdjacent,
      gridNodeStarAdjacent] at hab hcb hac ⊢
    omega
  exact ⟨i, j,
    mem_gridBasicSquareDirectedEdges_iff_vertices_adjacent.2
      ⟨haSq, hbSq, hab⟩,
    mem_gridBasicSquareDirectedEdges_iff_vertices_adjacent.2
      ⟨hcSq, hbSq, hcb⟩⟩

theorem exists_gridBasicSquareDirectedEdges_of_common_left_starAdjacent
    {a b c : GridNode}
    (hab : gridAdjacent a b) (hac : gridAdjacent a c)
    (hbc : gridNodeStarAdjacent b c) :
    ∃ i j, (a, b) ∈ gridBasicSquareDirectedEdges i j ∧
      (a, c) ∈ gridBasicSquareDirectedEdges i j := by
  let i := min (min a.1 b.1) c.1
  let j := min (min a.2 b.2) c.2
  have haSq : a ∈ gridBasicSquareVertices i j := by
    rcases a with ⟨ai, aj⟩
    rcases b with ⟨bi, bj⟩
    rcases c with ⟨ci, cj⟩
    simp [i, j, gridBasicSquareVertices, gridAdjacent,
      gridNodeStarAdjacent] at hab hac hbc ⊢
    omega
  have hbSq : b ∈ gridBasicSquareVertices i j := by
    rcases a with ⟨ai, aj⟩
    rcases b with ⟨bi, bj⟩
    rcases c with ⟨ci, cj⟩
    simp [i, j, gridBasicSquareVertices, gridAdjacent,
      gridNodeStarAdjacent] at hab hac hbc ⊢
    omega
  have hcSq : c ∈ gridBasicSquareVertices i j := by
    rcases a with ⟨ai, aj⟩
    rcases b with ⟨bi, bj⟩
    rcases c with ⟨ci, cj⟩
    simp [i, j, gridBasicSquareVertices, gridAdjacent,
      gridNodeStarAdjacent] at hab hac hbc ⊢
    omega
  exact ⟨i, j,
    mem_gridBasicSquareDirectedEdges_iff_vertices_adjacent.2
      ⟨haSq, hbSq, hab⟩,
    mem_gridBasicSquareDirectedEdges_iff_vertices_adjacent.2
      ⟨haSq, hcSq, hac⟩⟩

/-- Corner-inclusive adjacency for cut clauses: two dual edges are adjacent when
some pair of their endpoints is king-adjacent. This is deliberately weaker than
sharing an endpoint, and is the corrected contour relation for pinched
boundaries. -/
def gridClauseStarAdjacent (j₁ j₂ : GridClauseId) : Prop :=
  ∃ p, p ∈ gridClauseDualEndpoints j₁ ∧
    ∃ q, q ∈ gridClauseDualEndpoints j₂ ∧ gridNodeStarAdjacent p q

theorem gridClauseStarAdjacent_symm
    {j₁ j₂ : GridClauseId} :
    gridClauseStarAdjacent j₁ j₂ → gridClauseStarAdjacent j₂ j₁ := by
  rintro ⟨p, hp, q, hq, hpq⟩
  exact ⟨q, hq, p, hp, gridNodeStarAdjacent_symm hpq⟩

def gridClauseStarAdjacentIn
    (s : Finset GridClauseId) (j₁ j₂ : GridClauseId) : Prop :=
  j₁ ∈ s ∧ j₂ ∈ s ∧ gridClauseStarAdjacent j₁ j₂

theorem gridClauseStarAdjacentIn_symm
    {s : Finset GridClauseId} :
    Symmetric (gridClauseStarAdjacentIn s) := by
  intro a b hab
  exact ⟨hab.2.1, hab.1, gridClauseStarAdjacent_symm hab.2.2⟩

theorem gridClauseStarAdjacent_of_dualAdjacent
    {j₁ j₂ : GridClauseId} :
    gridClauseDualAdjacent j₁ j₂ → gridClauseStarAdjacent j₁ j₂ := by
  rintro ⟨p, hp₁, hp₂⟩
  exact ⟨p, hp₁, p, hp₂, gridNodeStarAdjacent_refl p⟩

theorem gridClauseStarAdjacent_self_of_mem_dualEndpoints
    {j : GridClauseId} {p : GridNode}
    (hp : p ∈ gridClauseDualEndpoints j) :
    gridClauseStarAdjacent j j :=
  gridClauseStarAdjacent_of_dualAdjacent
    (gridClauseDualAdjacent_self_of_mem_dualEndpoints hp)

def gridClausesSharePrimalEndpoint (c₁ c₂ : GridClauseId) : Prop :=
  ∃ p, p ∈ gridClausePrimalEndpoints c₁ ∧ p ∈ gridClausePrimalEndpoints c₂

theorem gridClausesSharePrimalEndpoint_gridAdjacentClauseId_of_common_left
    {a b c : GridNode}
    (hab : gridAdjacent a b) (hac : gridAdjacent a c) :
    gridClausesSharePrimalEndpoint
      (gridAdjacentClauseId a b) (gridAdjacentClauseId a c) := by
  exact ⟨a, left_mem_gridClausePrimalEndpoints_gridAdjacentClauseId hab,
    left_mem_gridClausePrimalEndpoints_gridAdjacentClauseId hac⟩

theorem gridClausesSharePrimalEndpoint_gridAdjacentClauseId_of_common_right
    {a b c : GridNode}
    (hab : gridAdjacent a b) (hcb : gridAdjacent c b) :
    gridClausesSharePrimalEndpoint
      (gridAdjacentClauseId a b) (gridAdjacentClauseId c b) := by
  exact ⟨b, right_mem_gridClausePrimalEndpoints_gridAdjacentClauseId hab,
    right_mem_gridClausePrimalEndpoints_gridAdjacentClauseId hcb⟩

theorem gridClausesSharePrimalEndpoint_gridAdjacentClauseId_of_path_middle
    {a b c : GridNode}
    (hab : gridAdjacent a b) (hbc : gridAdjacent b c) :
    gridClausesSharePrimalEndpoint
      (gridAdjacentClauseId a b) (gridAdjacentClauseId b c) := by
  exact ⟨b, right_mem_gridClausePrimalEndpoints_gridAdjacentClauseId hab,
    left_mem_gridClausePrimalEndpoints_gridAdjacentClauseId hbc⟩

theorem gridClauseStarAdjacent_of_common_cut_primalEndpoint
    {inside : Region GridNode} {c₁ c₂ : GridClauseId} {p : GridNode}
    (hc₁ : gridBaseClauseCutsRegion inside c₁)
    (hc₂ : gridBaseClauseCutsRegion inside c₂)
    (hp₁ : p ∈ gridClausePrimalEndpoints c₁)
    (hp₂ : p ∈ gridClausePrimalEndpoints c₂) :
    gridClauseStarAdjacent c₁ c₂ := by
  rcases p with ⟨pi, pj⟩
  cases c₁ <;> cases c₂ <;>
    simp [gridBaseClauseCutsRegion, gridClausePrimalEndpoints,
      gridClauseStarAdjacent, gridClauseDualEndpoints, gridNodeStarAdjacent]
      at hc₁ hc₂ hp₁ hp₂ ⊢
  all_goals omega

theorem gridClauseStarAdjacent_of_sharePrimalEndpoint_of_cuts
    {inside : Region GridNode} {c₁ c₂ : GridClauseId}
    (hc₁ : gridBaseClauseCutsRegion inside c₁)
    (hc₂ : gridBaseClauseCutsRegion inside c₂)
    (hshare : gridClausesSharePrimalEndpoint c₁ c₂) :
    gridClauseStarAdjacent c₁ c₂ := by
  rcases hshare with ⟨p, hp₁, hp₂⟩
  exact gridClauseStarAdjacent_of_common_cut_primalEndpoint
    hc₁ hc₂ hp₁ hp₂

/-- Impossibility witness, NOT a dependency: star-adjacent primal endpoints of
two cut clauses do not by themselves imply clause-star adjacency. The F4
contour route uses the common-basic-square bridge instead. -/
theorem exists_not_gridClauseStarAdjacent_of_starAdjacent_cut_primalEndpoints :
    ∃ inside : Region GridNode,
    ∃ c₁ c₂ : GridClauseId,
    ∃ p q : GridNode,
      gridBaseClauseCutsRegion inside c₁ ∧
        gridBaseClauseCutsRegion inside c₂ ∧
          p ∈ gridClausePrimalEndpoints c₁ ∧
            q ∈ gridClausePrimalEndpoints c₂ ∧
              gridNodeStarAdjacent p q ∧
                ¬ gridClauseStarAdjacent c₁ c₂ := by
  refine
    ⟨({(1, 0), (2, 1)} : Region GridNode),
      GridClauseId.horizontal 0 0,
      GridClauseId.horizontal 2 1,
      (1, 0), (2, 1), ?_⟩
  simp [gridBaseClauseCutsRegion, gridClausePrimalEndpoints,
    gridNodeStarAdjacent, gridClauseStarAdjacent, gridClauseDualEndpoints]

theorem gridClauseStarAdjacent_horizontal_vertical_primal_right
    (i j : ℕ) :
    gridClauseStarAdjacent
      (GridClauseId.horizontal i j)
      (GridClauseId.vertical (i + 1) j) := by
  simp [gridClauseStarAdjacent, gridClauseDualEndpoints, gridNodeStarAdjacent]
  left
  omega

theorem gridClauseStarAdjacent_horizontal_succ_vertical_primal_left
    (i j : ℕ) :
    gridClauseStarAdjacent
      (GridClauseId.horizontal i (j + 1))
      (GridClauseId.vertical i j) := by
  simp [gridClauseStarAdjacent, gridClauseDualEndpoints, gridNodeStarAdjacent]
  left
  omega

theorem gridClauseStarAdjacent_horizontal_succ_vertical_primal_right
    (i j : ℕ) :
    gridClauseStarAdjacent
      (GridClauseId.horizontal i (j + 1))
      (GridClauseId.vertical (i + 1) j) := by
  simp [gridClauseStarAdjacent, gridClauseDualEndpoints, gridNodeStarAdjacent]
  constructor <;> omega

theorem gridClauseStarAdjacent_gridAdjacentClauseId_of_common_left
    {inside : Region GridNode} {a b c : GridNode}
    (hab : gridAdjacent a b) (hac : gridAdjacent a c)
    (hcutAB : gridBaseClauseCutsRegion inside (gridAdjacentClauseId a b))
    (hcutAC : gridBaseClauseCutsRegion inside (gridAdjacentClauseId a c)) :
    gridClauseStarAdjacent (gridAdjacentClauseId a b) (gridAdjacentClauseId a c) := by
  exact gridClauseStarAdjacent_of_common_cut_primalEndpoint hcutAB hcutAC
    (left_mem_gridClausePrimalEndpoints_gridAdjacentClauseId hab)
    (left_mem_gridClausePrimalEndpoints_gridAdjacentClauseId hac)

theorem gridClauseStarAdjacent_gridAdjacentClauseId_of_common_right
    {inside : Region GridNode} {a b c : GridNode}
    (hab : gridAdjacent a b) (hcb : gridAdjacent c b)
    (hcutAB : gridBaseClauseCutsRegion inside (gridAdjacentClauseId a b))
    (hcutCB : gridBaseClauseCutsRegion inside (gridAdjacentClauseId c b)) :
    gridClauseStarAdjacent (gridAdjacentClauseId a b) (gridAdjacentClauseId c b) := by
  exact gridClauseStarAdjacent_of_common_cut_primalEndpoint hcutAB hcutCB
    (right_mem_gridClausePrimalEndpoints_gridAdjacentClauseId hab)
    (right_mem_gridClausePrimalEndpoints_gridAdjacentClauseId hcb)

theorem gridClauseStarAdjacent_gridAdjacentClauseId_of_path_middle
    {inside : Region GridNode} {a b c : GridNode}
    (hab : gridAdjacent a b) (hbc : gridAdjacent b c)
    (hcutAB : gridBaseClauseCutsRegion inside (gridAdjacentClauseId a b))
    (hcutBC : gridBaseClauseCutsRegion inside (gridAdjacentClauseId b c)) :
    gridClauseStarAdjacent (gridAdjacentClauseId a b) (gridAdjacentClauseId b c) := by
  exact gridClauseStarAdjacent_of_common_cut_primalEndpoint hcutAB hcutBC
    (right_mem_gridClausePrimalEndpoints_gridAdjacentClauseId hab)
    (left_mem_gridClausePrimalEndpoints_gridAdjacentClauseId hbc)

theorem gridClauseStarAdjacent_horizontal_succ
    (i j : ℕ) :
    gridClauseStarAdjacent
      (GridClauseId.horizontal i j)
      (GridClauseId.horizontal i (j + 1)) := by
  exact gridClauseStarAdjacent_of_dualAdjacent
    ⟨(i, j + 1), by simp [gridClauseDualEndpoints],
      by simp [gridClauseDualEndpoints]⟩

theorem gridClauseStarAdjacent_vertical_succ
    (i j : ℕ) :
    gridClauseStarAdjacent
      (GridClauseId.vertical i j)
      (GridClauseId.vertical (i + 1) j) := by
  exact gridClauseStarAdjacent_of_dualAdjacent
    ⟨(i + 1, j),
      by
        change (i + 1, j) ∈ ({(i, j), (i + 1, j)} : Finset GridNode)
        exact Finset.mem_insert_of_mem (Finset.mem_singleton_self _),
      by
        change (i + 1, j) ∈ ({(i + 1, j), (i + 1 + 1, j)} : Finset GridNode)
        exact Finset.mem_insert_self _ _⟩

theorem gridClauseStarAdjacent_gridAdjacentClauseId_of_mem_common_gridBasicSquareDirectedEdges
    {a b c d : GridNode} {i j : ℕ}
    (habSq : (a, b) ∈ gridBasicSquareDirectedEdges i j)
    (hcdSq : (c, d) ∈ gridBasicSquareDirectedEdges i j) :
    gridClauseStarAdjacent
      (gridAdjacentClauseId a b) (gridAdjacentClauseId c d) := by
  have hclause₁ :
      gridAdjacentClauseId a b = GridClauseId.horizontal i j ∨
        gridAdjacentClauseId a b = GridClauseId.vertical i j ∨
          gridAdjacentClauseId a b = GridClauseId.vertical (i + 1) j ∨
            gridAdjacentClauseId a b = GridClauseId.horizontal i (j + 1) := by
    rw [mem_gridBasicSquareDirectedEdges_iff] at habSq
    rcases habSq with h | h | h | h | h | h | h | h <;>
      cases h <;> simp
  have hclause₂ :
      gridAdjacentClauseId c d = GridClauseId.horizontal i j ∨
        gridAdjacentClauseId c d = GridClauseId.vertical i j ∨
          gridAdjacentClauseId c d = GridClauseId.vertical (i + 1) j ∨
            gridAdjacentClauseId c d = GridClauseId.horizontal i (j + 1) := by
    rw [mem_gridBasicSquareDirectedEdges_iff] at hcdSq
    rcases hcdSq with h | h | h | h | h | h | h | h <;>
      cases h <;> simp
  rcases hclause₁ with h₁ | h₁ | h₁ | h₁ <;>
    rcases hclause₂ with h₂ | h₂ | h₂ | h₂ <;>
      rw [h₁, h₂] <;>
        simp [gridClauseStarAdjacent, gridClauseDualEndpoints,
          gridNodeStarAdjacent] <;> omega

/-- A finite cut set whose dual-edge adjacency graph is connected from a
distinguished root, with every adjacency hop remaining inside the same cut set.
This is the structural contour condition needed before a rooted DFS traversal
can be replayed as a `CutWalkCode`. -/
def RootedDualConnectedCutSet
    (root : GridClauseId) (s : Finset GridClauseId) : Prop :=
  root ∈ s ∧
    ∀ x ∈ s,
      Relation.ReflTransGen
        (fun a b => a ∈ s ∧ b ∈ s ∧ gridClauseDualAdjacent a b) root x

theorem RootedDualConnectedCutSet.root_mem
    {root : GridClauseId} {s : Finset GridClauseId}
    (h : RootedDualConnectedCutSet root s) :
    root ∈ s :=
  h.1

theorem RootedDualConnectedCutSet.reachable
    {root x : GridClauseId} {s : Finset GridClauseId}
    (h : RootedDualConnectedCutSet root s) (hx : x ∈ s) :
    Relation.ReflTransGen gridClauseDualAdjacent root x := by
  have hreach := h.2 x hx
  exact Relation.ReflTransGen.mono (fun _ _ hstep => hstep.2.2) hreach

theorem rootedDualConnectedCutSet_singleton
    (root : GridClauseId) :
    RootedDualConnectedCutSet root ({root} : Finset GridClauseId) := by
  refine ⟨by simp, ?_⟩
  intro x hx
  simp at hx
  subst hx
  exact Relation.ReflTransGen.refl

/-- A finite cut set connected from a root by the corner-inclusive dual-edge
adjacency. This is the corrected contour connectivity predicate after the hook
witness refuted the fresh-only dual-adjacent route. -/
def RootedStarConnectedCutSet
    (root : GridClauseId) (s : Finset GridClauseId) : Prop :=
  root ∈ s ∧
    ∀ x ∈ s,
      Relation.ReflTransGen
        (fun a b => a ∈ s ∧ b ∈ s ∧ gridClauseStarAdjacent a b) root x

theorem RootedStarConnectedCutSet.root_mem
    {root : GridClauseId} {s : Finset GridClauseId}
    (h : RootedStarConnectedCutSet root s) :
    root ∈ s :=
  h.1

theorem RootedStarConnectedCutSet.reachable
    {root x : GridClauseId} {s : Finset GridClauseId}
    (h : RootedStarConnectedCutSet root s) (hx : x ∈ s) :
    Relation.ReflTransGen gridClauseStarAdjacent root x := by
  have hreach := h.2 x hx
  exact Relation.ReflTransGen.mono (fun _ _ hstep => hstep.2.2) hreach

theorem rootedStarConnectedCutSet_singleton
    (root : GridClauseId) :
    RootedStarConnectedCutSet root ({root} : Finset GridClauseId) := by
  refine ⟨by simp, ?_⟩
  intro x hx
  simp at hx
  subst hx
  exact Relation.ReflTransGen.refl

theorem RootedStarConnectedCutSet.of_rootedDualConnectedCutSet
    {root : GridClauseId} {s : Finset GridClauseId}
    (h : RootedDualConnectedCutSet root s) :
    RootedStarConnectedCutSet root s := by
  refine ⟨h.root_mem, ?_⟩
  intro x hx
  exact Relation.ReflTransGen.mono
    (fun _ _ hstep =>
      ⟨hstep.1, hstep.2.1,
        gridClauseStarAdjacent_of_dualAdjacent hstep.2.2⟩)
    (h.2 x hx)

theorem list_isChain_reflTransGen_of_mem
    {α : Type*} {R : α → α → Prop}
    {root x : α} {tail : List α}
    (hchain : List.IsChain R (root :: tail))
    (hx : x ∈ root :: tail) :
    Relation.ReflTransGen R root x := by
  induction tail generalizing root with
  | nil =>
      simp at hx
      subst hx
      exact Relation.ReflTransGen.refl
  | cons y ys ih =>
      rw [List.mem_cons] at hx
      rcases hx with rfl | hx
      · exact Relation.ReflTransGen.refl
      · have hpair :
            R root y ∧ List.IsChain R (y :: ys) := by
          simpa using (List.isChain_cons_cons.mp hchain)
        exact Relation.ReflTransGen.head hpair.1 (ih hpair.2 hx)

theorem rootedDualConnectedCutSet_of_clauseChain
    {root : GridClauseId} {s : Finset GridClauseId}
    {tail : List GridClauseId}
    (hroot : root ∈ s)
    (hchain : List.IsChain gridClauseDualAdjacent (root :: tail))
    (htailMem : ∀ c ∈ tail, c ∈ s)
    (hcover : ∀ x ∈ s, x = root ∨ x ∈ tail) :
    RootedDualConnectedCutSet root s := by
  refine ⟨hroot, ?_⟩
  intro x hx
  have hmemOfList : ∀ y ∈ root :: tail, y ∈ s := by
    intro y hy
    rw [List.mem_cons] at hy
    rcases hy with rfl | hy
    · exact hroot
    · exact htailMem y hy
  have hchainMem :
      List.IsChain
        (fun a b => a ∈ s ∧ b ∈ s ∧ gridClauseDualAdjacent a b)
        (root :: tail) := by
    exact hchain.imp_of_mem_imp (by
      intro a b ha hb hadj
      exact ⟨hmemOfList a ha, hmemOfList b hb, hadj⟩)
  rcases hcover x hx with rfl | hxTail
  · exact Relation.ReflTransGen.refl
  · exact list_isChain_reflTransGen_of_mem hchainMem (by simp [hxTail])

theorem rootedStarConnectedCutSet_of_clauseChain
    {root : GridClauseId} {s : Finset GridClauseId}
    {tail : List GridClauseId}
    (hroot : root ∈ s)
    (hchain : List.IsChain gridClauseStarAdjacent (root :: tail))
    (htailMem : ∀ c ∈ tail, c ∈ s)
    (hcover : ∀ x ∈ s, x = root ∨ x ∈ tail) :
    RootedStarConnectedCutSet root s := by
  refine ⟨hroot, ?_⟩
  intro x hx
  have hmemOfList : ∀ y ∈ root :: tail, y ∈ s := by
    intro y hy
    rw [List.mem_cons] at hy
    rcases hy with rfl | hy
    · exact hroot
    · exact htailMem y hy
  have hchainMem :
      List.IsChain
        (fun a b => a ∈ s ∧ b ∈ s ∧ gridClauseStarAdjacent a b)
        (root :: tail) := by
    exact hchain.imp_of_mem_imp (by
      intro a b ha hb hadj
      exact ⟨hmemOfList a ha, hmemOfList b hb, hadj⟩)
  rcases hcover x hx with rfl | hxTail
  · exact Relation.ReflTransGen.refl
  · exact list_isChain_reflTransGen_of_mem hchainMem (by simp [hxTail])

