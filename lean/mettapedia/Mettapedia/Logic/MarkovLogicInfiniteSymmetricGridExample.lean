    ⟨a, b, hab, hEq, hside⟩
  exact ⟨hull, hhull, hcutCard, hsEq, a, b, hab, hEq, hside⟩

theorem exists_dualEndpoint_of_mem_originConnectedHullCutSetCandidatesInCutCardBoxAxisAnchored
    {m i j : ℕ} {s : Finset GridClauseId} {x : GridClauseId}
