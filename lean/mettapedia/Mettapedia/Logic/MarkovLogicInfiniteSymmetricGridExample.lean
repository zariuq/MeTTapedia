    · rcases hdown with ⟨rfl, rfl⟩
      rcases hup with hnotStage | hext
      · exfalso
        exact hnotStage (by simp [gridExhaustion])
      · exfalso
        exact boundaryConnectedOutsideSubregion_not_mem_inside hext (by simp [hookSlackInside])
    · rcases hdown with ⟨rfl, rfl⟩
      exact Or.inr ⟨rfl, rfl⟩
  · rcases h with ⟨hdown, hup⟩
    simp [hookSlackInside] at hup
    rcases hup with hup | hup | hup
    · rcases hup with ⟨rfl, rfl⟩
      rcases hdown with hnotStage | hext
      · exfalso
        exact hnotStage (by simp [gridExhaustion])
      · exfalso
        exact boundaryConnectedOutsideSubregion_not_mem_inside hext (by simp [hookSlackInside])
    · rcases hup with ⟨rfl, rfl⟩
      rcases hdown with hnotStage | hext
      · exfalso
        exact hnotStage (by simp [gridExhaustion])
      · exfalso
        exact boundaryConnectedOutsideSubregion_not_mem_inside hext (by simp [hookSlackInside])
    · rcases hup with ⟨rfl, rfl⟩
      rcases hdown with hnotStage | hext
      · exfalso
        exact hnotStage (by simp [gridExhaustion])
      · exfalso
        exact boundaryConnectedOutsideSubregion_not_mem_inside hext (by simp [hookSlackInside])

theorem hookSlackHullCutSet_eq_explicit :
    hookSlackHullCutSet =
      ({ GridClauseId.horizontal 1 0,
         GridClauseId.horizontal 1 1,
         GridClauseId.horizontal 1 2,
         GridClauseId.horizontal 0 2,
         GridClauseId.vertical 0 1,
         GridClauseId.vertical 1 2 } : Finset GridClauseId) := by
  rw [hookSlackHullCutSet_eq_hookSlackInside_outerCut]
  apply Finset.Subset.antisymm
  · intro c hc
    rcases Finset.mem_filter.1 hc with ⟨_hsupp, hcut⟩
    cases c with
    | prior _ _ => cases hcut
    | horizontal i j =>
        have hcases := hookSlackInside_horizontal_outerCut_cases hcut
        simp at hcases ⊢
        rcases hcases with h | h
        · rcases h with ⟨rfl, hj⟩
          rcases hj with rfl | rfl | rfl <;> simp
        · rcases h with ⟨rfl, rfl⟩
          simp
    | vertical i j =>
        have hcases := hookSlackInside_vertical_outerCut_cases hcut
        simp at hcases ⊢
        rcases hcases with h | h
        · rcases h with ⟨rfl, rfl⟩
          simp
        · rcases h with ⟨rfl, rfl⟩
          simp
  · intro c hc
    rw [← hookSlackHullCutSet_eq_hookSlackInside_outerCut]
    rw [hookSlackHullCutSet_eq_hookSlackInside_outerCut]
    exact hookSlackInside_sixExplicitOuterCuts_subset hc

