theorem AxisAnchoredDiagHullProfile.horizontal_bridge_reachable_of_gV_drop
    {m i j : ℕ} {s : Finset GridClauseId}
    (prof : AxisAnchoredDiagHullProfile m i j s)
    (hdiag : m = i + j + 2)
    (k : Fin i)
    (hdrop :
      prof.gV ⟨k.1 + 1, Nat.succ_lt_succ k.2⟩ <
        prof.gV ⟨k.1, Nat.lt_trans k.2 (Nat.lt_succ_self i)⟩) :
    Relation.ReflTransGen (gridClauseStarAdjacentIn s)
      (GridClauseId.horizontal k.1
        (prof.gV ⟨k.1, Nat.lt_trans k.2 (Nat.lt_succ_self i)⟩))
      (GridClauseId.horizontal k.1
        (prof.gV ⟨k.1 + 1, Nat.succ_lt_succ k.2⟩ + 1)) := by
  let top := prof.gV ⟨k.1, Nat.lt_trans k.2 (Nat.lt_succ_self i)⟩
  let bot := prof.gV ⟨k.1 + 1, Nat.succ_lt_succ k.2⟩
  have hle : bot + 1 ≤ top := by
    dsimp [bot, top]
    omega
  have hreachUp :
      Relation.ReflTransGen (gridClauseStarAdjacentIn s)
        (GridClauseId.horizontal k.1 (bot + 1))
        (GridClauseId.horizontal k.1 top) := by
    refine reflTransGen_gridClauseStarAdjacentIn_horizontal_interval
      (s := s) k.1 (bot + 1) top hle ?_
    intro t htlo hthi
    exact prof.horizontal_mem_of_between_adjacent_gV hdiag k
      (by dsimp [bot] at htlo; omega)
      (by dsimp [top] at hthi; omega)
  exact
    reflTransGen_symm_of_symmetric
      (gridClauseStarAdjacentIn_symm (s := s)) hreachUp

theorem AxisAnchoredDiagHullProfile.vertical_bridge_reachable_of_gH_drop
    {m i j : ℕ} {s : Finset GridClauseId}
    (prof : AxisAnchoredDiagHullProfile m i j s)
    (hdiag : m = i + j + 2)
    (k : Fin j)
    (hdrop :
      prof.gH ⟨k.1 + 1, Nat.succ_lt_succ k.2⟩ <
        prof.gH ⟨k.1, Nat.lt_trans k.2 (Nat.lt_succ_self j)⟩) :
    Relation.ReflTransGen (gridClauseStarAdjacentIn s)
      (GridClauseId.vertical
        (prof.gH ⟨k.1, Nat.lt_trans k.2 (Nat.lt_succ_self j)⟩)
        k.1)
      (GridClauseId.vertical
        (prof.gH ⟨k.1 + 1, Nat.succ_lt_succ k.2⟩ + 1)
        k.1) := by
  let top := prof.gH ⟨k.1, Nat.lt_trans k.2 (Nat.lt_succ_self j)⟩
  let bot := prof.gH ⟨k.1 + 1, Nat.succ_lt_succ k.2⟩
  have hle : bot + 1 ≤ top := by
    dsimp [bot, top]
    omega
  have hreachUp :
      Relation.ReflTransGen (gridClauseStarAdjacentIn s)
        (GridClauseId.vertical (bot + 1) k.1)
        (GridClauseId.vertical top k.1) := by
    refine reflTransGen_gridClauseStarAdjacentIn_vertical_interval
      (s := s) k.1 (bot + 1) top hle ?_
    intro t htlo hthi
    exact prof.vertical_mem_of_between_adjacent_gH hdiag k
      (by dsimp [bot] at htlo; omega)
      (by dsimp [top] at hthi; omega)
  exact
    reflTransGen_symm_of_symmetric
      (gridClauseStarAdjacentIn_symm (s := s)) hreachUp

theorem AxisAnchoredDiagHullProfile.horizontal_profile_step_reachable
    {m i j : ℕ} {s : Finset GridClauseId}
    (prof : AxisAnchoredDiagHullProfile m i j s)
    (hdiag : m = i + j + 2)
    (k : Fin j) :
    Relation.ReflTransGen (gridClauseStarAdjacentIn s)
      (GridClauseId.horizontal
        (prof.gH ⟨k.1, Nat.lt_trans k.2 (Nat.lt_succ_self j)⟩)
        k.1)
      (GridClauseId.horizontal
        (prof.gH ⟨k.1 + 1, Nat.succ_lt_succ k.2⟩)
        (k.1 + 1)) := by
  let kD : Fin (j + 1) := ⟨k.1, Nat.lt_trans k.2 (Nat.lt_succ_self j)⟩
  let kU : Fin (j + 1) := ⟨k.1 + 1, Nat.succ_lt_succ k.2⟩
  have hmono : prof.gH kU ≤ prof.gH kD := by
    exact prof.hHMono kD kU (by simp [kD, kU])
  by_cases heq : prof.gH kU = prof.gH kD
  · have hstar := prof.horizontal_equal_step_star k heq
    exact Relation.ReflTransGen.tail Relation.ReflTransGen.refl
      ⟨prof.horizontal_mem kD, prof.horizontal_mem kU, hstar⟩
  · have hdrop : prof.gH kU < prof.gH kD :=
      lt_of_le_of_ne hmono heq
    have hstepTop :
        gridClauseStarAdjacentIn s
          (GridClauseId.horizontal (prof.gH kD) k.1)
          (GridClauseId.vertical (prof.gH kD) k.1) :=
      ⟨prof.horizontal_mem kD,
        prof.vertical_bridge_top_mem_of_gH_drop hdiag k hdrop,
        prof.lower_horizontal_top_vertical_star k⟩
    have hbridge :=
      prof.vertical_bridge_reachable_of_gH_drop hdiag k hdrop
    have hstepBottom :
        gridClauseStarAdjacentIn s
          (GridClauseId.vertical (prof.gH kU + 1) k.1)
          (GridClauseId.horizontal (prof.gH kU) (k.1 + 1)) :=
      ⟨prof.vertical_bridge_bottom_mem_of_gH_drop hdiag k hdrop,
        prof.horizontal_mem kU,
        prof.bottom_vertical_upper_horizontal_star k⟩
    exact Relation.ReflTransGen.head hstepTop
      (Relation.ReflTransGen.tail hbridge hstepBottom)

theorem AxisAnchoredDiagHullProfile.vertical_profile_step_reachable
    {m i j : ℕ} {s : Finset GridClauseId}
    (prof : AxisAnchoredDiagHullProfile m i j s)
    (hdiag : m = i + j + 2)
    (k : Fin i) :
    Relation.ReflTransGen (gridClauseStarAdjacentIn s)
      (GridClauseId.vertical
        k.1
        (prof.gV ⟨k.1, Nat.lt_trans k.2 (Nat.lt_succ_self i)⟩))
      (GridClauseId.vertical
        (k.1 + 1)
        (prof.gV ⟨k.1 + 1, Nat.succ_lt_succ k.2⟩)) := by
  let kL : Fin (i + 1) := ⟨k.1, Nat.lt_trans k.2 (Nat.lt_succ_self i)⟩
  let kR : Fin (i + 1) := ⟨k.1 + 1, Nat.succ_lt_succ k.2⟩
  have hmono : prof.gV kR ≤ prof.gV kL := by
    exact prof.hVMono kL kR (by simp [kL, kR])
  by_cases heq : prof.gV kR = prof.gV kL
  · have hstar := prof.vertical_equal_step_star k heq
    exact Relation.ReflTransGen.tail Relation.ReflTransGen.refl
      ⟨prof.vertical_mem kL, prof.vertical_mem kR, hstar⟩
  · have hdrop : prof.gV kR < prof.gV kL :=
      lt_of_le_of_ne hmono heq
    have hstepTop :
        gridClauseStarAdjacentIn s
          (GridClauseId.vertical k.1 (prof.gV kL))
          (GridClauseId.horizontal k.1 (prof.gV kL)) :=
      ⟨prof.vertical_mem kL,
        prof.horizontal_bridge_top_mem_of_gV_drop hdiag k hdrop,
        prof.left_vertical_top_horizontal_star k⟩
    have hbridge :=
      prof.horizontal_bridge_reachable_of_gV_drop hdiag k hdrop
    have hstepBottom :
        gridClauseStarAdjacentIn s
          (GridClauseId.horizontal k.1 (prof.gV kR + 1))
          (GridClauseId.vertical (k.1 + 1) (prof.gV kR)) :=
      ⟨prof.horizontal_bridge_bottom_mem_of_gV_drop hdiag k hdrop,
        prof.vertical_mem kR,
        prof.bottom_horizontal_right_vertical_star k⟩
    exact Relation.ReflTransGen.head hstepTop
      (Relation.ReflTransGen.tail hbridge hstepBottom)

theorem AxisAnchoredDiagHullProfile.horizontal_profile_reachable_nat_of_axisAnchored
    {m i j : ℕ} {s : Finset GridClauseId}
    (prof : AxisAnchoredDiagHullProfile m i j s)
    (hs : s ∈ originConnectedHullCutSetCandidatesInCutCardBoxAxisAnchored m i j)
    (hdiag : m = i + j + 2) :
    ∀ n, (hn : n ≤ j) →
      Relation.ReflTransGen (gridClauseStarAdjacentIn s)
        (GridClauseId.horizontal i 0)
        (GridClauseId.horizontal
          (prof.gH ⟨n, Nat.lt_succ_of_le hn⟩) n) := by
  intro n hn
  induction n with
  | zero =>
      have hzero : prof.gH (0 : Fin (j + 1)) = i :=
        prof.gH_zero_eq_of_axisAnchored hs
      simpa [hzero] using
        (Relation.ReflTransGen.refl :
          Relation.ReflTransGen (gridClauseStarAdjacentIn s)
            (GridClauseId.horizontal i 0) (GridClauseId.horizontal i 0))
  | succ n ih =>
      have hnltj : n < j := Nat.succ_le_iff.mp hn
      have hnle : n ≤ j := Nat.le_of_lt hnltj
      have hprev :
          Relation.ReflTransGen (gridClauseStarAdjacentIn s)
            (GridClauseId.horizontal i 0)
            (GridClauseId.horizontal
              (prof.gH ⟨n, Nat.lt_succ_of_le hnle⟩) n) :=
        ih hnle
      let k : Fin j := ⟨n, hnltj⟩
      have hstep :
          Relation.ReflTransGen (gridClauseStarAdjacentIn s)
            (GridClauseId.horizontal
              (prof.gH ⟨n, Nat.lt_succ_of_le hnle⟩) n)
            (GridClauseId.horizontal
              (prof.gH ⟨n + 1, Nat.lt_succ_of_le hn⟩) (n + 1)) := by
        simpa [k] using prof.horizontal_profile_step_reachable hdiag k
      exact hprev.trans hstep

theorem AxisAnchoredDiagHullProfile.horizontal_profile_reachable_of_axisAnchored
    {m i j : ℕ} {s : Finset GridClauseId}
    (prof : AxisAnchoredDiagHullProfile m i j s)
    (hs : s ∈ originConnectedHullCutSetCandidatesInCutCardBoxAxisAnchored m i j)
    (hdiag : m = i + j + 2)
    (r : Fin (j + 1)) :
    Relation.ReflTransGen (gridClauseStarAdjacentIn s)
      (GridClauseId.horizontal i 0)
      (GridClauseId.horizontal (prof.gH r) r.1) := by
  simpa using
    prof.horizontal_profile_reachable_nat_of_axisAnchored hs hdiag
      r.1 (Nat.le_of_lt_succ r.2)

theorem AxisAnchoredDiagHullProfile.vertical_profile_reachable_nat_of_axisAnchored
    {m i j : ℕ} {s : Finset GridClauseId}
    (prof : AxisAnchoredDiagHullProfile m i j s)
    (hs : s ∈ originConnectedHullCutSetCandidatesInCutCardBoxAxisAnchored m i j)
    (hdiag : m = i + j + 2) :
    ∀ n, (hn : n ≤ i) →
      Relation.ReflTransGen (gridClauseStarAdjacentIn s)
        (GridClauseId.vertical 0 j)
        (GridClauseId.vertical n
          (prof.gV ⟨n, Nat.lt_succ_of_le hn⟩)) := by
  intro n hn
  induction n with
  | zero =>
      have hzero : prof.gV (0 : Fin (i + 1)) = j :=
        prof.gV_zero_eq_of_axisAnchored hs
      simpa [hzero] using
        (Relation.ReflTransGen.refl :
          Relation.ReflTransGen (gridClauseStarAdjacentIn s)
            (GridClauseId.vertical 0 j) (GridClauseId.vertical 0 j))
  | succ n ih =>
      have hnlti : n < i := Nat.succ_le_iff.mp hn
      have hnle : n ≤ i := Nat.le_of_lt hnlti
      have hprev :
          Relation.ReflTransGen (gridClauseStarAdjacentIn s)
            (GridClauseId.vertical 0 j)
            (GridClauseId.vertical n
              (prof.gV ⟨n, Nat.lt_succ_of_le hnle⟩)) :=
        ih hnle
      let k : Fin i := ⟨n, hnlti⟩
      have hstep :
          Relation.ReflTransGen (gridClauseStarAdjacentIn s)
            (GridClauseId.vertical n
              (prof.gV ⟨n, Nat.lt_succ_of_le hnle⟩))
            (GridClauseId.vertical (n + 1)
              (prof.gV ⟨n + 1, Nat.lt_succ_of_le hn⟩)) := by
        simpa [k] using prof.vertical_profile_step_reachable hdiag k
      exact hprev.trans hstep

theorem AxisAnchoredDiagHullProfile.vertical_profile_reachable_of_axisAnchored
    {m i j : ℕ} {s : Finset GridClauseId}
    (prof : AxisAnchoredDiagHullProfile m i j s)
    (hs : s ∈ originConnectedHullCutSetCandidatesInCutCardBoxAxisAnchored m i j)
    (hdiag : m = i + j + 2)
    (c : Fin (i + 1)) :
    Relation.ReflTransGen (gridClauseStarAdjacentIn s)
      (GridClauseId.vertical 0 j)
      (GridClauseId.vertical c.1 (prof.gV c)) := by
  simpa using
    prof.vertical_profile_reachable_nat_of_axisAnchored hs hdiag
      c.1 (Nat.le_of_lt_succ c.2)

theorem AxisAnchoredDiagHullProfile.gV_topHorizontal_eq
    {m i j : ℕ} {s : Finset GridClauseId}
    (prof : AxisAnchoredDiagHullProfile m i j s) :
    prof.gV
        ⟨prof.gH ⟨j, Nat.lt_succ_self j⟩,
          lt_of_le_of_lt (prof.hHBound ⟨j, Nat.lt_succ_self j⟩)
            (Nat.lt_succ_self i)⟩ =
      j := by
  let rTop : Fin (j + 1) := ⟨j, Nat.lt_succ_self j⟩
  let cTop : Fin (i + 1) :=
    ⟨prof.gH rTop, lt_of_le_of_lt (prof.hHBound rTop) (Nat.lt_succ_self i)⟩
  change prof.gV cTop = j
  have hpoint : (cTop.1, rTop.1) ∈ prof.hull :=
    (prof.hRowExact rTop cTop.1).2 le_rfl
  have hjle : j ≤ prof.gV cTop := by
    exact (prof.hColExact cTop j).1 (by simpa [rTop] using hpoint)
  exact le_antisymm (prof.hVBound cTop) hjle

theorem AxisAnchoredDiagHullProfile.horizontal_root_reaches_vertical_root_of_axisAnchored
    {m i j : ℕ} {s : Finset GridClauseId}
    (prof : AxisAnchoredDiagHullProfile m i j s)
    (hs : s ∈ originConnectedHullCutSetCandidatesInCutCardBoxAxisAnchored m i j)
    (hdiag : m = i + j + 2) :
    Relation.ReflTransGen (gridClauseStarAdjacentIn s)
      (GridClauseId.horizontal i 0) (GridClauseId.vertical 0 j) := by
  let rTop : Fin (j + 1) := ⟨j, Nat.lt_succ_self j⟩
  let cTop : Fin (i + 1) :=
    ⟨prof.gH rTop, lt_of_le_of_lt (prof.hHBound rTop) (Nat.lt_succ_self i)⟩
  have hgV : prof.gV cTop = j := by
    simpa [cTop, rTop] using prof.gV_topHorizontal_eq
  have hHorizontal :
      Relation.ReflTransGen (gridClauseStarAdjacentIn s)
        (GridClauseId.horizontal i 0)
        (GridClauseId.horizontal (prof.gH rTop) j) := by
    simpa [rTop] using
      prof.horizontal_profile_reachable_of_axisAnchored hs hdiag rTop
  have hCorner :
      gridClauseStarAdjacentIn s
        (GridClauseId.horizontal (prof.gH rTop) j)
        (GridClauseId.vertical (prof.gH rTop) j) := by
    refine ⟨prof.horizontal_mem rTop, ?_, ?_⟩
    · simpa [cTop, hgV] using prof.vertical_mem cTop
    · exact gridClauseStarAdjacent_of_dualAdjacent
        (gridClauseDualAdjacent_horizontal_vertical_left (prof.gH rTop) j)
  have hVertical :
      Relation.ReflTransGen (gridClauseStarAdjacentIn s)
        (GridClauseId.vertical 0 j)
        (GridClauseId.vertical (prof.gH rTop) j) := by
    simpa [cTop, hgV] using
      prof.vertical_profile_reachable_of_axisAnchored hs hdiag cTop
  have hVerticalBack :
      Relation.ReflTransGen (gridClauseStarAdjacentIn s)
        (GridClauseId.vertical (prof.gH rTop) j)
        (GridClauseId.vertical 0 j) :=
    reflTransGen_symm_of_symmetric
      (gridClauseStarAdjacentIn_symm (s := s)) hVertical
  exact (Relation.ReflTransGen.tail hHorizontal hCorner).trans hVerticalBack

theorem AxisAnchoredDiagHullProfile.reachable_of_mem_axisAnchored_of_diag
    {m i j : ℕ} {s : Finset GridClauseId}
    (prof : AxisAnchoredDiagHullProfile m i j s)
    (hs : s ∈ originConnectedHullCutSetCandidatesInCutCardBoxAxisAnchored m i j)
    (hdiag : m = i + j + 2)
    {x : GridClauseId} (hx : x ∈ s) :
    Relation.ReflTransGen (gridClauseStarAdjacentIn s)
      (GridClauseId.horizontal i 0) x := by
  have hrootVert :
      Relation.ReflTransGen (gridClauseStarAdjacentIn s)
        (GridClauseId.horizontal i 0) (GridClauseId.vertical 0 j) :=
    prof.horizontal_root_reaches_vertical_root_of_axisAnchored hs hdiag
  rw [prof.hEq] at hx
  rcases Finset.mem_union.1 hx with hxV | hxH
  · rcases Finset.mem_image.1 hxV with ⟨c, _hc, hcEq⟩
    have hVert :
        Relation.ReflTransGen (gridClauseStarAdjacentIn s)
          (GridClauseId.vertical 0 j)
          (GridClauseId.vertical c.1 (prof.gV c)) :=
      prof.vertical_profile_reachable_of_axisAnchored hs hdiag c
    exact hrootVert.trans (by simpa [hcEq] using hVert)
  · rcases Finset.mem_image.1 hxH with ⟨r, _hr, hrEq⟩
    simpa [hrEq] using
      prof.horizontal_profile_reachable_of_axisAnchored hs hdiag r

theorem axisAnchoredDiagHullProfile_nonempty_of_mem
    {m i j : ℕ} {s : Finset GridClauseId}
    (hs : s ∈ originConnectedHullCutSetCandidatesInCutCardBoxAxisAnchored m i j)
    (hdiag : m = i + j + 2) :
    Nonempty (AxisAnchoredDiagHullProfile m i j s) := by
  rcases
    originConnectedHullCutSetCandidatesInCutCardBoxAxisAnchored_exists_hullMonotonePrefixRowColDecomposition_of_diag
      hs hdiag with
    ⟨hull, hhullBox, hcutCard, hsEq, gV, gH, hEq, hVBound, hHBound,
      hColExact, hRowExact, hVMono, hHMono⟩
  exact ⟨{
    hull := hull
    hhullBox := hhullBox
    hcutCard := hcutCard
    hsEq := hsEq
    gV := gV
    gH := gH
    hEq := hEq
    hVBound := hVBound
    hHBound := hHBound
    hColExact := hColExact
    hRowExact := hRowExact
    hVMono := hVMono
    hHMono := hHMono
  }⟩

noncomputable def axisAnchoredDiagHullProfileOfMem
    {m i j : ℕ} {s : Finset GridClauseId}
    (hs : s ∈ originConnectedHullCutSetCandidatesInCutCardBoxAxisAnchored m i j)
    (hdiag : m = i + j + 2) :
    AxisAnchoredDiagHullProfile m i j s :=
  Classical.choice (axisAnchoredDiagHullProfile_nonempty_of_mem hs hdiag)

theorem rootedStarConnectedCutSet_of_mem_axisAnchored_diag
    {m i j : ℕ} {s : Finset GridClauseId}
    (hs : s ∈ originConnectedHullCutSetCandidatesInCutCardBoxAxisAnchored m i j)
    (hdiag : m = i + j + 2) :
    RootedStarConnectedCutSet (GridClauseId.horizontal i 0) s := by
  let prof := axisAnchoredDiagHullProfileOfMem (s := s) hs hdiag
  refine
    ⟨horizontal_root_mem_of_mem_originConnectedHullCutSetCandidatesInCutCardBoxAxisAnchored hs,
      ?_⟩
  intro x hx
  exact prof.reachable_of_mem_axisAnchored_of_diag hs hdiag hx

theorem axisAnchoredRootedStarConnectedFamily_of_slack_case
    (hslack :
      ∀ m, 2 ≤ m → ∀ i ∈ Finset.range m,
        ∀ j ∈ Finset.range (m - (i + 1)),
          i + j + 2 < m →
            ∀ s :
              {s // s ∈ originConnectedHullCutSetCandidatesInCutCardBoxAxisAnchored m i j},
              RootedStarConnectedCutSet (GridClauseId.horizontal i 0) s.1) :
    ∀ m, 2 ≤ m → ∀ i ∈ Finset.range m,
      ∀ j ∈ Finset.range (m - (i + 1)),
        ∀ s :
          {s // s ∈ originConnectedHullCutSetCandidatesInCutCardBoxAxisAnchored m i j},
          RootedStarConnectedCutSet (GridClauseId.horizontal i 0) s.1 := by
  intro m hm i hi j hj s
  have hle : i + j + 2 ≤ m := by
    have hiLt : i < m := Finset.mem_range.1 hi
    have hjLt : j < m - (i + 1) := Finset.mem_range.1 hj
    omega
  rcases lt_or_eq_of_le hle with hslack' | hdiag
  · exact hslack m hm i hi j hj hslack' s
  · exact rootedStarConnectedCutSet_of_mem_axisAnchored_diag s.2 hdiag.symm

noncomputable def axisAnchoredDiagStaircaseCode
    {i j : ℕ}
    (gV : Fin (i + 1) → ℕ)
    (hVMono : ∀ a b : Fin (i + 1), a.1 ≤ b.1 → gV b ≤ gV a) :
    Fin i ↪o Fin (i + j) :=
  OrderEmbedding.ofStrictMono
    (fun k =>
      ⟨k.1 + (j - gV ⟨k.1 + 1, Nat.succ_lt_succ k.2⟩), by
        have hklt : k.1 < i := k.2
        have hsub :
            j - gV ⟨k.1 + 1, Nat.succ_lt_succ k.2⟩ ≤ j := Nat.sub_le _ _
        omega⟩)
    (by
      intro a b hab
      have habNat : a.1 < b.1 := hab
      have habSucc :
          (⟨a.1 + 1, Nat.succ_lt_succ a.2⟩ : Fin (i + 1)).1 ≤
            (⟨b.1 + 1, Nat.succ_lt_succ b.2⟩ : Fin (i + 1)).1 := by
        exact Nat.succ_le_succ (Nat.le_of_lt habNat)
      have hgv :
          gV ⟨b.1 + 1, Nat.succ_lt_succ b.2⟩ ≤
            gV ⟨a.1 + 1, Nat.succ_lt_succ a.2⟩ :=
        hVMono _ _ habSucc
      have hsub :
          j - gV ⟨a.1 + 1, Nat.succ_lt_succ a.2⟩ ≤
            j - gV ⟨b.1 + 1, Nat.succ_lt_succ b.2⟩ :=
        Nat.sub_le_sub_left hgv j
      show a.1 + (j - gV ⟨a.1 + 1, Nat.succ_lt_succ a.2⟩) <
        b.1 + (j - gV ⟨b.1 + 1, Nat.succ_lt_succ b.2⟩)
      exact lt_of_lt_of_le
        (Nat.add_lt_add_right habNat _)
        (Nat.add_le_add_left hsub _))

@[simp] theorem axisAnchoredDiagStaircaseCode_apply
    {i j : ℕ}
    (gV : Fin (i + 1) → ℕ)
    (hVMono : ∀ a b : Fin (i + 1), a.1 ≤ b.1 → gV b ≤ gV a)
    (k : Fin i) :
    (axisAnchoredDiagStaircaseCode (j := j) gV hVMono k).1 =
      k.1 + (j - gV ⟨k.1 + 1, Nat.succ_lt_succ k.2⟩) := rfl

theorem originConnectedHullCutSetCandidatesInCutCardBoxAxisAnchored_card_le_binom_of_diag
    {m i j : ℕ}
    (hdiag : m = i + j + 2) :
    (originConnectedHullCutSetCandidatesInCutCardBoxAxisAnchored m i j).card ≤
      Nat.choose (i + j) i := by
  classical
  let S := originConnectedHullCutSetCandidatesInCutCardBoxAxisAnchored m i j
  let code : S → Fin i ↪o Fin (i + j) := fun s =>
    let prof := axisAnchoredDiagHullProfileOfMem (s := s.1) s.2 hdiag
    axisAnchoredDiagStaircaseCode (j := j) prof.gV prof.hVMono
  have hcode_inj : Function.Injective code := by
    intro sx sy hcode
    let profx := axisAnchoredDiagHullProfileOfMem (s := sx.1) sx.2 hdiag
    let profy := axisAnchoredDiagHullProfileOfMem (s := sy.1) sy.2 hdiag
    have hgVx0 : profx.gV 0 = j := by
      have hvert : GridClauseId.vertical 0 j ∈ (sx : Finset GridClauseId) :=
        (Finset.mem_filter.1 sx.2).2.2
      rw [profx.hEq] at hvert
      rcases Finset.mem_union.1 hvert with hvert | hvert
      · rcases Finset.mem_image.1 hvert with ⟨c, _hc, hcEq⟩
        cases c using Fin.cases with
        | zero =>
            simpa using congrArg
              (fun d =>
                match d with
                | GridClauseId.vertical _ jj => jj
                | _ => 0) hcEq
        | succ c =>
            simp at hcEq
      · rcases Finset.mem_image.1 hvert with ⟨r, _hr, hrEq⟩
        simp at hrEq
    have hgVy0 : profy.gV 0 = j := by
      have hvert : GridClauseId.vertical 0 j ∈ (sy : Finset GridClauseId) :=
        (Finset.mem_filter.1 sy.2).2.2
      rw [profy.hEq] at hvert
      rcases Finset.mem_union.1 hvert with hvert | hvert
      · rcases Finset.mem_image.1 hvert with ⟨c, _hc, hcEq⟩
        cases c using Fin.cases with
        | zero =>
            simpa using congrArg
              (fun d =>
                match d with
                | GridClauseId.vertical _ jj => jj
                | _ => 0) hcEq
        | succ c =>
            simp at hcEq
      · rcases Finset.mem_image.1 hvert with ⟨r, _hr, hrEq⟩
        simp at hrEq
    have hgVSucc :
        ∀ k : Fin i,
          profx.gV ⟨k.1 + 1, Nat.succ_lt_succ k.2⟩ =
            profy.gV ⟨k.1 + 1, Nat.succ_lt_succ k.2⟩ := by
      intro k
      let codex :=
        axisAnchoredDiagStaircaseCode (j := j) profx.gV profx.hVMono
      let codey :=
        axisAnchoredDiagStaircaseCode (j := j) profy.gV profy.hVMono
      have hk : codex k = codey k := by
        simpa [code, codex, codey, profx, profy] using congrArg (fun f => f k) hcode
      have hkVal : (codex k).1 = (codey k).1 := by
        simpa using congrArg Fin.val hk
      rw [axisAnchoredDiagStaircaseCode_apply, axisAnchoredDiagStaircaseCode_apply] at hkVal
      have hboundx : profx.gV ⟨k.1 + 1, Nat.succ_lt_succ k.2⟩ ≤ j :=
        profx.hVBound _
      have hboundy : profy.gV ⟨k.1 + 1, Nat.succ_lt_succ k.2⟩ ≤ j :=
        profy.hVBound _
      omega
    have hgV :
        ∀ c : Fin (i + 1), profx.gV c = profy.gV c := by
      intro c
      cases c using Fin.cases with
      | zero =>
          exact hgVx0.trans hgVy0.symm
      | succ k =>
          exact hgVSucc k
    have hgH :
        ∀ r : Fin (j + 1), profx.gH r = profy.gH r := by
      intro r
      have hxy : profx.gH r ≤ profy.gH r := by
        let c : Fin (i + 1) :=
          ⟨profx.gH r, lt_of_le_of_lt (profx.hHBound r) (Nat.lt_succ_self i)⟩
        have hcIn : (c.1, r.1) ∈ profx.hull := by
          change (profx.gH r, r.1) ∈ profx.hull
          exact (profx.hRowExact r (profx.gH r)).2 le_rfl
        have hcle : r.1 ≤ profx.gV c := (profx.hColExact c r.1).1 hcIn
        have hcIn' : (c.1, r.1) ∈ profy.hull := by
          exact (profy.hColExact c r.1).2 (by simpa [hgV c] using hcle)
        exact (profy.hRowExact r c.1).1 hcIn'
      have hyx : profy.gH r ≤ profx.gH r := by
        let c : Fin (i + 1) :=
          ⟨profy.gH r, lt_of_le_of_lt (profy.hHBound r) (Nat.lt_succ_self i)⟩
        have hcIn : (c.1, r.1) ∈ profy.hull := by
          change (profy.gH r, r.1) ∈ profy.hull
          exact (profy.hRowExact r (profy.gH r)).2 le_rfl
        have hcle : r.1 ≤ profy.gV c := (profy.hColExact c r.1).1 hcIn
        have hcIn' : (c.1, r.1) ∈ profx.hull := by
          exact (profx.hColExact c r.1).2 (by simpa [hgV c] using hcle)
        exact (profx.hRowExact r c.1).1 hcIn'
      exact le_antisymm hxy hyx
    have hgVfun : profx.gV = profy.gV := funext hgV
    have hgHfun : profx.gH = profy.gH := funext hgH
    apply Subtype.ext
    rw [profx.hEq, profy.hEq]
    simp [profx, profy, hgVfun, hgHfun]
  have hcardSubtype : Fintype.card S = S.card := by
    exact Fintype.card_coe S
  have hEmbCard : Fintype.card (Fin i ↪o Fin (i + j)) = Nat.choose (i + j) i := by
    rw [Fintype.card_eq_nat_card]
    calc
      Nat.card (Fin i ↪o Fin (i + j))
          = Nat.card (Set.powersetCard (Fin (i + j)) i) := by
              exact Nat.card_congr Set.powersetCard.ofFinEmbEquiv
      _ = Nat.choose (Nat.card (Fin (i + j))) i := by
            simpa using (Set.powersetCard.card (α := Fin (i + j)) (n := i))
      _ = Nat.choose (i + j) i := by
            simp
  have hle :
      S.card ≤ Nat.choose (i + j) i := by
    calc
      S.card = Fintype.card S := hcardSubtype.symm
      _ ≤ Fintype.card (Fin i ↪o Fin (i + j)) :=
        Fintype.card_le_of_injective code hcode_inj
      _ = Nat.choose (i + j) i := hEmbCard
  simpa [S] using hle

theorem choose_add_left_le_two_pow (i j : ℕ) :
    Nat.choose (i + j) i ≤ 2 ^ (i + j) := by
  have hi : i ∈ Finset.range (i + j + 1) := Finset.mem_range.mpr (by omega)
  calc
    Nat.choose (i + j) i ≤
        ∑ k ∈ Finset.range (i + j + 1), Nat.choose (i + j) k := by
          exact Finset.single_le_sum (fun _ _ => Nat.zero_le _) hi
    _ = 2 ^ (i + j) := Nat.sum_range_choose (i + j)

theorem originConnectedHullCutSetCandidatesInCutCardBoxAxisAnchored_card_le_two_pow_of_diag
    {m i j : ℕ}
    (hdiag : m = i + j + 2) :
    (originConnectedHullCutSetCandidatesInCutCardBoxAxisAnchored m i j).card ≤ 2 ^ m := by
  calc
    (originConnectedHullCutSetCandidatesInCutCardBoxAxisAnchored m i j).card ≤
        Nat.choose (i + j) i :=
      originConnectedHullCutSetCandidatesInCutCardBoxAxisAnchored_card_le_binom_of_diag hdiag
    _ ≤ 2 ^ (i + j) :=
      choose_add_left_le_two_pow i j
    _ ≤ 2 ^ m := by
      exact Nat.pow_le_pow_right (by decide) (by omega)

theorem originConnectedHullCutSetCandidatesInCutCardBoxAxisAnchored_card_le_geometricBound_two_of_diag
    {m i j : ℕ}
    (hdiag : m = i + j + 2) :
    (((originConnectedHullCutSetCandidatesInCutCardBoxAxisAnchored m i j).card : ENNReal)) ≤
      ((2 : ENNReal) ^ m) := by
  exact_mod_cast
    originConnectedHullCutSetCandidatesInCutCardBoxAxisAnchored_card_le_two_pow_of_diag
      (m := m) (i := i) (j := j) hdiag

/-- The four lattice directions used by the crude walk-code carrier for
connected cut sets. -/
inductive CutWalkMove where
  | north
  | south
  | east
  | west
deriving DecidableEq, Fintype

/-- A one-bit tag recording whether a walk step discovers a fresh clause or
revisits an already seen one. This keeps the first contour carrier deliberately
coarse: exact geometry will come from the injection theorem, not from the
carrier itself. -/
inductive CutWalkVisitTag where
  | fresh
  | revisit
deriving DecidableEq, Fintype

/-- A crude length-`2m` walk code over an 8-symbol alphabet. This is the
planned carrier for a future DFS-style encoding of connected cut sets; its
cardinality is exactly `64^m`. -/
abbrev CutWalkCode (m : ℕ) := Fin (2 * m) → (CutWalkMove × CutWalkVisitTag)

/-- The canonical dual-grid start point for the bottom-row horizontal root
`GridClauseId.horizontal i 0`. The first northward fresh step crosses that root
clause. -/
def cutWalkRoot (i : ℕ) : GridNode :=
  (i, 0)

/-- Move one half-step in the dual grid. South and west are total by truncating at
the coordinate axes; valid contour encodings never use those truncated moves at
the boundary. -/
def cutWalkMoveTarget : GridNode → CutWalkMove → GridNode
  | (i, j), .north => (i, j + 1)
  | (i, j), .south => (i, j.pred)
  | (i, j), .east => (i + 1, j)
  | (i, j), .west => (i.pred, j)

/-- Replay a short list of ordinary dual-grid moves from a starting node. This
is the bridge primitive for star-adjacent contour clauses: a king-adjacent
endpoint pair costs at most two ordinary half-steps. -/
def cutWalkMoveListTarget : GridNode → List CutWalkMove → GridNode
  | p, [] => p
  | p, move :: moves => cutWalkMoveListTarget (cutWalkMoveTarget p move) moves

def cutWalkMoveValidAt : GridNode → CutWalkMove → Prop
  | _, .north => True
  | (_, j), .south => 0 < j
  | _, .east => True
  | (i, _), .west => 0 < i

def cutWalkMoveListValidFrom : GridNode → List CutWalkMove → Prop
  | _, [] => True
  | p, move :: moves =>
      cutWalkMoveValidAt p move ∧
        cutWalkMoveListValidFrom (cutWalkMoveTarget p move) moves

theorem cutWalkMoveListTarget_append
    (p : GridNode) (moves₁ moves₂ : List CutWalkMove) :
    cutWalkMoveListTarget p (moves₁ ++ moves₂) =
      cutWalkMoveListTarget (cutWalkMoveListTarget p moves₁) moves₂ := by
  induction moves₁ generalizing p with
  | nil => simp [cutWalkMoveListTarget]
  | cons move moves ih => simp [cutWalkMoveListTarget, ih]

theorem cutWalkMoveListValidFrom_append
    {p : GridNode} {moves₁ moves₂ : List CutWalkMove}
    (hvalid₁ : cutWalkMoveListValidFrom p moves₁)
    (hvalid₂ : cutWalkMoveListValidFrom (cutWalkMoveListTarget p moves₁) moves₂) :
    cutWalkMoveListValidFrom p (moves₁ ++ moves₂) := by
  induction moves₁ generalizing p with
  | nil => simpa [cutWalkMoveListTarget] using hvalid₂
  | cons move moves ih =>
      rcases hvalid₁ with ⟨hmove, hmoves⟩
      exact ⟨hmove, ih hmoves hvalid₂⟩

theorem exists_cutWalkMoveListTarget_of_gridNodeStarAdjacent
    {p q : GridNode} (hstar : gridNodeStarAdjacent p q) :
    ∃ moves : List CutWalkMove,
      moves.length ≤ 2 ∧ cutWalkMoveListTarget p moves = q := by
  rcases p with ⟨pi, pj⟩
  rcases q with ⟨qi, qj⟩
  rcases hstar with ⟨hpi, hqi, hpj, hqj⟩
  rcases Nat.lt_trichotomy pi qi with hix | hix | hix
  · have hqiEq : qi = pi + 1 := by omega
    subst hqiEq
    rcases Nat.lt_trichotomy pj qj with hjy | hjy | hjy
    · have hqjEq : qj = pj + 1 := by omega
      subst hqjEq
      refine ⟨[CutWalkMove.east, CutWalkMove.north], by decide, ?_⟩
      simp [cutWalkMoveListTarget, cutWalkMoveTarget]
    · subst hjy
      refine ⟨[CutWalkMove.east], by decide, ?_⟩
      simp [cutWalkMoveListTarget, cutWalkMoveTarget]
    · have hpjEq : pj = qj + 1 := by omega
      subst hpjEq
      refine ⟨[CutWalkMove.east, CutWalkMove.south], by decide, ?_⟩
      simp [cutWalkMoveListTarget, cutWalkMoveTarget]
  · subst hix
    rcases Nat.lt_trichotomy pj qj with hjy | hjy | hjy
    · have hqjEq : qj = pj + 1 := by omega
      subst hqjEq
      refine ⟨[CutWalkMove.north], by decide, ?_⟩
      simp [cutWalkMoveListTarget, cutWalkMoveTarget]
    · subst hjy
      refine ⟨[], by decide, ?_⟩
      simp [cutWalkMoveListTarget]
    · have hpjEq : pj = qj + 1 := by omega
      subst hpjEq
      refine ⟨[CutWalkMove.south], by decide, ?_⟩
      simp [cutWalkMoveListTarget, cutWalkMoveTarget]
  · have hpiEq : pi = qi + 1 := by omega
    subst hpiEq
    rcases Nat.lt_trichotomy pj qj with hjy | hjy | hjy
    · have hqjEq : qj = pj + 1 := by omega
      subst hqjEq
      refine ⟨[CutWalkMove.west, CutWalkMove.north], by decide, ?_⟩
      simp [cutWalkMoveListTarget, cutWalkMoveTarget]
    · subst hjy
      refine ⟨[CutWalkMove.west], by decide, ?_⟩
      simp [cutWalkMoveListTarget, cutWalkMoveTarget]
    · have hpjEq : pj = qj + 1 := by omega
      subst hpjEq
      refine ⟨[CutWalkMove.west, CutWalkMove.south], by decide, ?_⟩
      simp [cutWalkMoveListTarget, cutWalkMoveTarget]

theorem exists_cutWalkMoveListTarget_between_gridClauseDualEndpoints
    {c : GridClauseId} {p q : GridNode}
    (hp : p ∈ gridClauseDualEndpoints c)
    (hq : q ∈ gridClauseDualEndpoints c) :
    ∃ moves : List CutWalkMove,
      moves.length ≤ 1 ∧ cutWalkMoveListTarget p moves = q := by
  cases c with
  | prior i j => simp [gridClauseDualEndpoints] at hp
  | horizontal i j =>
      simp [gridClauseDualEndpoints] at hp hq
      rcases hp with rfl | rfl <;> rcases hq with rfl | rfl
      · exact ⟨[], by decide, by simp [cutWalkMoveListTarget]⟩
      · exact ⟨[CutWalkMove.north], by decide,
          by simp [cutWalkMoveListTarget, cutWalkMoveTarget]⟩
      · exact ⟨[CutWalkMove.south], by decide,
          by simp [cutWalkMoveListTarget, cutWalkMoveTarget]⟩
      · exact ⟨[], by decide, by simp [cutWalkMoveListTarget]⟩
  | vertical i j =>
      simp [gridClauseDualEndpoints] at hp hq
      rcases hp with rfl | rfl <;> rcases hq with rfl | rfl
      · exact ⟨[], by decide, by simp [cutWalkMoveListTarget]⟩
      · exact ⟨[CutWalkMove.east], by decide,
          by simp [cutWalkMoveListTarget, cutWalkMoveTarget]⟩
      · exact ⟨[CutWalkMove.west], by decide,
          by simp [cutWalkMoveListTarget, cutWalkMoveTarget]⟩
      · exact ⟨[], by decide, by simp [cutWalkMoveListTarget]⟩

theorem exists_cutWalkMoveListTarget_of_gridClauseStarAdjacent_endpoint
    {c₁ c₂ : GridClauseId} {p : GridNode}
    (hp : p ∈ gridClauseDualEndpoints c₁)
    (hadj : gridClauseStarAdjacent c₁ c₂) :
    ∃ q ∈ gridClauseDualEndpoints c₂,
      ∃ moves : List CutWalkMove,
        moves.length ≤ 3 ∧ cutWalkMoveListTarget p moves = q := by
  rcases hadj with ⟨p', hp', q, hq, hpq⟩
  rcases exists_cutWalkMoveListTarget_between_gridClauseDualEndpoints hp hp' with
    ⟨moves₁, hlen₁, htarget₁⟩
  rcases exists_cutWalkMoveListTarget_of_gridNodeStarAdjacent hpq with
    ⟨moves₂, hlen₂, htarget₂⟩
  refine ⟨q, hq, moves₁ ++ moves₂, ?_, ?_⟩
  · simp only [List.length_append]
    omega
  · rw [cutWalkMoveListTarget_append, htarget₁, htarget₂]

theorem exists_valid_cutWalkMoveListTarget_of_gridNodeStarAdjacent
    {p q : GridNode} (hstar : gridNodeStarAdjacent p q) :
    ∃ moves : List CutWalkMove,
      moves.length ≤ 2 ∧ cutWalkMoveListValidFrom p moves ∧
        cutWalkMoveListTarget p moves = q := by
  rcases p with ⟨pi, pj⟩
  rcases q with ⟨qi, qj⟩
  rcases hstar with ⟨hpi, hqi, hpj, hqj⟩
  rcases Nat.lt_trichotomy pi qi with hix | hix | hix
  · have hqiEq : qi = pi + 1 := by omega
    subst hqiEq
    rcases Nat.lt_trichotomy pj qj with hjy | hjy | hjy
    · have hqjEq : qj = pj + 1 := by omega
      subst hqjEq
      refine ⟨[CutWalkMove.east, CutWalkMove.north], by decide, ?_, ?_⟩
      · simp [cutWalkMoveListValidFrom, cutWalkMoveValidAt]
      · simp [cutWalkMoveListTarget, cutWalkMoveTarget]
    · subst hjy
      refine ⟨[CutWalkMove.east], by decide, ?_, ?_⟩
      · simp [cutWalkMoveListValidFrom, cutWalkMoveValidAt]
      · simp [cutWalkMoveListTarget, cutWalkMoveTarget]
    · have hpjEq : pj = qj + 1 := by omega
      subst hpjEq
      refine ⟨[CutWalkMove.east, CutWalkMove.south], by decide, ?_, ?_⟩
      · simp [cutWalkMoveListValidFrom, cutWalkMoveValidAt, cutWalkMoveTarget]
      · simp [cutWalkMoveListTarget, cutWalkMoveTarget]
  · subst hix
    rcases Nat.lt_trichotomy pj qj with hjy | hjy | hjy
    · have hqjEq : qj = pj + 1 := by omega
      subst hqjEq
      refine ⟨[CutWalkMove.north], by decide, ?_, ?_⟩
      · simp [cutWalkMoveListValidFrom, cutWalkMoveValidAt]
      · simp [cutWalkMoveListTarget, cutWalkMoveTarget]
    · subst hjy
      refine ⟨[], by decide, ?_, ?_⟩
      · simp [cutWalkMoveListValidFrom]
      · simp [cutWalkMoveListTarget]
    · have hpjEq : pj = qj + 1 := by omega
      subst hpjEq
      refine ⟨[CutWalkMove.south], by decide, ?_, ?_⟩
      · simp [cutWalkMoveListValidFrom, cutWalkMoveValidAt]
      · simp [cutWalkMoveListTarget, cutWalkMoveTarget]
  · have hpiEq : pi = qi + 1 := by omega
    subst hpiEq
    rcases Nat.lt_trichotomy pj qj with hjy | hjy | hjy
    · have hqjEq : qj = pj + 1 := by omega
      subst hqjEq
      refine ⟨[CutWalkMove.west, CutWalkMove.north], by decide, ?_, ?_⟩
      · simp [cutWalkMoveListValidFrom, cutWalkMoveValidAt]
      · simp [cutWalkMoveListTarget, cutWalkMoveTarget]
    · subst hjy
      refine ⟨[CutWalkMove.west], by decide, ?_, ?_⟩
      · simp [cutWalkMoveListValidFrom, cutWalkMoveValidAt]
      · simp [cutWalkMoveListTarget, cutWalkMoveTarget]
    · have hpjEq : pj = qj + 1 := by omega
      subst hpjEq
      refine ⟨[CutWalkMove.west, CutWalkMove.south], by decide, ?_, ?_⟩
      · simp [cutWalkMoveListValidFrom, cutWalkMoveValidAt, cutWalkMoveTarget]
      · simp [cutWalkMoveListTarget, cutWalkMoveTarget]

theorem exists_valid_cutWalkMoveListTarget_between_gridClauseDualEndpoints
    {c : GridClauseId} {p q : GridNode}
    (hp : p ∈ gridClauseDualEndpoints c)
    (hq : q ∈ gridClauseDualEndpoints c) :
    ∃ moves : List CutWalkMove,
      moves.length ≤ 1 ∧ cutWalkMoveListValidFrom p moves ∧
        cutWalkMoveListTarget p moves = q := by
  cases c with
  | prior i j => simp [gridClauseDualEndpoints] at hp
  | horizontal i j =>
      simp [gridClauseDualEndpoints] at hp hq
      rcases hp with rfl | rfl <;> rcases hq with rfl | rfl
      · exact ⟨[], by decide, by simp [cutWalkMoveListValidFrom],
          by simp [cutWalkMoveListTarget]⟩
      · exact ⟨[CutWalkMove.north], by decide,
          by simp [cutWalkMoveListValidFrom, cutWalkMoveValidAt],
          by simp [cutWalkMoveListTarget, cutWalkMoveTarget]⟩
      · exact ⟨[CutWalkMove.south], by decide,
          by simp [cutWalkMoveListValidFrom, cutWalkMoveValidAt],
          by simp [cutWalkMoveListTarget, cutWalkMoveTarget]⟩
      · exact ⟨[], by decide, by simp [cutWalkMoveListValidFrom],
          by simp [cutWalkMoveListTarget]⟩
  | vertical i j =>
      simp [gridClauseDualEndpoints] at hp hq
      rcases hp with rfl | rfl <;> rcases hq with rfl | rfl
      · exact ⟨[], by decide, by simp [cutWalkMoveListValidFrom],
          by simp [cutWalkMoveListTarget]⟩
      · exact ⟨[CutWalkMove.east], by decide,
          by simp [cutWalkMoveListValidFrom, cutWalkMoveValidAt],
          by simp [cutWalkMoveListTarget, cutWalkMoveTarget]⟩
      · exact ⟨[CutWalkMove.west], by decide,
          by simp [cutWalkMoveListValidFrom, cutWalkMoveValidAt],
          by simp [cutWalkMoveListTarget, cutWalkMoveTarget]⟩
      · exact ⟨[], by decide, by simp [cutWalkMoveListValidFrom],
          by simp [cutWalkMoveListTarget]⟩

theorem exists_valid_cutWalkMoveListTarget_of_gridClauseStarAdjacent_endpoint
    {c₁ c₂ : GridClauseId} {p : GridNode}
    (hp : p ∈ gridClauseDualEndpoints c₁)
    (hadj : gridClauseStarAdjacent c₁ c₂) :
    ∃ q ∈ gridClauseDualEndpoints c₂,
      ∃ moves : List CutWalkMove,
        moves.length ≤ 3 ∧ cutWalkMoveListValidFrom p moves ∧
          cutWalkMoveListTarget p moves = q := by
  rcases hadj with ⟨p', hp', q, hq, hpq⟩
  rcases exists_valid_cutWalkMoveListTarget_between_gridClauseDualEndpoints hp hp' with
    ⟨moves₁, hlen₁, hvalid₁, htarget₁⟩
  rcases exists_valid_cutWalkMoveListTarget_of_gridNodeStarAdjacent hpq with
    ⟨moves₂, hlen₂, hvalid₂, htarget₂⟩
  refine ⟨q, hq, moves₁ ++ moves₂, ?_, ?_, ?_⟩
  · simp only [List.length_append]
    omega
  · apply cutWalkMoveListValidFrom_append hvalid₁
    simpa [htarget₁] using hvalid₂
  · rw [cutWalkMoveListTarget_append, htarget₁, htarget₂]

/-- The primal grid clause crossed by a dual half-step. -/
def cutWalkMoveClause : GridNode → CutWalkMove → GridClauseId
  | (i, j), .north => GridClauseId.horizontal i j
  | (i, j), .south => GridClauseId.horizontal i j.pred
  | (i, j), .east => GridClauseId.vertical i j
  | (i, j), .west => GridClauseId.vertical i.pred j

/-- The move that crosses a chosen clause when replay begins at one of its dual
endpoints. This is the local inverse to `cutWalkMoveClause` used by the future
contour decoder. -/
def cutWalkMoveFromClauseEndpoint : GridClauseId → GridNode → CutWalkMove
  | .prior _ _, _ => .north
  | .horizontal i j, p => if p = (i, j) then .north else .south
  | .vertical i j, p => if p = (i, j) then .east else .west

theorem cutWalkMoveFromClauseEndpoint_cutWalkMoveClause_of_valid
    {p : GridNode} {move : CutWalkMove}
    (hvalid : cutWalkMoveValidAt p move) :
    cutWalkMoveFromClauseEndpoint (cutWalkMoveClause p move) p = move := by
  rcases p with ⟨i, j⟩
  cases move <;> simp [cutWalkMoveValidAt, cutWalkMoveClause,
    cutWalkMoveFromClauseEndpoint] at hvalid ⊢
  · omega
  · omega

@[simp] theorem cutWalkRoot_mem_horizontal_zero_dualEndpoints
    (i : ℕ) :
    cutWalkRoot i ∈ gridClauseDualEndpoints (GridClauseId.horizontal i 0) := by
  simp [cutWalkRoot, gridClauseDualEndpoints]

@[simp] theorem cutWalkMoveFromClauseEndpoint_horizontal_zero_cutWalkRoot
    (i : ℕ) :
    cutWalkMoveFromClauseEndpoint (GridClauseId.horizontal i 0) (cutWalkRoot i) =
      CutWalkMove.north := by
  simp [cutWalkMoveFromClauseEndpoint, cutWalkRoot]

theorem cutWalkMoveClause_horizontal_zero_cutWalkRoot
    (i : ℕ) :
    cutWalkMoveClause (cutWalkRoot i)
        (cutWalkMoveFromClauseEndpoint (GridClauseId.horizontal i 0) (cutWalkRoot i)) =
      GridClauseId.horizontal i 0 := by
  simp [cutWalkMoveFromClauseEndpoint, cutWalkRoot, cutWalkMoveClause]

theorem cutWalkMoveClause_cutWalkMoveFromClauseEndpoint
    {c : GridClauseId} {p : GridNode}
    (hp : p ∈ gridClauseDualEndpoints c) :
    cutWalkMoveClause p (cutWalkMoveFromClauseEndpoint c p) = c := by
  cases c with
  | prior i j =>
      simp [gridClauseDualEndpoints] at hp
  | horizontal i j =>
      rcases p with ⟨a, b⟩
      simp [gridClauseDualEndpoints] at hp
      rcases hp with hp | hp
      · rcases hp with ⟨rfl, rfl⟩
        simp [cutWalkMoveFromClauseEndpoint, cutWalkMoveClause]
      · rcases hp with ⟨rfl, rfl⟩
        simp [cutWalkMoveFromClauseEndpoint, cutWalkMoveClause]
  | vertical i j =>
      rcases p with ⟨a, b⟩
      simp [gridClauseDualEndpoints] at hp
      rcases hp with hp | hp
      · rcases hp with ⟨rfl, rfl⟩
        simp [cutWalkMoveFromClauseEndpoint, cutWalkMoveClause]
      · rcases hp with ⟨rfl, rfl⟩
        simp [cutWalkMoveFromClauseEndpoint, cutWalkMoveClause]

theorem cutWalkMoveFromClauseEndpoint_target_mem_dualEndpoints
    {c : GridClauseId} {p : GridNode}
    (hp : p ∈ gridClauseDualEndpoints c) :
    cutWalkMoveTarget p (cutWalkMoveFromClauseEndpoint c p) ∈
      gridClauseDualEndpoints c := by
  cases c with
  | prior i j =>
      simp [gridClauseDualEndpoints] at hp
  | horizontal i j =>
      rcases p with ⟨a, b⟩
      simp [gridClauseDualEndpoints] at hp
      rcases hp with hp | hp
      · rcases hp with ⟨rfl, rfl⟩
        simp [cutWalkMoveFromClauseEndpoint, cutWalkMoveTarget, gridClauseDualEndpoints]
      · rcases hp with ⟨rfl, rfl⟩
        simp [cutWalkMoveFromClauseEndpoint, cutWalkMoveTarget, gridClauseDualEndpoints]
  | vertical i j =>
      rcases p with ⟨a, b⟩
      simp [gridClauseDualEndpoints] at hp
      rcases hp with hp | hp
      · rcases hp with ⟨rfl, rfl⟩
        simp [cutWalkMoveFromClauseEndpoint, cutWalkMoveTarget, gridClauseDualEndpoints]
      · rcases hp with ⟨rfl, rfl⟩
        simp [cutWalkMoveFromClauseEndpoint, cutWalkMoveTarget, gridClauseDualEndpoints]

theorem cutWalkMoveFromClauseEndpoint_target_target
    {c : GridClauseId} {p : GridNode}
    (hp : p ∈ gridClauseDualEndpoints c) :
    cutWalkMoveTarget
        (cutWalkMoveTarget p (cutWalkMoveFromClauseEndpoint c p))
        (cutWalkMoveFromClauseEndpoint c
          (cutWalkMoveTarget p (cutWalkMoveFromClauseEndpoint c p))) =
      p := by
  cases c with
  | prior i j =>
      simp [gridClauseDualEndpoints] at hp
  | horizontal i j =>
      rcases p with ⟨a, b⟩
      simp [gridClauseDualEndpoints] at hp
      rcases hp with hp | hp
      · rcases hp with ⟨rfl, rfl⟩
        simp [cutWalkMoveFromClauseEndpoint, cutWalkMoveTarget]
      · rcases hp with ⟨rfl, rfl⟩
        simp [cutWalkMoveFromClauseEndpoint, cutWalkMoveTarget]
  | vertical i j =>
      rcases p with ⟨a, b⟩
      simp [gridClauseDualEndpoints] at hp
      rcases hp with hp | hp
      · rcases hp with ⟨rfl, rfl⟩
        simp [cutWalkMoveFromClauseEndpoint, cutWalkMoveTarget]
      · rcases hp with ⟨rfl, rfl⟩
        simp [cutWalkMoveFromClauseEndpoint, cutWalkMoveTarget]

theorem eq_or_eq_cutWalkMoveTarget_of_mem_dualEndpoints
    {c : GridClauseId} {p q : GridNode}
    (hp : p ∈ gridClauseDualEndpoints c)
    (hq : q ∈ gridClauseDualEndpoints c) :
    q = p ∨ q = cutWalkMoveTarget p (cutWalkMoveFromClauseEndpoint c p) := by
  cases c with
  | prior i j =>
      simp [gridClauseDualEndpoints] at hp
  | horizontal i j =>
      rcases p with ⟨a, b⟩
      rcases q with ⟨a', b'⟩
      simp [gridClauseDualEndpoints] at hp hq
      rcases hp with hp | hp <;> rcases hq with hq | hq
      · rcases hp with ⟨rfl, rfl⟩
        rcases hq with ⟨rfl, rfl⟩
        simp
      · rcases hp with ⟨rfl, rfl⟩
        rcases hq with ⟨rfl, rfl⟩
        simp [cutWalkMoveFromClauseEndpoint, cutWalkMoveTarget]
      · rcases hp with ⟨rfl, rfl⟩
        rcases hq with ⟨rfl, rfl⟩
        simp [cutWalkMoveFromClauseEndpoint, cutWalkMoveTarget]
      · rcases hp with ⟨rfl, rfl⟩
        rcases hq with ⟨rfl, rfl⟩
        simp
  | vertical i j =>
      rcases p with ⟨a, b⟩
      rcases q with ⟨a', b'⟩
      simp [gridClauseDualEndpoints] at hp hq
      rcases hp with hp | hp <;> rcases hq with hq | hq
      · rcases hp with ⟨rfl, rfl⟩
        rcases hq with ⟨rfl, rfl⟩
        simp
      · rcases hp with ⟨rfl, rfl⟩
        rcases hq with ⟨rfl, rfl⟩
        simp [cutWalkMoveFromClauseEndpoint, cutWalkMoveTarget]
      · rcases hp with ⟨rfl, rfl⟩
        rcases hq with ⟨rfl, rfl⟩
        simp [cutWalkMoveFromClauseEndpoint, cutWalkMoveTarget]
      · rcases hp with ⟨rfl, rfl⟩
        rcases hq with ⟨rfl, rfl⟩
        simp

theorem dualAdjacent_source_or_target_mem
    {c₁ c₂ : GridClauseId} {p : GridNode}
    (hp : p ∈ gridClauseDualEndpoints c₁)
    (hadj : gridClauseDualAdjacent c₁ c₂) :
    p ∈ gridClauseDualEndpoints c₂ ∨
      cutWalkMoveTarget p (cutWalkMoveFromClauseEndpoint c₁ p) ∈
        gridClauseDualEndpoints c₂ := by
  rcases hadj with ⟨q, hq₁, hq₂⟩
  rcases eq_or_eq_cutWalkMoveTarget_of_mem_dualEndpoints hp hq₁ with hq | hq
  · left
    simpa [hq] using hq₂
  · right
    simpa [hq] using hq₂

theorem dualAdjacent_cross_next_or_backtrack
    {c₁ c₂ : GridClauseId} {p : GridNode}
    (hp : p ∈ gridClauseDualEndpoints c₁)
    (hadj : gridClauseDualAdjacent c₁ c₂) :
    cutWalkMoveClause
          (cutWalkMoveTarget p (cutWalkMoveFromClauseEndpoint c₁ p))
          (cutWalkMoveFromClauseEndpoint c₂
            (cutWalkMoveTarget p (cutWalkMoveFromClauseEndpoint c₁ p))) =
        c₂ ∨
      (cutWalkMoveClause
            (cutWalkMoveTarget p (cutWalkMoveFromClauseEndpoint c₁ p))
            (cutWalkMoveFromClauseEndpoint c₁
              (cutWalkMoveTarget p (cutWalkMoveFromClauseEndpoint c₁ p))) =
          c₁ ∧
        cutWalkMoveTarget
            (cutWalkMoveTarget p (cutWalkMoveFromClauseEndpoint c₁ p))
            (cutWalkMoveFromClauseEndpoint c₁
              (cutWalkMoveTarget p (cutWalkMoveFromClauseEndpoint c₁ p))) =
          p ∧
        cutWalkMoveClause p (cutWalkMoveFromClauseEndpoint c₂ p) = c₂) := by
  rcases dualAdjacent_source_or_target_mem hp hadj with hp₂ | htarget₂
  · right
    have htarget₁ :
        cutWalkMoveTarget p (cutWalkMoveFromClauseEndpoint c₁ p) ∈
          gridClauseDualEndpoints c₁ :=
      cutWalkMoveFromClauseEndpoint_target_mem_dualEndpoints hp
    exact ⟨cutWalkMoveClause_cutWalkMoveFromClauseEndpoint htarget₁,
      cutWalkMoveFromClauseEndpoint_target_target hp,
      cutWalkMoveClause_cutWalkMoveFromClauseEndpoint hp₂⟩
  · left
    exact cutWalkMoveClause_cutWalkMoveFromClauseEndpoint htarget₂

theorem dualAdjacent_follow_direct_or_backtrack
    {c₁ c₂ : GridClauseId} {p : GridNode}
    (hp : p ∈ gridClauseDualEndpoints c₁)
    (hadj : gridClauseDualAdjacent c₁ c₂) :
    (cutWalkMoveTarget p (cutWalkMoveFromClauseEndpoint c₁ p) ∈
        gridClauseDualEndpoints c₂ ∧
      cutWalkMoveClause
          (cutWalkMoveTarget p (cutWalkMoveFromClauseEndpoint c₁ p))
          (cutWalkMoveFromClauseEndpoint c₂
            (cutWalkMoveTarget p (cutWalkMoveFromClauseEndpoint c₁ p))) =
        c₂) ∨
      (cutWalkMoveTarget p (cutWalkMoveFromClauseEndpoint c₁ p) ∈
          gridClauseDualEndpoints c₁ ∧
        cutWalkMoveTarget
            (cutWalkMoveTarget p (cutWalkMoveFromClauseEndpoint c₁ p))
            (cutWalkMoveFromClauseEndpoint c₁
              (cutWalkMoveTarget p (cutWalkMoveFromClauseEndpoint c₁ p))) =
          p ∧
        p ∈ gridClauseDualEndpoints c₂ ∧
        cutWalkMoveClause p (cutWalkMoveFromClauseEndpoint c₂ p) = c₂) := by
  rcases dualAdjacent_source_or_target_mem hp hadj with hp₂ | htarget₂
  · right
    exact
      ⟨cutWalkMoveFromClauseEndpoint_target_mem_dualEndpoints hp,
        cutWalkMoveFromClauseEndpoint_target_target hp,
        hp₂,
        cutWalkMoveClause_cutWalkMoveFromClauseEndpoint hp₂⟩
  · left
    exact ⟨htarget₂, cutWalkMoveClause_cutWalkMoveFromClauseEndpoint htarget₂⟩

theorem cutWalkMoveClause_source_mem_dualEndpoints
    (p : GridNode) (move : CutWalkMove) :
    p ∈ gridClauseDualEndpoints (cutWalkMoveClause p move) := by
  rcases p with ⟨i, j⟩
  cases move
  · simp [cutWalkMoveClause, gridClauseDualEndpoints]
  · cases j <;> simp [cutWalkMoveClause, gridClauseDualEndpoints]
  · simp [cutWalkMoveClause, gridClauseDualEndpoints]
  · cases i <;> simp [cutWalkMoveClause, gridClauseDualEndpoints]

theorem cutWalkMoveClause_target_mem_dualEndpoints
    (p : GridNode) (move : CutWalkMove) :
    cutWalkMoveTarget p move ∈
      gridClauseDualEndpoints (cutWalkMoveClause p move) := by
  rcases p with ⟨i, j⟩
  cases move
  · simp [cutWalkMoveTarget, cutWalkMoveClause, gridClauseDualEndpoints]
  · cases j <;> simp [cutWalkMoveTarget, cutWalkMoveClause, gridClauseDualEndpoints]
  · simp [cutWalkMoveTarget, cutWalkMoveClause, gridClauseDualEndpoints]
  · cases i <;> simp [cutWalkMoveTarget, cutWalkMoveClause, gridClauseDualEndpoints]

theorem cutWalkMoveClause_dualAdjacent_next
    (p : GridNode) (move nextMove : CutWalkMove) :
    gridClauseDualAdjacent
      (cutWalkMoveClause p move)
      (cutWalkMoveClause (cutWalkMoveTarget p move) nextMove) := by
  refine ⟨cutWalkMoveTarget p move, ?_, ?_⟩
  · exact cutWalkMoveClause_target_mem_dualEndpoints p move
  · exact cutWalkMoveClause_source_mem_dualEndpoints
      (cutWalkMoveTarget p move) nextMove

/-- The node sequence obtained by repeatedly crossing the same dual edge. This
is the padding/base primitive for replay traces: once a trace is at an endpoint
of a clause, it can keep bouncing across that clause without leaving it. -/
def cutWalkBounceNode (c : GridClauseId) (p : GridNode) : ℕ → GridNode
  | 0 => p
  | n + 1 =>
      cutWalkMoveTarget (cutWalkBounceNode c p n)
        (cutWalkMoveFromClauseEndpoint c (cutWalkBounceNode c p n))

theorem cutWalkBounceNode_succ
    (c : GridClauseId) (p : GridNode) (n : ℕ) :
    cutWalkBounceNode c p (n + 1) =
      cutWalkMoveTarget (cutWalkBounceNode c p n)
        (cutWalkMoveFromClauseEndpoint c (cutWalkBounceNode c p n)) :=
  rfl

theorem cutWalkBounceNode_mem_dualEndpoints
    {c : GridClauseId} {p : GridNode}
    (hp : p ∈ gridClauseDualEndpoints c) :
    ∀ n, cutWalkBounceNode c p n ∈ gridClauseDualEndpoints c := by
  intro n
  induction n with
  | zero =>
      exact hp
  | succ n ih =>
      rw [cutWalkBounceNode_succ]
      exact cutWalkMoveFromClauseEndpoint_target_mem_dualEndpoints ih

/-- The dual-grid node reached after the first `n` half-steps of a code. -/
def cutWalkTraceNode (m : ℕ) (root : GridNode) (code : CutWalkCode m) :
    ℕ → GridNode
  | 0 => root
  | n + 1 =>
      if h : n < 2 * m then
        cutWalkMoveTarget (cutWalkTraceNode m root code n) (code ⟨n, h⟩).1
      else
        cutWalkTraceNode m root code n

theorem cutWalkTraceNode_succ_of_lt
    {m : ℕ} {root : GridNode} {code : CutWalkCode m} {n : ℕ}
    (hn : n < 2 * m) :
    cutWalkTraceNode m root code (n + 1) =
      cutWalkMoveTarget (cutWalkTraceNode m root code n) (code ⟨n, hn⟩).1 := by
  simp [cutWalkTraceNode, hn]

/-- The clause crossed at a given step of a walk code replayed from the
axis-root dual node. -/
def cutWalkStepClause (m i : ℕ) (code : CutWalkCode m) (k : Fin (2 * m)) :
    GridClauseId :=
  cutWalkMoveClause (cutWalkTraceNode m (cutWalkRoot i) code k.1) (code k).1

theorem cutWalkStepClause_eq_of_moveFromClauseEndpoint
    {m i : ℕ} {code : CutWalkCode m} {k : Fin (2 * m)}
    {c : GridClauseId}
    (hp :
      cutWalkTraceNode m (cutWalkRoot i) code k.1 ∈ gridClauseDualEndpoints c)
    (hmove :
      (code k).1 =
        cutWalkMoveFromClauseEndpoint c
          (cutWalkTraceNode m (cutWalkRoot i) code k.1)) :
    cutWalkStepClause m i code k = c := by
  unfold cutWalkStepClause
  rw [hmove]
  exact cutWalkMoveClause_cutWalkMoveFromClauseEndpoint hp

theorem cutWalkStepClause_dualAdjacent_succ
    {m i : ℕ} (code : CutWalkCode m) {n : ℕ}
    (hn : n + 1 < 2 * m) :
    gridClauseDualAdjacent
      (cutWalkStepClause m i code ⟨n, Nat.lt_trans (Nat.lt_succ_self n) hn⟩)
      (cutWalkStepClause m i code ⟨n + 1, hn⟩) := by
  have hprev : n < 2 * m := Nat.lt_trans (Nat.lt_succ_self n) hn
  change gridClauseDualAdjacent
    (cutWalkMoveClause (cutWalkTraceNode m (cutWalkRoot i) code n) (code ⟨n, hprev⟩).1)
    (cutWalkMoveClause (cutWalkTraceNode m (cutWalkRoot i) code (n + 1))
      (code ⟨n + 1, hn⟩).1)
  simp [cutWalkTraceNode, hprev]
  exact cutWalkMoveClause_dualAdjacent_next
    (cutWalkTraceNode m (cutWalkRoot i) code n)
    (code ⟨n, hprev⟩).1
    (code ⟨n + 1, hn⟩).1

theorem cutWalkStepClause_reachable_from_root
    {m i : ℕ} (code : CutWalkCode m)
    (h0 : 0 < 2 * m)
    (hfirst : code ⟨0, h0⟩ = (CutWalkMove.north, CutWalkVisitTag.fresh)) :
    ∀ (n : ℕ) (hn : n < 2 * m),
      Relation.ReflTransGen gridClauseDualAdjacent
        (GridClauseId.horizontal i 0)
        (cutWalkStepClause m i code ⟨n, hn⟩) := by
  intro n
  induction n with
  | zero =>
      intro hn
      have hclause :
          cutWalkStepClause m i code ⟨0, hn⟩ = GridClauseId.horizontal i 0 := by
        simp [cutWalkStepClause, cutWalkTraceNode, cutWalkRoot, cutWalkMoveClause, hfirst]
      simpa [hclause] using
        (Relation.ReflTransGen.refl :
          Relation.ReflTransGen gridClauseDualAdjacent
            (GridClauseId.horizontal i 0) (GridClauseId.horizontal i 0))
  | succ n ih =>
      intro hn
      have hprev : n < 2 * m := Nat.lt_trans (Nat.lt_succ_self n) hn
      exact Relation.ReflTransGen.tail (ih hprev)
        (cutWalkStepClause_dualAdjacent_succ code hn)

/-- Decode a walk code by replaying it from the axis root and collecting exactly
the clauses crossed by fresh-tagged half-steps. -/
noncomputable def cutWalkDecode (m i _j : ℕ) (code : CutWalkCode m) :
    Finset GridClauseId :=
  ((Finset.univ : Finset (Fin (2 * m))).filter
      (fun k => (code k).2 = CutWalkVisitTag.fresh)).image
    (cutWalkStepClause m i code)

theorem cutWalkStepClause_mem_cutWalkDecode_of_fresh
    {m i j : ℕ} {code : CutWalkCode m} {k : Fin (2 * m)}
    (hfresh : (code k).2 = CutWalkVisitTag.fresh) :
    cutWalkStepClause m i code k ∈ cutWalkDecode m i j code := by
  unfold cutWalkDecode
  refine Finset.mem_image.2 ?_
  exact ⟨k, by simp [hfresh], rfl⟩

theorem cutWalkDecode_subset_of_fresh_step_mem
    {m i j : ℕ} {code : CutWalkCode m} {s : Finset GridClauseId}
    (hmem :
      ∀ k : Fin (2 * m),
        (code k).2 = CutWalkVisitTag.fresh →
          cutWalkStepClause m i code k ∈ s) :
    cutWalkDecode m i j code ⊆ s := by
  intro x hx
  unfold cutWalkDecode at hx
  rcases Finset.mem_image.1 hx with ⟨k, hk, rfl⟩
  exact hmem k (Finset.mem_filter.1 hk).2

theorem subset_cutWalkDecode_of_fresh_step_cover
    {m i j : ℕ} {code : CutWalkCode m} {s : Finset GridClauseId}
    (hcover :
      ∀ x ∈ s,
        ∃ k : Fin (2 * m),
          (code k).2 = CutWalkVisitTag.fresh ∧
            cutWalkStepClause m i code k = x) :
    s ⊆ cutWalkDecode m i j code := by
  intro x hx
  rcases hcover x hx with ⟨k, hfresh, hstep⟩
  rw [← hstep]
  exact cutWalkStepClause_mem_cutWalkDecode_of_fresh
    (m := m) (i := i) (j := j) (code := code) (k := k) hfresh

theorem cutWalkDecode_eq_of_fresh_step_mem_and_cover
    {m i j : ℕ} {code : CutWalkCode m} {s : Finset GridClauseId}
    (hmem :
      ∀ k : Fin (2 * m),
        (code k).2 = CutWalkVisitTag.fresh →
          cutWalkStepClause m i code k ∈ s)
    (hcover :
      ∀ x ∈ s,
        ∃ k : Fin (2 * m),
          (code k).2 = CutWalkVisitTag.fresh ∧
            cutWalkStepClause m i code k = x) :
    cutWalkDecode m i j code = s :=
  Finset.Subset.antisymm
    (cutWalkDecode_subset_of_fresh_step_mem hmem)
    (subset_cutWalkDecode_of_fresh_step_cover hcover)

/-- A replay trace is the clause/node-level object that the planar contour
construction must produce. Once it exists, `cutWalkReplayTraceCode` turns it
into a concrete `CutWalkCode`; the remaining fields state exactly that each
step crosses the prescribed clause from a valid dual endpoint. -/
structure CutWalkReplayTrace (m i : ℕ) where
  node : ℕ → GridNode
  step : Fin (2 * m) → GridClauseId
  tag : Fin (2 * m) → CutWalkVisitTag
  node_zero : node 0 = cutWalkRoot i
  source_mem :
    ∀ k : Fin (2 * m), node k.1 ∈ gridClauseDualEndpoints (step k)
  node_succ :
    ∀ k : Fin (2 * m),
      node (k.1 + 1) =
        cutWalkMoveTarget (node k.1)
          (cutWalkMoveFromClauseEndpoint (step k) (node k.1))

/-- A finite prefix of a replay trace. This is the construction scaffold for a
DFS contour traversal before it is padded to the fixed `2m` length required by
`CutWalkCode`. -/
structure CutWalkReplayPrefix (i : ℕ) where
  len : ℕ
  node : ℕ → GridNode
  step : Fin len → GridClauseId
  tag : Fin len → CutWalkVisitTag
  node_zero : node 0 = cutWalkRoot i
  source_mem :
    ∀ k : Fin len, node k.1 ∈ gridClauseDualEndpoints (step k)
  node_succ :
    ∀ k : Fin len,
      node (k.1 + 1) =
        cutWalkMoveTarget (node k.1)
          (cutWalkMoveFromClauseEndpoint (step k) (node k.1))

def CutWalkReplayPrefix.lastStep
    {i : ℕ} (pref : CutWalkReplayPrefix i) (hlen : 0 < pref.len) :
    GridClauseId :=
  pref.step ⟨pref.len - 1, Nat.sub_one_lt (Nat.ne_of_gt hlen)⟩

theorem CutWalkReplayPrefix.terminal_mem
    {i : ℕ} (pref : CutWalkReplayPrefix i)
    (hlen : 0 < pref.len) :
    pref.node pref.len ∈ gridClauseDualEndpoints (pref.lastStep hlen) := by
  let k : Fin pref.len := ⟨pref.len - 1, Nat.sub_one_lt (Nat.ne_of_gt hlen)⟩
  have hsrc : pref.node k.1 ∈ gridClauseDualEndpoints (pref.step k) :=
    pref.source_mem k
  have htarget :
      cutWalkMoveTarget (pref.node k.1)
          (cutWalkMoveFromClauseEndpoint (pref.step k) (pref.node k.1)) ∈
        gridClauseDualEndpoints (pref.step k) :=
    cutWalkMoveFromClauseEndpoint_target_mem_dualEndpoints hsrc
  have hsucc := pref.node_succ k
  have hk : k.1 + 1 = pref.len := by
    simp [k, Nat.sub_one_add_one_eq_of_pos hlen]
  simpa [CutWalkReplayPrefix.lastStep, k, hk, hsucc.symm] using htarget

theorem CutWalkReplayPrefix.terminal_source_or_backtrack_mem
    {i : ℕ} (pref : CutWalkReplayPrefix i) (hlen : 0 < pref.len)
    {c : GridClauseId}
    (hadj : gridClauseDualAdjacent (pref.lastStep hlen) c) :
    pref.node pref.len ∈ gridClauseDualEndpoints c ∨
      cutWalkMoveTarget (pref.node pref.len)
          (cutWalkMoveFromClauseEndpoint (pref.lastStep hlen) (pref.node pref.len)) ∈
        gridClauseDualEndpoints c := by
  exact dualAdjacent_source_or_target_mem (pref.terminal_mem hlen) hadj

theorem CutWalkReplayPrefix.backtrack_lastStep_terminal
    {i : ℕ} (pref : CutWalkReplayPrefix i) (hlen : 0 < pref.len) :
    cutWalkMoveTarget (pref.node pref.len)
        (cutWalkMoveFromClauseEndpoint (pref.lastStep hlen) (pref.node pref.len)) =
      pref.node (pref.len - 1) := by
  let k : Fin pref.len := ⟨pref.len - 1, Nat.sub_one_lt (Nat.ne_of_gt hlen)⟩
  have hsrc : pref.node k.1 ∈ gridClauseDualEndpoints (pref.step k) :=
    pref.source_mem k
  have hsucc := pref.node_succ k
  have hk : k.1 + 1 = pref.len := by
    simp [k, Nat.sub_one_add_one_eq_of_pos hlen]
  have hreturn := cutWalkMoveFromClauseEndpoint_target_target hsrc
  simpa [CutWalkReplayPrefix.lastStep, k, hk, hsucc.symm] using hreturn

theorem CutWalkReplayPrefix.terminal_follow_direct_or_backtrack
    {i : ℕ} (pref : CutWalkReplayPrefix i) (hlen : 0 < pref.len)
    {c : GridClauseId}
    (hadj : gridClauseDualAdjacent (pref.lastStep hlen) c) :
    (pref.node pref.len ∈ gridClauseDualEndpoints c ∧
      cutWalkMoveClause (pref.node pref.len)
          (cutWalkMoveFromClauseEndpoint c (pref.node pref.len)) =
        c) ∨
      (cutWalkMoveTarget (pref.node pref.len)
            (cutWalkMoveFromClauseEndpoint (pref.lastStep hlen) (pref.node pref.len)) ∈
          gridClauseDualEndpoints c ∧
        cutWalkMoveClause
            (cutWalkMoveTarget (pref.node pref.len)
              (cutWalkMoveFromClauseEndpoint (pref.lastStep hlen) (pref.node pref.len)))
            (cutWalkMoveFromClauseEndpoint c
              (cutWalkMoveTarget (pref.node pref.len)
                (cutWalkMoveFromClauseEndpoint (pref.lastStep hlen) (pref.node pref.len)))) =
          c) := by
  rcases pref.terminal_source_or_backtrack_mem hlen hadj with hdirect | hback
  · exact Or.inl ⟨hdirect, cutWalkMoveClause_cutWalkMoveFromClauseEndpoint hdirect⟩
  · exact Or.inr ⟨hback, cutWalkMoveClause_cutWalkMoveFromClauseEndpoint hback⟩

def CutWalkReplayPrefix.appendDirect
    {i : ℕ} (pref : CutWalkReplayPrefix i)
    (c : GridClauseId)
    (hc : pref.node pref.len ∈ gridClauseDualEndpoints c) :
    CutWalkReplayPrefix i where
  len := pref.len + 1
  node := fun n =>
    if h : n ≤ pref.len then
      pref.node n
    else
      cutWalkMoveTarget (pref.node pref.len)
        (cutWalkMoveFromClauseEndpoint c (pref.node pref.len))
  step := fun k =>
    if h : k.1 < pref.len then
      pref.step ⟨k.1, h⟩
    else
      c
  tag := fun k =>
    if h : k.1 < pref.len then
      pref.tag ⟨k.1, h⟩
    else
      CutWalkVisitTag.fresh
  node_zero := by
    simpa using pref.node_zero
  source_mem := by
    intro k
    by_cases hk : k.1 < pref.len
    · have hle : k.1 ≤ pref.len := Nat.le_of_lt hk
      simp [hk, hle, pref.source_mem ⟨k.1, hk⟩]
    · have hkEq : k.1 = pref.len := by omega
      simp [hkEq, hc]
  node_succ := by
    intro k
    by_cases hnext : k.1 + 1 ≤ pref.len
    · have hk : k.1 < pref.len := Nat.lt_of_succ_le hnext
      have hle : k.1 ≤ pref.len := Nat.le_of_lt hk
      simp [hk, hle, hnext, pref.node_succ ⟨k.1, hk⟩]
    · have hkEq : k.1 = pref.len := by omega
      simp [hkEq]

