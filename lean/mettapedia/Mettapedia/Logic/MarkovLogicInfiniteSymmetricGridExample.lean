theorem falseInsideTrueCutBoundaryRegionFinset_subset_flipGainAssignmentFinset
    {Λ : Region GridNode} (inside : Region GridNode) (hInsideΛ : inside ⊆ Λ)
    (ξ : BoundaryCondition GridNode) :
    falseInsideTrueCutBoundaryRegionFinset inside hInsideΛ ξ ⊆
      symmetricGridFlipGainAssignmentFinset inside hInsideΛ ξ := by
  classical
  intro x hx
  rw [mem_falseInsideTrueCutBoundaryRegionFinset] at hx
  rw [symmetricGridFlipGainAssignmentFinset, Finset.mem_filter]
  refine ⟨by simp, ?_⟩
  exact falseInside_trueCutBoundaryRegion_imp_flipGainCondition hx

theorem falseInside_trueCutBoundaryRegion_imp_boundaryConnectedHull_flipGainCondition
    {n : ℕ} {inside : Region GridNode}
    (hInside : inside ⊆ gridExhaustion.region n)
    {x : LocalAssignment GridNode (gridExhaustion.region n)}
    {ξ : BoundaryCondition GridNode}
    (hsep : FalseInsideTrueCutBoundaryRegion inside hInside x ξ) :
    ∀ j ∈ (gridRegionSupport (gridExhaustion.region n)).filter
        (gridBaseClauseCutsRegion (boundaryConnectedHullRegion n inside)),
      symmetricGridBaseClauseFlipGainCondition
        (boundaryConnectedHullRegion n inside)
        (boundaryConnectedHullRegion_subset_stage (n := n) (inside := inside))
        x ξ j := by
  intro j hj
  rcases hsep with ⟨hinsideFalse, hcutTrue⟩
  have hjSupport : j ∈ gridRegionSupport (gridExhaustion.region n) :=
    (Finset.mem_filter.mp hj).1
  have hjOuter : gridBaseClauseCutsOuterRegion n inside j :=
    (gridBaseClauseCutsRegion_boundaryConnectedHullRegion_iff hInside).1
      ((Finset.mem_filter.mp hj).2)
  have hjInside :
      j ∈ (gridRegionSupport (gridExhaustion.region n)).filter
        (gridBaseClauseCutsRegion inside) := by
    exact Finset.mem_filter.mpr
      ⟨hjSupport, gridBaseClauseCutsOuterRegion_imp_cutsRegion hInside hjOuter⟩
  have hout := hcutTrue j hjInside
  cases j with
  | prior i j =>
      cases hjOuter
  | horizontal i j =>
      rcases hjOuter with h | h
      · rcases h with ⟨hLeftIn, hRightOut⟩
        refine Or.inl ⟨⟨inside_subset_boundaryConnectedHullRegion hInside hLeftIn, ?_⟩,
          hinsideFalse _ hLeftIn, hout.1 hLeftIn⟩
        rcases hRightOut with hRightOut | hRightExt
        · exact not_mem_boundaryConnectedHullRegion_of_not_stage hRightOut
        · exact not_mem_boundaryConnectedHullRegion_of_mem_boundaryConnectedOutside hRightExt
      · rcases h with ⟨hLeftOut, hRightIn⟩
        refine Or.inr ⟨⟨?_, inside_subset_boundaryConnectedHullRegion hInside hRightIn⟩,
          hout.2 hRightIn, hinsideFalse _ hRightIn⟩
        rcases hLeftOut with hLeftOut | hLeftExt
        · exact not_mem_boundaryConnectedHullRegion_of_not_stage hLeftOut
        · exact not_mem_boundaryConnectedHullRegion_of_mem_boundaryConnectedOutside hLeftExt
  | vertical i j =>
      rcases hjOuter with h | h
      · rcases h with ⟨hDownIn, hUpOut⟩
        refine Or.inl ⟨⟨inside_subset_boundaryConnectedHullRegion hInside hDownIn, ?_⟩,
          hinsideFalse _ hDownIn, hout.1 hDownIn⟩
        rcases hUpOut with hUpOut | hUpExt
        · exact not_mem_boundaryConnectedHullRegion_of_not_stage hUpOut
        · exact not_mem_boundaryConnectedHullRegion_of_mem_boundaryConnectedOutside hUpExt
      · rcases h with ⟨hDownOut, hUpIn⟩
        refine Or.inr ⟨⟨?_, inside_subset_boundaryConnectedHullRegion hInside hUpIn⟩,
          hout.2 hUpIn, hinsideFalse _ hUpIn⟩
        rcases hDownOut with hDownOut | hDownExt
        · exact not_mem_boundaryConnectedHullRegion_of_not_stage hDownOut
        · exact not_mem_boundaryConnectedHullRegion_of_mem_boundaryConnectedOutside hDownExt

theorem originContainingSubregionAssignmentEvent_subset_boundaryConnectedHullFlipGainAssignmentFinset
    {n : ℕ} {inside : Region GridNode}
    (hInside : inside ⊆ gridExhaustion.region n)
    (ξ : BoundaryCondition GridNode) :
    originContainingSubregionAssignmentEvent n ξ inside ⊆
      (((symmetricGridFlipGainAssignmentFinset
          (boundaryConnectedHullRegion n inside)
          (boundaryConnectedHullRegion_subset_stage (n := n) (inside := inside))
          ξ :
            Finset (LocalAssignment GridNode (gridExhaustion.region n))) :
          Set (LocalAssignment GridNode (gridExhaustion.region n)))) := by
  intro x hx
  have hsep :
      FalseInsideTrueCutBoundaryRegion inside hInside x ξ :=
    (mem_originContainingSubregionAssignmentEvent_of_subset hInside ξ x).1 hx
  simp [symmetricGridFlipGainAssignmentFinset]
  intro j hjSupport hjCut
  exact falseInside_trueCutBoundaryRegion_imp_boundaryConnectedHull_flipGainCondition
    (n := n) hInside hsep j (Finset.mem_filter.mpr ⟨hjSupport, hjCut⟩)

theorem originConnectedHullAssignmentEvent_subset_flipGainAssignmentFinset
    {n : ℕ} {hull : Region GridNode}
    (hhull : hull ∈ originConnectedHullContainingSubregions n) :
    originConnectedHullAssignmentEvent n hull ⊆
      (((symmetricGridFlipGainAssignmentFinset hull
          (mem_originContainingSubregions_iff.1
            (mem_originConnectedHullContainingSubregions_imp_originContaining hhull)).1
          gridPlusBoundary :
            Finset (LocalAssignment GridNode (gridExhaustion.region n))) :
            Set (LocalAssignment GridNode (gridExhaustion.region n)))) := by
  intro x hx
  rcases (mem_originConnectedHullAssignmentEvent x).1 hx with ⟨_horigin, hhullEq⟩
  let inside := originConnectedSubregion (patchedFalseRegion x gridPlusBoundary)
  have hInside :
      inside ⊆ gridExhaustion.region n :=
    originConnectedSubregion_subset_trans (patchedFalseRegion_subset x gridPlusBoundary)
  have hsep :
      FalseInsideTrueCutBoundaryRegion inside hInside x gridPlusBoundary := by
    exact falseInside_trueCutBoundaryRegion_originConnectedSubregion
      (falseInside_trueCutBoundaryRegion_patchedFalseRegion_gridPlusBoundary x)
  have hxInside :
      x ∈ originContainingSubregionAssignmentEvent n gridPlusBoundary inside := by
    exact (mem_originContainingSubregionAssignmentEvent_of_subset hInside gridPlusBoundary x).2 hsep
  have hxGain :
      x ∈
        (((symmetricGridFlipGainAssignmentFinset
            (boundaryConnectedHullRegion n inside)
            (boundaryConnectedHullRegion_subset_stage (n := n) (inside := inside))
            gridPlusBoundary :
              Finset (LocalAssignment GridNode (gridExhaustion.region n))) :
            Set (LocalAssignment GridNode (gridExhaustion.region n)))) :=
    originContainingSubregionAssignmentEvent_subset_boundaryConnectedHullFlipGainAssignmentFinset
      (n := n) hInside gridPlusBoundary hxInside
  subst hhullEq
  simpa [patchedFalseOriginConnectedHull, inside] using hxGain

