    rw [Finset.disjoint_left]
    intro x hxV hxH
    rcases Finset.mem_image.1 hxV with ⟨kV, _hkV, hEqV⟩
    rcases Finset.mem_image.1 hxH with ⟨kH, _hkH, hEqH⟩
    have hEq : fV kV = fH kH := hEqV.trans hEqH.symm
    simp [fV, fH] at hEq
  have hsubset : skel ⊆ originContainingSubregionOuterCutBaseClauses n inside := by
    intro x hx
    have hx' : x ∈ (Finset.univ.image fV) ∪ (Finset.univ.image fH) := by
      simpa [skel] using hx
    rcases Finset.mem_union.1 hx' with hxV | hxH
    · exact hsubsetV hxV
    · exact hsubsetH hxH
  have hcard :
      skel.card = i + j + 2 := by
    calc
      skel.card = ((Finset.univ.image fV) ∪ (Finset.univ.image fH)).card := by
        rfl
      _ = (Finset.univ.image fV).card + (Finset.univ.image fH).card := by
        exact Finset.card_union_of_disjoint hdisj
      _ = (Finset.univ : Finset (Fin (i + 1))).card +
            (Finset.univ : Finset (Fin (j + 1))).card := by
        rw [Finset.card_image_of_injective _ hinjV, Finset.card_image_of_injective _ hinjH]
      _ = i + j + 2 := by
        rw [Finset.card_univ, Fintype.card_fin, Finset.card_univ, Fintype.card_fin]
        omega
  exact ⟨skel, hsubset, hcard⟩

theorem exists_extra_outerCut_of_insideEndpoints_of_slack
    {n : ℕ} {inside : Region GridNode}
    (hinside : inside ∈ originConnectedContainingSubregions n)
    {a b : GridNode}
    (ha : a ∈ inside) (hb : b ∈ inside)
    (hslack : a.1 + b.2 + 2 < originContainingSubregionOuterCutCard n inside) :
    ∃ skel : Finset GridClauseId,
      skel ⊆ originContainingSubregionOuterCutBaseClauses n inside ∧
        skel.card = a.1 + b.2 + 2 ∧
        ∃ j ∈ originContainingSubregionOuterCutBaseClauses n inside, j ∉ skel := by
  rcases exists_outerCutRowColSkeleton_of_insideEndpoints hinside ha hb with ⟨skel, hsubset, hcard⟩
  have hneq : skel ≠ originContainingSubregionOuterCutBaseClauses n inside := by
    intro hEq
    have hlt :
        skel.card < (originContainingSubregionOuterCutBaseClauses n inside).card := by
      simpa [originContainingSubregionOuterCutCard, hcard] using hslack
    rw [hEq] at hlt
    exact (lt_irrefl _ hlt).elim
  have hsup : ¬ originContainingSubregionOuterCutBaseClauses n inside ⊆ skel := by
    intro hsup
    exact hneq (Finset.Subset.antisymm hsubset hsup)
  have hextra : ∃ j ∈ originContainingSubregionOuterCutBaseClauses n inside, j ∉ skel := by
    by_contra hno
    have hsup' : originContainingSubregionOuterCutBaseClauses n inside ⊆ skel := by
      intro j hjCut
      by_contra hjNot
      exact hno ⟨j, hjCut, hjNot⟩
    exact hsup hsup'
  rcases hextra with ⟨j, hjCut, hjNot⟩
  exact ⟨skel, hsubset, hcard, j, hjCut, hjNot⟩

theorem exists_outerCutRowColSkeleton_of_bottomHorizontal_leftVertical
    {n i j : ℕ} {inside : Region GridNode}
    (hinside : inside ∈ originConnectedContainingSubregions n)
    (hhor :
      GridClauseId.horizontal i 0 ∈ originContainingSubregionOuterCutBaseClauses n inside)
    (hvert :
      GridClauseId.vertical 0 j ∈ originContainingSubregionOuterCutBaseClauses n inside) :
    ∃ skel : Finset GridClauseId,
      skel ⊆ originContainingSubregionOuterCutBaseClauses n inside ∧
        skel.card = i + j + 2 := by
  have hhorCut : gridBaseClauseCutsOuterRegion n inside (GridClauseId.horizontal i 0) :=
    (Finset.mem_filter.1 hhor).2
  have hvertCut : gridBaseClauseCutsOuterRegion n inside (GridClauseId.vertical 0 j) :=
    (Finset.mem_filter.1 hvert).2
  rcases hhorCut with h | h
  · rcases hvertCut with h' | h'
    · exact exists_outerCutRowColSkeleton_of_insideEndpoints_bounded
        hinside h.1 h'.1 (le_rfl) (le_rfl)
    · exact exists_outerCutRowColSkeleton_of_insideEndpoints_bounded
        hinside h.1 h'.2 (le_rfl) (Nat.le_succ _)
  · rcases hvertCut with h' | h'
    · exact exists_outerCutRowColSkeleton_of_insideEndpoints_bounded
        hinside h.2 h'.1 (Nat.le_succ _) (le_rfl)
    · exact exists_outerCutRowColSkeleton_of_insideEndpoints_bounded
        hinside h.2 h'.2 (Nat.le_succ _) (Nat.le_succ _)

theorem exists_extra_outerCut_of_bottomHorizontal_leftVertical_of_slack
