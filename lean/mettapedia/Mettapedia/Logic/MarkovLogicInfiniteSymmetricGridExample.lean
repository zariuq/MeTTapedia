theorem exists_contourDecode_eq_of_starClosedWalk_eight
    {m i j : ℕ} (hm : 1 ≤ m) {s : Finset GridClauseId}
    {G : SimpleGraph GridClauseId}
    (p : G.Walk (GridClauseId.horizontal i 0) (GridClauseId.horizontal i 0))
    (hlen : p.length ≤ 2 * (m - 1))
    (hAdj : ∀ a b, G.Adj a b → gridClauseStarAdjacent a b)
    (hmem : ∀ x ∈ p.support, x ∈ s)
    (hcover : ∀ x ∈ s, x ∈ p.support) :
    ∃ code : ContourCode 8 m, contourDecode 8 m i j code = s := by
  rcases exists_clauseChain_of_simpleGraph_closedWalk
      (R := gridClauseStarAdjacent) p hAdj hmem hcover with
    ⟨tail, htailLenEq, hchain, htailMem, htailCover⟩
