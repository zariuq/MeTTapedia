/-- The finite set of local assignments on `Λ` whose cut clauses along `inside`
all satisfy the separator flip-gain condition against the boundary `ξ`. -/
noncomputable def symmetricGridFlipGainAssignmentFinset
    {Λ : Region GridNode} (inside : Region GridNode) (hInsideΛ : inside ⊆ Λ)
    (ξ : BoundaryCondition GridNode) : Finset (LocalAssignment GridNode Λ) := by
  classical
  exact (Finset.univ : Finset (LocalAssignment GridNode Λ)).filter (fun x =>
    ∀ j ∈ (gridRegionSupport Λ).filter (gridBaseClauseCutsRegion inside),
      symmetricGridBaseClauseFlipGainCondition inside hInsideΛ x ξ j)

/-- The finite set of local assignments on `Λ` whose patched worlds satisfy the
explicit generic separator event for the chosen inside region. -/
noncomputable def falseInsideTrueCutBoundaryRegionFinset
    {Λ : Region GridNode} (inside : Region GridNode) (hInsideΛ : inside ⊆ Λ)
    (ξ : BoundaryCondition GridNode) : Finset (LocalAssignment GridNode Λ) := by
  classical
  exact (Finset.univ : Finset (LocalAssignment GridNode Λ)).filter (fun x =>
    FalseInsideTrueCutBoundaryRegion inside hInsideΛ x ξ)

theorem mem_falseInsideTrueCutBoundaryRegionFinset
    {Λ : Region GridNode} (inside : Region GridNode) (hInsideΛ : inside ⊆ Λ)
    (ξ : BoundaryCondition GridNode)
    (x : LocalAssignment GridNode Λ) :
    x ∈ falseInsideTrueCutBoundaryRegionFinset inside hInsideΛ ξ ↔
      FalseInsideTrueCutBoundaryRegion inside hInsideΛ x ξ := by
