    a ∈ boundaryConnectedOutsideSubregion n inside ∧
      Relation.ReflTransGen
        (gridAdjacentInRegion (boundaryConnectedOutsideSubregion n inside)) b a := by
  induction hreach with
  | refl =>
      exact ⟨hbExt, Relation.ReflTransGen.refl⟩
  | @tail x y hprev hstep ih =>
      rcases ih with ⟨hxExt, hreachExt⟩
      rcases hstep with ⟨_hxOutside, hyOutside, hxy⟩
      have hyExt :
          y ∈ boundaryConnectedOutsideSubregion n inside :=
        mem_boundaryConnectedOutsideSubregion_of_mem_outside_of_adj
          hyOutside hxExt hxy
      exact ⟨hyExt,
        Relation.ReflTransGen.tail hreachExt ⟨hxExt, hyExt, hxy⟩⟩

theorem visibleBoundarySeparatorEdges_reachable_from_stageBoundary_to_right_in_boundaryConnectedOutside
