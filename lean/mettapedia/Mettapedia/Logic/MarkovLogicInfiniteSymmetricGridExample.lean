  rcases mem_visibleOuterBoundary_erase_or_gridAdjacent_deleted (v := v) hp with
    hpErase | hpGrid
  · rcases mem_visibleOuterBoundary_erase_or_gridAdjacent_deleted (v := v) hq with
      hqErase | hqGrid
    · have hreachGraph :
          (visibleOuterBoundaryStarGraph n (hull.erase v.1)).Reachable
            ⟨p, hpErase⟩ ⟨q, hqErase⟩ :=
        herase ⟨p, hpErase⟩ ⟨q, hqErase⟩
      have hreachSubtype :
