  intro hrev
  exact visibleBoundarySeparatorEdges_reverse_not_mem
    (separatorSquareComponent_subset_separator he)
    (separatorSquareComponent_subset_separator hrev)

theorem separatorSquareComponent_root_mem
    {m : ℕ} {hull : Region GridNode} {root : GridNode × GridNode}
    (hroot : root ∈ visibleBoundarySeparatorEdges m hull) :
    root ∈ separatorSquareComponent m hull root := by
  rw [mem_separatorSquareComponent_iff]
  exact ⟨hroot, Relation.ReflTransGen.refl⟩

theorem separatorSquareComponent_square_closed
    {m : ℕ} {hull : Region GridNode} {root c s : GridNode × GridNode}
    {i j : ℕ}
    (hc : c ∈ separatorSquareComponent m hull root)
    (hs : s ∈ visibleBoundarySeparatorEdges m hull)
    (hcSq : c ∈ gridBasicSquareDirectedEdges i j)
    (hsSq : s ∈ gridBasicSquareDirectedEdges i j) :
    s ∈ separatorSquareComponent m hull root := by
  rw [mem_separatorSquareComponent_iff] at hc ⊢
  exact ⟨hs,
    Relation.ReflTransGen.tail hc.2
      ⟨hc.1, hs, i, j, hcSq, hsSq⟩⟩

theorem separatorSquareComponent_basicSquare_filter_eq_separator_of_mem
    {m : ℕ} {hull : Region GridNode} {root c : GridNode × GridNode}
    {i j : ℕ}
    (hc : c ∈ separatorSquareComponent m hull root)
    (hcSq : c ∈ gridBasicSquareDirectedEdges i j) :
    (separatorSquareComponent m hull root).filter
        (fun e => e ∈ gridBasicSquareDirectedEdges i j) =
      (visibleBoundarySeparatorEdges m hull).filter
        (fun e => e ∈ gridBasicSquareDirectedEdges i j) := by
  ext e
  constructor
  · intro he
    rcases Finset.mem_filter.1 he with ⟨heComp, heSq⟩
    exact Finset.mem_filter.2
      ⟨separatorSquareComponent_subset_separator heComp, heSq⟩
  · intro he
    rcases Finset.mem_filter.1 he with ⟨heSep, heSq⟩
    exact Finset.mem_filter.2
      ⟨separatorSquareComponent_square_closed hc heSep hcSq heSq, heSq⟩

theorem separatorSquareComponent_basicSquare_card_even
    {m : ℕ} {hull : Region GridNode} {root : GridNode × GridNode}
    (hm : 1 ≤ m)
    (hHull : hull ⊆ gridExhaustion.region (m - 1))
    (hco : StageCoConnectedRegion (m - 1) hull)
    (i j : ℕ) :
    Even
      (((separatorSquareComponent m hull root).filter
        (fun e => e ∈ gridBasicSquareDirectedEdges i j)).card) := by
  classical
  by_cases hhit :
      ∃ c ∈ separatorSquareComponent m hull root,
        c ∈ gridBasicSquareDirectedEdges i j
  · rcases hhit with ⟨c, hc, hcSq⟩
    rw [separatorSquareComponent_basicSquare_filter_eq_separator_of_mem
      hc hcSq]
    exact visibleBoundarySeparatorEdges_basicSquare_card_even_of_stageCoConnected
      hm hHull hco i j
  · have hEmpty :
        (separatorSquareComponent m hull root).filter
            (fun e => e ∈ gridBasicSquareDirectedEdges i j) = ∅ := by
      ext e
      constructor
      · intro he
        rcases Finset.mem_filter.1 he with ⟨heComp, heSq⟩
        exact False.elim (hhit ⟨e, heComp, heSq⟩)
      · intro he
        simp at he
    rw [hEmpty]
    exact ⟨0, by simp⟩

