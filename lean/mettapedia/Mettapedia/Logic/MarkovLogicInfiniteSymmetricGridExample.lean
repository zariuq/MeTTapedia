    rcases not_mem_boundaryConnectedHullRegion_iff.1 haNotHull with
      haNotStage | haExt
    · exact False.elim (haNotStage haStage)
    · exact haExt
  · intro ha
    rw [mem_outsideRegionInStage_iff]
    exact ⟨boundaryConnectedOutsideSubregion_subset_stage ha,
      not_mem_boundaryConnectedHullRegion_of_mem_boundaryConnectedOutside ha⟩

theorem boundaryConnectedOutsideSubregion.reach_inside_boundaryConnectedOutside
    {n : ℕ} {inside : Region GridNode} {b a : GridNode}
    (hbExt : b ∈ boundaryConnectedOutsideSubregion n inside)
    (hreach :
