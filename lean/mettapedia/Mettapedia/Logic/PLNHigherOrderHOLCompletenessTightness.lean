import Mettapedia.Logic.PLNHigherOrderHOLCredalBridge
import Mettapedia.Logic.PLNWorldModelHOLCompleteness

/-!
# Completeness-Tight Higher-Order HOL Credal Envelopes

This module starts the endpoint-first weld between classical Henkin completeness
and the higher-order WM-PLN credal layer.

The first tranche is intentionally formula-level: it builds the canonical family
of all Henkin models of a classical theory, maps each model to a Dirac
hierarchical ProbHOL state, and exposes the countermodel/model witnesses supplied
by the already-landed Henkin completeness theorem.
-/

namespace Mettapedia.Logic.PLNHigherOrderHOLCompletenessTightness

open Mettapedia.Logic.HOL
open Mettapedia.Logic.HOL.WithParams
open Mettapedia.Logic.HOL.WorldModel
open Mettapedia.Logic.HOL.Probabilistic
open Mettapedia.Logic.HOL.Probabilistic.ModelSpace
open Mettapedia.Logic.HOL.Probabilistic.HierarchicalState
open Mettapedia.Logic.PLNWorldModelHOLCompleteness
open Mettapedia.Logic.PLNHigherOrderHOLCredalBridge
open Mettapedia.ProbabilityTheory.ImpreciseProbability.CredalSets
open MeasureTheory
open scoped ENNReal

universe u v w

variable {Base : Type u} {Const : Ty Base → Type v}

/-- The canonical model family for a classical higher-order theory: all pointed
Henkin models satisfying every sentence of `T`. -/
def TheoryModel (T : ClosedTheorySet (WithParams Const)) :=
  {M : ClassicalHOLPointed (Base := Base) (Const := Const) //
    ∀ ψ ∈ T, HenkinModel.models M ψ}

/-- The proof-tight canonical model family: all pointed Henkin models satisfying
`T` and satisfying the extensional argument-congruence condition needed for
`ExtDerivation` soundness. -/
def ExtensionalTheoryModel (T : ClosedTheorySet (WithParams Const)) :=
  {M : ClassicalHOLPointed (Base := Base) (Const := Const) //
    (∀ ψ ∈ T, HenkinModel.models M ψ) ∧ HenkinModel.FunctionsRespectEqv M}

/-- Classical Henkin completeness makes the canonical theory-model family
nonempty under the real param-free + EM-closed hypotheses of the term-model
theorem. -/
theorem nonempty_theoryModel_of_consistent_classical
    {T : ClosedTheorySet (WithParams Const)}
    (enum : Nat → Body Const)
    (henum : ∀ b : Body Const, ∃ n, enum n = b)
    (hCons : ClosedTheorySet.Consistent (Const := WithParams Const) T)
    (hT0 : ∀ ψ ∈ T, ∀ (σ : Ty Base) (k : Nat), NoConstOccurrence (param σ k) ψ)
    (hEM : ∀ ψ ∈ EMSchema Const, ψ ∈ T) :
    Nonempty (TheoryModel (Base := Base) (Const := Const) T) := by
  obtain ⟨M, hM⟩ :=
    exists_model_of_consistent_classicalTheory
      (Base := Base) (Const := Const) (T := T) enum henum hCons hT0 hEM
  exact ⟨⟨M, hM⟩⟩

/-- Classical Henkin completeness makes the proof-tight extensional
theory-model family nonempty under the same real param-free + EM-closed
hypotheses. -/
theorem nonempty_extensionalTheoryModel_of_consistent_classical
    {T : ClosedTheorySet (WithParams Const)}
    (enum : Nat → Body Const)
    (henum : ∀ b : Body Const, ∃ n, enum n = b)
    (hCons : ClosedTheorySet.Consistent (Const := WithParams Const) T)
    (hT0 : ∀ ψ ∈ T, ∀ (σ : Ty Base) (k : Nat), NoConstOccurrence (param σ k) ψ)
    (hEM : ∀ ψ ∈ EMSchema Const, ψ ∈ T) :
    Nonempty (ExtensionalTheoryModel (Base := Base) (Const := Const) T) := by
  obtain ⟨M, hM, hExt⟩ :=
    exists_extensional_model_of_consistent_classicalTheory
      (Base := Base) (Const := Const) (T := T) enum henum hCons hT0 hEM
  exact ⟨⟨M, hM, hExt⟩⟩

/-- A singleton indexed model space generated by one pointed Henkin model. -/
noncomputable def singletonModelSpace
    (M : ClassicalHOLPointed (Base := Base) (Const := Const)) :
    ModelSpace.{u, v, v, 0} Base (WithParams Const) where
  Idx := Unit
  instMeasurableSpace := inferInstance
  model := fun _ => M
  measurable_sentence_event := by
    intro φ
    by_cases hφ : HenkinModel.models M φ
    · have hEvent :
        {i : Unit | holSatisfies M φ} = Set.univ := by
          ext i
          simp [holSatisfies, hφ]
      simp [hEvent]
    · have hEvent :
        {i : Unit | holSatisfies M φ} = ∅ := by
          ext i
          simp [holSatisfies, hφ]
      simp [hEvent]

/-- The Dirac hierarchical ProbHOL state concentrated on one pointed model. -/
noncomputable def diracHierarchicalStateOfModel
    (M : ClassicalHOLPointed (Base := Base) (Const := Const)) :
    HierarchicalState Base (WithParams Const) :=
  HierarchicalState.ofConstantMeasure
    (singletonModelSpace (Base := Base) (Const := Const) M)
    (Measure.dirac ())

/-- The canonical ProbHOL state attached to one member of the model family of
`T`. -/
noncomputable def theoryModelHierarchicalState
    {T : ClosedTheorySet (WithParams Const)}
    (M : TheoryModel (Base := Base) (Const := Const) T) :
    HierarchicalState Base (WithParams Const) :=
  diracHierarchicalStateOfModel (Base := Base) (Const := Const) M.1

/-- The canonical ProbHOL state attached to one member of the extensional
model family of `T`. -/
noncomputable def extensionalTheoryModelHierarchicalState
    {T : ClosedTheorySet (WithParams Const)}
    (M : ExtensionalTheoryModel (Base := Base) (Const := Const) T) :
    HierarchicalState Base (WithParams Const) :=
  diracHierarchicalStateOfModel (Base := Base) (Const := Const) M.1

/-- Formula probability in a singleton model-space is `1` when the model
satisfies the formula. -/
theorem sentenceProb_singletonModelSpace_eq_one_of_models
    (M : ClassicalHOLPointed (Base := Base) (Const := Const))
    {φ : ClosedFormula (WithParams Const)}
    (hφ : HenkinModel.models M φ) :
    sentenceProb
        (singletonModelSpace (Base := Base) (Const := Const) M)
        (Measure.dirac ())
        φ = 1 := by
  have hEvent :
      (singletonModelSpace (Base := Base) (Const := Const) M).sentenceEvent φ =
        Set.univ := by
    ext i
    simp [ModelSpace.sentenceEvent, singletonModelSpace, holSatisfies, hφ]
  simp [sentenceProb, hEvent]

/-- Formula probability in a singleton model-space is `0` when the model
refutes the formula. -/
theorem sentenceProb_singletonModelSpace_eq_zero_of_not_models
    (M : ClassicalHOLPointed (Base := Base) (Const := Const))
    {φ : ClosedFormula (WithParams Const)}
    (hφ : ¬ HenkinModel.models M φ) :
    sentenceProb
        (singletonModelSpace (Base := Base) (Const := Const) M)
        (Measure.dirac ())
        φ = 0 := by
  have hEvent :
      (singletonModelSpace (Base := Base) (Const := Const) M).sentenceEvent φ =
        ∅ := by
    ext i
    simp [ModelSpace.sentenceEvent, singletonModelSpace, holSatisfies, hφ]
    exact Iff.rfl
  simp [sentenceProb, hEvent]

/-- The Dirac hierarchical state has real-valued HOL formula strength `1` when
its model satisfies the formula. -/
theorem credalHOLFormulaValue_dirac_eq_one_of_models
    (M : ClassicalHOLPointed (Base := Base) (Const := Const))
    {φ : ClosedFormula (WithParams Const)}
    (hφ : HenkinModel.models M φ) :
    credalHOLFormulaValue
        (diracHierarchicalStateOfModel (Base := Base) (Const := Const) M)
        φ = 1 := by
  unfold credalHOLFormulaValue diracHierarchicalStateOfModel
  rw [hierarchicalProbQueryStrength_eq_sentenceProb,
    hierarchicalSentenceProb_ofConstantMeasure_eq_sentenceProb,
    sentenceProb_singletonModelSpace_eq_one_of_models
      (Base := Base) (Const := Const) M hφ]
  simp

/-- The Dirac hierarchical state has real-valued HOL formula strength `0` when
its model refutes the formula. -/
theorem credalHOLFormulaValue_dirac_eq_zero_of_not_models
    (M : ClassicalHOLPointed (Base := Base) (Const := Const))
    {φ : ClosedFormula (WithParams Const)}
    (hφ : ¬ HenkinModel.models M φ) :
    credalHOLFormulaValue
        (diracHierarchicalStateOfModel (Base := Base) (Const := Const) M)
        φ = 0 := by
  unfold credalHOLFormulaValue diracHierarchicalStateOfModel
  rw [hierarchicalProbQueryStrength_eq_sentenceProb,
    hierarchicalSentenceProb_ofConstantMeasure_eq_sentenceProb,
    sentenceProb_singletonModelSpace_eq_zero_of_not_models
      (Base := Base) (Const := Const) M hφ]
  simp

/-- Canonical theory-model interval: the existing credal HOL formula interval
specialized to all Henkin models of `T`, each represented as a Dirac
hierarchical state. This is a wrapper, not a second credal semantics. -/
noncomputable def theoryCredalHOLFormulaInterval
    (T : ClosedTheorySet (WithParams Const))
    [Nonempty (TheoryModel (Base := Base) (Const := Const) T)]
    (φ : ClosedFormula (WithParams Const)) :
    Interval :=
  credalHOLFormulaInterval
    (Base := Base)
    (Const := WithParams Const)
    (fun M : TheoryModel (Base := Base) (Const := Const) T =>
      theoryModelHierarchicalState (Base := Base) (Const := Const) M)
    φ

/-- Proof-tight canonical theory interval: the existing credal HOL formula
interval specialized to all extensional Henkin models of `T`, each represented
as a Dirac hierarchical state. -/
noncomputable def extensionalTheoryCredalHOLFormulaInterval
    (T : ClosedTheorySet (WithParams Const))
    [Nonempty (ExtensionalTheoryModel (Base := Base) (Const := Const) T)]
    (φ : ClosedFormula (WithParams Const)) :
    Interval :=
  credalHOLFormulaInterval
    (Base := Base)
    (Const := WithParams Const)
    (fun M : ExtensionalTheoryModel (Base := Base) (Const := Const) T =>
      extensionalTheoryModelHierarchicalState (Base := Base) (Const := Const) M)
    φ

/-- Typeclass-free canonical theory interval when the classical Henkin
consistency hypotheses provide the nonempty all-model family. This only
instantiates `theoryCredalHOLFormulaInterval`; it does not introduce a second
credal semantics. -/
noncomputable def theoryCredalHOLFormulaIntervalOfConsistent
    (T : ClosedTheorySet (WithParams Const))
    (enum : Nat → Body Const)
    (henum : ∀ b : Body Const, ∃ n, enum n = b)
    (hCons : ClosedTheorySet.Consistent (Const := WithParams Const) T)
    (hT0 : ∀ ψ ∈ T, ∀ (σ : Ty Base) (k : Nat), NoConstOccurrence (param σ k) ψ)
    (hEM : ∀ ψ ∈ EMSchema Const, ψ ∈ T)
    (φ : ClosedFormula (WithParams Const)) :
    Interval :=
  letI : Nonempty (TheoryModel (Base := Base) (Const := Const) T) :=
    nonempty_theoryModel_of_consistent_classical
      (Base := Base) (Const := Const) (T := T)
      enum henum hCons hT0 hEM
  theoryCredalHOLFormulaInterval (Base := Base) (Const := Const) T φ

/-- Typeclass-free proof-tight canonical interval when the classical Henkin
consistency hypotheses provide the nonempty extensional model family. -/
noncomputable def extensionalTheoryCredalHOLFormulaIntervalOfConsistent
    (T : ClosedTheorySet (WithParams Const))
    (enum : Nat → Body Const)
    (henum : ∀ b : Body Const, ∃ n, enum n = b)
    (hCons : ClosedTheorySet.Consistent (Const := WithParams Const) T)
    (hT0 : ∀ ψ ∈ T, ∀ (σ : Ty Base) (k : Nat), NoConstOccurrence (param σ k) ψ)
    (hEM : ∀ ψ ∈ EMSchema Const, ψ ∈ T)
    (φ : ClosedFormula (WithParams Const)) :
    Interval :=
  letI : Nonempty (ExtensionalTheoryModel (Base := Base) (Const := Const) T) :=
    nonempty_extensionalTheoryModel_of_consistent_classical
      (Base := Base) (Const := Const) (T := T)
      enum henum hCons hT0 hEM
  extensionalTheoryCredalHOLFormulaInterval (Base := Base) (Const := Const) T φ

/-- If one completion gives formula value `0`, the lower endpoint of the
formula interval is exactly `0`. -/
theorem credalHOLFormulaInterval_lower_eq_zero_of_exists_value_zero
    {ι : Type w} [Nonempty ι]
    (Hs : ι → HierarchicalState Base (WithParams Const))
    (φ : ClosedFormula (WithParams Const))
    (h0 : ∃ i, credalHOLFormulaValue (Hs i) φ = 0) :
    (credalHOLFormulaInterval (Base := Base) (Const := WithParams Const)
      Hs φ).lower = 0 := by
  rcases h0 with ⟨i, hi⟩
  apply le_antisymm
  · unfold credalHOLFormulaInterval
    dsimp [IntervalAddSemantics.intervalOf]
    rw [← hi]
    exact
      csInf_le
        (credalHOLFormulaValue_bddBelow
          (Base := Base) (Const := WithParams Const) Hs φ)
        ⟨i, rfl⟩
  · exact
      credalHOLFormulaInterval_lower_nonneg
        (Base := Base) (Const := WithParams Const) Hs φ

/-- If one completion gives formula value `1`, the upper endpoint of the
formula interval is exactly `1`. -/
theorem credalHOLFormulaInterval_upper_eq_one_of_exists_value_one
    {ι : Type w} [Nonempty ι]
    (Hs : ι → HierarchicalState Base (WithParams Const))
    (φ : ClosedFormula (WithParams Const))
    (h1 : ∃ i, credalHOLFormulaValue (Hs i) φ = 1) :
    (credalHOLFormulaInterval (Base := Base) (Const := WithParams Const)
      Hs φ).upper = 1 := by
  rcases h1 with ⟨i, hi⟩
  apply le_antisymm
  · exact
      credalHOLFormulaInterval_upper_le_one
        (Base := Base) (Const := WithParams Const) Hs φ
  · unfold credalHOLFormulaInterval
    dsimp [IntervalAddSemantics.intervalOf]
    rw [← hi]
    exact
      le_csSup
        (credalHOLFormulaValue_bddAbove
          (Base := Base) (Const := WithParams Const) Hs φ)
        ⟨i, rfl⟩

/-- Semantic collapse at the top endpoint: if every theory model satisfies the
formula, the canonical theory interval is the point interval `1`. -/
theorem theoryCredalHOLFormulaInterval_eq_const_one_of_all_models
    {T : ClosedTheorySet (WithParams Const)}
    [Nonempty (TheoryModel (Base := Base) (Const := Const) T)]
    {φ : ClosedFormula (WithParams Const)}
    (hAll : ∀ M : TheoryModel (Base := Base) (Const := Const) T,
      HenkinModel.models M.1 φ) :
    theoryCredalHOLFormulaInterval (Base := Base) (Const := Const) T φ =
      constInterval 1 := by
  exact
    credalHOLFormulaInterval_eq_const_of_pointwise_value_eq
      (Base := Base) (Const := WithParams Const)
      (fun M : TheoryModel (Base := Base) (Const := Const) T =>
        theoryModelHierarchicalState (Base := Base) (Const := Const) M)
      φ 1
      (fun M =>
        credalHOLFormulaValue_dirac_eq_one_of_models
          (Base := Base) (Const := Const) M.1 (hAll M))

/-- Semantic collapse at the bottom endpoint: if every theory model refutes the
formula, the canonical theory interval is the point interval `0`. -/
theorem theoryCredalHOLFormulaInterval_eq_const_zero_of_all_not_models
    {T : ClosedTheorySet (WithParams Const)}
    [Nonempty (TheoryModel (Base := Base) (Const := Const) T)]
    {φ : ClosedFormula (WithParams Const)}
    (hAll : ∀ M : TheoryModel (Base := Base) (Const := Const) T,
      ¬ HenkinModel.models M.1 φ) :
    theoryCredalHOLFormulaInterval (Base := Base) (Const := Const) T φ =
      constInterval 0 := by
  exact
    credalHOLFormulaInterval_eq_const_of_pointwise_value_eq
      (Base := Base) (Const := WithParams Const)
      (fun M : TheoryModel (Base := Base) (Const := Const) T =>
        theoryModelHierarchicalState (Base := Base) (Const := Const) M)
      φ 0
      (fun M =>
        credalHOLFormulaValue_dirac_eq_zero_of_not_models
          (Base := Base) (Const := Const) M.1 (hAll M))

/-- Extensional closed-theory provability is sound in any extensional Henkin
model satisfying the theory. -/
theorem models_of_provable_of_functionsRespectEqv
    {T : ClosedTheorySet (WithParams Const)}
    {φ : ClosedFormula (WithParams Const)}
    (hProv : ClosedTheorySet.Provable (Const := WithParams Const) T φ)
    (M : ClassicalHOLPointed (Base := Base) (Const := Const))
    (hMT : ∀ ψ ∈ T, HenkinModel.models M ψ)
    (hExt : HenkinModel.FunctionsRespectEqv M) :
    HenkinModel.models M φ := by
  rcases hProv with ⟨Γ, hΓ, d⟩
  exact
    Mettapedia.Logic.HOL.Soundness.extDerivation_sound
      (Base := Base) (Const := WithParams Const) d
      (M := M) (ρ := fun v => nomatch v) hExt
      (by intro τ v; nomatch v)
      (by
        intro ψ hψ
        exact hMT ψ (hΓ ψ hψ))

/-- Semantic collapse at the top endpoint over the proof-tight extensional
family. -/
theorem extensionalTheoryCredalHOLFormulaInterval_eq_const_one_of_all_models
    {T : ClosedTheorySet (WithParams Const)}
    [Nonempty (ExtensionalTheoryModel (Base := Base) (Const := Const) T)]
    {φ : ClosedFormula (WithParams Const)}
    (hAll : ∀ M : ExtensionalTheoryModel (Base := Base) (Const := Const) T,
      HenkinModel.models M.1 φ) :
    extensionalTheoryCredalHOLFormulaInterval (Base := Base) (Const := Const) T φ =
      constInterval 1 := by
  exact
    credalHOLFormulaInterval_eq_const_of_pointwise_value_eq
      (Base := Base) (Const := WithParams Const)
      (fun M : ExtensionalTheoryModel (Base := Base) (Const := Const) T =>
        extensionalTheoryModelHierarchicalState (Base := Base) (Const := Const) M)
      φ 1
      (fun M =>
        credalHOLFormulaValue_dirac_eq_one_of_models
          (Base := Base) (Const := Const) M.1 (hAll M))

/-- Semantic collapse at the bottom endpoint over the proof-tight extensional
family. -/
theorem extensionalTheoryCredalHOLFormulaInterval_eq_const_zero_of_all_not_models
    {T : ClosedTheorySet (WithParams Const)}
    [Nonempty (ExtensionalTheoryModel (Base := Base) (Const := Const) T)]
    {φ : ClosedFormula (WithParams Const)}
    (hAll : ∀ M : ExtensionalTheoryModel (Base := Base) (Const := Const) T,
      ¬ HenkinModel.models M.1 φ) :
    extensionalTheoryCredalHOLFormulaInterval (Base := Base) (Const := Const) T φ =
      constInterval 0 := by
  exact
    credalHOLFormulaInterval_eq_const_of_pointwise_value_eq
      (Base := Base) (Const := WithParams Const)
      (fun M : ExtensionalTheoryModel (Base := Base) (Const := Const) T =>
        extensionalTheoryModelHierarchicalState (Base := Base) (Const := Const) M)
      φ 0
      (fun M =>
        credalHOLFormulaValue_dirac_eq_zero_of_not_models
          (Base := Base) (Const := Const) M.1 (hAll M))

/-- If `T` does not prove `χ`, the canonical family contains a model whose
Dirac ProbHOL state gives value `0` to `χ`. -/
theorem exists_theoryModel_dirac_value_zero_of_not_provable
    {T : ClosedTheorySet (WithParams Const)}
    {χ : ClosedFormula (WithParams Const)}
    (enum : Nat → Body Const)
    (henum : ∀ b : Body Const, ∃ n, enum n = b)
    (hT0 : ∀ ψ ∈ T, ∀ (σ : Ty Base) (k : Nat), NoConstOccurrence (param σ k) ψ)
    (hEM : ∀ ψ ∈ EMSchema Const, ψ ∈ T)
    (hχ0 : ∀ (σ : Ty Base) (k : Nat), NoConstOccurrence (param σ k) χ)
    (hNotProv : ¬ ClosedTheorySet.Provable (Const := WithParams Const) T χ) :
    ∃ M : TheoryModel (Base := Base) (Const := Const) T,
      credalHOLFormulaValue
        (theoryModelHierarchicalState (Base := Base) (Const := Const) M)
        χ = 0 := by
  obtain ⟨M, hMT, hNotχ⟩ :=
    exists_model_not_models_of_not_provable_classical
      (Base := Base) (Const := Const) (T := T) (χ := χ)
      enum henum hT0 hEM hχ0 hNotProv
  refine ⟨⟨M, hMT⟩, ?_⟩
  exact
    credalHOLFormulaValue_dirac_eq_zero_of_not_models
      (Base := Base) (Const := Const) M hNotχ

/-- If `T` does not prove `¬χ`, the canonical family contains a model whose
Dirac ProbHOL state gives value `1` to `χ`. -/
theorem exists_theoryModel_dirac_value_one_of_not_provable_not
    {T : ClosedTheorySet (WithParams Const)}
    {χ : ClosedFormula (WithParams Const)}
    (enum : Nat → Body Const)
    (henum : ∀ b : Body Const, ∃ n, enum n = b)
    (hT0 : ∀ ψ ∈ T, ∀ (σ : Ty Base) (k : Nat), NoConstOccurrence (param σ k) ψ)
    (hEM : ∀ ψ ∈ EMSchema Const, ψ ∈ T)
    (hχ0 : ∀ (σ : Ty Base) (k : Nat), NoConstOccurrence (param σ k) χ)
    (hNotProvNot : ¬ ClosedTheorySet.Provable (Const := WithParams Const) T (.not χ)) :
    ∃ M : TheoryModel (Base := Base) (Const := Const) T,
      credalHOLFormulaValue
        (theoryModelHierarchicalState (Base := Base) (Const := Const) M)
        χ = 1 := by
  obtain ⟨M, hMT, hχ⟩ :=
    exists_model_models_of_not_provable_not_classical
      (Base := Base) (Const := Const) (T := T) (χ := χ)
      enum henum hT0 hEM hχ0 hNotProvNot
  refine ⟨⟨M, hMT⟩, ?_⟩
  exact
    credalHOLFormulaValue_dirac_eq_one_of_models
      (Base := Base) (Const := Const) M hχ

/-- If `T` does not prove `χ`, the proof-tight extensional family contains a
model whose Dirac ProbHOL state gives value `0` to `χ`. -/
theorem exists_extensionalTheoryModel_dirac_value_zero_of_not_provable
    {T : ClosedTheorySet (WithParams Const)}
    {χ : ClosedFormula (WithParams Const)}
    (enum : Nat → Body Const)
    (henum : ∀ b : Body Const, ∃ n, enum n = b)
    (hT0 : ∀ ψ ∈ T, ∀ (σ : Ty Base) (k : Nat), NoConstOccurrence (param σ k) ψ)
    (hEM : ∀ ψ ∈ EMSchema Const, ψ ∈ T)
    (hχ0 : ∀ (σ : Ty Base) (k : Nat), NoConstOccurrence (param σ k) χ)
    (hNotProv : ¬ ClosedTheorySet.Provable (Const := WithParams Const) T χ) :
    ∃ M : ExtensionalTheoryModel (Base := Base) (Const := Const) T,
      credalHOLFormulaValue
        (extensionalTheoryModelHierarchicalState (Base := Base) (Const := Const) M)
        χ = 0 := by
  obtain ⟨M, hMT, hNotχ, hExt⟩ :=
    exists_extensional_model_not_models_of_not_provable_classical
      (Base := Base) (Const := Const) (T := T) (χ := χ)
      enum henum hT0 hEM hχ0 hNotProv
  refine ⟨⟨M, hMT, hExt⟩, ?_⟩
  exact
    credalHOLFormulaValue_dirac_eq_zero_of_not_models
      (Base := Base) (Const := Const) M hNotχ

/-- If `T` does not prove `¬χ`, the proof-tight extensional family contains a
model whose Dirac ProbHOL state gives value `1` to `χ`. -/
theorem exists_extensionalTheoryModel_dirac_value_one_of_not_provable_not
    {T : ClosedTheorySet (WithParams Const)}
    {χ : ClosedFormula (WithParams Const)}
    (enum : Nat → Body Const)
    (henum : ∀ b : Body Const, ∃ n, enum n = b)
    (hT0 : ∀ ψ ∈ T, ∀ (σ : Ty Base) (k : Nat), NoConstOccurrence (param σ k) ψ)
    (hEM : ∀ ψ ∈ EMSchema Const, ψ ∈ T)
    (hχ0 : ∀ (σ : Ty Base) (k : Nat), NoConstOccurrence (param σ k) χ)
    (hNotProvNot : ¬ ClosedTheorySet.Provable (Const := WithParams Const) T (.not χ)) :
    ∃ M : ExtensionalTheoryModel (Base := Base) (Const := Const) T,
      credalHOLFormulaValue
        (extensionalTheoryModelHierarchicalState (Base := Base) (Const := Const) M)
        χ = 1 := by
  obtain ⟨M, hMT, hχ, hExt⟩ :=
    exists_extensional_model_models_of_not_provable_not_classical
      (Base := Base) (Const := Const) (T := T) (χ := χ)
      enum henum hT0 hEM hχ0 hNotProvNot
  refine ⟨⟨M, hMT, hExt⟩, ?_⟩
  exact
    credalHOLFormulaValue_dirac_eq_one_of_models
      (Base := Base) (Const := Const) M hχ

/-- If `T` does not prove `χ`, the lower endpoint of the canonical
all-theory-model interval for `χ` is attained at `0`. This is the first
endpoint-tightness direction supplied by Henkin completeness. -/
theorem theoryCredalHOLFormulaInterval_lower_eq_zero_of_not_provable
    {T : ClosedTheorySet (WithParams Const)}
    {χ : ClosedFormula (WithParams Const)}
    (enum : Nat → Body Const)
    (henum : ∀ b : Body Const, ∃ n, enum n = b)
    (hCons : ClosedTheorySet.Consistent (Const := WithParams Const) T)
