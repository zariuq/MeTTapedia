    (henum : ∀ b : Body Const, ∃ n, enum n = b)
    (hCons : ClosedTheorySet.Consistent (Const := WithParams Const) T)
    (hT0 : ∀ ψ ∈ T, ∀ (σ : Ty Base) (k : Nat), NoConstOccurrence (param σ k) ψ)
    (hEM : ∀ ψ ∈ EMSchema Const, ψ ∈ T)
    (hχ0 : ∀ (σ : Ty Base) (k : Nat), NoConstOccurrence (param σ k) χ)
    (hLower :
      (theoryCredalHOLFormulaIntervalOfConsistent
        (Base := Base) (Const := Const) T enum henum hCons hT0 hEM χ).lower = 1) :
    ClosedTheorySet.Provable (Const := WithParams Const) T χ := by
  by_contra hNotProv
  have hLowerZero :
      (theoryCredalHOLFormulaIntervalOfConsistent
        (Base := Base) (Const := Const) T enum henum hCons hT0 hEM χ).lower = 0 :=
    theoryCredalHOLFormulaInterval_lower_eq_zero_of_not_provable
      (Base := Base) (Const := Const) (T := T) (χ := χ)
      enum henum hCons hT0 hEM hχ0 hNotProv
  rw [hLower] at hLowerZero
  norm_num at hLowerZero

/-- If the upper endpoint of the canonical interval is `0`, then `T` proves
`¬χ`. This is the dual endpoint-to-proof half of tightness. -/
theorem provable_not_of_theoryCredalHOLFormulaInterval_upper_eq_zero
    {T : ClosedTheorySet (WithParams Const)}
    {χ : ClosedFormula (WithParams Const)}
    (enum : Nat → Body Const)
    (henum : ∀ b : Body Const, ∃ n, enum n = b)
    (hCons : ClosedTheorySet.Consistent (Const := WithParams Const) T)
    (hT0 : ∀ ψ ∈ T, ∀ (σ : Ty Base) (k : Nat), NoConstOccurrence (param σ k) ψ)
    (hEM : ∀ ψ ∈ EMSchema Const, ψ ∈ T)
    (hχ0 : ∀ (σ : Ty Base) (k : Nat), NoConstOccurrence (param σ k) χ)
    (hUpper :
      (theoryCredalHOLFormulaIntervalOfConsistent
        (Base := Base) (Const := Const) T enum henum hCons hT0 hEM χ).upper = 0) :
    ClosedTheorySet.Provable (Const := WithParams Const) T (.not χ) := by
  by_contra hNotProvNot
  have hUpperOne :
      (theoryCredalHOLFormulaIntervalOfConsistent
        (Base := Base) (Const := Const) T enum henum hCons hT0 hEM χ).upper = 1 :=
    theoryCredalHOLFormulaInterval_upper_eq_one_of_not_provable_not
      (Base := Base) (Const := Const) (T := T) (χ := χ)
      enum henum hCons hT0 hEM hχ0 hNotProvNot
  rw [hUpper] at hUpperOne
  norm_num at hUpperOne

/-- A collapsed canonical formula interval cannot hide an undecided formula:
if the all-theory-model interval has width zero, then `T` decides `χ` by
proving either `χ` or `¬χ`.

The converse direction needs a proof-to-semantics bridge for the extensional
`ClosedTheorySet.Provable` surface and is intentionally not claimed here. -/
theorem decides_of_theoryCredalHOLFormulaInterval_width_eq_zero
    {T : ClosedTheorySet (WithParams Const)}
    {χ : ClosedFormula (WithParams Const)}
    (enum : Nat → Body Const)
    (henum : ∀ b : Body Const, ∃ n, enum n = b)
    (hCons : ClosedTheorySet.Consistent (Const := WithParams Const) T)
    (hT0 : ∀ ψ ∈ T, ∀ (σ : Ty Base) (k : Nat), NoConstOccurrence (param σ k) ψ)
    (hEM : ∀ ψ ∈ EMSchema Const, ψ ∈ T)
    (hχ0 : ∀ (σ : Ty Base) (k : Nat), NoConstOccurrence (param σ k) χ)
    (hWidth :
      (theoryCredalHOLFormulaIntervalOfConsistent
        (Base := Base) (Const := Const) T enum henum hCons hT0 hEM χ).width = 0) :
    ClosedTheorySet.Provable (Const := WithParams Const) T χ ∨
      ClosedTheorySet.Provable (Const := WithParams Const) T (.not χ) := by
  by_cases hProv : ClosedTheorySet.Provable (Const := WithParams Const) T χ
  · exact Or.inl hProv
  · right
    by_contra hNotProvNot
    have hLowerZero :
        (theoryCredalHOLFormulaIntervalOfConsistent
          (Base := Base) (Const := Const) T enum henum hCons hT0 hEM χ).lower = 0 :=
      theoryCredalHOLFormulaInterval_lower_eq_zero_of_not_provable
        (Base := Base) (Const := Const) (T := T) (χ := χ)
        enum henum hCons hT0 hEM hχ0 hProv
    have hUpperOne :
        (theoryCredalHOLFormulaIntervalOfConsistent
          (Base := Base) (Const := Const) T enum henum hCons hT0 hEM χ).upper = 1 :=
      theoryCredalHOLFormulaInterval_upper_eq_one_of_not_provable_not
        (Base := Base) (Const := Const) (T := T) (χ := χ)
        enum henum hCons hT0 hEM hχ0 hNotProvNot
    have hWidthOne : (1 : ℝ) = 0 := by
      simp [Interval.width, hLowerZero, hUpperOne] at hWidth
    norm_num at hWidthOne

/-- Flagship decidedness canary: every classical theory collapses the
proof-tight extensional interval for `⊤` to width `0`.

This is the executable shape of "the system knows when it knows": the theorem
reuses the endpoint-tight canonical family and the existing proof of `⊤`,
rather than introducing a separate example semantics. -/
theorem extensionalTheoryCredalHOLFormulaInterval_top_width_eq_zero
    {T : ClosedTheorySet (WithParams Const)}
    (enum : Nat → Body Const)
    (henum : ∀ b : Body Const, ∃ n, enum n = b)
    (hCons : ClosedTheorySet.Consistent (Const := WithParams Const) T)
    (hT0 : ∀ ψ ∈ T, ∀ (σ : Ty Base) (k : Nat), NoConstOccurrence (param σ k) ψ)
    (hEM : ∀ ψ ∈ EMSchema Const, ψ ∈ T) :
    (extensionalTheoryCredalHOLFormulaIntervalOfConsistent
      (Base := Base) (Const := Const) T enum henum hCons hT0 hEM
        (.top : ClosedFormula (WithParams Const))).width = 0 := by
  have hTop0 :
      ∀ (σ : Ty Base) (k : Nat),
        NoConstOccurrence (param σ k)
          (.top : ClosedFormula (WithParams Const)) := by
    intro σ k
    exact NoConstOccurrence.top
  exact
    (extensionalTheoryCredalHOLFormulaInterval_width_eq_zero_iff_decides
      (Base := Base) (Const := Const) (T := T)
      (χ := (.top : ClosedFormula (WithParams Const)))
      enum henum hCons hT0 hEM hTop0).2
      (Or.inl (ClosedTheorySet.provable_top (Const := WithParams Const) T))

/-- Flagship openness canary: if a classical theory proves neither `χ` nor
`¬χ`, the proof-tight extensional canonical interval for `χ` has full width
`1`.

This is the executable shape of "the system knows when it does not know":
uncertainty is not an arbitrary confidence penalty, but the exact spread across
the Henkin completions supplied by the completeness theorem. -/
theorem extensionalTheoryCredalHOLFormulaInterval_width_eq_one_of_undecided
    {T : ClosedTheorySet (WithParams Const)}
    {χ : ClosedFormula (WithParams Const)}
    (enum : Nat → Body Const)
    (henum : ∀ b : Body Const, ∃ n, enum n = b)
    (hCons : ClosedTheorySet.Consistent (Const := WithParams Const) T)
    (hT0 : ∀ ψ ∈ T, ∀ (σ : Ty Base) (k : Nat), NoConstOccurrence (param σ k) ψ)
    (hEM : ∀ ψ ∈ EMSchema Const, ψ ∈ T)
    (hχ0 : ∀ (σ : Ty Base) (k : Nat), NoConstOccurrence (param σ k) χ)
    (hNotProv : ¬ ClosedTheorySet.Provable (Const := WithParams Const) T χ)
    (hNotProvNot :
      ¬ ClosedTheorySet.Provable (Const := WithParams Const) T (.not χ)) :
    (extensionalTheoryCredalHOLFormulaIntervalOfConsistent
      (Base := Base) (Const := Const) T enum henum hCons hT0 hEM χ).width = 1 := by
  have hLower :
      (extensionalTheoryCredalHOLFormulaIntervalOfConsistent
        (Base := Base) (Const := Const) T enum henum hCons hT0 hEM χ).lower = 0 :=
    extensionalTheoryCredalHOLFormulaInterval_lower_eq_zero_of_not_provable
      (Base := Base) (Const := Const) (T := T) (χ := χ)
      enum henum hCons hT0 hEM hχ0 hNotProv
  have hUpper :
      (extensionalTheoryCredalHOLFormulaIntervalOfConsistent
        (Base := Base) (Const := Const) T enum henum hCons hT0 hEM χ).upper = 1 :=
    extensionalTheoryCredalHOLFormulaInterval_upper_eq_one_of_not_provable_not
      (Base := Base) (Const := Const) (T := T) (χ := χ)
      enum henum hCons hT0 hEM hχ0 hNotProvNot
  simp [Interval.width, hLower, hUpper]

