  change
    lowerProb (deductionEndpointCredalSet pA pB pC sAB sBC hFeas)
      DeductionAtom.eventAC = deductionCredalJointLower pA pB pC sAB sBC
  exact deductionEndpointCredalSet_lowerProb_eventAC_eq pA pB pC sAB sBC hFeas

@[simp] theorem deductionEndpointJointTypedITV_upper
    (pA pB pC sAB sBC : ℝ)
