/-- Provenance-tagged version of the no-independence deduction strength ITV.

The tag is the generic ITV constructor because this bridge only proves bounded
interval endpoints; Bayesian/Walley/Kyburg constructor semantics are deliberately
not asserted here. -/
noncomputable def deductionCredalStrengthTypedITV
    (pA pB pC sAB sBC : ℝ)
    (hpA : 0 < pA)
    (hFeas : DeductionBranchFeasibility pA pB pC sAB sBC)
    (credibility : ℝ) (hc : credibility ∈ Set.Icc (0 : ℝ) 1) :
    Mettapedia.Logic.PLNTruthTower.TypedITV
      Mettapedia.Logic.PLNTruthTower.genericITVSemantics :=
  Mettapedia.Logic.PLNTruthTower.TypedITV.fromGeneric
    (deductionCredalStrengthITV pA pB pC sAB sBC hpA hFeas credibility hc)

@[simp] theorem deductionCredalStrengthTypedITV_value
    (pA pB pC sAB sBC : ℝ)
    (hpA : 0 < pA)
    (hFeas : DeductionBranchFeasibility pA pB pC sAB sBC)
    (credibility : ℝ) (hc : credibility ∈ Set.Icc (0 : ℝ) 1) :
    (deductionCredalStrengthTypedITV pA pB pC sAB sBC hpA hFeas
      credibility hc).value =
      deductionCredalStrengthITV pA pB pC sAB sBC hpA hFeas credibility hc :=
  rfl

/-- The traditional PLN point deduction formula is a member of the generic ITV
interval exactly under the same explicit branch-admissibility hypotheses as the
underlying interval theorem. -/
theorem simpleDeductionStrengthFormula_mem_deductionCredalStrengthITV
    (pA pB pC sAB sBC : ℝ)
    (hpA : 0 < pA)
    (hpB_small : pB ≤ 0.99)
    (hFeas : DeductionBranchFeasibility pA pB pC sAB sBC)
    (h_consist : conditionalProbabilityConsistency pA pB sAB ∧
                 conditionalProbabilityConsistency pB pC sBC)
    (ht_lower :
      deductionBBranchLower pA pB sAB sBC ≤ pA * sAB * sBC)
    (ht_upper :
      pA * sAB * sBC ≤ deductionBBranchUpper pA pB sAB sBC)
    (hu_lower :
      deductionNotBBranchLower pA pB pC sAB sBC ≤
        pA * (1 - sAB) * complementConditionalFromMarginal pB pC sBC)
    (hu_upper :
      pA * (1 - sAB) * complementConditionalFromMarginal pB pC sBC ≤
        deductionNotBBranchUpper pA pB pC sAB sBC)
    (credibility : ℝ) (hc : credibility ∈ Set.Icc (0 : ℝ) 1) :
    let itv :=
      deductionCredalStrengthITV pA pB pC sAB sBC hpA hFeas credibility hc
    itv.lower ≤ simpleDeductionStrengthFormula pA pB pC sAB sBC ∧
      simpleDeductionStrengthFormula pA pB pC sAB sBC ≤ itv.upper := by
  dsimp
  simpa using
    simpleDeductionStrengthFormula_mem_credal_interval_of_branch_bounds
      pA pB pC sAB sBC hpA hpB_small h_consist
      ht_lower ht_upper hu_lower hu_upper

/-- The traditional PLN point deduction formula lies inside the normalized
endpoint joint envelope under the same explicit branch-admissibility hypotheses.

This is a corollary of the generic strength-ITV membership theorem plus the
proved endpoint normalization above; it does not add any independence
assumption. -/
theorem simpleDeductionStrengthFormula_mem_normalized_endpointJointTypedITV
    (pA pB pC sAB sBC : ℝ)
    (hpA : 0 < pA)
    (hpB_small : pB ≤ 0.99)
    (hFeas : DeductionBranchFeasibility pA pB pC sAB sBC)
    (h_consist : conditionalProbabilityConsistency pA pB sAB ∧
                 conditionalProbabilityConsistency pB pC sBC)
    (ht_lower :
      deductionBBranchLower pA pB sAB sBC ≤ pA * sAB * sBC)
    (ht_upper :
      pA * sAB * sBC ≤ deductionBBranchUpper pA pB sAB sBC)
    (hu_lower :
      deductionNotBBranchLower pA pB pC sAB sBC ≤
        pA * (1 - sAB) * complementConditionalFromMarginal pB pC sBC)
    (hu_upper :
      pA * (1 - sAB) * complementConditionalFromMarginal pB pC sBC ≤
        deductionNotBBranchUpper pA pB pC sAB sBC)
    (credibility : ℝ) (hc : credibility ∈ Set.Icc (0 : ℝ) 1) :
    let joint :=
      deductionEndpointJointTypedITV pA pB pC sAB sBC hFeas credibility hc
    joint.lower / pA ≤ simpleDeductionStrengthFormula pA pB pC sAB sBC ∧
      simpleDeductionStrengthFormula pA pB pC sAB sBC ≤ joint.upper / pA := by
  dsimp
  have hMem :=
    simpleDeductionStrengthFormula_mem_deductionCredalStrengthITV
      pA pB pC sAB sBC hpA hpB_small hFeas h_consist
      ht_lower ht_upper hu_lower hu_upper credibility hc
  constructor
  · rw [← deductionCredalStrengthITV_lower_eq_endpointJoint_lower_div
      pA pB pC sAB sBC hpA hFeas credibility hc]
    exact hMem.1
  · rw [← deductionCredalStrengthITV_upper_eq_endpointJoint_upper_div
      pA pB pC sAB sBC hpA hFeas credibility hc]
    exact hMem.2

/-- The traditional PLN point deduction formula also lies inside the normalized
full admissible-allocation joint envelope.

This is the non-independence reading: the point formula is one admissible member
of the no-laundering credal interval, while the full interval keeps the residual
degrees of freedom visible when the independence assumptions are not supplied. -/
theorem simpleDeductionStrengthFormula_mem_normalized_allocationJointTypedITV
    (pA pB pC sAB sBC : ℝ)
    (hpA : 0 < pA)
    (hpB_small : pB ≤ 0.99)
    (hFeas : DeductionBranchFeasibility pA pB pC sAB sBC)
    (h_consist : conditionalProbabilityConsistency pA pB sAB ∧
                 conditionalProbabilityConsistency pB pC sBC)
    (ht_lower :
      deductionBBranchLower pA pB sAB sBC ≤ pA * sAB * sBC)
    (ht_upper :
      pA * sAB * sBC ≤ deductionBBranchUpper pA pB sAB sBC)
    (hu_lower :
      deductionNotBBranchLower pA pB pC sAB sBC ≤
        pA * (1 - sAB) * complementConditionalFromMarginal pB pC sBC)
    (hu_upper :
      pA * (1 - sAB) * complementConditionalFromMarginal pB pC sBC ≤
        deductionNotBBranchUpper pA pB pC sAB sBC)
    (credibility : ℝ) (hc : credibility ∈ Set.Icc (0 : ℝ) 1) :
    let joint :=
      deductionAllocationJointTypedITV pA pB pC sAB sBC hFeas credibility hc
    joint.lower / pA ≤ simpleDeductionStrengthFormula pA pB pC sAB sBC ∧
      simpleDeductionStrengthFormula pA pB pC sAB sBC ≤ joint.upper / pA := by
  dsimp
  have hMem :=
    simpleDeductionStrengthFormula_mem_deductionCredalStrengthITV
      pA pB pC sAB sBC hpA hpB_small hFeas h_consist
      ht_lower ht_upper hu_lower hu_upper credibility hc
  constructor
  · rw [← deductionCredalStrengthITV_lower_eq_allocationJoint_lower_div
      pA pB pC sAB sBC hpA hFeas credibility hc]
    exact hMem.1
  · rw [← deductionCredalStrengthITV_upper_eq_allocationJoint_upper_div
      pA pB pC sAB sBC hpA hFeas credibility hc]
    exact hMem.2

end Mettapedia.Logic.PLNDeduction
