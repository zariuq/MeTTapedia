/-- The conditional-strength width is the full allocation joint-envelope width
normalized by `P(A)`. -/
theorem deductionCredalStrengthITV_width_eq_allocationJoint_width_div
    (pA pB pC sAB sBC : ℝ)
    (hpA : 0 < pA)
    (hFeas : DeductionBranchFeasibility pA pB pC sAB sBC)
    (credibility : ℝ) (hc : credibility ∈ Set.Icc (0 : ℝ) 1) :
