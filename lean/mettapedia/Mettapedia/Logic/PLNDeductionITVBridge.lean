    (DeductionBranchAllocation.expected_eventAC_eq
      (deductionUpperEndpointBranchAllocation pA pB pC sAB sBC hFeas))

@[simp] theorem deductionEndpointCredalSet_lowerProb_eventAC_eq
    (pA pB pC sAB sBC : ℝ)
    (hFeas : DeductionBranchFeasibility pA pB pC sAB sBC) :
    lowerProb (deductionEndpointCredalSet pA pB pC sAB sBC hFeas)
        DeductionAtom.eventAC =
      deductionCredalJointLower pA pB pC sAB sBC := by
  have hPQ :
      expectedValue
          ((deductionLowerEndpointBranchAllocation pA pB pC sAB sBC hFeas).probDist)
          DeductionAtom.eventAC ≤
        expectedValue
          ((deductionUpperEndpointBranchAllocation pA pB pC sAB sBC hFeas).probDist)
          DeductionAtom.eventAC := by
    rw [deductionLowerEndpoint_expected_eventAC_eq,
      deductionUpperEndpoint_expected_eventAC_eq]
    exact deductionCredalJointLower_le_upper_of_branch_feasible pA pB pC sAB sBC hFeas
  calc
    lowerProb (deductionEndpointCredalSet pA pB pC sAB sBC hFeas)
        DeductionAtom.eventAC =
      expectedValue
        ((deductionLowerEndpointBranchAllocation pA pB pC sAB sBC hFeas).probDist)
        DeductionAtom.eventAC := by
        exact lowerProb_insert_singleton_eq_left_of_le _ _ _ hPQ
    _ = deductionCredalJointLower pA pB pC sAB sBC := by
        exact deductionLowerEndpoint_expected_eventAC_eq pA pB pC sAB sBC hFeas

@[simp] theorem deductionEndpointCredalSet_upperProb_eventAC_eq
    (pA pB pC sAB sBC : ℝ)
    (hFeas : DeductionBranchFeasibility pA pB pC sAB sBC) :
    upperProb (deductionEndpointCredalSet pA pB pC sAB sBC hFeas)
        DeductionAtom.eventAC =
      deductionCredalJointUpper pA pB pC sAB sBC := by
  have hPQ :
      expectedValue
          ((deductionLowerEndpointBranchAllocation pA pB pC sAB sBC hFeas).probDist)
          DeductionAtom.eventAC ≤
        expectedValue
          ((deductionUpperEndpointBranchAllocation pA pB pC sAB sBC hFeas).probDist)
          DeductionAtom.eventAC := by
    rw [deductionLowerEndpoint_expected_eventAC_eq,
      deductionUpperEndpoint_expected_eventAC_eq]
    exact deductionCredalJointLower_le_upper_of_branch_feasible pA pB pC sAB sBC hFeas
  calc
    upperProb (deductionEndpointCredalSet pA pB pC sAB sBC hFeas)
        DeductionAtom.eventAC =
      expectedValue
        ((deductionUpperEndpointBranchAllocation pA pB pC sAB sBC hFeas).probDist)
        DeductionAtom.eventAC := by
        exact upperProb_insert_singleton_eq_right_of_le _ _ _ hPQ
    _ = deductionCredalJointUpper pA pB pC sAB sBC := by
        exact deductionUpperEndpoint_expected_eventAC_eq pA pB pC sAB sBC hFeas

/-- Truth-tower source for the joint `P(A ∧ C)` endpoint envelope.

The normalized strength interval divides this joint envelope by `P(A)` at the
deduction layer; the unit-bounded gamble exposed to Walley's constructor is the
actual event indicator. -/
noncomputable def deductionEndpointJointITVSource
    (pA pB pC sAB sBC : ℝ)
    (hFeas : DeductionBranchFeasibility pA pB pC sAB sBC)
    (credibility : ℝ) (hc : credibility ∈ Set.Icc (0 : ℝ) 1) :
    Mettapedia.Logic.PLNTruthTower.CredalEnvelopeITVSource DeductionAtom where
  credal := deductionEndpointCredalSet pA pB pC sAB sBC hFeas
  gamble := DeductionAtom.eventAC
  credal_nonempty := deductionEndpointCredalSet_nonempty pA pB pC sAB sBC hFeas
  gamble_in_unit := DeductionAtom.eventAC_in_unit
  credibility := credibility
  credibility_in_unit := hc

/-- Provenance-tagged Walley-envelope ITV for the endpoint joint `P(A ∧ C)`. -/
noncomputable def deductionEndpointJointTypedITV
    (pA pB pC sAB sBC : ℝ)
    (hFeas : DeductionBranchFeasibility pA pB pC sAB sBC)
    (credibility : ℝ) (hc : credibility ∈ Set.Icc (0 : ℝ) 1) :
    Mettapedia.Logic.PLNTruthTower.TypedITV
      (Mettapedia.Logic.PLNTruthTower.credalEnvelopeITVSemantics DeductionAtom) :=
  Mettapedia.Logic.PLNTruthTower.TypedITV.fromCredalEnvelope
    (deductionEndpointJointITVSource pA pB pC sAB sBC hFeas credibility hc)

@[simp] theorem deductionEndpointJointTypedITV_lower
