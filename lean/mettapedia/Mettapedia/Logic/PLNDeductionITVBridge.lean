/-- The normalized deduction-strength lower endpoint is exactly the lower joint
credal-envelope endpoint divided by `P(A)`. -/
@[simp] theorem deductionCredalStrengthITV_lower_eq_endpointJoint_lower_div
    (pA pB pC sAB sBC : ℝ)
    (hpA : 0 < pA)
    (hFeas : DeductionBranchFeasibility pA pB pC sAB sBC)
    (credibility : ℝ) (hc : credibility ∈ Set.Icc (0 : ℝ) 1) :
    (deductionCredalStrengthITV pA pB pC sAB sBC hpA hFeas
      credibility hc).lower =
      (deductionEndpointJointTypedITV pA pB pC sAB sBC hFeas
        credibility hc).lower / pA := by
  simp [deductionCredalStrengthLower]

/-- The normalized deduction-strength upper endpoint is exactly the upper joint
credal-envelope endpoint divided by `P(A)`. -/
@[simp] theorem deductionCredalStrengthITV_upper_eq_endpointJoint_upper_div
    (pA pB pC sAB sBC : ℝ)
    (hpA : 0 < pA)
    (hFeas : DeductionBranchFeasibility pA pB pC sAB sBC)
    (credibility : ℝ) (hc : credibility ∈ Set.Icc (0 : ℝ) 1) :
    (deductionCredalStrengthITV pA pB pC sAB sBC hpA hFeas
      credibility hc).upper =
      (deductionEndpointJointTypedITV pA pB pC sAB sBC hFeas
        credibility hc).upper / pA := by
  simp [deductionCredalStrengthUpper]

/-- Width normalizes with the same positive `P(A)` denominator as the endpoints.

This is the precise bridge from the Walley envelope over the joint event
`A ∧ C` to the conditional-strength interval `P(C | A)`. -/
theorem deductionCredalStrengthITV_width_eq_endpointJoint_width_div
    (pA pB pC sAB sBC : ℝ)
    (hpA : 0 < pA)
    (hFeas : DeductionBranchFeasibility pA pB pC sAB sBC)
    (credibility : ℝ) (hc : credibility ∈ Set.Icc (0 : ℝ) 1) :
    (deductionCredalStrengthITV pA pB pC sAB sBC hpA hFeas
      credibility hc).width =
      (deductionEndpointJointTypedITV pA pB pC sAB sBC hFeas
        credibility hc).width / pA := by
  have hJointWidth :
      (deductionEndpointJointTypedITV pA pB pC sAB sBC hFeas
        credibility hc).width =
        deductionCredalJointUpper pA pB pC sAB sBC -
          deductionCredalJointLower pA pB pC sAB sBC := by
    change
      (deductionEndpointJointTypedITV pA pB pC sAB sBC hFeas
        credibility hc).upper -
        (deductionEndpointJointTypedITV pA pB pC sAB sBC hFeas
          credibility hc).lower =
        deductionCredalJointUpper pA pB pC sAB sBC -
          deductionCredalJointLower pA pB pC sAB sBC
    simp
  rw [hJointWidth]
  simp [Mettapedia.Logic.PLNIndefiniteTruth.ITV.width,
    deductionCredalStrengthLower, deductionCredalStrengthUpper]
  ring_nf

/-- The normalized deduction-strength lower endpoint is also the lower endpoint
of the full admissible-allocation joint envelope divided by `P(A)`. -/
@[simp] theorem deductionCredalStrengthITV_lower_eq_allocationJoint_lower_div
