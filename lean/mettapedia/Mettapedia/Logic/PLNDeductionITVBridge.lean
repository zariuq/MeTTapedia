import Mettapedia.Logic.PLNDeduction
import Mettapedia.Logic.PLNTruthTower

/-!
# PLN Deduction Credal Intervals as ITVs

This file connects the no-independence deduction interval from
`PLNDeduction.lean` to the shared WM-PLN indefinite-truth-value surface.

The bridge is intentionally narrow:

* `PLNDeduction.lean` supplies branch allocations and their eight-atom finite
  table readouts.
* this file proves those readouts make the normalized `P(C | A)` interval a
  well-formed generic ITV, with credibility chosen explicitly by the caller;
* it also packages the endpoint realizers as a two-point Walley credal envelope
  for the joint event `A ∧ C`, so the no-independence interval is connected to
  the shared truth-tower constructor without pretending that conditional
  normalization is itself a unit-bounded gamble.

The normalized strength ITV remains a generic interval.  Bayesian, IDM, or
Kyburg readings are later consumers of the same endpoint witnesses.
-/

namespace Mettapedia.Logic.PLNDeduction

open Mettapedia.ProbabilityTheory.ImpreciseProbability.DesirableGambles

/-- The eight atoms of the Boolean algebra generated by `A`, `B`, and `C` in a
deduction instance. -/
inductive DeductionAtom where
  | abc
  | abNotC
  | aNotBC
  | aNotBNotC
  | notABC
  | notABNotC
  | notANotBC
  | notANotBNotC
  deriving DecidableEq, Fintype

namespace DeductionAtom

theorem univ_eq :
    (Finset.univ : Finset DeductionAtom) =
      {abc, abNotC, aNotBC, aNotBNotC, notABC, notABNotC,
        notANotBC, notANotBNotC} := by
  ext ω
  cases ω <;> simp

/-- Expand a finite sum over the eight deduction atoms. -/
theorem sum_eq (f : DeductionAtom → ℝ) :
    (∑ ω : DeductionAtom, f ω) =
      f abc + f abNotC + f aNotBC + f aNotBNotC +
        f notABC + f notABNotC + f notANotBC + f notANotBNotC := by
  rw [univ_eq]
  simp [add_assoc]

/-- Indicator gamble for event `A`. -/
def eventA : Gamble DeductionAtom
  | abc => 1
  | abNotC => 1
  | aNotBC => 1
  | aNotBNotC => 1
  | notABC => 0
  | notABNotC => 0
  | notANotBC => 0
  | notANotBNotC => 0

/-- Indicator gamble for event `B`. -/
def eventB : Gamble DeductionAtom
  | abc => 1
  | abNotC => 1
  | aNotBC => 0
  | aNotBNotC => 0
  | notABC => 1
  | notABNotC => 1
  | notANotBC => 0
  | notANotBNotC => 0

/-- Indicator gamble for event `C`. -/
def eventC : Gamble DeductionAtom
  | abc => 1
  | abNotC => 0
  | aNotBC => 1
  | aNotBNotC => 0
  | notABC => 1
  | notABNotC => 0
  | notANotBC => 1
  | notANotBNotC => 0

/-- Indicator gamble for event `A ∧ B`. -/
def eventAB : Gamble DeductionAtom
  | abc => 1
  | abNotC => 1
  | aNotBC => 0
  | aNotBNotC => 0
  | notABC => 0
  | notABNotC => 0
  | notANotBC => 0
  | notANotBNotC => 0

/-- Indicator gamble for event `B ∧ C`. -/
def eventBC : Gamble DeductionAtom
  | abc => 1
  | abNotC => 0
  | aNotBC => 0
  | aNotBNotC => 0
  | notABC => 1
  | notABNotC => 0
  | notANotBC => 0
  | notANotBNotC => 0

/-- Indicator gamble for event `A ∧ C`, the numerator of deduction's
conclusion `P(C | A)`. -/
def eventAC : Gamble DeductionAtom
  | abc => 1
  | abNotC => 0
  | aNotBC => 1
  | aNotBNotC => 0
  | notABC => 0
  | notABNotC => 0
  | notANotBC => 0
  | notANotBNotC => 0

theorem eventA_in_unit : ∀ ω, eventA ω ∈ Set.Icc (0 : ℝ) 1 := by
  intro ω
  cases ω <;> norm_num [eventA]

theorem eventB_in_unit : ∀ ω, eventB ω ∈ Set.Icc (0 : ℝ) 1 := by
  intro ω
  cases ω <;> norm_num [eventB]

theorem eventC_in_unit : ∀ ω, eventC ω ∈ Set.Icc (0 : ℝ) 1 := by
  intro ω
  cases ω <;> norm_num [eventC]

theorem eventAB_in_unit : ∀ ω, eventAB ω ∈ Set.Icc (0 : ℝ) 1 := by
  intro ω
  cases ω <;> norm_num [eventAB]

theorem eventBC_in_unit : ∀ ω, eventBC ω ∈ Set.Icc (0 : ℝ) 1 := by
  intro ω
  cases ω <;> norm_num [eventBC]

theorem eventAC_in_unit : ∀ ω, eventAC ω ∈ Set.Icc (0 : ℝ) 1 := by
  intro ω
  cases ω <;> norm_num [eventAC]

end DeductionAtom

namespace DeductionBranchAllocation

/-- The atom mass function induced by a branch allocation. -/
noncomputable def atomMass
    {pA pB pC sAB sBC : ℝ}
    (alloc : DeductionBranchAllocation pA pB pC sAB sBC) :
    DeductionAtom → ℝ
  | DeductionAtom.abc => alloc.atomABC
  | DeductionAtom.abNotC => alloc.atomABNotC
  | DeductionAtom.aNotBC => alloc.atomANotBC
  | DeductionAtom.aNotBNotC => alloc.atomANotBNotC
  | DeductionAtom.notABC => alloc.atomNotABC
  | DeductionAtom.notABNotC => alloc.atomNotABNotC
  | DeductionAtom.notANotBC => alloc.atomNotANotBC
  | DeductionAtom.notANotBNotC => alloc.atomNotANotBNotC

theorem atomMass_nonneg
    {pA pB pC sAB sBC : ℝ}
    (alloc : DeductionBranchAllocation pA pB pC sAB sBC) :
    ∀ ω, 0 ≤ alloc.atomMass ω := by
  intro ω
  cases ω <;> simp [atomMass,
    atomABC_nonneg, atomABNotC_nonneg, atomANotBC_nonneg,
    atomANotBNotC_nonneg, atomNotABC_nonneg, atomNotABNotC_nonneg,
    atomNotANotBC_nonneg, atomNotANotBNotC_nonneg]

theorem atomMass_sum_one
    {pA pB pC sAB sBC : ℝ}
    (alloc : DeductionBranchAllocation pA pB pC sAB sBC) :
    ∑ ω : DeductionAtom, alloc.atomMass ω = 1 := by
  rw [DeductionAtom.sum_eq]
  simpa [atomMass] using alloc.atom_total_eq_one

/-- The finite probability distribution on the eight `A/B/C` atoms induced by
an admissible branch allocation. -/
noncomputable def probDist
    {pA pB pC sAB sBC : ℝ}
    (alloc : DeductionBranchAllocation pA pB pC sAB sBC) :
    ProbDist DeductionAtom where
  prob := alloc.atomMass
  non_neg := by
    intro ω
    exact alloc.atomMass_nonneg ω
  sum_one := alloc.atomMass_sum_one

@[simp] theorem probDist_prob
    {pA pB pC sAB sBC : ℝ}
    (alloc : DeductionBranchAllocation pA pB pC sAB sBC)
    (ω : DeductionAtom) :
    (alloc.probDist).prob ω = alloc.atomMass ω :=
  rfl

theorem expected_eventA_eq
    {pA pB pC sAB sBC : ℝ}
    (alloc : DeductionBranchAllocation pA pB pC sAB sBC) :
    expectedValue alloc.probDist DeductionAtom.eventA = pA := by
  unfold expectedValue
  rw [DeductionAtom.sum_eq]
  simpa [probDist, atomMass, DeductionAtom.eventA] using alloc.atom_marginalA_eq

theorem expected_eventB_eq
    {pA pB pC sAB sBC : ℝ}
    (alloc : DeductionBranchAllocation pA pB pC sAB sBC) :
    expectedValue alloc.probDist DeductionAtom.eventB = pB := by
  unfold expectedValue
  rw [DeductionAtom.sum_eq]
  simpa [probDist, atomMass, DeductionAtom.eventB] using alloc.atom_marginalB_eq

theorem expected_eventC_eq
    {pA pB pC sAB sBC : ℝ}
    (alloc : DeductionBranchAllocation pA pB pC sAB sBC) :
    expectedValue alloc.probDist DeductionAtom.eventC = pC := by
  unfold expectedValue
  rw [DeductionAtom.sum_eq]
  simpa [probDist, atomMass, DeductionAtom.eventC] using alloc.atom_marginalC_eq

theorem expected_eventAB_eq
    {pA pB pC sAB sBC : ℝ}
    (alloc : DeductionBranchAllocation pA pB pC sAB sBC) :
    expectedValue alloc.probDist DeductionAtom.eventAB =
      deductionJointAB pA sAB := by
  unfold expectedValue
  rw [DeductionAtom.sum_eq]
  simpa [probDist, atomMass, DeductionAtom.eventAB] using alloc.atom_jointAB_eq

theorem expected_eventBC_eq
    {pA pB pC sAB sBC : ℝ}
    (alloc : DeductionBranchAllocation pA pB pC sAB sBC) :
    expectedValue alloc.probDist DeductionAtom.eventBC =
      deductionJointBC pB sBC := by
  unfold expectedValue
  rw [DeductionAtom.sum_eq]
  simpa [probDist, atomMass, DeductionAtom.eventBC] using alloc.atom_jointBC_eq

theorem expected_eventAC_eq
    {pA pB pC sAB sBC : ℝ}
    (alloc : DeductionBranchAllocation pA pB pC sAB sBC) :
    expectedValue alloc.probDist DeductionAtom.eventAC = alloc.jointAC := by
  unfold expectedValue
  rw [DeductionAtom.sum_eq]
  simpa [probDist, atomMass, DeductionAtom.eventAC] using alloc.atom_jointAC_eq

/-- The realized `A ∧ C` joint mass of a branch allocation is nonnegative. -/
theorem jointAC_nonneg
    {pA pB pC sAB sBC : ℝ}
    (alloc : DeductionBranchAllocation pA pB pC sAB sBC) :
    0 ≤ alloc.jointAC := by
  have hABC := alloc.atomABC_nonneg
  have hANotBC := alloc.atomANotBC_nonneg
  unfold jointAC atomABC atomANotBC at *
  linarith

/-- The realized `A ∧ C` joint mass of a branch allocation is bounded by
`P(A)`. -/
theorem jointAC_le_pA
    {pA pB pC sAB sBC : ℝ}
    (alloc : DeductionBranchAllocation pA pB pC sAB sBC) :
    alloc.jointAC ≤ pA := by
  have hABNotC := alloc.atomABNotC_nonneg
  have hANotBNotC := alloc.atomANotBNotC_nonneg
  have hA := alloc.atom_marginalA_eq
  unfold jointAC atomABC atomANotBC at *
  linarith

/-- The normalized `P(C | A)` readout of an allocation is a unit-interval
strength whenever `P(A) > 0`. -/
theorem strengthAC_in_unit
    {pA pB pC sAB sBC : ℝ}
    (alloc : DeductionBranchAllocation pA pB pC sAB sBC)
    (hpA : 0 < pA) :
    alloc.strengthAC ∈ Set.Icc (0 : ℝ) 1 := by
  constructor
  · unfold strengthAC
    exact div_nonneg alloc.jointAC_nonneg (le_of_lt hpA)
  · unfold strengthAC
    exact (div_le_one hpA).2 alloc.jointAC_le_pA

end DeductionBranchAllocation

private theorem lowerProb_insert_singleton_eq_left_of_le
    {Ω : Type*} [Fintype Ω] (P Q : ProbDist Ω) (f : Gamble Ω)
    (hPQ : expectedValue P f ≤ expectedValue Q f) :
    lowerProb (Set.insert P (Set.singleton Q)) f = expectedValue P f := by
  let S : Set ℝ :=
    Set.image (fun R => expectedValue R f) (Set.insert P (Set.singleton Q))
  have hS_ne : S.Nonempty := by
    exact ⟨expectedValue P f,
      ⟨P, Set.mem_insert P (Set.singleton Q), rfl⟩⟩
  have hS_bddBelow : BddBelow S := by
    refine ⟨expectedValue P f, ?_⟩
    rintro x ⟨R, hR, rfl⟩
    rcases Set.mem_insert_iff.mp hR with rfl | hR
    · exact le_rfl
    · have hRQ : R = Q := Set.mem_singleton_iff.mp hR
      subst R
      exact hPQ
  unfold lowerProb
  change sInf S = expectedValue P f
  apply le_antisymm
  · exact csInf_le hS_bddBelow
      ⟨P, Set.mem_insert P (Set.singleton Q), rfl⟩
  · exact le_csInf hS_ne (by
      rintro x ⟨R, hR, rfl⟩
      rcases Set.mem_insert_iff.mp hR with rfl | hR
      · exact le_rfl
      · have hRQ : R = Q := Set.mem_singleton_iff.mp hR
        subst R
        exact hPQ)

private theorem upperProb_insert_singleton_eq_right_of_le
    {Ω : Type*} [Fintype Ω] (P Q : ProbDist Ω) (f : Gamble Ω)
    (hPQ : expectedValue P f ≤ expectedValue Q f) :
    upperProb (Set.insert P (Set.singleton Q)) f = expectedValue Q f := by
  let S : Set ℝ :=
    Set.image (fun R => expectedValue R f) (Set.insert P (Set.singleton Q))
  have hS_ne : S.Nonempty := by
    exact ⟨expectedValue P f,
      ⟨P, Set.mem_insert P (Set.singleton Q), rfl⟩⟩
  have hS_bddAbove : BddAbove S := by
    refine ⟨expectedValue Q f, ?_⟩
    rintro x ⟨R, hR, rfl⟩
    rcases Set.mem_insert_iff.mp hR with rfl | hR
    · exact hPQ
    · have hRQ : R = Q := Set.mem_singleton_iff.mp hR
      subst R
      exact le_rfl
  unfold upperProb
  change sSup S = expectedValue Q f
  apply le_antisymm
  · exact csSup_le hS_ne (by
      rintro x ⟨R, hR, rfl⟩
      rcases Set.mem_insert_iff.mp hR with rfl | hR
      · exact hPQ
      · have hRQ : R = Q := Set.mem_singleton_iff.mp hR
        subst R
        exact le_rfl)
  · exact le_csSup hS_bddAbove
      ⟨Q, Set.mem_insert_of_mem P (Set.mem_singleton Q), rfl⟩

private theorem lowerProb_eq_expectedValue_of_mem_forall_le
    {Ω : Type*} [Fintype Ω] (C : CredalSetFinite Ω) (P₀ : ProbDist Ω)
    (f : Gamble Ω) (hP₀ : P₀ ∈ C)
    (hmin : ∀ P ∈ C, expectedValue P₀ f ≤ expectedValue P f) :
    lowerProb C f = expectedValue P₀ f := by
  let S : Set ℝ := Set.image (fun P => expectedValue P f) C
  have hS_ne : S.Nonempty :=
    ⟨expectedValue P₀ f, ⟨P₀, hP₀, rfl⟩⟩
  have hS_bddBelow : BddBelow S := by
    refine ⟨expectedValue P₀ f, ?_⟩
    rintro x ⟨P, hP, rfl⟩
    exact hmin P hP
  unfold lowerProb
  change sInf S = expectedValue P₀ f
  apply le_antisymm
  · exact csInf_le hS_bddBelow ⟨P₀, hP₀, rfl⟩
  · exact le_csInf hS_ne (by
      rintro x ⟨P, hP, rfl⟩
      exact hmin P hP)

private theorem upperProb_eq_expectedValue_of_mem_forall_le
    {Ω : Type*} [Fintype Ω] (C : CredalSetFinite Ω) (Q₀ : ProbDist Ω)
    (f : Gamble Ω) (hQ₀ : Q₀ ∈ C)
    (hmax : ∀ P ∈ C, expectedValue P f ≤ expectedValue Q₀ f) :
    upperProb C f = expectedValue Q₀ f := by
  let S : Set ℝ := Set.image (fun P => expectedValue P f) C
  have hS_ne : S.Nonempty :=
    ⟨expectedValue Q₀ f, ⟨Q₀, hQ₀, rfl⟩⟩
  have hS_bddAbove : BddAbove S := by
    refine ⟨expectedValue Q₀ f, ?_⟩
    rintro x ⟨P, hP, rfl⟩
    exact hmax P hP
  unfold upperProb
  change sSup S = expectedValue Q₀ f
  apply le_antisymm
  · exact csSup_le hS_ne (by
      rintro x ⟨P, hP, rfl⟩
      exact hmax P hP)
  · exact le_csSup hS_bddAbove ⟨Q₀, hQ₀, rfl⟩

open Mettapedia.Logic.PLNIndefiniteTruth

/-- The full finite credal family generated by all admissible branch allocations
for one deduction instance. -/
noncomputable def deductionAllocationCredalSet
    (pA pB pC sAB sBC : ℝ) : CredalSetFinite DeductionAtom :=
  { P | ∃ alloc : DeductionBranchAllocation pA pB pC sAB sBC,
      P = alloc.probDist }

@[simp] theorem probDist_mem_deductionAllocationCredalSet
    {pA pB pC sAB sBC : ℝ}
    (alloc : DeductionBranchAllocation pA pB pC sAB sBC) :
    alloc.probDist ∈ deductionAllocationCredalSet pA pB pC sAB sBC :=
  ⟨alloc, rfl⟩

@[simp] theorem deductionLowerEndpointProbDist_mem_allocationCredalSet
    (pA pB pC sAB sBC : ℝ)
    (hFeas : DeductionBranchFeasibility pA pB pC sAB sBC) :
    (deductionLowerEndpointBranchAllocation pA pB pC sAB sBC hFeas).probDist ∈
      deductionAllocationCredalSet pA pB pC sAB sBC := by
  exact probDist_mem_deductionAllocationCredalSet
    (deductionLowerEndpointBranchAllocation pA pB pC sAB sBC hFeas)

@[simp] theorem deductionUpperEndpointProbDist_mem_allocationCredalSet
    (pA pB pC sAB sBC : ℝ)
    (hFeas : DeductionBranchFeasibility pA pB pC sAB sBC) :
    (deductionUpperEndpointBranchAllocation pA pB pC sAB sBC hFeas).probDist ∈
      deductionAllocationCredalSet pA pB pC sAB sBC := by
  exact probDist_mem_deductionAllocationCredalSet
    (deductionUpperEndpointBranchAllocation pA pB pC sAB sBC hFeas)

theorem deductionAllocationCredalSet_nonempty
    (pA pB pC sAB sBC : ℝ)
    (hFeas : DeductionBranchFeasibility pA pB pC sAB sBC) :
    (deductionAllocationCredalSet pA pB pC sAB sBC).Nonempty :=
  ⟨(deductionLowerEndpointBranchAllocation pA pB pC sAB sBC hFeas).probDist,
    deductionLowerEndpointProbDist_mem_allocationCredalSet pA pB pC sAB sBC hFeas⟩

/-- Every distribution in the allocation credal family reads the joint `A ∧ C`
inside the deduction joint interval. -/
theorem expected_eventAC_mem_interval_of_mem_allocationCredalSet
    (pA pB pC sAB sBC : ℝ)
    (P : ProbDist DeductionAtom)
    (hP : P ∈ deductionAllocationCredalSet pA pB pC sAB sBC) :
    deductionCredalJointLower pA pB pC sAB sBC ≤
        expectedValue P DeductionAtom.eventAC ∧
      expectedValue P DeductionAtom.eventAC ≤
        deductionCredalJointUpper pA pB pC sAB sBC := by
  rcases hP with ⟨alloc, rfl⟩
  rw [DeductionBranchAllocation.expected_eventAC_eq alloc]
  exact alloc.jointAC_mem_interval

@[simp] theorem deductionAllocationCredalSet_lowerProb_eventAC_eq
    (pA pB pC sAB sBC : ℝ)
    (hFeas : DeductionBranchFeasibility pA pB pC sAB sBC) :
    lowerProb (deductionAllocationCredalSet pA pB pC sAB sBC)
        DeductionAtom.eventAC =
      deductionCredalJointLower pA pB pC sAB sBC := by
  let P₀ :=
    (deductionLowerEndpointBranchAllocation pA pB pC sAB sBC hFeas).probDist
  have hP₀_expected :
      expectedValue P₀ DeductionAtom.eventAC =
        deductionCredalJointLower pA pB pC sAB sBC := by
    dsimp [P₀]
    simpa using
      (DeductionBranchAllocation.expected_eventAC_eq
        (deductionLowerEndpointBranchAllocation pA pB pC sAB sBC hFeas))
  have hP₀ : P₀ ∈ deductionAllocationCredalSet pA pB pC sAB sBC := by
    dsimp [P₀]
    exact deductionLowerEndpointProbDist_mem_allocationCredalSet
      pA pB pC sAB sBC hFeas
  calc
    lowerProb (deductionAllocationCredalSet pA pB pC sAB sBC)
        DeductionAtom.eventAC =
      expectedValue P₀ DeductionAtom.eventAC := by
        exact lowerProb_eq_expectedValue_of_mem_forall_le
          (deductionAllocationCredalSet pA pB pC sAB sBC)
          P₀ DeductionAtom.eventAC hP₀ (by
            intro P hP
            have hInterval :=
              expected_eventAC_mem_interval_of_mem_allocationCredalSet
                pA pB pC sAB sBC P hP
            rw [hP₀_expected]
            exact hInterval.1)
    _ = deductionCredalJointLower pA pB pC sAB sBC := by
        exact hP₀_expected

@[simp] theorem deductionAllocationCredalSet_upperProb_eventAC_eq
    (pA pB pC sAB sBC : ℝ)
    (hFeas : DeductionBranchFeasibility pA pB pC sAB sBC) :
    upperProb (deductionAllocationCredalSet pA pB pC sAB sBC)
        DeductionAtom.eventAC =
      deductionCredalJointUpper pA pB pC sAB sBC := by
  let Q₀ :=
    (deductionUpperEndpointBranchAllocation pA pB pC sAB sBC hFeas).probDist
  have hQ₀_expected :
      expectedValue Q₀ DeductionAtom.eventAC =
        deductionCredalJointUpper pA pB pC sAB sBC := by
    dsimp [Q₀]
    simpa using
      (DeductionBranchAllocation.expected_eventAC_eq
        (deductionUpperEndpointBranchAllocation pA pB pC sAB sBC hFeas))
  have hQ₀ : Q₀ ∈ deductionAllocationCredalSet pA pB pC sAB sBC := by
    dsimp [Q₀]
    exact deductionUpperEndpointProbDist_mem_allocationCredalSet
      pA pB pC sAB sBC hFeas
  calc
    upperProb (deductionAllocationCredalSet pA pB pC sAB sBC)
        DeductionAtom.eventAC =
      expectedValue Q₀ DeductionAtom.eventAC := by
        exact upperProb_eq_expectedValue_of_mem_forall_le
          (deductionAllocationCredalSet pA pB pC sAB sBC)
          Q₀ DeductionAtom.eventAC hQ₀ (by
            intro P hP
            have hInterval :=
              expected_eventAC_mem_interval_of_mem_allocationCredalSet
                pA pB pC sAB sBC P hP
            rw [hQ₀_expected]
            exact hInterval.2)
    _ = deductionCredalJointUpper pA pB pC sAB sBC := by
        exact hQ₀_expected

/-- The two endpoint branch allocations, seen as a finite credal set over the
eight atoms of a deduction instance. -/
noncomputable def deductionEndpointCredalSet
    (pA pB pC sAB sBC : ℝ)
    (hFeas : DeductionBranchFeasibility pA pB pC sAB sBC) :
    CredalSetFinite DeductionAtom :=
  Set.insert
    ((deductionLowerEndpointBranchAllocation pA pB pC sAB sBC hFeas).probDist)
    (Set.singleton
      ((deductionUpperEndpointBranchAllocation pA pB pC sAB sBC hFeas).probDist))

@[simp] theorem deductionLowerEndpointProbDist_mem_endpointCredalSet
    (pA pB pC sAB sBC : ℝ)
    (hFeas : DeductionBranchFeasibility pA pB pC sAB sBC) :
    (deductionLowerEndpointBranchAllocation pA pB pC sAB sBC hFeas).probDist ∈
      deductionEndpointCredalSet pA pB pC sAB sBC hFeas := by
  exact
    Set.mem_insert
      (deductionLowerEndpointBranchAllocation pA pB pC sAB sBC hFeas).probDist
      (Set.singleton
        (deductionUpperEndpointBranchAllocation pA pB pC sAB sBC hFeas).probDist)

@[simp] theorem deductionUpperEndpointProbDist_mem_endpointCredalSet
    (pA pB pC sAB sBC : ℝ)
    (hFeas : DeductionBranchFeasibility pA pB pC sAB sBC) :
    (deductionUpperEndpointBranchAllocation pA pB pC sAB sBC hFeas).probDist ∈
      deductionEndpointCredalSet pA pB pC sAB sBC hFeas := by
  exact
    Set.mem_insert_of_mem
      (deductionLowerEndpointBranchAllocation pA pB pC sAB sBC hFeas).probDist
      (Set.mem_singleton
        (deductionUpperEndpointBranchAllocation pA pB pC sAB sBC hFeas).probDist)

theorem deductionEndpointCredalSet_nonempty
    (pA pB pC sAB sBC : ℝ)
    (hFeas : DeductionBranchFeasibility pA pB pC sAB sBC) :
    (deductionEndpointCredalSet pA pB pC sAB sBC hFeas).Nonempty :=
  ⟨(deductionLowerEndpointBranchAllocation pA pB pC sAB sBC hFeas).probDist,
    deductionLowerEndpointProbDist_mem_endpointCredalSet pA pB pC sAB sBC hFeas⟩

@[simp] theorem deductionLowerEndpoint_expected_eventAC_eq
    (pA pB pC sAB sBC : ℝ)
    (hFeas : DeductionBranchFeasibility pA pB pC sAB sBC) :
    expectedValue
        ((deductionLowerEndpointBranchAllocation pA pB pC sAB sBC hFeas).probDist)
        DeductionAtom.eventAC =
      deductionCredalJointLower pA pB pC sAB sBC := by
  simpa using
    (DeductionBranchAllocation.expected_eventAC_eq
      (deductionLowerEndpointBranchAllocation pA pB pC sAB sBC hFeas))

@[simp] theorem deductionUpperEndpoint_expected_eventAC_eq
    (pA pB pC sAB sBC : ℝ)
    (hFeas : DeductionBranchFeasibility pA pB pC sAB sBC) :
    expectedValue
        ((deductionUpperEndpointBranchAllocation pA pB pC sAB sBC hFeas).probDist)
        DeductionAtom.eventAC =
