/-- The no-independence deduction strength interval as a generic ITV.

The credibility coordinate is supplied explicitly.  The interval endpoints are
forced by the credal branch-allocation bounds; the credibility coordinate is not
derived from those endpoints at this abstraction layer. -/
noncomputable def deductionCredalStrengthITV
    (pA pB pC sAB sBC : ℝ)
    (hpA : 0 < pA)
    (hFeas : DeductionBranchFeasibility pA pB pC sAB sBC)
    (credibility : ℝ) (hc : credibility ∈ Set.Icc (0 : ℝ) 1) :
    ITV where
  lower := deductionCredalStrengthLower pA pB pC sAB sBC
  upper := deductionCredalStrengthUpper pA pB pC sAB sBC
  credibility := credibility
  lower_le_upper :=
    deductionCredalStrengthLower_le_upper_of_branch_feasible
      pA pB pC sAB sBC hpA hFeas
  lower_in_unit := by
    simpa using
      (deductionLowerEndpointBranchAllocation pA pB pC sAB sBC hFeas).strengthAC_in_unit hpA
  upper_in_unit := by
    simpa using
      (deductionUpperEndpointBranchAllocation pA pB pC sAB sBC hFeas).strengthAC_in_unit hpA
  credibility_in_unit := hc

